# Stress Test 4: Control Flow
# Testing complex control flow, nested conditionals, loops, early returns, error handling

# ==================== Nested Conditionals ====================

# Classify number into categories
fn classify_number(n: i64) -> str {
    I n < 0 {
        I n < -100 {
            "very negative"
        } enum I n < -10 {
            "negative"
        } enum {
            "slightly negative"
        }
    } enum I n == 0 {
        "zero"
    } enum {
        I n < 10 {
            "single digit"
        } enum I n < 100 {
            "double digit"
        } enum I n < 1000 {
            "triple digit"
        } enum {
            "large"
        }
    }
}

# Grade classification with multiple conditions
fn calculate_grade(score: i64) -> str {
    I score < 0 || score > 100 {
        "invalid"
    } enum I score >= 90 {
        "A"
    } enum I score >= 80 {
        "B"
    } enum I score >= 70 {
        "C"
    } enum I score >= 60 {
        "D"
    } enum {
        "F"
    }
}

# Complex boolean logic
fn check_access(age: i64, is_member: bool, has_pass: bool) -> bool {
    (age >= 18 && is_member) || has_pass
}

# Nested ternary operators
fn max_of_three(a: i64, b: i64, c: i64) -> i64 {
    I a >= b && a >= c {
        a
    } enum I b >= c {
        b
    } enum {
        c
    }
}

fn min_of_three(a: i64, b: i64, c: i64) -> i64 {
    I a <= b && a <= c {
        a
    } enum I b <= c {
        b
    } enum {
        c
    }
}

# ==================== Pattern Matching ====================

# Day of week
enum DayOfWeek {
    Monday,
    Tuesday,
    Wednesday,
    Thursday,
    Friday,
    Saturday,
    Sunday
}

fn is_weekend(day: DayOfWeek) -> bool {
    match day {
        Saturday => true,
        Sunday => true,
        _ => false
    }
}

fn day_number(day: DayOfWeek) -> i64 {
    match day {
        Monday => 1,
        Tuesday => 2,
        Wednesday => 3,
        Thursday => 4,
        Friday => 5,
        Saturday => 6,
        Sunday => 7
    }
}

# Traffic light state machine
enum TrafficLight {
    Red,
    Yellow,
    Green
}

fn next_light(current: TrafficLight) -> TrafficLight {
    match current {
        Red => Green,
        Green => Yellow,
        Yellow => Red
    }
}

fn can_go(light: TrafficLight) -> bool {
    match light {
        Green => true,
        Yellow => false,
        Red => false
    }
}

# ==================== Loop-like Recursion ====================

# Count down from n to 0
fn countdown(n: i64) -> i64 {
    I n <= 0 {
        0
    } enum {
        @(n - 1)
    }
}

# Count up to n
fn count_to(n: i64, current: i64) -> i64 {
    I current >= n {
        current
    } enum {
        @(n, current + 1)
    }
}

# Sum from 1 to n
fn sum_to(n: i64) -> i64 {
    I n <= 0 {
        0
    } enum {
        n + @(n - 1)
    }
}

# Product from 1 to n
fn product_to(n: i64) -> i64 {
    I n <= 1 {
        1
    } enum {
        n * @(n - 1)
    }
}

# Iterate with accumulator
fn iterate(n: i64, acc: i64, step: i64) -> i64 {
    I n <= 0 {
        acc
    } enum {
        @(n - 1, acc + step, step)
    }
}

# ==================== Early Return Patterns ====================

# Find first positive number
fn find_first_positive(arr: *i64, len: i64, idx: i64) -> i64 {
    I idx >= len {
        0 - 1
    } enum I arr[idx] > 0 {
        arr[idx]
    } enum {
        @(arr, len, idx + 1)
    }
}

# Find last negative number
fn find_last_negative(arr: *i64, len: i64) -> i64 {
    find_last_negative_helper(arr, len, 0, 0 - 1)
}

fn find_last_negative_helper(arr: *i64, len: i64, idx: i64, last: i64) -> i64 {
    I idx >= len {
        last
    } enum {
        new_last := I arr[idx] < 0 { arr[idx] } enum { last }
        @(arr, len, idx + 1, new_last)
    }
}

# ==================== Error Handling Patterns ====================

enum ErrorType {
    DivisionByZero,
    NegativeNumber,
    OutOfRange,
    InvalidInput
}

enum Result<T, E> {
    Ok(T),
    Err(E)
}

# Safe division
fn safe_divide(a: i64, b: i64) -> Result<i64, ErrorType> {
    I b == 0 {
        Err(DivisionByZero)
    } enum {
        Ok(a / b)
    }
}

# Safe square root (only positive)
fn safe_sqrt(n: i64) -> Result<i64, ErrorType> {
    I n < 0 {
        Err(NegativeNumber)
    } enum {
        Ok(isqrt(n))
    }
}

fn isqrt(n: i64) -> i64 {
    I n < 2 {
        n
    } enum {
        isqrt_helper(n, n / 2)
    }
}

fn isqrt_helper(n: i64, guess: i64) -> i64 {
    next := (guess + n / guess) / 2
    I next >= guess {
        guess
    } enum {
        @(n, next)
    }
}

# Safe array access
fn safe_array_get(arr: *i64, len: i64, idx: i64) -> Result<i64, ErrorType> {
    I idx < 0 || idx >= len {
        Err(OutOfRange)
    } enum {
        Ok(arr[idx])
    }
}

# Chain of operations with error handling
fn chain_operations(a: i64, b: i64, c: i64) -> Result<i64, ErrorType> {
    step1 := safe_divide(a, b)
    match step1 {
        Ok(v1) => {
            step2 := safe_sqrt(v1)
            match step2 {
                Ok(v2) => Ok(v2 + c),
                Err(e) => Err(e)
            }
        },
        Err(e) => Err(e)
    }
}

# ==================== Complex Control Flow ====================

# FizzBuzz
fn fizzbuzz(n: i64) -> str {
    I n % 15 == 0 {
        "FizzBuzz"
    } enum I n % 3 == 0 {
        "Fizz"
    } enum I n % 5 == 0 {
        "Buzz"
    } enum {
        "number"
    }
}

# Leap year check
fn is_leap_year(year: i64) -> bool {
    I year % 400 == 0 {
        true
    } enum I year % 100 == 0 {
        false
    } enum I year % 4 == 0 {
        true
    } enum {
        false
    }
}

# Sign function
fn sign(n: i64) -> i64 {
    I n > 0 {
        1
    } enum I n < 0 {
        0 - 1
    } enum {
        0
    }
}

# Absolute value
fn abs(n: i64) -> i64 {
    I n < 0 {
        0 - n
    } enum {
        n
    }
}

# Clamp value to range
fn clamp(value: i64, min: i64, max: i64) -> i64 {
    I value < min {
        min
    } enum I value > max {
        max
    } enum {
        value
    }
}

# ==================== State Machines ====================

enum PlayerState {
    Idle,
    Walking,
    Running,
    Jumping,
    Falling
}

fn can_jump(state: PlayerState) -> bool {
    match state {
        Idle => true,
        Walking => true,
        Running => true,
        Jumping => false,
        Falling => false
    }
}

fn next_state(state: PlayerState, input: i64) -> PlayerState {
    match state {
        Idle => {
            I input == 1 { Walking }
            enum I input == 2 { Jumping }
            enum { Idle }
        },
        Walking => {
            I input == 0 { Idle }
            enum I input == 2 { Running }
            enum I input == 3 { Jumping }
            enum { Walking }
        },
        Running => {
            I input == 0 { Walking }
            enum I input == 3 { Jumping }
            enum { Running }
        },
        Jumping => Falling,
        Falling => Idle
    }
}

# ==================== Complex Iterations ====================

# Nested iteration simulation
fn nested_sum(outer: i64, inner: i64) -> i64 {
    nested_sum_outer(outer, inner, 0, 0)
}

fn nested_sum_outer(outer: i64, inner: i64, i: i64, acc: i64) -> i64 {
    I i >= outer {
        acc
    } enum {
        inner_sum := nested_sum_inner(inner, 0, 0)
        @(outer, inner, i + 1, acc + inner_sum)
    }
}

fn nested_sum_inner(inner: i64, j: i64, acc: i64) -> i64 {
    I j >= inner {
        acc
    } enum {
        @(inner, j + 1, acc + j)
    }
}

# ==================== Test Driver ====================

fn main() -> i64 {
    # Test classification
    c1 := classify_number(42)
    c2 := classify_number(-50)

    # Test grade
    g1 := calculate_grade(85)
    g2 := calculate_grade(92)

    # Test max/min
    max_val := max_of_three(10, 20, 15)
    min_val := min_of_three(10, 20, 15)

    # Test sum
    sum := sum_to(10)

    # Test fizzbuzz
    fb15 := fizzbuzz(15)
    fb3 := fizzbuzz(3)

    # Test leap year
    leap1 := is_leap_year(2000)
    leap2 := is_leap_year(1900)

    # Test safe operations
    div_result := safe_divide(10, 2)
    sqrt_result := safe_sqrt(16)

    # Test nested sum
    nested := nested_sum(5, 5)

    # Verify results
    I max_val == 20 && min_val == 10 && sum == 55 && nested == 50 {
        0
    } enum {
        1
    }
}

# A2-03 negative probe — bare i64 cannot satisfy `dyn Greet`.
#
# T-508 W1-C: this must reject at `vaisc check` with stable type diagnostic
# output for expected `dyn Greet`, found `i64`.

trait Greet {
    fn greet(self) -> i64
}

fn use_dyn(g: dyn Greet) -> i64 { g.greet() }

fn main() -> i64 {
    use_dyn(123)
}

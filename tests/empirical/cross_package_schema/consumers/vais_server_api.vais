# Consumer: vais-server-style API handler returning email.
# See vaisdb_table.vais header for the cat-based concatenation note.

fn handler_email(u: User) -> str {
    return u.email
}

fn main() -> i64 {
    u: User = User { id: 2, email: "api@b.c", name: "ada" }
    I handler_email(u) != "api@b.c" {
        return 1
    }
    return 0
}

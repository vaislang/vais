# Consumer: vaisdb-style table builder.
# Compiled by gate.sh as `cat ../schema/user.vais this-file > combined.vais`
# (module imports across separate files do not currently resolve in
# user-space outside std/, so the gate works around it by concatenating
# schema + consumer at gate time. The semantic intent is identical: a
# consumer references the schema's User type and its `email` field.)

fn build_user(id: i64, email: str, name: str) -> User {
    return User { id: id, email: email, name: name }
}

fn lookup_email(u: User) -> str {
    return u.email
}

fn main() -> i64 {
    u: User = build_user(1, "a@b.c", "alice")
    I lookup_email(u) != "a@b.c" {
        return 1
    }
    return 0
}

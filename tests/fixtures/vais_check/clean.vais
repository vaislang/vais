import math.add

pub struct User {
    pub name: Str,
    id: Int,
}

struct Metric {
    docs: Int,
    terms: Int,
}

struct Record {
    title_len: Int,
    body_terms: Int,
    score: Int,
}

pub fn make_user(name: Str, id: Int) -> User {
    return User { name: name, id: id }
}

fn result_title_len(flow: Result<Str, Int>) -> Int {
    let n = match flow { Ok(title) => title.len(), Err(code) => code }
    return n
}

fn result_metric_score(flow: Result<Metric, Int>) -> Int {
    let n = match flow { Ok(metric) => metric.docs + metric.terms, Err(code) => code }
    return n
}

fn result_record_score(flow: Result<Record, Int>) -> Int {
    let n = match flow { Ok(record) => record.title_len + record.body_terms + record.score, Err(code) => code }
    return n
}


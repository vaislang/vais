use src/core/context

# __SHARED_USER_SCHEMA__

fn smoke_contains(haystack: str, needle: str) -> i64 {
    smoke_contains_rec(haystack, needle, 0)
}

fn smoke_contains_rec(haystack: str, needle: str, i: i64) -> i64 {
    I needle.len() == 0 { return 1 }
    I i >= haystack.len() { return 0 }
    I smoke_match_prefix(haystack, needle, i, 0) == 1 { return 1 }
    smoke_contains_rec(haystack, needle, i + 1)
}

fn smoke_match_prefix(haystack: str, needle: str, hi: i64, ni: i64) -> i64 {
    nc := needle.char_at(ni)
    I nc == 0 { return 1 }
    hc := haystack.char_at(hi)
    I hc == 0 { return 0 }
    I hc != nc { return 0 }
    smoke_match_prefix(haystack, needle, hi + 1, ni + 1)
}

fn user_json(u: User) -> str {
    "{\"id\":7,\"email\":\"" + u.email + "\",\"name\":\"" + u.name + "\"}"
}

fn main() -> i64 {
    u: User = User { id: 7, email: "ada@vais.dev", name: "Ada" }
    ctx := mut Context.new("GET", "/api/users/7")
    res := ctx.json(200, user_json(u))

    I res.status != 200 { return 1 }
    I res.content_type != "application/json; charset=utf-8" { return 2 }
    I smoke_contains(res.body, "ada@vais.dev") != 1 { return 3 }
    I smoke_contains(res.body, "\"email\"") != 1 { return 4 }
    0
}

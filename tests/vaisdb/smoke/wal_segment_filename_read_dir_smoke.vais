use storage/wal/segment
use storage/wal/naming
use storage/file
use storage/error
use std/string.{str_byte_at}

fn wal_name_path(dir: str, segment_num: u32) -> str {
    filename := mut WalSegmentHeader.segment_filename(segment_num)
    dir.clone() + "/" + filename
}

fn expect_byte_at(name: str, index: i64, expected: i64) -> bool {
    str_byte_at(name, index) == expected
}

fn verify_segment_name_code(name: str, segment_num: u32, d0: i64, d1: i64, d2: i64, d3: i64, d4: i64, d5: i64, base: i64) -> i64 {
    I name.len() != 10 { return base + 1 }
    I !expect_byte_at(name, 0, d0) { return base + 2 }
    I !expect_byte_at(name, 1, d1) { return base + 3 }
    I !expect_byte_at(name, 2, d2) { return base + 4 }
    I !expect_byte_at(name, 3, d3) { return base + 5 }
    I !expect_byte_at(name, 4, d4) { return base + 6 }
    I !expect_byte_at(name, 5, d5) { return base + 7 }
    I !expect_byte_at(name, 6, 46) { return base + 8 }
    I !expect_byte_at(name, 7, 119) { return base + 9 }
    I !expect_byte_at(name, 8, 97) { return base + 10 }
    I !expect_byte_at(name, 9, 108) { return base + 11 }
    I !is_wal_segment_filename(name) { return base + 12 }
    parsed := mut match parse_wal_segment_number(name) {
        Ok(v) => v,
        Err(_) => { return base + 13 },
    }
    I parsed != segment_num { return base + 14 }
    0
}

fn create_empty_segment_file(dir: str, segment_num: u32) -> Result<(), VaisError> {
    path := mut wal_name_path(dir, segment_num)
    file := mut File.open(path, "rw+")?;
    file.truncate(0)?;
    file.fsync()
}

fn main() -> i64 {
    name_1 := mut WalSegmentHeader.segment_filename(1 as u32)
    name_1_code := mut verify_segment_name_code(name_1, 1 as u32, 48, 48, 48, 48, 48, 49, 10)
    I name_1_code != 0 { return name_1_code }

    name_42 := mut WalSegmentHeader.segment_filename(42 as u32)
    name_42_code := mut verify_segment_name_code(name_42, 42 as u32, 48, 48, 48, 48, 52, 50, 30)
    I name_42_code != 0 { return name_42_code }

    name_max := mut WalSegmentHeader.segment_filename(123456 as u32)
    name_max_code := mut verify_segment_name_code(name_max, 123456 as u32, 49, 50, 51, 52, 53, 54, 50)
    I name_max_code != 0 { return name_max_code }

    wal_dir := mut "wal_segment_filename_read_dir_wal"
    match create_dir_all(&wal_dir) {
        Ok(_) => {},
        Err(_) => { return 4 },
    }
    match create_empty_segment_file(wal_dir.clone(), 1 as u32) {
        Ok(_) => {},
        Err(_) => { return 5 },
    }
    match create_empty_segment_file(wal_dir.clone(), 42 as u32) {
        Ok(_) => {},
        Err(_) => { return 6 },
    }

    entries := mut match read_dir(&wal_dir) {
        Ok(v) => v,
        Err(_) => { return 7 },
    }
    saw_1 := mut false
    saw_42 := mut false

    LF entry: &entries {
        name := mut entry.file_name()
        I is_wal_segment_filename(name) {
            segment_num := mut match parse_wal_segment_number(name) {
                Ok(v) => v,
                Err(_) => { return 8 },
            }
            I segment_num == 1 as u32 {
                saw_1 = true
            }
            I segment_num == 42 as u32 {
                saw_42 = true
            }
        }
    }

    I !saw_1 { return 9 }
    I !saw_42 { return 10 }

    return 0
}

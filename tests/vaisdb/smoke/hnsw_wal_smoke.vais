use vector/hnsw/types
use vector/hnsw/wal
use storage/wal/record_types
use storage/wal/record_vector
use storage/wal/group_commit
use storage/wal/writer
use storage/bytes
use storage/error

struct WalSmokeStore {
    n7: HnswNode,
    n8: HnswNode,
    has7: bool,
    has8: bool,
    stored_count: u64,
}

impl WalSmokeStore {
    fn new() -> WalSmokeStore {
        WalSmokeStore {
            n7: HnswNode.new(0, 0, 0, 0, 0, 0),
            n8: HnswNode.new(0, 0, 0, 0, 0, 0),
            has7: false,
            has8: false,
            stored_count: 0,
        }
    }
}

impl WalSmokeStore : NodeStore {
    fn load_node(self, node_id: u64) -> Result<HnswNode, VaisError> {
        I node_id == 7 && self.has7 {
            return Ok(self.n7.clone())
        }
        I node_id == 8 && self.has8 {
            return Ok(self.n8.clone())
        }
        Err(err_internal("missing smoke wal node"))
    }

    fn load_vector(self, node_id: u64) -> Result<Vec<f32>, VaisError> {
        values: Vec<f32> := mut Vec.with_capacity(2)
        values.push(node_id as f32)
        values.push(0.0)
        Ok(values)
    }

    fn store_node(mut self, node: HnswNode) -> Result<(), VaisError> {
        node_id := mut node.node_id
        I node_id == 7 {
            self.n7 = node
            self.has7 = true
            self.stored_count += 1
            return Ok(())
        }
        I node_id == 8 {
            self.n8 = node
            self.has8 = true
            self.stored_count += 1
            return Ok(())
        }
        Err(err_internal("unexpected smoke wal node"))
    }

    fn allocate_node_id(mut self) -> u64 {
        7
    }

    fn get_file_page(self, node_id: u64) -> Result<(u8, u32), VaisError> {
        Ok((3 as u8, node_id as u32))
    }

    fn allocate_node_page(mut self, node_id: u64) -> Result<(u8, u32), VaisError> {
        Ok((3 as u8, node_id as u32))
    }
}

fn main() -> i64 {
    neighbors: Vec<(u64, f32)> := mut Vec.with_capacity(2)
    neighbors.push((11, 1.25 as f32))
    neighbors.push((12, 2.5 as f32))

    affected: Vec<(u8, u32)> := mut Vec.with_capacity(1)
    affected.push((3 as u8, 77 as u32))

    insert_payload := mut HnswInsertNodePayload {
        node_id: 7,
        layer: 1 as u8,
        neighbors,
        file_id: 3 as u8,
        page_id: 77 as u32,
        affected_pages: affected,
    }

    insert_buf := mut ByteBuffer.with_capacity(128)
    insert_payload.serialize(&mut insert_buf)
    insert_bytes := mut insert_buf.to_vec()
    insert_read := mut ByteBuffer.wrap_readonly(&insert_bytes)
    decoded_insert := mut match HnswInsertNodePayload.deserialize(&insert_read) {
        Ok(v) => v,
        Err(_) => { return 1 },
    }

    I decoded_insert.node_id != 7 { return 2 }
    I decoded_insert.layer != 1 as u8 { return 3 }
    I decoded_insert.neighbors.len() != 2 { return 4 }
    I decoded_insert.neighbors[0].0 != 11 { return 5 }
    I decoded_insert.file_id != 3 as u8 { return 6 }
    I decoded_insert.affected_pages.len() != 1 { return 7 }

    store := mut WalSmokeStore.new()
    match redo_hnsw_insert(&decoded_insert, &mut store) {
        Ok(_) => {},
        Err(_) => { return 8 },
    }

    inserted := mut match store.load_node(7) {
        Ok(n) => n,
        Err(_) => { return 9 },
    }
    I inserted.max_layer != 1 as u8 { return 10 }
    I inserted.neighbors.len() != 2 { return 11 }
    layer0 := mut match inserted.get_neighbors(0 as u8) {
        Ok(v) => v,
        Err(_) => { return 12 },
    }
    I layer0.len() != 2 { return 13 }
    I layer0[0].node_id != 11 { return 14 }

    old_neighbors: Vec<u64> := mut Vec.with_capacity(2)
    old_neighbors.push(11)
    old_neighbors.push(12)
    new_neighbors: Vec<u64> := mut Vec.with_capacity(1)
    new_neighbors.push(99)
    update_payload := mut HnswUpdateEdgesPayload {
        node_id: 7,
        layer: 0 as u8,
        old_neighbors,
        new_neighbors,
        file_id: 3 as u8,
        page_id: 77 as u32,
    }

    update_buf := mut ByteBuffer.with_capacity(128)
    update_payload.serialize(&mut update_buf)
    update_bytes := mut update_buf.to_vec()

    match redo_hnsw_update_edges(&update_payload, &mut store) {
        Ok(_) => {},
        Err(_) => { return 15 },
    }
    updated := mut match store.load_node(7) {
        Ok(n) => n,
        Err(_) => { return 16 },
    }
    updated_layer0 := mut match updated.get_neighbors(0 as u8) {
        Ok(v) => v,
        Err(_) => { return 17 },
    }
    I updated_layer0.len() != 1 { return 18 }
    I updated_layer0[0].node_id != 99 { return 19 }
    I updated_layer0[0].distance != 0.0 as f32 { return 20 }

    match dispatch_vector_undo(HNSW_UPDATE_EDGES, &update_bytes, &mut store) {
        Ok(_) => {},
        Err(_) => { return 21 },
    }
    restored := mut match store.load_node(7) {
        Ok(n) => n,
        Err(_) => { return 22 },
    }
    restored_layer0 := mut match restored.get_neighbors(0 as u8) {
        Ok(v) => v,
        Err(_) => { return 23 },
    }
    I restored_layer0.len() != 2 { return 24 }
    I restored_layer0[1].node_id != 12 { return 25 }

    promote_payload := mut HnswLayerPromotePayload {
        node_id: 7,
        new_max_layer: 3 as u8,
        file_id: 3 as u8,
        page_id: 77 as u32,
    }
    match redo_hnsw_layer_promote(&promote_payload, &mut store) {
        Ok(_) => {},
        Err(_) => { return 26 },
    }
    promoted := mut match store.load_node(7) {
        Ok(n) => n,
        Err(_) => { return 27 },
    }
    I promoted.max_layer != 3 as u8 { return 28 }
    I promoted.neighbors.len() != 4 { return 29 }

    match undo_hnsw_insert(&decoded_insert, &mut store) {
        Ok(_) => {},
        Err(_) => { return 30 },
    }
    deleted := mut match store.load_node(7) {
        Ok(n) => n,
        Err(_) => { return 31 },
    }
    I !deleted.is_deleted { return 32 }

    delete_layers: Vec<u8> := mut Vec.with_capacity(2)
    delete_layers.push(0 as u8)
    delete_layers.push(1 as u8)
    delete_payload := mut HnswDeleteNodePayload {
        node_id: 7,
        layers_affected: delete_layers,
        file_id: 3 as u8,
        page_id: 77 as u32,
    }
    match undo_hnsw_delete(&delete_payload, &mut store) {
        Ok(_) => { return 33 },
        Err(e) => {
            I e.code != "VAIS-0209003" { return 34 }
        },
    }

    writer := mut match WalWriter.new("/tmp/vais-smoke-hnsw-wal", 4096 as u32) {
        Ok(w) => w,
        Err(_) => { return 35 },
    }
    gcm := mut GroupCommitManager.new(GroupCommitConfig.async_mode(), writer)
    wal_mgr := mut HnswWalManager.new(&gcm)
    log_layers: Vec<u8> := mut Vec.with_capacity(2)
    log_layers.push(0 as u8)
    log_layers.push(1 as u8)
    lsn := mut match wal_mgr.log_delete_node(700, 7, &log_layers, 3 as u8, 77 as u32) {
        Ok(v) => v,
        Err(_) => { return 36 },
    }
    I lsn == 0 { return 37 }

    return 0
}

use sql/catalog/schema
use sql/types
use storage/bytes
use std/bytebuffer

fn main() -> i64 {
    table := mut TableInfo.new(101 as u32, "docs", 2 as u16, 55 as u32)
    table.row_count_estimate = 9 as u64

    table_buf := mut ByteBuffer.new()
    table.serialize(&mut table_buf)
    I table_buf.len() <= 0 { return 1 }

    table_rt := mut match TableInfo.deserialize(&table_buf) {
        Ok(v) => v,
        Err(_) => { return 2 },
    }
    I table_rt.table_id as i64 != 101 { return 3 }
    I table_rt.name != "docs" { return 4 }
    I table_rt.column_count as i64 != 2 { return 5 }
    I table_rt.is_system { return 6 }
    I table_rt.first_page_id as i64 != 55 { return 7 }
    I table_rt.row_count_estimate as i64 != 9 { return 8 }

    table_key_bytes := mut table_rt.to_catalog_key()
    I table_key_bytes.len() != 6 { return 9 }
    I table_key_bytes[0] != 84 { return 10 }
    I table_key_bytes[1] != 58 { return 11 }
    I table_key_bytes[2] != 100 { return 12 }

    col := mut ColumnInfo.new_primary_key(101 as u32, 0 as u16, "id", SqlType.Int)
    col.default_value = Some("0")

    col_buf := mut ByteBuffer.new()
    col.serialize(&mut col_buf)
    col_rt := mut match ColumnInfo.deserialize(&col_buf) {
        Ok(v) => v,
        Err(_) => { return 13 },
    }
    I col_rt.table_id as i64 != 101 { return 14 }
    I col_rt.column_index as i64 != 0 { return 15 }
    I col_rt.name != "id" { return 16 }
    I col_rt.nullable { return 17 }
    I !col_rt.is_primary_key { return 18 }
    match col_rt.data_type {
        Int => {},
        _ => { return 19 },
    }
    match col_rt.default_value {
        Some(v) => {
            I v != "0" { return 20 }
        },
        None => { return 21 },
    }

    col_key_bytes := mut col_rt.to_catalog_key()
    I col_key_bytes.len() != 9 { return 22 }
    I col_key_bytes[0] != 67 { return 23 }
    I col_key_bytes[1] != 58 { return 24 }
    I col_key_bytes[5] != 101 { return 25 }

    idx_cols: Vec<str> := mut Vec.with_capacity(2)
    idx_cols.push("id")
    idx_cols.push("title")
    idx := mut IndexInfo.new_primary(201 as u32, "idx_docs_id", 101 as u32, idx_cols, 77 as u32)

    idx_buf := mut ByteBuffer.new()
    idx.serialize(&mut idx_buf)
    idx_rt := mut match IndexInfo.deserialize(&idx_buf) {
        Ok(v) => v,
        Err(_) => { return 26 },
    }
    I idx_rt.index_id as i64 != 201 { return 27 }
    I idx_rt.name != "idx_docs_id" { return 28 }
    I idx_rt.table_id as i64 != 101 { return 29 }
    I idx_rt.columns.len() != 2 { return 30 }
    I idx_rt.columns[0] != "id" { return 31 }
    I idx_rt.columns[1] != "title" { return 32 }
    I !idx_rt.is_unique { return 33 }
    I !idx_rt.is_primary { return 34 }
    I idx_rt.root_page_id as i64 != 77 { return 35 }

    idx_key_bytes := mut idx_rt.to_catalog_key()
    I idx_key_bytes.len() != 13 { return 36 }
    I idx_key_bytes[0] != 73 { return 37 }
    I idx_key_bytes[1] != 58 { return 38 }

    idx_table_key := mut idx_rt.to_table_index_key()
    I idx_table_key.len() != 19 { return 39 }
    I idx_table_key[0] != 73 { return 40 }
    I idx_table_key[1] != 84 { return 41 }
    I idx_table_key[2] != 58 { return 42 }
    I idx_table_key[6] != 101 { return 43 }
    I idx_table_key[7] != 58 { return 44 }

    return 0
}

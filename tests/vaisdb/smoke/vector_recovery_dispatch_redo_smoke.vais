U storage/recovery/redo
U storage/wal/header
U storage/wal/record_types
U storage/wal/record_vector
U storage/constants
U storage/error
U storage/file
U storage/page/manager
U storage/page/types
U storage/page/header
U storage/buffer/pool
U storage/bytes

F dispatch_redo_open_clean(path: str) -> Result<File, VaisError> {
    file := mut File.open(path, "rw+")?;
    file.truncate(0)?;
    Ok(file)
}

F dispatch_redo_open_existing(path: str) -> Result<File, VaisError> {
    File.open(path, "rw+")
}

F dispatch_redo_files_clean(prefix: str) -> Result<Vec<File>, VaisError> {
    files: Vec<File> := mut Vec.with_capacity(5)
    data_file := mut dispatch_redo_open_clean(prefix + "_data.vdb")?;
    vector_file := mut dispatch_redo_open_clean(prefix + "_vectors.vdb")?;
    graph_file := mut dispatch_redo_open_clean(prefix + "_graph.vdb")?;
    fulltext_file := mut dispatch_redo_open_clean(prefix + "_fulltext.vdb")?;
    undo_file := mut dispatch_redo_open_clean(prefix + "_undo.vdb")?;
    files.push(data_file)
    files.push(vector_file)
    files.push(graph_file)
    files.push(fulltext_file)
    files.push(undo_file)
    Ok(files)
}

F dispatch_redo_files_existing(prefix: str) -> Result<Vec<File>, VaisError> {
    files: Vec<File> := mut Vec.with_capacity(5)
    data_file := mut dispatch_redo_open_existing(prefix + "_data.vdb")?;
    vector_file := mut dispatch_redo_open_existing(prefix + "_vectors.vdb")?;
    graph_file := mut dispatch_redo_open_existing(prefix + "_graph.vdb")?;
    fulltext_file := mut dispatch_redo_open_existing(prefix + "_fulltext.vdb")?;
    undo_file := mut dispatch_redo_open_existing(prefix + "_undo.vdb")?;
    files.push(data_file)
    files.push(vector_file)
    files.push(graph_file)
    files.push(fulltext_file)
    files.push(undo_file)
    Ok(files)
}

F dispatch_redo_write_u64_le(page_data: &Vec<u8>, offset: u32, value: u64) {
    LF i: 0..8u32 {
        page_data[(offset + i) as u64] = ((value >> (i * 8)) & 255) as u8
    }
}

F main() -> i64 {
    prefix := mut "vector_recovery_dispatch_redo"
    page_id := mut 2 as u32
    offset := mut 256 as u16
    lsn := mut 12345 as u64

    files := mut M dispatch_redo_files_clean(prefix) {
        Ok(v) => v,
        Err(_) => { R 1 },
    }
    page_manager := mut PageManager.new(files, PAGE_SIZE_8K)
    initial := mut M page_manager.allocate_page(
        FILE_ID_VECTORS,
        page_id,
        PAGE_TYPE_VECTOR_DATA,
        ENGINE_TAG_VECTOR
    ) {
        Ok(page) => page,
        Err(_) => { R 2 },
    }

    initial[(offset as u64) - 2] = 17 as u8
    initial[(offset as u64) - 1] = 18 as u8
    initial[(offset as u64) + 8] = 19 as u8
    initial[(offset as u64) + 9] = 20 as u8
    M page_manager.write_page(FILE_ID_VECTORS, page_id, &initial) {
        Ok(_) => {},
        Err(_) => { R 3 },
    }

    expected := mut initial.clone()
    patch: Vec<u8> := mut Vec.with_capacity(8)
    patch.push(1 as u8)
    patch.push(2 as u8)
    patch.push(3 as u8)
    patch.push(4 as u8)
    patch.push(250 as u8)
    patch.push(0 as u8)
    patch.push(17 as u8)
    patch.push(99 as u8)

    i := mut 0u64
    LW i < patch.len() {
        expected[(offset as u64) + i] = patch[i]
        i = i + 1
    }
    dispatch_redo_write_u64_le(&expected, 0, lsn)
    PageHeader.update_checksum_vec(&expected)

    payload := mut VectorDataWritePayload {
        file_id: FILE_ID_VECTORS,
        page_id,
        offset,
        vector_data: patch,
    }
    payload_buf := mut ByteBuffer.with_capacity(64)
    payload.serialize(&mut payload_buf)
    payload_bytes := mut payload_buf.to_vec()
    header := mut WalRecordHeader.new(
        lsn,
        77 as u64,
        0 as u64,
        VECTOR_DATA_WRITE,
        ENGINE_VECTOR,
        WAL_RECORD_HEADER_SIZE + (payload_bytes.len() as u32)
    )

    pool := mut BufferPool.new(page_manager, PAGE_SIZE_8K, 4 as u32)
    M redo_record(&mut pool, &header, &payload_bytes) {
        Ok(_) => {},
        Err(_) => { R 4 },
    }

    memory_frame_id := mut M pool.pin_page(FILE_ID_VECTORS, page_id) {
        Ok(v) => v,
        Err(_) => { R 20 },
    }
    memory_page := mut pool.get_page(memory_frame_id)
    mem_i := mut 0u64
    LW mem_i < payload.vector_data.len() {
        I memory_page[(offset as u64) + mem_i] != payload.vector_data[mem_i] {
            pool.unpin_page(memory_frame_id, false)
            R 21
        }
        mem_i = mem_i + 1
    }
    pool.unpin_page(memory_frame_id, false)

    I pool.dirty_count() == 0 {
        R 22
    }

    M pool.flush_all() {
        Ok(_) => {},
        Err(_) => { R 5 },
    }
    I pool.dirty_count() != 0 {
        R 23
    }

    reader_files := mut M dispatch_redo_files_existing(prefix) {
        Ok(v) => v,
        Err(_) => { R 6 },
    }
    reader := mut PageManager.new(reader_files, PAGE_SIZE_8K)
    replayed := mut M reader.read_page(FILE_ID_VECTORS, page_id) {
        Ok(page) => page,
        Err(_) => { R 7 },
    }
    replayed_header := mut M PageHeader.read_from_page(&replayed) {
        Ok(h) => h,
        Err(_) => { R 8 },
    }
    I replayed_header.page_lsn != lsn {
        R 9
    }
    I replayed.len() != expected.len() { R 10 }
    I replayed[(offset as u64) - 2] != 17 as u8 { R 11 }
    I replayed[(offset as u64) - 1] != 18 as u8 { R 12 }
    I replayed[(offset as u64) + 8] != 19 as u8 { R 13 }
    I replayed[(offset as u64) + 9] != 20 as u8 { R 14 }

    k := mut 0u64
    LW k < payload.vector_data.len() {
        I replayed[(offset as u64) + k] != payload.vector_data[k] {
            R 15
        }
        k = k + 1
    }

    j := mut 0u64
    LW j < expected.len() {
        I j >= 20 && j < 24 {
            j = j + 1
        } E {
            I replayed[j] != expected[j] {
                R 16
            }
            j = j + 1
        }
    }

    R 0
}

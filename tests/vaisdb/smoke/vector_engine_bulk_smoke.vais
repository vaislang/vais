use vector/mod
use vector/hnsw/types
use vector/hnsw/bulk
use vector/distance
use storage/constants
use storage/error
use storage/file
use storage/page/manager
use storage/page/allocator
use storage/page/freelist
use storage/page/types
use storage/buffer/pool
use storage/wal/group_commit
use storage/wal/writer

fn engine_smoke_vec2(a: f32, b: f32) -> Vec<f32> {
    values: Vec<f32> := mut Vec.with_capacity(2)
    values.push(a)
    values.push(b)
    values
}

fn open_clean_file(path: str) -> Result<File, VaisError> {
    file := mut File.open(path, "rw+")?;
    file.truncate(0)?;
    Ok(file)
}

fn main() -> i64 {
    files: Vec<File> := mut Vec.with_capacity(5)
    data_file := mut match open_clean_file("/tmp/vais-smoke-vector-engine-bulk-data.vdb") {
        Ok(f) => f,
        Err(_) => { return 1 },
    }
    vector_file := mut match open_clean_file("/tmp/vais-smoke-vector-engine-bulk-vectors.vdb") {
        Ok(f) => f,
        Err(_) => { return 2 },
    }
    graph_file := mut match open_clean_file("/tmp/vais-smoke-vector-engine-bulk-graph.vdb") {
        Ok(f) => f,
        Err(_) => { return 3 },
    }
    fulltext_file := mut match open_clean_file("/tmp/vais-smoke-vector-engine-bulk-fulltext.vdb") {
        Ok(f) => f,
        Err(_) => { return 4 },
    }
    undo_file := mut match open_clean_file("/tmp/vais-smoke-vector-engine-bulk-undo.vdb") {
        Ok(f) => f,
        Err(_) => { return 5 },
    }

    files.push(data_file)
    files.push(vector_file)
    files.push(graph_file)
    files.push(fulltext_file)
    files.push(undo_file)

    page_manager := mut PageManager.new(files, PAGE_SIZE_8K)
    match page_manager.allocate_page(FILE_ID_VECTORS, 2 as u32, PAGE_TYPE_VECTOR_DATA, ENGINE_TAG_VECTOR) {
        Ok(_) => {},
        Err(_) => { return 6 },
    }
    match page_manager.allocate_page(FILE_ID_VECTORS, 3 as u32, PAGE_TYPE_VECTOR_DATA, ENGINE_TAG_VECTOR) {
        Ok(_) => {},
        Err(_) => { return 7 },
    }

    pool := mut BufferPool.new(page_manager, PAGE_SIZE_8K, 8 as u32)
    allocator := mut PageAllocator.new(PAGE_SIZE_8K)
    bitmap := mut FreelistBitmap.new_all_free()
    pages_per_bitmap := mut pages_per_bitmap_page(PAGE_SIZE_8K)
    bitmap.set_bit(0 as u32, pages_per_bitmap, false)
    bitmap.set_bit(1 as u32, pages_per_bitmap, false)

    config := mut match HnswConfig.new(2 as u16, 4 as u16, 4 as u32, 4 as u32, 8 as u64, DISTANCE_L2) {
        Ok(v) => v,
        Err(_) => { return 8 },
    }
    config.dim = 2 as u32
    config.metric = DISTANCE_L2

    writer := mut match WalWriter.new("/tmp/vais-smoke-vector-engine-bulk-wal", 4096 as u32) {
        Ok(w) => w,
        Err(_) => { return 9 },
    }
    gcm := mut GroupCommitManager.new(GroupCommitConfig.async_mode(), writer)

    engine := mut match VectorEngine.new(config, 11 as u32, &pool, &allocator, &bitmap, &mut gcm) {
        Ok(e) => e,
        Err(_) => { return 10 },
    }
    engine.is_open = true

    v1 := mut engine_smoke_vec2(0.0, 0.0)
    v2 := mut engine_smoke_vec2(1.0, 0.0)
    vectors: Vec<&[f32]> := mut Vec.new()
    vectors.push(&v1)
    vectors.push(&v2)

    load_config := mut BulkLoadConfig.with_batch_size(2)
    load_config = load_config.with_wal_bypass()
    load_config = load_config.with_seed(42)

    result := mut match engine.bulk_load(&vectors, load_config, 501) {
        Ok(r) => r,
        Err(e) => {
            I e.code == "VAIS-0202004" { return 11 }
            I e.code == "VAIS-0203001" { return 12 }
            I e.code == "VAIS-0208001" { return 13 }
            return 14
        },
    }

    I result.vectors_inserted != 2 { return 15 }
    I !result.wal_skipped { return 16 }
    I engine.node_count() != 2 { return 17 }
    I engine.meta.total_nodes != 2 { return 18 }
    I engine.meta.entry_point != 1 { return 19 }

    stored1 := mut match engine.node_store.load_node(1) {
        Ok(n) => n,
        Err(_) => { return 20 },
    }
    stored2 := mut match engine.node_store.load_node(2) {
        Ok(n) => n,
        Err(_) => { return 21 },
    }
    I stored1.vector_page_id != 2 as u32 { return 22 }
    I stored2.vector_page_id != 3 as u32 { return 23 }
    I stored1.vector_offset != 0 as u16 { return 24 }
    I stored2.vector_offset != 0 as u16 { return 25 }

    loaded1 := mut match engine.node_store.load_vector(1) {
        Ok(v) => v,
        Err(_) => { return 26 },
    }
    loaded2 := mut match engine.node_store.load_vector(2) {
        Ok(v) => v,
        Err(_) => { return 27 },
    }
    I loaded1.len() != 2 { return 28 }
    I loaded2.len() != 2 { return 29 }
    I !approx_eq_f32(loaded1[0], 0.0, 0.0001) { return 30 }
    I !approx_eq_f32(loaded1[1], 0.0, 0.0001) { return 31 }
    I !approx_eq_f32(loaded2[0], 1.0, 0.0001) { return 32 }
    I !approx_eq_f32(loaded2[1], 0.0, 0.0001) { return 33 }

    n1_neighbors := mut match stored1.get_neighbors(0) {
        Ok(v) => v,
        Err(_) => { return 34 },
    }
    n2_neighbors := mut match stored2.get_neighbors(0) {
        Ok(v) => v,
        Err(_) => { return 35 },
    }
    I n1_neighbors.len() != 1 { return 36 }
    I n2_neighbors.len() != 1 { return 37 }
    I n1_neighbors[0].node_id != 2 { return 38 }
    I n2_neighbors[0].node_id != 1 { return 39 }
    I !approx_eq_f32(n1_neighbors[0].distance, 1.0 as f32, 0.0001 as f32) { return 40 }
    I !approx_eq_f32(n2_neighbors[0].distance, 1.0 as f32, 0.0001 as f32) { return 41 }

    return 0
}

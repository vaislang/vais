    # --- Negative boundary: out-of-shape SQL must return Err, not succeed ---
    #
    # The provisional embedded SQL surface is shape-recognition over the fixed
    # people-table forms only (see docs/design/db-required-language-profile.md).
    # These assertions pin that boundary so future widening is a deliberate,
    # gated change. They add no new accepted SQL behavior. If any call below
    # returns Ok, the smoke fails loudly with a dedicated exit code instead of
    # the rejection being lost in prose.
    neg_cfg := mut EmbeddedConfig.default()
    neg_cfg = neg_cfg.with_data_dir(db_path.clone())
    neg_cfg = neg_cfg.with_page_size(PAGE_SIZE_8K)
    neg_db := mut match EmbeddedDatabase.open(neg_cfg) {
        Ok(v) => v,
        Err(_) => { return 198 },
    }

    # Non-people table name: CREATE/INSERT/SELECT against a table the fixed
    # shape recognizer does not know must be rejected, not silently accepted.
    match neg_db.execute("create table accounts (id int, name int)") {
        Ok(_) => { return 200 },
        Err(_) => {},
    }
    match neg_db.execute("insert into accounts values (1, 'eve')") {
        Ok(_) => { return 201 },
        Err(_) => {},
    }
    match neg_db.query("select * from accounts") {
        Ok(_) => { return 202 },
        Err(_) => {},
    }

    # JOIN: multi-table SELECT is outside the promoted single-table shapes.
    match neg_db.query("select people.name from people join accounts on people.id = accounts.id") {
        Ok(_) => { return 203 },
        Err(_) => {},
    }

    # INSERT ... SELECT: query-sourced INSERT is not a promoted shape.
    match neg_db.execute("insert into people select id, name from people") {
        Ok(_) => { return 204 },
        Err(_) => {},
    }

    # UPDATE: only the fixed plain-table `SET name = <string literal> WHERE id
    # = <int literal>` shape is promoted. Other mutation shapes remain Err.
    match neg_db.execute("update people set id = 99 where id = 42") {
        Ok(_) => { return 224 },
        Err(_) => {},
    }
    match neg_db.execute("update people set name = 'no_where'") {
        Ok(_) => { return 225 },
        Err(_) => {},
    }
    match neg_db.execute("update people set name = name where id = 42") {
        Ok(_) => { return 226 },
        Err(_) => {},
    }
    match neg_db.execute("delete from people") {
        Ok(_) => { return 227 },
        Err(_) => {},
    }
    match neg_db.execute("delete from people where name = 'grace'") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }

    # Unsupported projection/expression: aggregate/computed projections outside
    # SELECT * / SELECT name, id must be rejected, not silently run.
    match neg_db.query("select count(*) from people") {
        Ok(_) => { return 205 },
        Err(_) => {},
    }
    match neg_db.query("select id, id from people") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    # Unsupported filters/predicates: only id equality against INT literals is
    # promoted. Text filters, boolean predicates, non-equality comparisons, and
    # expression predicates must stay rejected before any name-filter or planner
    # bridge promotion.
    match neg_db.query("select * from people where name = 'ada'") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select id from people where name = 'ada'") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select * from people where id = 42 and name = 'ada'") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select * from people where id = 42 or id = 7") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select * from people where id > 7") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select * from people where id + 1 = 43") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match neg_db.query("select id + 1 from people") {
        Ok(_) => { return 206 },
        Err(_) => {},
    }

    match neg_db.close() {
        Ok(_) => {},
        Err(_) => { return 207 },
    }


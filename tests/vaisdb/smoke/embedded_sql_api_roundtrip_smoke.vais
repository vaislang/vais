    I output_alias.column_count() != 2 as u64 { return 124 }
    I output_alias.row_count() != 1 as u64 { return 125 }
    output_alias_cols := mut output_alias.get_columns()
    I !expect_column(output_alias_cols, 0, "person_name", "TEXT") { return 126 }
    I !expect_column(output_alias_cols, 1, "person_id", "INT") { return 127 }
    output_alias_rows := mut output_alias.get_rows()
    output_alias_row := mut &output_alias_rows[0]
    I !expect_cell(output_alias_row, 0, "ada") { return 128 }
    I !expect_cell(output_alias_row, 1, "42") { return 129 }
    output_alias.free_owned_text()
    output_alias.free_owned_text()

    output_alias_id_name := mut match db.query("select id as person_id, name as person_name from people where id = 42") {

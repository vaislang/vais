    I output_alias_id_name.column_count() != 2 as u64 { return 255 }
    I output_alias_id_name.row_count() != 1 as u64 { return 255 }
    output_alias_id_name_cols := mut output_alias_id_name.get_columns()
    I !expect_column(output_alias_id_name_cols, 0, "person_id", "INT") { return 255 }
    I !expect_column(output_alias_id_name_cols, 1, "person_name", "TEXT") { return 255 }
    output_alias_id_name_rows := mut output_alias_id_name.get_rows()
    output_alias_id_name_row := mut &output_alias_id_name_rows[0]
    I !expect_cell(output_alias_id_name_row, 0, "42") { return 255 }
    I !expect_cell(output_alias_id_name_row, 1, "ada") { return 255 }
    output_alias_id_name.free_owned_text()
    output_alias_id_name.free_owned_text()

    output_alias_single := mut match db.query("select id as person_id from people where id = 42") {

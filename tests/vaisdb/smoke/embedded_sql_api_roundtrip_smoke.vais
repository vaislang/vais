    aliased_star := mut match db.query("select p.* from people p where p.id = 7") {
        Ok(r) => r,
        Err(_) => { return 94 },
    }
    I aliased_star.column_count() != 2 as u64 { return 95 }
    I aliased_star.row_count() != 1 as u64 { return 96 }

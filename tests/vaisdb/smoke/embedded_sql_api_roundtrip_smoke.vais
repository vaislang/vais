    I qualified_name.column_count() != 1 as u64 { return 255 }
    I qualified_name.row_count() != 1 as u64 { return 255 }
    qualified_name_cols := mut qualified_name.get_columns()
    I !expect_column(qualified_name_cols, 0, "name", "TEXT") { return 255 }
    qualified_name_rows := mut qualified_name.get_rows()
    qualified_name_row := mut &qualified_name_rows[0]
    I !expect_cell(qualified_name_row, 0, "grace") { return 255 }
    qualified_name.free_owned_text()
    qualified_name.free_owned_text()

    aliased := mut match db.query("select p.name, p.id from people as p where p.id = 42") {

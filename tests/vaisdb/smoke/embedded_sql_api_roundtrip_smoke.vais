# EmbeddedDatabase public SQL API round-trip runtime smoke.
#
# Characterization scope (slice 2 — public embedded SQL surface):
#   - Opens an EmbeddedDatabase with a real .vaisdb directory.
#   - Executes tokenized fixed CREATE TABLE through EmbeddedDatabase.execute().
#   - Executes tokenized fixed INSERT VALUES forms through EmbeddedDatabase.execute().
#   - Explicitly frees tokenizer-owned identifier/string token text twice.
#   - Reads multiple rows back through EmbeddedDatabase.query("SELECT * FROM ...").
#   - Reads a fixed-form projected query and verifies column/result ordering.
#   - Reads fixed-form WHERE id filters and verifies match/no-match behavior.
#   - Explicitly frees query result row text payloads and verifies the free is
#     idempotent.
#   - Closes the handle, flips is_open=false, and rejects repeated close plus
#     SQL calls after close.
#   - Reopens the same data directory and reads both rows back through the
#     persisted catalog root + heap path.
#   - Pins the provisional embedded SQL boundary with negative assertions:
#     out-of-shape SQL (non-people table name, JOIN, INSERT ... SELECT, and an
#     unsupported projection/expression shape) must return Err from the public
#     EmbeddedDatabase.execute()/query() API instead of silently succeeding.
#   - Promotes the narrow NOT NULL, literal DEFAULT, id PRIMARY KEY,
#     name UNIQUE, and id CHECK subsets on the fixed people(id INT, name TEXT)
#     shape. NOT NULL flags, literal defaults, and promoted constraint metadata
#     persist through close/reopen. Composite/table-level constraints, foreign
#     key/reference constraints, and non-literal/default type-mismatch forms
#     stay rejected.
#   - Promotes descriptor-backed books(id INT, title TEXT) CREATE,
#     values-only INSERT, and unfiltered SELECT, including close/reopen
#     visibility, bounded WAL redo recovery evidence for values-only INSERT,
#     and negative books filter/join/projection boundaries.
#   - Promotes authors(id INT, name TEXT) as the second registered descriptor
#     with exact CREATE/VALUES INSERT/SELECT and close/reopen evidence while
#     keeping filters, joins, schema browsing, and unregistered SELECT rejected.
#   - Promotes the first catalog-derived dynamic descriptor CREATE boundary:
#     exact CREATE TABLE albums(id INT, title TEXT) succeeds without adding
#     albums to the static registry, duplicate CREATE is rejected before and
#     after close/reopen, and dynamic full-row INSERT plus descriptor-order
#     SELECT readback and equality filters are promoted in later sections.
#   - Promotes authors(id INT, name TEXT) values-only INSERT recovery after
#     durable schema setup by restoring the authors heap page to its pre-INSERT
#     image and reopening through EmbeddedDatabase.open().
#   - Promotes catalog-derived dynamic albums(id INT, title TEXT) values-only
#     INSERT recovery after durable schema setup by restoring the dynamic table
#     heap page to its pre-INSERT image and reopening through
#     EmbeddedDatabase.open().
#   - Promotes catalog-derived dynamic notes(id INT, body TEXT) full-column-list
#     INSERT recovery after durable schema setup by restoring the dynamic table
#     heap page to its pre-INSERT image and reopening through
#     EmbeddedDatabase.open().
#   - Promotes the first catalog-derived three-column descriptor metadata
#     boundary for exact tasks(id INT, title TEXT, status TEXT), plus bounded
#     full-column-list INSERT, SELECT/filter, and open-time recovery evidence
#     while keeping server/web behavior unpromoted for that shape.
#   - Promotes the first arbitrary-name/arbitrary-text-column three-column
#     descriptor metadata boundary for tickets(id INT, summary TEXT, state TEXT)
#     plus full-column-list INSERT and selected SELECT/filter readback while
#     keeping recovery/server/web behavior unpromoted for that shape.
#   - Promotes descriptor SELECT * TEXT equality filters for books.title and
#     authors.name, including reversed literal equality, while keeping people
#     name filters, descriptor id filters, projections plus filters, qualified
#     refs, joins, and broad predicates rejected.
#   - Promotes bounded WAL redo recovery evidence for the fixed plain
#     `update people set name = 'lovelace' where id = 42` path, including
#     stale tuple hiding and current row visibility through public SELECT after
#     explicit recovery.
#   - Promotes bounded WAL redo recovery evidence for the fixed plain
#     `delete from people where id = 7` path, including target hiding,
#     survivor visibility, and row-count proof through public SELECT after
#     explicit recovery.
#   - Promotes automatic recovery-on-open evidence for the fixed primary-key
#     DELETE path and the fixed non-null secondary UNIQUE DELETE path by
#     restoring heap plus index pages to pre-DELETE images and reopening
#     through EmbeddedDatabase.open().
#
# This keeps broader SQL planning out of scope; it locks the first SQLite-like
# in-process SQL API boundary over the already-certified catalog + heap DML
# path. The negative block below pins that boundary as executable: it does NOT
# add any new accepted SQL behavior — it only proves the current rejection.

use server/embedded
use storage/constants
use storage/file
use storage/page/manager
use storage/page/meta
use storage/buffer/pool
use storage/recovery/redo
use storage/wal/lsn
use sql/catalog/schema
use sql/parser/token
use std/time

impl fn __str_eq(a: str, b: str) -> i64

fn expect_cell(row: &Vec<Option<str>>, idx: u64, expected: str) -> bool {
    match row[idx] {
        Some(v) => __str_eq(v, expected) != 0,
        None => false,
    }
}

fn expect_none_cell(row: &Vec<Option<str>>, idx: u64) -> bool {
    match row[idx] {
        Some(_) => false,
        None => true,
    }
}

fn expect_column(cols: &Vec<EmbeddedColumn>, idx: u64, expected_name: str, expected_type: str) -> bool {
    col := mut &cols[idx]
    (__str_eq(col.name, expected_name) != 0) && (__str_eq(col.type_name, expected_type) != 0)
}

fn expect_catalog_column(cols: &Vec<ColumnInfo>, idx: u64, expected_name: str, expected_type: str) -> bool {
    col := mut &cols[idx]
    (__str_eq(col.name, expected_name) != 0) && (__str_eq(col.data_type.name(), expected_type) != 0)
}

fn copy_smoke_page(data: &[u8]) -> Vec<u8> {
    out: Vec<u8> := mut Vec.with_capacity(data.len())
    i := mut 0u64
    LW i < data.len() {
        out.push(data[i])
        i = i + 1
    }
    out
}

fn restore_smoke_data_page(db_path: str, page_id: u32, page_image: Vec<u8>) -> i64 {
    data_path := mut db_path.clone() + "/" + FILE_NAME_DATA
    page_offset := mut (page_id as u64) * (PAGE_SIZE_8K as u64)

    restore_file := mut match File.open(data_path, "rw+") {
        Ok(f) => f,
        Err(_) => { return 224 },
    }
    match restore_file.write_at(page_offset, &page_image[0..page_image.len()]) {
        Ok(_) => {},
        Err(_) => { return 225 },
    }
    match restore_file.fsync() {
        Ok(_) => {},
        Err(_) => { return 226 },
    }

    0
}

fn set_smoke_checkpoint_lsn(db_path: str, checkpoint_lsn: u64) -> i64 {
    meta_path := mut db_path.clone() + "/" + FILE_NAME_META
    meta_file := mut match File.open(meta_path, "rw+") {
        Ok(f) => f,
        Err(_) => { return 224 },
    }
    page := mut match meta_file.read_at(0, PAGE_SIZE_8K as u64) {
        Ok(p) => p,
        Err(_) => { return 225 },
    }
    meta := mut match MetaPageHeader.read_from_page(&page) {
        Ok(m) => m,
        Err(_) => { return 226 },
    }
    meta.set_checkpoint_lsn(checkpoint_lsn)
    meta.write_to_page(&page)
    match meta_file.write_at(0, &page[0..page.len()]) {
        Ok(_) => {},
        Err(_) => { return 227 },
    }
    match meta_file.fsync() {
        Ok(_) => {},
        Err(_) => { return 228 },
    }

    0
}

fn expect_page_wal_recovery(db_path: str, page_id: u32, start_lsn: u64, pre_mutation_page: Vec<u8>, min_txn_entries: u64, min_records_redone: u64) -> i64 {
    restore_code := mut restore_smoke_data_page(db_path.clone(), page_id, pre_mutation_page)
    I restore_code != 0 {
        return restore_code
    }

    data_path := mut db_path.clone() + "/" + FILE_NAME_DATA
    recovery_file := mut match File.open(data_path, "rw+") {
        Ok(f) => f,
        Err(_) => { return 227 },
    }
    files: Vec<File> := mut Vec.with_capacity(1)
    files.push(recovery_file)
    manager := mut PageManager.new(files, PAGE_SIZE_8K)
    pool := mut BufferPool.new(manager, PAGE_SIZE_8K, 4 as u32)
    wal_dir := mut db_path.clone() + "/" + DIR_NAME_WAL

    analysis := mut match recovery_analysis(&wal_dir, start_lsn) {
        Ok(v) => v,
        Err(_) => { return 228 },
    }
    I analysis.txn_entries.len() < min_txn_entries {
        return 229
    }

    records_redone := mut match recovery_redo(&wal_dir, &analysis, &mut pool) {
        Ok(v) => v,
        Err(_) => { return 230 },
    }
    I records_redone < min_records_redone {
        return 231
    }

    match pool.flush_all() {
        Ok(_) => {},
        Err(_) => { return 232 },
    }

    0
}

fn expect_books_insert_wal_recovery(db_path: str, page_id: u32, start_lsn: u64, pre_insert_page: Vec<u8>) -> i64 {
    expect_page_wal_recovery(db_path, page_id, start_lsn, pre_insert_page, 2 as u64, 2 as u64)
}

fn expect_people_update_wal_recovery(db_path: str, page_id: u32, start_lsn: u64, pre_update_page: Vec<u8>) -> i64 {
    replay_code := mut expect_page_wal_recovery(db_path.clone(), page_id, start_lsn, pre_update_page, 1 as u64, 1 as u64)
    I replay_code != 0 {
        return replay_code
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path)
    cfg = cfg.with_page_size(PAGE_SIZE_8K)
    recovered := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 233 },
    }

    current := mut match recovered.query("select * from people where id = 42") {
        Ok(r) => r,
        Err(_) => { return 234 },
    }
    I current.row_count() != 1 as u64 { return 235 }
    rows := mut current.get_rows()
    row := mut &rows[0]
    I !expect_cell(row, 0, "42") { return 236 }
    I !expect_cell(row, 1, "lovelace") { return 237 }
    current.free_owned_text()
    current.free_owned_text()

    all_rows := mut match recovered.query("select * from people") {
        Ok(r) => r,
        Err(_) => { return 238 },
    }
    I all_rows.row_count() != 2 as u64 { return 239 }
    all_rows.free_owned_text()
    all_rows.free_owned_text()

    match recovered.close() {
        Ok(_) => {},
        Err(_) => { return 240 },
    }

    0
}

fn expect_people_delete_wal_recovery(db_path: str, page_id: u32, start_lsn: u64, pre_delete_page: Vec<u8>) -> i64 {
    replay_code := mut expect_page_wal_recovery(db_path.clone(), page_id, start_lsn, pre_delete_page, 1 as u64, 1 as u64)
    I replay_code != 0 {
        return replay_code
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path)
    cfg = cfg.with_page_size(PAGE_SIZE_8K)
    recovered := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 241 },
    }

    deleted_probe := mut match recovered.query("select * from people where id = 7") {
        Ok(r) => r,
        Err(_) => { return 242 },
    }
    I deleted_probe.row_count() != 0 as u64 { return 243 }
    deleted_probe.free_owned_text()
    deleted_probe.free_owned_text()

    survivor := mut match recovered.query("select * from people where id = 42") {
        Ok(r) => r,
        Err(_) => { return 244 },
    }
    I survivor.row_count() != 1 as u64 { return 245 }
    survivor_rows := mut survivor.get_rows()
    survivor_row := mut &survivor_rows[0]
    I !expect_cell(survivor_row, 0, "42") { return 246 }
    I !expect_cell(survivor_row, 1, "lovelace") { return 247 }
    survivor.free_owned_text()
    survivor.free_owned_text()

    all_rows := mut match recovered.query("select * from people") {
        Ok(r) => r,
        Err(_) => { return 248 },
    }
    I all_rows.row_count() != 11 as u64 { return 249 }
    all_rows.free_owned_text()
    all_rows.free_owned_text()

    match recovered.close() {
        Ok(_) => {},
        Err(_) => { return 250 },
    }

    0
}

fn expect_token_text_free_idempotent() -> i64 {
    tokenizer := mut Tokenizer.new("insert into people values (7, 'token_payload')")
    tokens := mut match tokenizer.tokenize_all() {
        Ok(v) => v,
        Err(_) => { return 70 },
    }
    I tokens.len() < 9 { return 71 }

    match &tokens[2].kind {
        TokenKind.Identifier { v } => {
            I __str_eq(*v, "people") == 0 { return 72 }
        },
        _ => { return 73 },
    }
    match &tokens[7].kind {
        TokenKind.StringLit { v } => {
            I __str_eq(*v, "token_payload") == 0 { return 74 }
        },
        _ => { return 75 },
    }

    free_token_vec_owned_text(&mut tokens)
    free_token_vec_owned_text(&mut tokens)

    match &tokens[2].kind {
        TokenKind.Eof => {},
        _ => { return 76 },
    }
    match &tokens[7].kind {
        TokenKind.Eof => {},
        _ => { return 77 },
    }

    0
}

fn main() -> i64 {
    token_free_code := mut expect_token_text_free_idempotent()
    I token_free_code != 0 { return token_free_code }

    db_suffix := mut time_micros()
    db_path := mut "embedded_sql_api_roundtrip_db_{db_suffix}"

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 1 },
    }

    # Still-unsupported people-table CREATE forms keep deterministic rejection.
    # Only simple INT/TEXT literal defaults and the fixed column-level
    # PRIMARY KEY/UNIQUE/CHECK shapes are promoted; type-mismatched defaults,
    # name PRIMARY KEY, id UNIQUE, table-level/composite constraints,
    # foreign-key/reference constraints, and unsupported CHECK forms are not in
    # the promoted shape.
    match db.execute("create table people (id int check (id > 0), name text)") {
        Ok(_) => { return 196 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text check (name = 'ada'))") {
        Ok(_) => { return 198 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text not null unique check (name = 'ada'))") {
        Ok(_) => { return 199 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text default true)") {
        Ok(_) => { return 208 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text primary key)") {
        Ok(_) => { return 209 },
        Err(_) => {},
    }
    match db.execute("create table people (id int primary key, name text default 'anon')") {
        Ok(_) => { return 255 },
        Err(_) => {},
    }
    match db.execute("create table people (id int unique, name text)") {
        Ok(_) => { return 210 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, primary key (id))") {
        Ok(_) => { return 211 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, primary key (id, name))") {
        Ok(_) => { return 212 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, unique (name))") {
        Ok(_) => { return 213 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, unique (id, name))") {
        Ok(_) => { return 214 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, check (id > 0))") {
        Ok(_) => { return 215 },
        Err(_) => {},
    }
    match db.execute("create table people (id int, name text, foreign key (id) references other (id))") {
        Ok(_) => { return 216 },
        Err(_) => {},
    }
    match db.execute("create table people (id int references other (id), name text)") {
        Ok(_) => { return 217 },
        Err(_) => {},
    }

    created := mut match db.execute("create table people (id int, name text)") {
        Ok(n) => n,
        Err(_) => { return 2 },
    }
    I created != 0 as u64 { return 3 }

    inserted := mut match db.execute("INSERT INTO people VALUES (42, 'ada');") {
        Ok(n) => n,
        Err(_) => { return 4 },
    }
    I inserted != 1 as u64 { return 5 }

    inserted2 := mut match db.execute(" insert into people values (7, 'grace') ") {
        Ok(n) => n,
        Err(_) => { return 6 },
    }
    I inserted2 != 1 as u64 { return 7 }

    result := mut match db.query("SELECT * FROM people;") {
        Ok(r) => r,
        Err(_) => { return 8 },
    }
    I result.column_count() != 2 as u64 { return 9 }
    I result.row_count() != 2 as u64 { return 10 }
    columns := mut result.get_columns()
    I !expect_column(columns, 0, "id", "INT") { return 11 }
    I !expect_column(columns, 1, "name", "TEXT") { return 12 }

    rows := mut result.get_rows()
    row0 := mut &rows[0]
    row1 := mut &rows[1]
    I !expect_cell(row0, 0, "42") { return 13 }
    I !expect_cell(row0, 1, "ada") { return 14 }
    I !expect_cell(row1, 0, "7") { return 15 }
    I !expect_cell(row1, 1, "grace") { return 16 }

    result.free_owned_text()
    result.free_owned_text()
    freed_rows := mut result.get_rows()
    freed_row0 := mut &freed_rows[0]
    freed_row1 := mut &freed_rows[1]
    match freed_row0[0] {
        Some(_) => { return 17 },
        None => {},
    }
    match freed_row0[1] {
        Some(_) => { return 18 },
        None => {},
    }
    match freed_row1[0] {
        Some(_) => { return 19 },
        None => {},
    }
    match freed_row1[1] {
        Some(_) => { return 20 },
        None => {},
    }

    projected := mut match db.query("select name, id from people") {
        Ok(r) => r,
        Err(_) => { return 21 },
    }
    I projected.column_count() != 2 as u64 { return 22 }
    I projected.row_count() != 2 as u64 { return 23 }
    projected_cols := mut projected.get_columns()
    I !expect_column(projected_cols, 0, "name", "TEXT") { return 24 }
    I !expect_column(projected_cols, 1, "id", "INT") { return 25 }
    projected_rows := mut projected.get_rows()
    projected_row0 := mut &projected_rows[0]
    projected_row1 := mut &projected_rows[1]
    I !expect_cell(projected_row0, 0, "ada") { return 26 }
    I !expect_cell(projected_row0, 1, "42") { return 27 }
    I !expect_cell(projected_row1, 0, "grace") { return 28 }
    I !expect_cell(projected_row1, 1, "7") { return 29 }
    projected.free_owned_text()
    projected.free_owned_text()

    projected_id_name := mut match db.query("select id, name from people") {
        Ok(r) => r,
        Err(_) => { return 255 },
    }
    I projected_id_name.column_count() != 2 as u64 { return 255 }
    I projected_id_name.row_count() != 2 as u64 { return 255 }
    projected_id_name_cols := mut projected_id_name.get_columns()
    I !expect_column(projected_id_name_cols, 0, "id", "INT") { return 255 }
    I !expect_column(projected_id_name_cols, 1, "name", "TEXT") { return 255 }
    projected_id_name_rows := mut projected_id_name.get_rows()
    projected_id_name_row0 := mut &projected_id_name_rows[0]
    projected_id_name_row1 := mut &projected_id_name_rows[1]
    I !expect_cell(projected_id_name_row0, 0, "42") { return 255 }
    I !expect_cell(projected_id_name_row0, 1, "ada") { return 255 }
    I !expect_cell(projected_id_name_row1, 0, "7") { return 255 }
    I !expect_cell(projected_id_name_row1, 1, "grace") { return 255 }
    projected_id_name.free_owned_text()
    projected_id_name.free_owned_text()

    projected_id := mut match db.query("select id from people") {
        Ok(r) => r,
        Err(_) => { return 255 },
    }
    I projected_id.column_count() != 1 as u64 { return 255 }
    I projected_id.row_count() != 2 as u64 { return 255 }
    projected_id_cols := mut projected_id.get_columns()
    I !expect_column(projected_id_cols, 0, "id", "INT") { return 255 }
    projected_id_rows := mut projected_id.get_rows()
    projected_id_row0 := mut &projected_id_rows[0]
    projected_id_row1 := mut &projected_id_rows[1]
    I !expect_cell(projected_id_row0, 0, "42") { return 255 }
    I !expect_cell(projected_id_row1, 0, "7") { return 255 }
    projected_id.free_owned_text()
    projected_id.free_owned_text()

    projected_name := mut match db.query("select name from people") {
        Ok(r) => r,
        Err(_) => { return 255 },
    }
    I projected_name.column_count() != 1 as u64 { return 255 }
    I projected_name.row_count() != 2 as u64 { return 255 }
    projected_name_cols := mut projected_name.get_columns()
    I !expect_column(projected_name_cols, 0, "name", "TEXT") { return 255 }
    projected_name_rows := mut projected_name.get_rows()
    projected_name_row0 := mut &projected_name_rows[0]
    projected_name_row1 := mut &projected_name_rows[1]
    I !expect_cell(projected_name_row0, 0, "ada") { return 255 }
    I !expect_cell(projected_name_row1, 0, "grace") { return 255 }
    projected_name.free_owned_text()
    projected_name.free_owned_text()

    qualified := mut match db.query("select people.name, people.id from people where people.id = 7") {
        Ok(r) => r,
        Err(_) => { return 80 },
    }
    I qualified.column_count() != 2 as u64 { return 81 }
    I qualified.row_count() != 1 as u64 { return 82 }
    qualified_cols := mut qualified.get_columns()
    I !expect_column(qualified_cols, 0, "name", "TEXT") { return 83 }
    I !expect_column(qualified_cols, 1, "id", "INT") { return 84 }
    qualified_rows := mut qualified.get_rows()
    qualified_row := mut &qualified_rows[0]
    I !expect_cell(qualified_row, 0, "grace") { return 85 }
    I !expect_cell(qualified_row, 1, "7") { return 86 }
    qualified.free_owned_text()
    qualified.free_owned_text()

    qualified_id_name := mut match db.query("select people.id, people.name from people where people.id = 7") {
        Ok(r) => r,
        Err(_) => { return 255 },
    }
    I qualified_id_name.column_count() != 2 as u64 { return 255 }
    I qualified_id_name.row_count() != 1 as u64 { return 255 }
    qualified_id_name_cols := mut qualified_id_name.get_columns()
    I !expect_column(qualified_id_name_cols, 0, "id", "INT") { return 255 }
    I !expect_column(qualified_id_name_cols, 1, "name", "TEXT") { return 255 }
    qualified_id_name_rows := mut qualified_id_name.get_rows()
    qualified_id_name_row := mut &qualified_id_name_rows[0]
    I !expect_cell(qualified_id_name_row, 0, "7") { return 255 }
    I !expect_cell(qualified_id_name_row, 1, "grace") { return 255 }
    qualified_id_name.free_owned_text()
    qualified_id_name.free_owned_text()

    qualified_id := mut match db.query("select people.id from people where people.id = 7") {
        Ok(r) => r,
        Err(_) => { return 255 },
    }
    I qualified_id.column_count() != 1 as u64 { return 255 }
    I qualified_id.row_count() != 1 as u64 { return 255 }
    qualified_id_cols := mut qualified_id.get_columns()
    I !expect_column(qualified_id_cols, 0, "id", "INT") { return 255 }
    qualified_id_rows := mut qualified_id.get_rows()
    qualified_id_row := mut &qualified_id_rows[0]
    I !expect_cell(qualified_id_row, 0, "7") { return 255 }
    qualified_id.free_owned_text()
    qualified_id.free_owned_text()

    qualified_name := mut match db.query("select people.name from people where 7 = people.id") {
        Ok(r) => r,

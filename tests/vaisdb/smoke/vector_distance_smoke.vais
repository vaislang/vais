U vector/distance
U std/vec.{vec_new_t}

F main() -> i64 {
    a: Vec<f32> := mut vec_new_t()
    a.push(1.0)
    a.push(2.0)
    a.push(3.0)

    b: Vec<f32> := mut vec_new_t()
    b.push(4.0)
    b.push(5.0)
    b.push(6.0)

    dot := mut dot_product_scalar(&a, &b)
    I !approx_eq_f32(dot, -32.0, 0.0001) { R 1 }

    l2 := mut l2_distance_scalar(&a, &a)
    I !approx_eq_f32(l2, 0.0, 0.0001) { R 2 }

    computer := mut DistanceComputer.new(DotProduct)
    computed: f32 := mut M computer.compute(&a, &b) {
        Ok(v) => v,
        Err(_) => { R 3 },
    }
    I !approx_eq_f32(computed, -32.0, 0.0001) { R 4 }

    mismatch: Vec<f32> := mut vec_new_t()
    mismatch.push(1.0)
    M computer.compute(&a, &mismatch) {
        Ok(_) => { R 5 },
        Err(_) => {},
    }

    R 0
}

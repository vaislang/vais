U vector/hnsw/types
U vector/hnsw/delete
U vector/hnsw/search
U storage/error

S SmokeDeleteStore {
    node: HnswNode,
    vector: Vec<f32>,
    has_node: bool,
    stored_count: u64,
}

X SmokeDeleteStore {
    F new(node: HnswNode) -> SmokeDeleteStore {
        vector: Vec<f32> := mut Vec.with_capacity(2)
        vector.push(0.0)
        vector.push(0.0)
        SmokeDeleteStore {
            node,
            vector,
            has_node: true,
            stored_count: 0,
        }
    }
}

X SmokeDeleteStore : NodeStore {
    F load_node(self, node_id: u64) -> Result<HnswNode, VaisError> {
        I node_id == self.node.node_id && self.has_node {
            R Ok(self.node.clone())
        }
        Err(err_internal("missing smoke delete node"))
    }

    F load_vector(self, node_id: u64) -> Result<Vec<f32>, VaisError> {
        values: Vec<f32> := mut Vec.with_capacity(2)
        values.push(0.0)
        values.push(0.0)
        Ok(values)
    }

    F store_node(mut self, node: HnswNode) -> Result<(), VaisError> {
        I node.node_id != self.node.node_id {
            R Err(err_internal("unexpected smoke delete node"))
        }
        self.node = node
        self.has_node = true
        self.stored_count += 1
        Ok(())
    }

    F allocate_node_id(mut self) -> u64 {
        1
    }

    F get_file_page(self, node_id: u64) -> Result<(u8, u32), VaisError> {
        Ok((9 as u8, node_id as u32))
    }

    F allocate_node_page(mut self, node_id: u64) -> Result<(u8, u32), VaisError> {
        Ok((9 as u8, node_id as u32))
    }
}

X SmokeDeleteStore : NodeLookup {
    F get_node(self, node_id: u64) -> Result<&HnswNode, VaisError> {
        I node_id == self.node.node_id && self.has_node {
            R Ok(&self.node)
        }
        Err(err_internal("missing smoke delete lookup node"))
    }

    F get_vector(self, node_id: u64) -> Result<&[f32], VaisError> {
        I node_id == self.node.node_id && self.has_node {
            R Ok(self.vector[0..2])
        }
        Err(err_internal("missing smoke delete lookup vector"))
    }
}

F main() -> i64 {
    config := mut M HnswConfig.new(2 as u16, 4 as u16, 4 as u32, 4 as u32, 8 as u64, DISTANCE_L2) {
        Ok(v) => v,
        Err(_) => { R 1 },
    }
    meta := mut HnswMeta.new(config, 13 as u32)
    meta.add_node()
    meta.update_entry_point(1, 1 as u8)

    node := mut HnswNode.new(1, 7 as u32, 0 as u16, 1 as u8, 100, 1 as u32)
    M node.add_neighbor(0 as u8, HnswNeighbor.new(2, 1.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 2 },
    }
    M node.add_neighbor(1 as u8, HnswNeighbor.new(3, 2.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 3 },
    }

    store := mut SmokeDeleteStore.new(node)
    layers := mut M hnsw_delete(
        1,
        &mut meta,
        &mut store,
        200,
        4 as u32,
        9 as u8,
        44 as u32,
    ) {
        Ok(v) => v,
        Err(e) => {
            I e.code == "VE-02-03-004" { R 30 }
            R 4
        },
    }

    I layers.len() != 2 { R 5 }
    I layers[0] != 0 as u8 { R 6 }
    I layers[1] != 1 as u8 { R 7 }
    I meta.total_nodes != 1 { R 8 }
    I meta.total_deleted != 1 { R 9 }
    I meta.active_nodes() != 0 { R 10 }
    I store.stored_count != 1 { R 11 }

    deleted := mut M store.load_node(1) {
        Ok(n) => n,
        Err(_) => { R 12 },
    }
    I !deleted.is_deleted { R 13 }
    I deleted.txn_id_expire != 200 { R 14 }
    I deleted.expire_cmd_id != 4 as u32 { R 15 }
    I deleted.is_current() { R 16 }

    M hnsw_delete(
        1,
        &mut meta,
        &mut store,
        201,
        5 as u32,
        9 as u8,
        44 as u32,
    ) {
        Ok(_) => { R 17 },
        Err(e) => {
            I e.code != "VE-02-03-004" { R 18 }
        },
    }

    M hnsw_delete(
        INVALID_NODE_ID,
        &mut meta,
        &mut store,
        202,
        6 as u32,
        9 as u8,
        44 as u32,
    ) {
        Ok(_) => { R 19 },
        Err(e) => {
            I e.code != "VE-02-03-004" { R 20 }
        },
    }

    R 0
}

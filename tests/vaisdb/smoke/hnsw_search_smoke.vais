U vector/hnsw/types
U vector/hnsw/search
U vector/distance
U storage/constants
U storage/error

S SmokeLookup {
    n1: HnswNode,
    n2: HnswNode,
    n3: HnswNode,
    v1: Vec<f32>,
    v2: Vec<f32>,
    v3: Vec<f32>,
}

X SmokeLookup {
    F new(n1: HnswNode, n2: HnswNode, n3: HnswNode, v1: Vec<f32>, v2: Vec<f32>, v3: Vec<f32>) -> SmokeLookup {
        SmokeLookup { n1, n2, n3, v1, v2, v3 }
    }
}

X SmokeLookup : NodeStore {
    F load_node(self, node_id: u64) -> Result<HnswNode, VaisError> {
        I node_id == 1 { R Ok(self.n1.clone()) }
        I node_id == 2 { R Ok(self.n2.clone()) }
        I node_id == 3 { R Ok(self.n3.clone()) }
        Err(err_internal("missing smoke HNSW node"))
    }

    F load_vector(self, node_id: u64) -> Result<Vec<f32>, VaisError> {
        I node_id == 1 { R Ok(self.v1.clone()) }
        I node_id == 2 { R Ok(self.v2.clone()) }
        I node_id == 3 { R Ok(self.v3.clone()) }
        Err(err_internal("missing smoke HNSW vector"))
    }

    F store_node(mut self, node: HnswNode) -> Result<(), VaisError> {
        I node.node_id == 1 {
            self.n1 = node
            R Ok(())
        }
        I node.node_id == 2 {
            self.n2 = node
            R Ok(())
        }
        I node.node_id == 3 {
            self.n3 = node
            R Ok(())
        }
        Err(err_internal("unexpected smoke HNSW node"))
    }

    F allocate_node_id(mut self) -> u64 {
        4
    }

    F get_file_page(self, node_id: u64) -> Result<(u8, u32), VaisError> {
        I node_id == 1 || node_id == 2 || node_id == 3 {
            R Ok((FILE_ID_VECTORS, node_id as u32))
        }
        Err(err_internal("missing smoke HNSW node page"))
    }

    F allocate_node_page(mut self, node_id: u64) -> Result<(u8, u32), VaisError> {
        Ok((FILE_ID_VECTORS, node_id as u32))
    }
}

F vec2(a: f32, b: f32) -> Vec<f32> {
    values: Vec<f32> := mut Vec.with_capacity(2)
    values.push(a)
    values.push(b)
    values
}

F main() -> i64 {
    n1 := mut HnswNode.new(1, 0, 0, 0, 10, 1)
    n2 := mut HnswNode.new(2, 0, 0, 0, 10, 2)
    n3 := mut HnswNode.new(3, 0, 0, 0, 10, 3)

    M n1.add_neighbor(0, HnswNeighbor.new(2, 1.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 1 },
    }
    M n1.add_neighbor(0, HnswNeighbor.new(3, 3.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 2 },
    }
    M n2.add_neighbor(0, HnswNeighbor.new(1, 1.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 3 },
    }
    M n3.add_neighbor(0, HnswNeighbor.new(1, 3.0 as f32)) {
        Ok(_) => {},
        Err(_) => { R 4 },
    }

    lookup := mut SmokeLookup.new(
        n1,
        n2,
        n3,
        vec2(0.0, 0.0),
        vec2(1.0, 0.0),
        vec2(3.0, 0.0),
    )

    config := mut M HnswConfig.new(2 as u16, 4 as u16, 4 as u32, 4 as u32, 3 as u64, DISTANCE_L2) {
        Ok(v) => v,
        Err(_) => { R 5 },
    }
    meta := mut HnswMeta.new(config, 7 as u32)
    meta.update_entry_point(1, 0)
    meta.add_node()
    meta.add_node()
    meta.add_node()
    I meta.is_empty() { R 15 }
    I meta.total_nodes != 3 { R 16 }
    I meta.entry_point != 1 { R 17 }

    distance := mut DistanceComputer.new(L2)
    query := mut vec2(0.9 as f32, 0.0)

    search_result := mut M knn_search(&query, 2, 3 as u32, &meta, &mut lookup, &distance) {
        Ok(v) => v,
        Err(e) => {
            I e.code == "VE-02-03-001" { R 18 }
            I e.code == "VE-02-03-002" { R 19 }
            I e.code == "VE-02-03-003" { R 20 }
            I e.code == "VAIS-0205001" { R 21 }
            I e.code == "VAIS-0205002" { R 22 }
            R 6
        },
    }

    I search_result.results.len() != 2 { R 7 }
    I search_result.distance_computations == 0 { R 8 }
    I search_result.nodes_visited == 0 { R 9 }

    first := mut &search_result.results[0]
    second := mut &search_result.results[1]
    I first.node_id != 2 { R 10 }
    I !approx_eq_f32(first.distance, 0.1 as f32, 0.0001 as f32) { R 11 }
    I second.node_id != 1 { R 12 }
    I !approx_eq_f32(second.distance, 0.9 as f32, 0.0001 as f32) { R 13 }

    M knn_search(&query, 0, 3 as u32, &meta, &mut lookup, &distance) {
        Ok(_) => { R 14 },
        Err(_) => {},
    }

    R 0
}

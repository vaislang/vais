use sql/parser/parser
use sql/parser/ast
use sql/parser/token
use sql/planner/types

fn check_int_literal(expr: Expr, expected: i64, code: i64) -> i64 {
    match expr {
        Expr.Literal { value } => {
            match value {
                SqlValue.IntVal { v } => {
                    I v != expected { return code }
                    return 0
                },
                _ => { return code },
            }
        },
        _ => { return code },
    }
}

fn anchor_parser_link_symbols() -> i64 {
    cte_columns: Vec<str> := mut Vec.with_capacity(0)
    cte_query := mut SelectQuery.empty()
    ctes: Vec<Cte> := mut Vec.with_capacity(1)
    ctes.push(Cte {
        name: "cte",
        columns: cte_columns,
        query: cte_query,
        recursive: false,
    })
    I ctes.len() != 1 { return 31 }

    columns: Vec<ColumnDef> := mut Vec.with_capacity(1)
    columns.push(ColumnDef.new("id", SqlType.Int))
    I columns.len() != 1 { return 32 }

    upper := mut "select".to_uppercase()
    I upper != "SELECT" { return 33 }
    I "p1".char_at(0) != 112 { return 34 }

    return 0
}

fn check_parser_owned_text_cleanup() -> i64 {
    literal_tokenizer := mut Tokenizer.new("SELECT 'ada' AS label LIMIT 1;")
    literal_tokens := mut match literal_tokenizer.tokenize_all() {
        Ok(v) => v,
        Err(_) => { return 60 },
    }
    literal_parser := mut Parser.new(literal_tokens)
    match literal_parser.expect(TokenKind.Select) {
        Ok(_) => {},
        Err(_) => { return 61 },
    }
    literal_items := mut match literal_parser.parse_select_list() {
        Ok(v) => v,
        Err(_) => { return 62 },
    }
    literal_parser.free_owned_token_text()
    literal_parser.free_owned_token_text()
    I literal_items.len() != 1 { return 63 }

    literal_item := mut literal_items[0].clone()
    match literal_item {
        SelectItem.Expr { expr, alias } => {
            match expr {
                Expr.Literal { value } => {
                    match value {
                        SqlValue.StringVal { v } => {
                            I v != "ada" { return 64 }
                        },
                        _ => { return 65 },
                    }
                },
                _ => { return 66 },
            }
            match alias {
                Some(a) => {
                    I a != "label" { return 67 }
                },
                None => { return 68 },
            }
        },
        _ => { return 69 },
    }

    column_tokenizer := mut Tokenizer.new("SELECT name AS alias LIMIT 1;")
    column_tokens := mut match column_tokenizer.tokenize_all() {
        Ok(v) => v,
        Err(_) => { return 70 },
    }
    column_parser := mut Parser.new(column_tokens)
    match column_parser.expect(TokenKind.Select) {
        Ok(_) => {},
        Err(_) => { return 71 },
    }
    column_items := mut match column_parser.parse_select_list() {
        Ok(v) => v,
        Err(_) => { return 72 },
    }
    column_parser.free_owned_token_text_payloads()
    column_parser.free_owned_token_text_payloads()
    I column_items.len() != 1 { return 73 }

    column_item := mut column_items[0].clone()
    match column_item {
        SelectItem.Expr { expr, alias } => {
            match expr {
                Expr.ColumnRef { table, column } => {
                    match table {
                        Some(_) => { return 74 },
                        None => {},
                    }
                    I column != "name" { return 75 }
                },
                _ => { return 76 },
            }
            match alias {
                Some(a) => {
                    I a != "alias" { return 77 }
                },
                None => { return 78 },
            }
        },
        _ => { return 79 },
    }

    parsed := mut match parse_sql("SELECT 'eve' AS label;") {
        Ok(v) => v,
        Err(_) => { return 80 },
    }
    I parsed.len() != 1 { return 81 }
    parsed_stmt := mut parsed[0].clone()
    match parsed_stmt {
        Statement.Select { query } => {
            I query.select_list.len() != 1 { return 82 }
            parsed_item := mut query.select_list[0].clone()
            match parsed_item {
                SelectItem.Expr { expr, alias } => {
                    match expr {
                        Expr.Literal { value } => {
                            match value {
                                SqlValue.StringVal { v } => {
                                    I v != "eve" { return 83 }
                                },
                                _ => { return 84 },
                            }
                        },
                        _ => { return 85 },
                    }
                    match alias {
                        Some(a) => {
                            I a != "label" { return 86 }
                        },
                        None => { return 87 },
                    }
                },
                _ => { return 88 },
            }
        },
        _ => { return 89 },
    }
    parsed_stmt = parsed_stmt.free_parser_owned_text()
    parsed_stmt = parsed_stmt.free_parser_owned_text()
    match parsed_stmt {
        Statement.CommitTxn => {},
        _ => { return 90 },
    }

    set_parsed := mut match parse_sql("SELECT name FROM people UNION SELECT title FROM books;") {
        Ok(v) => v,
        Err(_) => { return 91 },
    }
    I set_parsed.len() != 1 { return 92 }
    set_stmt := mut set_parsed[0].clone()
    match set_stmt {
        Statement.Select { query } => {
            match query.set_op {
                Some(_) => {},
                None => { return 93 },
            }
        },
        _ => { return 94 },
    }
    set_stmt = set_stmt.free_parser_owned_text()
    set_stmt = set_stmt.free_parser_owned_text()
    match set_stmt {
        Statement.CommitTxn => {},
        _ => { return 95 },
    }

    join_parsed := mut match parse_sql("SELECT name FROM people JOIN pets ON 1 = 1;") {
        Ok(v) => v,
        Err(_) => { return 96 },
    }
    I join_parsed.len() != 1 { return 97 }
    join_stmt := mut join_parsed[0].clone()
    match join_stmt {
        Statement.Select { query } => {
            match query.from {
                Some(refs) => {
                    I refs.len() != 1 { return 98 }
                    first_ref := mut refs[0].clone()
                    match first_ref {
                        TableRef.Join { .. } => {},
                        _ => { return 99 },
                    }
                },
                None => { return 100 },
            }
        },
        _ => { return 101 },
    }
    join_stmt = join_stmt.free_parser_owned_text()
    join_stmt = join_stmt.free_parser_owned_text()
    match join_stmt {
        Statement.CommitTxn => {},
        _ => { return 102 },
    }

    return 0
}

fn main() -> i64 {
    anchor_code := mut anchor_parser_link_symbols()
    I anchor_code != 0 { return anchor_code }

    cleanup_code := mut check_parser_owned_text_cleanup()
    I cleanup_code != 0 { return cleanup_code }

    tokenizer := mut Tokenizer.new("SELECT 1 + 2 AS total LIMIT 1;")
    I tokenizer.input.len() == 0 { return 50 }
    I tokenizer.peek() != 83u8 { return 51 }
    tokens := mut match tokenizer.tokenize_all() {
        Ok(v) => v,
        Err(_) => { return 1 },
    }
    I tokens.len() == 0 { return 35 }
    I token_kind_tag(&tokens[0].kind) != token_kind_tag(&TokenKind.Select) { return 49 }

    parser := mut Parser.new(tokens)
    match parser.expect(TokenKind.Select) {
        Ok(_) => {},
        Err(_) => { return 39 },
    }
    select_list_probe := mut match parser.parse_select_list() {
        Ok(v) => v,
        Err(_) => { return 40 },
    }
    I select_list_probe.len() != 1 { return 41 }
    match parser.parse_where_clause() {
        Ok(_) => {},
        Err(_) => { return 42 },
    }
    match parser.parse_group_by() {
        Ok(_) => {},
        Err(_) => { return 43 },
    }
    match parser.parse_having() {
        Ok(_) => {},
        Err(_) => { return 44 },
    }
    match parser.parse_order_by() {
        Ok(_) => {},
        Err(_) => { return 45 },
    }
    limit_opt: Option<Expr> := mut Option.None
    offset_opt: Option<Expr> := mut Option.None
    I parser.match_token(TokenKind.Limit) {
        limit_expr := mut match parser.parse_expr() {
            Ok(v) => v,
            Err(_) => { return 46 },
        }
        limit_opt = Option.Some(limit_expr)
    }

    query := mut SelectQuery {
        ctes: Vec.with_capacity(0),
        select_list: select_list_probe,
        from: Option.None,
        where_clause: Option.None,
        group_by: Vec.with_capacity(0),
        having: Option.None,
        order_by: Vec.with_capacity(0),
        limit: limit_opt,
        offset: offset_opt,
        distinct: false,
        set_op: Option.None,
    }

    I query.ctes.len() != 0 { return 4 }
    I query.select_list.len() != 1 { return 5 }
    I query.distinct { return 6 }
    match &query.from {
        Some(_) => { return 7 },
        None => {},
    }

    item := mut query.select_list[0].clone()
    plan_expr: Expr := mut Expr.Star
    match item {
        SelectItem.Expr { expr, alias } => {
            plan_expr = expr.clone()
            match alias {
                Some(a) => {
                    I a != "total" { return 8 }
                },
                None => { return 9 },
            }

            match expr {
                Expr.BinaryOp { left, op, right } => {
                    match op {
                        BinOp.Add => {},
                        _ => { return 10 },
                    }
                    left_expr: Expr := mut *left
                    left_code := mut check_int_literal(left_expr, 1, 11)
                    I left_code != 0 { return left_code }
                    right_expr: Expr := mut *right
                    right_code := mut check_int_literal(right_expr, 2, 12)
                    I right_code != 0 { return right_code }
                },
                _ => { return 13 },
            }
        },
        _ => { return 14 },
    }

    limit_code := mut match &query.limit {
        Some(v) => check_int_literal(v.clone(), 1, 16),
        None => { return 15 },
    }
    I limit_code != 0 { return limit_code }

    project_columns: Vec<ProjectColumn> := mut Vec.with_capacity(1)
    project_columns.push(ProjectColumn.with_alias(plan_expr, "total"))

    value_rows: Vec<Vec<Expr>> := mut Vec.with_capacity(0)
    I value_rows.len() != 0 { return 27 }
    values_plan := mut PlanNode.Values { rows: value_rows }
    limit_plan := mut PlanNode.Limit {
        input: Box.new(values_plan),
        limit: Some(1 as u64),
        offset: None,
    }
    match limit_plan {
        PlanNode.Limit { limit, offset, .. } => {
            match limit {
                Some(v) => {
                    I v != 1 { return 24 }
                },
                None => { return 25 },
            }
            match offset {
                Some(_) => { return 26 },
                None => {},
            }
        },
        _ => { return 29 },
    }

    plan := mut PlanNode.Project {
        input: Box.new(limit_plan),
        columns: project_columns,
    }

    match plan {
        PlanNode.Project { columns, .. } => {
            I columns.len() != 1 { return 21 }
            projected := mut columns[0].clone()
            match projected.alias {
                Some(a) => {
                    I a != "total" { return 22 }
                },
                None => { return 23 },
            }
        },
        _ => { return 30 },
    }

    return 0
}

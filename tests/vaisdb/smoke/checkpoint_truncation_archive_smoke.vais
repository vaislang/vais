U storage/recovery/truncation
U storage/wal/segment
U storage/wal/lsn
U storage/bytes
U storage/constants
U storage/file
U storage/error

F trunc_smoke_segment_path(wal_dir: str, segment_num: u32) -> str {
    filename := mut WalSegmentHeader.segment_filename(segment_num)
    wal_dir.clone() + "/" + filename
}

F trunc_smoke_archive_path(archive_dir: str, segment_num: u32) -> str {
    filename := mut WalSegmentHeader.segment_filename(segment_num)
    archive_dir.clone() + "/" + filename
}

F trunc_smoke_write_segment(wal_dir: str, segment_num: u32, last_lsn: u64) -> Result<(), VaisError> {
    create_dir_all(&wal_dir)?;
    path := mut trunc_smoke_segment_path(wal_dir, segment_num)
    file := mut File.open(path, "rw+")?;
    file.truncate(0)?;

    first_lsn := mut encode_lsn(segment_num, 0 as u32)
    header := mut WalSegmentHeader.new(segment_num, first_lsn)
    header.last_lsn = last_lsn
    header_bytes := mut header.to_bytes()
    file.write_vec_at(0, &header_bytes)?;
    file.fsync()
}

F trunc_smoke_write_segments(wal_dir: str) -> Result<(), VaisError> {
    trunc_smoke_write_segment(wal_dir.clone(), 1 as u32, encode_lsn(1 as u32, 128 as u32))?;
    trunc_smoke_write_segment(wal_dir.clone(), 2 as u32, encode_lsn(2 as u32, 128 as u32))?;
    trunc_smoke_write_segment(wal_dir.clone(), 3 as u32, encode_lsn(3 as u32, 128 as u32))?;
    trunc_smoke_write_segment(wal_dir.clone(), 4 as u32, encode_lsn(4 as u32, 128 as u32))?;
    Ok(())
}

F trunc_smoke_segment_exists(wal_dir: str, segment_num: u32) -> bool {
    path := mut trunc_smoke_segment_path(wal_dir, segment_num)
    path_exists(&path)
}

F trunc_smoke_archive_exists(archive_dir: str, segment_num: u32) -> bool {
    path := mut trunc_smoke_archive_path(archive_dir, segment_num)
    path_exists(&path)
}

F trunc_smoke_archive_size(archive_dir: str, segment_num: u32) -> Result<u64, VaisError> {
    path := mut trunc_smoke_archive_path(archive_dir, segment_num)
    file_size(&path)
}

F main() -> i64 {
    wal_dir := mut "checkpoint_truncation_archive_wal"
    archive_dir := mut "checkpoint_truncation_archive_dir"
    M create_dir_all(&wal_dir) {
        Ok(_) => {},
        Err(_) => { R 1 },
    }
    M create_dir_all(&archive_dir) {
        Ok(_) => {},
        Err(_) => { R 2 },
    }
    M trunc_smoke_write_segments(wal_dir.clone()) {
        Ok(_) => {},
        Err(_) => { R 3 },
    }

    cfg := mut TruncationConfig.with_archive(archive_dir.clone())
    cfg.min_segments_to_keep = 2 as u32
    mgr := mut TruncationManager.new(wal_dir.clone(), cfg)
    result := mut M mgr.truncate(encode_lsn(4 as u32, 64 as u32), NULL_LSN) {
        Ok(v) => v,
        Err(_) => { R 4 },
    }

    I result.segments_deleted != 2 as u32 { R 5 }
    I result.segments_archived != 2 as u32 { R 6 }
    I result.oldest_remaining_segment != 3 as u32 { R 7 }
    I trunc_smoke_segment_exists(wal_dir.clone(), 1 as u32) { R 8 }
    I trunc_smoke_segment_exists(wal_dir.clone(), 2 as u32) { R 9 }
    I !trunc_smoke_segment_exists(wal_dir.clone(), 3 as u32) { R 10 }
    I !trunc_smoke_segment_exists(wal_dir.clone(), 4 as u32) { R 11 }
    I !trunc_smoke_archive_exists(archive_dir.clone(), 1 as u32) { R 12 }
    I !trunc_smoke_archive_exists(archive_dir.clone(), 2 as u32) { R 13 }
    I trunc_smoke_archive_exists(archive_dir.clone(), 3 as u32) { R 14 }
    archive_size := mut M trunc_smoke_archive_size(archive_dir.clone(), 1 as u32) {
        Ok(v) => v,
        Err(_) => { R 15 },
    }
    I archive_size < WAL_SEGMENT_HEADER_SIZE as u64 { R 16 }

    active_wal_dir := mut "checkpoint_truncation_active_wal"
    active_archive_dir := mut "checkpoint_truncation_active_archive"
    M create_dir_all(&active_wal_dir) {
        Ok(_) => {},
        Err(_) => { R 17 },
    }
    M create_dir_all(&active_archive_dir) {
        Ok(_) => {},
        Err(_) => { R 18 },
    }
    M trunc_smoke_write_segments(active_wal_dir.clone()) {
        Ok(_) => {},
        Err(_) => { R 19 },
    }

    active_cfg := mut TruncationConfig.with_archive(active_archive_dir.clone())
    active_cfg.min_segments_to_keep = 1 as u32
    active_mgr := mut TruncationManager.new(active_wal_dir.clone(), active_cfg)
    active_result := mut M active_mgr.truncate(
        encode_lsn(4 as u32, 64 as u32),
        encode_lsn(2 as u32, 0 as u32),
    ) {
        Ok(v) => v,
        Err(_) => { R 20 },
    }

    I active_result.segments_deleted != 1 as u32 { R 21 }
    I active_result.segments_archived != 1 as u32 { R 22 }
    I active_result.oldest_remaining_segment != 2 as u32 { R 23 }
    I trunc_smoke_segment_exists(active_wal_dir.clone(), 1 as u32) { R 24 }
    I !trunc_smoke_segment_exists(active_wal_dir.clone(), 2 as u32) { R 25 }
    I !trunc_smoke_segment_exists(active_wal_dir.clone(), 3 as u32) { R 26 }
    I !trunc_smoke_segment_exists(active_wal_dir.clone(), 4 as u32) { R 27 }
    I !trunc_smoke_archive_exists(active_archive_dir.clone(), 1 as u32) { R 28 }
    I trunc_smoke_archive_exists(active_archive_dir.clone(), 2 as u32) { R 29 }

    R 0
}

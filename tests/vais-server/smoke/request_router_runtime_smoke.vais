U src/http/header
U src/http/method
U src/http/request
U src/router/router

F smoke_request_headers() -> i64 {
    req := mut Request.new(HttpMethod.Post, "/users")
    req.headers = req.headers.set(CONTENT_TYPE, "application/json; charset=utf-8")
    req.headers = req.headers.set(USER_AGENT, "vais-smoke")

    I req.method.to_str() != "POST" {
        println("FAIL request method")
        R 1
    }
    I req.path != "/users" {
        println("FAIL request path")
        R 2
    }
    I req.get_header(CONTENT_TYPE) != "application/json; charset=utf-8" {
        println("FAIL request content-type header")
        R 3
    }
    I req.content_type() != "application/json; charset=utf-8" {
        println("FAIL request content_type")
        R 4
    }
    I req.is_json() != 1 {
        println("FAIL request is_json")
        R 5
    }
    I req.headers.has(USER_AGENT) != 1 {
        println("FAIL request has_header")
        R 6
    }

    0
}

F smoke_router_static() -> i64 {
    router := mut Router.new()
    router.get("/health", 10)
    router.post("/users", 20)

    found := router.match_route(METHOD_GET, "/health")
    I !found.is_found() {
        println("FAIL router get /health found")
        R 10
    }
    I found.handler_id != 10 {
        println("FAIL router get /health handler")
        R 11
    }

    post_found := router.match_route(METHOD_POST, "/users")
    I !post_found.is_found() {
        println("FAIL router post /users found")
        R 12
    }
    I post_found.handler_id != 20 {
        println("FAIL router post /users handler")
        R 13
    }

    missing := router.match_route(METHOD_GET, "/missing")
    I !missing.is_not_found() {
        println("FAIL router missing path")
        R 14
    }

    wrong_method := router.match_route(METHOD_POST, "/health")
    I !wrong_method.is_method_not_allowed() {
        println("FAIL router method not allowed")
        R 15
    }
    I wrong_method.allowed_methods.len() == 0 {
        println("FAIL router allowed methods")
        R 16
    }

    0
}

F main() -> i64 {
    failures := mut 0
    failures += smoke_request_headers()
    failures += smoke_router_static()

    I failures > 0 {
        println("VAIS_SERVER_REQUEST_ROUTER_RUNTIME_FAIL")
        R failures
    }
    println("VAIS_SERVER_REQUEST_ROUTER_RUNTIME_OK")
    0
}

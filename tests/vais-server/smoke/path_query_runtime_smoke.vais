use src/http/method
use src/http/request
use src/router/params
use src/router/router

fn smoke_request_query() -> i64 {
    req := mut Request.new(HttpMethod.Get, "/users/42?tab=posts&limit=10&empty")
    req = req.parse_query_string()

    I req.path != "/users/42" {
        println("FAIL query path split")
        return 1
    }
    I req.query_params.len() != 3 {
        println("FAIL query param count")
        return 2
    }
    I req.get_query("tab") != "posts" {
        println("FAIL query tab")
        return 3
    }
    I req.get_query("limit") != "10" {
        println("FAIL query limit")
        return 4
    }
    I req.get_query("empty") != "" {
        println("FAIL query empty value")
        return 5
    }

    0
}

fn smoke_params_query() -> i64 {
    params := mut Params.new()
    params.parse_query("q=v&page=2")

    I !params.has("q") {
        println("FAIL params query has q")
        return 10
    }
    I params.get_or("q", "") != "v" {
        println("FAIL params query q")
        return 11
    }
    I params.get_or("page", "") != "2" {
        println("FAIL params query page")
        return 12
    }
    I params.get_or("missing", "fallback") != "fallback" {
        println("FAIL params query fallback")
        return 13
    }

    0
}

fn smoke_router_path_params() -> i64 {
    router := mut Router.new()
    router.get("/users/:id/posts/:post_id", 77)

    found := router.match_route(METHOD_GET, "/users/42/posts/abc")
    I !found.is_found() {
        println("FAIL router param route found")
        return 20
    }
    I found.handler_id != 77 {
        println("FAIL router param handler")
        return 21
    }
    I found.params.get_or("id", "") != "42" {
        println("FAIL router id param")
        return 22
    }
    I found.params.get_or("post_id", "") != "abc" {
        println("FAIL router post_id param")
        return 23
    }

    wrong_method := router.match_route(METHOD_POST, "/users/42/posts/abc")
    I !wrong_method.is_method_not_allowed() {
        println("FAIL router param method-not-allowed")
        return 24
    }
    I wrong_method.allowed_methods.len() == 0 {
        println("FAIL router param allowed methods")
        return 25
    }

    missing := router.match_route(METHOD_GET, "/users/42/comments/abc")
    I !missing.is_not_found() {
        println("FAIL router param mismatch")
        return 26
    }

    0
}

fn main() -> i64 {
    failures := mut 0
    failures += smoke_request_query()
    failures += smoke_params_query()
    failures += smoke_router_path_params()

    I failures > 0 {
        println("VAIS_SERVER_PATH_QUERY_RUNTIME_FAIL")
        return failures
    }
    println("VAIS_SERVER_PATH_QUERY_RUNTIME_OK")
    0
}

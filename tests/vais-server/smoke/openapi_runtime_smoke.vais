# vais-server OpenAPI JSON generation runtime smoke.
#
# Directly exercises the bounded `src/api/openapi.vais` OpenAPI 3.0 document
# generation boundary: parameter / request-body / response / operation / spec
# serialization, grouped paths with two methods on the same path, path-param
# extraction for both `{id}` and `:post_id`, and JSON escaping of dynamic
# title / description / summary / tag / server / path / response text values.

use src/api/openapi
use std/vec

fn smoke_contains(haystack: str, needle: str) -> i64 {
    smoke_contains_rec(haystack, needle, 0)
}

fn smoke_contains_rec(haystack: str, needle: str, i: i64) -> i64 {
    I needle.len() == 0 { return 1 }
    I i >= haystack.len() { return 0 }
    I smoke_match_prefix(haystack, needle, i, 0) == 1 { return 1 }
    smoke_contains_rec(haystack, needle, i + 1)
}

fn smoke_match_prefix(haystack: str, needle: str, hi: i64, ni: i64) -> i64 {
    nc := needle.char_at(ni)
    I nc == 0 { return 1 }
    hc := haystack.char_at(hi)
    I hc == 0 { return 0 }
    I hc != nc { return 0 }
    smoke_match_prefix(haystack, needle, hi + 1, ni + 1)
}

# --- ApiParameter.to_json -----------------------------------------------------

fn check_api_parameter() -> i64 {
    param := mut ApiParameter.new("id", ParamLocation.Path, 1, "string")
    param.description = "user \"id\" value"
    pj := param.to_json()
    I smoke_contains(pj, "\"name\": \"id\"") != 1 {
        println("FAIL parameter name")
        return 1
    }
    I smoke_contains(pj, "\"in\": \"path\"") != 1 {
        println("FAIL parameter location")
        return 2
    }
    I smoke_contains(pj, "\"required\": true") != 1 {
        println("FAIL parameter required")
        return 3
    }
    I smoke_contains(pj, "\"schema\": {\"type\": \"string\"}") != 1 {
        println("FAIL parameter schema")
        return 4
    }
    # quote in the description must be JSON-escaped
    I smoke_contains(pj, "\"description\": \"user \\\"id\\\" value\"") != 1 {
        println("FAIL parameter description escape")
        return 5
    }
    0
}

# --- ApiResponseEntry.to_json / with_json ------------------------------------

fn check_api_response() -> i64 {
    bodyless := ApiResponseEntry.new("404", "missing \\ resource")
    bj := bodyless.to_json()
    I smoke_contains(bj, "\"description\": \"missing \\\\ resource\"") != 1 {
        println("FAIL response bodyless description escape")
        return 10
    }
    I smoke_contains(bj, "content") == 1 {
        println("FAIL bodyless response should not carry content")
        return 11
    }

    with_body := ApiResponseEntry.with_json("200", "ok", "#/components/schemas/User")
    wj := with_body.to_json()
    I smoke_contains(wj, "\"description\": \"ok\"") != 1 {
        println("FAIL response with_json description")
        return 12
    }
    I smoke_contains(wj, "\"$ref\": \"#/components/schemas/User\"") != 1 {
        println("FAIL response with_json schema ref")
        return 13
    }
    I smoke_contains(wj, "\"application/json\"") != 1 {
        println("FAIL response with_json content type")
        return 14
    }
    0
}

# --- ApiRequestBody.json_ref(...).to_json ------------------------------------

fn check_api_request_body() -> i64 {
    body := ApiRequestBody.json_ref("#/components/schemas/CreateUser")
    rj := body.to_json()
    I smoke_contains(rj, "\"required\": true") != 1 {
        println("FAIL request body required")
        return 20
    }
    I smoke_contains(rj, "\"application/json\"") != 1 {
        println("FAIL request body content type")
        return 21
    }
    I smoke_contains(rj, "\"$ref\": \"#/components/schemas/CreateUser\"") != 1 {
        println("FAIL request body schema ref")
        return 22
    }
    0
}

# --- ApiPath.operation_to_json -----------------------------------------------

fn check_operation_to_json() -> i64 {
    brace_user_path := "/users/\{id\}"
    op := mut ApiPath.new(brace_user_path, "get", "fetch \"one\" user")
    op.description = "returns a single user"
    op.operation_id = "getUser"
    op.add_tag("users")
    op.add_parameter(ApiParameter.new("id", ParamLocation.Path, 1, "string"))
    op.add_response(ApiResponseEntry.with_json("200", "ok", "#/components/schemas/User"))

    oj := op.operation_to_json()
    I smoke_contains(oj, "\"summary\": \"fetch \\\"one\\\" user\"") != 1 {
        println("FAIL operation summary escape")
        return 30
    }
    I smoke_contains(oj, "\"description\": \"returns a single user\"") != 1 {
        println("FAIL operation description")
        return 31
    }
    I smoke_contains(oj, "\"operationId\": \"getUser\"") != 1 {
        println("FAIL operation id")
        return 32
    }
    I smoke_contains(oj, "\"tags\": [\"users\"]") != 1 {
        println("FAIL operation tags")
        return 33
    }
    I smoke_contains(oj, "\"parameters\": [") != 1 {
        println("FAIL operation parameters")
        return 34
    }
    I smoke_contains(oj, "\"responses\": {\"200\":") != 1 {
        println("FAIL operation responses")
        return 35
    }

    default_op := ApiPath.new("/health", "get", "")
    default_json := default_op.operation_to_json()
    I default_json != "{\"responses\": {\"200\": {\"description\": \"OK\"}}}" {
        println("FAIL default operation response JSON")
        println(default_json)
        return 36
    }
    0
}

# --- ApiSpec.to_json / generate_spec — grouped paths + escaping --------------

fn build_routes() -> Vec<ApiPath> {
    routes: Vec<ApiPath> := mut Vec.new()

    # Two operations grouped under the same path "/posts/:post_id".
    get_post := mut ApiPath.new("/posts/:post_id", "get", "read \"post\"")
    get_post.add_parameter(ApiParameter.new("post_id", ParamLocation.Path, 1, "string"))
    get_post.add_response(ApiResponseEntry.with_json("200", "ok", "#/components/schemas/Post"))
    routes.push(get_post)

    del_post := mut ApiPath.new("/posts/:post_id", "delete", "remove post")
    del_post.add_parameter(ApiParameter.new("post_id", ParamLocation.Path, 1, "string"))
    del_post.add_response(ApiResponseEntry.new("204", "deleted"))
    routes.push(del_post)

    # A distinct brace-style path.
    brace_user_path := "/users/\{id\}"
    get_user := mut ApiPath.new(brace_user_path, "get", "read user")
    get_user.add_parameter(ApiParameter.new("id", ParamLocation.Path, 1, "string"))
    get_user.set_request_body(ApiRequestBody.json_ref("#/components/schemas/User"))
    get_user.add_response(ApiResponseEntry.with_json("200", "ok", "#/components/schemas/User"))
    routes.push(get_user)

    routes
}

fn check_api_spec() -> i64 {
    spec := mut ApiSpec.new("Demo \"API\"", "1.2.0", "back \\ slash desc")
    spec.add_server("https://api.example.com/v1")

    routes := build_routes()
    i := mut 0
    LW i < routes.len() {
        spec.add_path(routes.get(i))
        i += 1
    }

    sj := spec.to_json()

    I smoke_contains(sj, "\"openapi\": \"3.0.0\"") != 1 {
        println("FAIL spec openapi version")
        return 40
    }
    # escaped title (embedded quotes) and description (embedded backslash)
    I smoke_contains(sj, "\"title\": \"Demo \\\"API\\\"\"") != 1 {
        println("FAIL spec title escape")
        return 41
    }
    I smoke_contains(sj, "\"description\": \"back \\\\ slash desc\"") != 1 {
        println("FAIL spec description escape")
        return 42
    }
    I smoke_contains(sj, "\"servers\": [{\"url\": \"https://api.example.com/v1\"}]") != 1 {
        println("FAIL spec server url")
        return 43
    }
    # grouped path: both get and delete fold under one "/posts/:post_id" key
    I smoke_contains(sj, "\"/posts/:post_id\": {\"get\":") != 1 {
        println("FAIL spec grouped path get")
        return 44
    }
    I smoke_contains(sj, "\"delete\":") != 1 {
        println("FAIL spec grouped path delete")
        return 45
    }
    brace_user_key := "\"/users/\{id\}\": {\"get\":"
    I smoke_contains(sj, brace_user_key) != 1 {
        println("FAIL spec brace path")
        return 46
    }
    I smoke_contains(sj, "\"requestBody\":") != 1 {
        println("FAIL spec request body")
        return 47
    }
    0
}

# --- generate_spec standalone entry point ------------------------------------

fn check_generate_spec() -> i64 {
    routes := build_routes()
    gj := generate_spec(routes)
    I smoke_contains(gj, "\"openapi\": \"3.0.0\"") != 1 {
        println("FAIL generate_spec openapi")
        return 50
    }
    I smoke_contains(gj, "\"/posts/:post_id\": {\"get\":") != 1 {
        println("FAIL generate_spec grouped path")
        return 51
    }
    0
}

# --- path param extraction: {id} and :post_id --------------------------------

fn check_path_param_extraction() -> i64 {
    brace_path := "/users/\{id\}/files/\{file_id\}"
    brace := extract_path_params(brace_path)
    I brace.len() != 2 {
        println("FAIL brace param count")
        return 60
    }
    I brace.get(0) != "id" {
        println("FAIL brace param 0")
        return 61
    }
    I brace.get(1) != "file_id" {
        println("FAIL brace param 1")
        return 62
    }

    colon := extract_path_params("/posts/:post_id/comments/:comment_id")
    I colon.len() != 2 {
        println("FAIL colon param count")
        return 63
    }
    I colon.get(0) != "post_id" {
        println("FAIL colon param 0")
        return 64
    }
    I colon.get(1) != "comment_id" {
        println("FAIL colon param 1")
        return 65
    }

    none := extract_path_params("/health")
    I none.len() != 0 {
        println("FAIL static path should have no params")
        return 66
    }
    0
}

fn main() -> i64 {
    r1 := check_api_parameter()
    I r1 != 0 { return r1 }

    r2 := check_api_response()
    I r2 != 0 { return r2 }

    r3 := check_api_request_body()
    I r3 != 0 { return r3 }

    r4 := check_operation_to_json()
    I r4 != 0 { return r4 }

    r5 := check_api_spec()
    I r5 != 0 { return r5 }

    r6 := check_generate_spec()
    I r6 != 0 { return r6 }

    r7 := check_path_param_extraction()
    I r7 != 0 { return r7 }

    println("VAIS_SERVER_OPENAPI_RUNTIME_OK")
    0
}

        println("FAIL cors custom config preflight headers")
        println(output.response.headers)
        return 102
    }
    I output.response.body != "" {
        println("FAIL cors custom config preflight body")
        return 103
    }
    I output.response.content_type != "text/plain" {
        println("FAIL cors custom config preflight content type")
        return 104
    }

    0
}


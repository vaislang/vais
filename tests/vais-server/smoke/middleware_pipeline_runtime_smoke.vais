use src/core/context
use src/auth/runtime
use src/middleware/compress
use src/middleware/cors
use src/middleware/pipeline
use src/middleware/rate_limit
use src/middleware/recovery

fn smoke_pipeline_registration() -> i64 {
    p := mut Pipeline.new()
    p = p.add("first")
    p = p.add("second")

    I p.len() != 2 {
        println("FAIL middleware len")
        return 1
    }
    I p.name_at(0) != "first" {
        println("FAIL middleware first name")
        return 2
    }
    I p.name_at(1) != "second" {
        println("FAIL middleware second name")
        return 3
    }

    0
}

fn smoke_before_passthrough() -> i64 {
    p := mut Pipeline.new()
    p = p.add("unknown")
    p = p.add("after-a")

    ctx := Context.new("GET", "/pipeline")
    output := p.run_before(ctx)

    I output.short_circuit {
        println("FAIL passthrough short circuit")
        return 10
    }
    I output.ctx.path != "/pipeline" {
        println("FAIL passthrough ctx")
        return 11
    }

    0
}

fn smoke_before_short_circuit() -> i64 {
    p := mut Pipeline.new()
    p = p.add("unknown")
    p = p.add("deny")
    p = p.add("after-a")

    ctx := Context.new("POST", "/protected")
    output := p.run_before(ctx)

    I !output.short_circuit {
        println("FAIL deny did not short circuit")
        return 20
    }
    I output.response.status != 401 {
        println("FAIL deny status")
        return 21
    }
    I output.response.body != "middleware-denied" {
        println("FAIL deny body")
        return 22
    }

    0
}

fn smoke_after_reverse_order() -> i64 {
    p := mut Pipeline.new()
    p = p.add("after-a")
    p = p.add("after-b")

    ctx := Context.new("GET", "/after")
    response := ctx.text(200, "handler")
    final := p.run_after(ctx, response)

    I final.status != 200 {
        println("FAIL after status")
        return 30
    }
    I final.body != "handler|b|a" {
        println("FAIL after reverse order")
        println(final.body)
        return 31
    }
    I final.content_type != "text/plain; charset=utf-8" {
        println("FAIL after content type")
        return 32
    }

    0
}

fn smoke_after_body_concat_transform() -> i64 {
    p := mut Pipeline.new()
    p = p.add("after-a")
    p = p.add("unknown")
    p = p.add("after-b")

    ctx := Context.new("GET", "/after-transform")
    response := ctx.json(202, "{\"ok\":true}")
    final := p.run_after(ctx, response)

    I final.status != 202 {
        println("FAIL after transform status")
        return 40
    }
    I final.body != "{\"ok\":true}|b|a" {
        println("FAIL after transform body")
        println(final.body)
        return 41
    }
    I final.content_type != "application/json; charset=utf-8" {
        println("FAIL after transform content type")
        return 42
    }

    0
}

fn smoke_context_set_header_appends_owned_headers() -> i64 {
    ctx1 := Context.new("GET", "/headers").set_header("X-One", "1")
    ctx2 := ctx1.set_header("X-Two", "2")
    expected_headers := "X-One: 1\nX-Two: 2"

    I ctx2.response_headers != expected_headers {
        println("FAIL context set_header append")
        println(ctx2.response_headers)
        return 50
    }

    response := ctx2.text(200, "headers")
    I response.headers != expected_headers {
        println("FAIL context set_header response headers")
        println(response.headers)
        return 51
    }

    0
}

fn smoke_recovery_after_direct_module() -> i64 {
    mw := RecoveryMiddleware.default()
    ctx := Context.new("GET", "/panic")
    panic_response := Response {
        status: 200,
        body: "PANIC:boom",
        content_type: "text/plain; charset=utf-8",
        headers: "",
        redirect_url: "",
    }

    final := mw.after(ctx, panic_response)

    I final.status != 500 {
        println("FAIL recovery panic status")
        return 60
    }
    I final.body != "{\"error\": \"Internal Server Error\"}" {
        println("FAIL recovery panic body")
        println(final.body)
        return 61
    }
    I final.content_type != "application/json; charset=utf-8" {
        println("FAIL recovery panic content type")
        return 62
    }

    zero_response := Response {
        status: 0,
        body: "runtime sentinel",
        content_type: "text/plain; charset=utf-8",
        headers: "",
        redirect_url: "",
    }
    zero_final := mw.after(ctx, zero_response)
    I zero_final.status != 500 {
        println("FAIL recovery zero status")
        return 63
    }
    I zero_final.body != "{\"error\": \"Internal Server Error\"}" {
        println("FAIL recovery zero body")
        return 64
    }

    ok_response := ctx.text(201, "created")
    ok_final := mw.after(ctx, ok_response)
    I ok_final.status != 201 {
        println("FAIL recovery passthrough status")
        return 65
    }
    I ok_final.body != "created" {
        println("FAIL recovery passthrough body")
        return 66
    }

    0
}

fn smoke_cors_preflight_direct_module() -> i64 {
    mw := CorsMiddleware.default()
    ctx := Context.new("OPTIONS", "/cors").set_state("https://client.example")
    output := mw.before(ctx)

    I output.is_next() {
        println("FAIL cors preflight did not short circuit")
        return 70
    }
    I output.response.status != 204 {
        println("FAIL cors preflight status")
        return 71
    }
    expected_headers := "Access-Control-Allow-Origin: *\nAccess-Control-Allow-Methods: GET, POST, PUT, DELETE, PATCH, OPTIONS\nAccess-Control-Allow-Headers: Content-Type, Authorization, Accept\nAccess-Control-Max-Age: 86400"
    I output.response.headers != expected_headers {
        println("FAIL cors preflight headers")
        println(output.response.headers)
        return 72
    }
    I output.response.body != "" {
        println("FAIL cors preflight body")
        return 73
    }
    I output.response.content_type != "text/plain" {
        println("FAIL cors preflight content type")
        return 74
    }

    0
}


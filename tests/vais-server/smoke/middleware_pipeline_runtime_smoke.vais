fn smoke_cors_custom_config_credentials_direct_module() -> i64 {
    cfg_preflight_match := CorsConfig {
        allowed_origin: "https://secure.example",
        allowed_methods: "GET, POST, OPTIONS",
        allowed_headers: "X-Trace, Authorization",
        allow_credentials: true,
        max_age: 321,
    }
    mw_preflight_match := CorsMiddleware.new(cfg_preflight_match)
    base_preflight_match := Context.new("OPTIONS", "/cors-custom-credentials").set_header("X-Smoke", "ok")
    ctx_preflight_match := base_preflight_match.set_state("https://secure.example")
    output_preflight_match := mw_preflight_match.before(ctx_preflight_match)

    I output_preflight_match.is_next() {
        println("FAIL cors custom credentials preflight did not short circuit")
        return 180
    }
    expected_preflight_headers := "X-Smoke: ok\nAccess-Control-Allow-Origin: https://secure.example\nAccess-Control-Allow-Methods: GET, POST, OPTIONS\nAccess-Control-Allow-Headers: X-Trace, Authorization\nAccess-Control-Allow-Credentials: true\nAccess-Control-Max-Age: 321"
    I output_preflight_match.response.headers != expected_preflight_headers {
        println("FAIL cors custom credentials preflight headers")
        println(output_preflight_match.response.headers)
        return 181
    }

    cfg_preflight_miss := CorsConfig {
        allowed_origin: "https://secure.example",
        allowed_methods: "GET, POST, OPTIONS",
        allowed_headers: "X-Trace, Authorization",
        allow_credentials: true,
        max_age: 321,
    }
    mw_preflight_miss := CorsMiddleware.new(cfg_preflight_miss)
    base_preflight_miss := Context.new("OPTIONS", "/cors-custom-credentials-miss").set_header("X-Smoke", "ok")
    ctx_preflight_miss := base_preflight_miss.set_state("https://other.example")
    output_preflight_miss := mw_preflight_miss.before(ctx_preflight_miss)

    I output_preflight_miss.is_next() {
        println("FAIL cors custom credentials non-matching preflight did not short circuit")
        return 182
    }
    I output_preflight_miss.response.headers != expected_preflight_headers {
        println("FAIL cors custom credentials non-matching preflight headers")
        println(output_preflight_miss.response.headers)
        return 183
    }

    cfg_get_match := CorsConfig {
        allowed_origin: "https://secure.example",
        allowed_methods: "GET, POST, OPTIONS",
        allowed_headers: "X-Trace, Authorization",
        allow_credentials: true,
        max_age: 321,
    }
    mw_get_match := CorsMiddleware.new(cfg_get_match)
    base_get_match := Context.new("GET", "/cors-custom-credentials-get").set_header("X-Smoke", "ok")
    ctx_get_match := base_get_match.set_state("https://secure.example")
    output_get_match := mw_get_match.before(ctx_get_match)

    I !output_get_match.is_next() {
        println("FAIL cors custom credentials get short circuited")
        return 184
    }
    expected_get_headers := "X-Smoke: ok\nAccess-Control-Allow-Origin: https://secure.example\nAccess-Control-Allow-Methods: GET, POST, OPTIONS\nAccess-Control-Allow-Headers: X-Trace, Authorization\nAccess-Control-Allow-Credentials: true"
    I output_get_match.ctx.response_headers != expected_get_headers {
        println("FAIL cors custom credentials get headers")
        println(output_get_match.ctx.response_headers)
        return 185
    }
    response_get_match := output_get_match.ctx.text(200, "ok")
    I response_get_match.headers != expected_get_headers {
        println("FAIL cors custom credentials get response headers")
        println(response_get_match.headers)
        return 186
    }

    cfg_get_miss := CorsConfig {
        allowed_origin: "https://secure.example",
        allowed_methods: "GET, POST, OPTIONS",
        allowed_headers: "X-Trace, Authorization",
        allow_credentials: true,
        max_age: 321,
    }
    mw_get_miss := CorsMiddleware.new(cfg_get_miss)
    base_get_miss := Context.new("GET", "/cors-custom-credentials-get-miss").set_header("X-Smoke", "ok")
    ctx_get_miss := base_get_miss.set_state("https://other.example")
    output_get_miss := mw_get_miss.before(ctx_get_miss)

    I !output_get_miss.is_next() {
        println("FAIL cors custom credentials get non-matching short circuited")
        return 187
    }
    I output_get_miss.ctx.response_headers != expected_get_headers {
        println("FAIL cors custom credentials get non-matching headers")
        println(output_get_miss.ctx.response_headers)
        return 188
    }
    response_get_miss := output_get_miss.ctx.text(200, "ok")
    I response_get_miss.headers != expected_get_headers {
        println("FAIL cors custom credentials get non-matching response headers")
        println(response_get_miss.headers)
        return 189
    }

    0
}

fn smoke_compress_direct_module() -> i64 {
    mw := CompressMiddleware.new(CompressConfig.new(4, "gzip"))
    ctx := Context.new("GET", "/compress").set_state("br, gzip")
    before := mw.before(ctx)

    I !before.is_next() {
        println("FAIL compress before short circuited")
        return 190
    }
    I before.ctx.state != "compress=gzip" {
        println("FAIL compress before state")
        println(before.ctx.state)
        return 191
    }

    response := before.ctx.text(200, "payload")
    final := mw.after(before.ctx, response)
    I final.status != 200 {
        println("FAIL compress after status")
        return 192
    }
    I final.body != "payload" {
        println("FAIL compress after body")
        return 193
    }
    I final.headers != "Content-Encoding: gzip" {
        println("FAIL compress after header")
        println(final.headers)
        return 194
    }

    ctx_with_header := before.ctx.set_header("X-Smoke", "ok")
    response_with_header := ctx_with_header.text(200, "payload")
    final_with_header := mw.after(ctx_with_header, response_with_header)
    expected_headers := "X-Smoke: ok\nContent-Encoding: gzip"
    I final_with_header.headers != expected_headers {
        println("FAIL compress after appends header")
        println(final_with_header.headers)
        return 195
    }

    small_mw := CompressMiddleware.new(CompressConfig.new(100, "gzip"))
    small_response := before.ctx.text(200, "short")
    small_final := small_mw.after(before.ctx, small_response)
    I small_final.headers != "" {
        println("FAIL compress small body headers")
        println(small_final.headers)
        return 196
    }

    no_gzip := mw.before(Context.new("GET", "/compress").set_state("br"))
    I !no_gzip.is_next() {
        println("FAIL compress no-gzip before")
        return 197
    }

    0
}

fn smoke_rate_limit_store_direct_module() -> i64 {
    store := mut RateLimitStore.new()

    first := store.check_and_increment("203.0.113.9", 7000000, 1000)
    I first != 1 {
        println("FAIL rate-limit store first")
        return 210
    }

    second := store.check_and_increment("203.0.113.9", 7000500, 1000)
    I second != 2 {
        println("FAIL rate-limit store second")
        return 211
    }

    other := store.check_and_increment("203.0.113.10", 7000500, 1000)
    I other != 1 {
        println("FAIL rate-limit store other ip")
        return 212
    }

    reset := store.check_and_increment("203.0.113.9", 7001501, 1000)
    I reset != 1 {
        println("FAIL rate-limit store reset")
        return 213
    }

    0
}

fn smoke_rate_limit_before_direct_module() -> i64 {
    auth_set_test_time_sec(7000)
    mw := mut RateLimitMiddleware.new(RateLimitConfig.new(2, 1000))

    first := mw.before(Context.new("GET", "/limited").set_state("198.51.100.7"))
    I !first.is_next() {
        println("FAIL rate-limit first short circuited")
        auth_clear_test_time_sec()
        return 220
    }
    expected_first_headers := "X-RateLimit-Limit: 2\nX-RateLimit-Remaining: 1"
    I first.ctx.response_headers != expected_first_headers {
        println("FAIL rate-limit first headers")
        println(first.ctx.response_headers)
        auth_clear_test_time_sec()
        return 221
    }

    second := mw.before(Context.new("GET", "/limited").set_state("198.51.100.7"))
    I !second.is_next() {
        println("FAIL rate-limit second short circuited")
        auth_clear_test_time_sec()
        return 222
    }
    expected_second_headers := "X-RateLimit-Limit: 2\nX-RateLimit-Remaining: 0"
    I second.ctx.response_headers != expected_second_headers {
        println("FAIL rate-limit second headers")
        println(second.ctx.response_headers)
        auth_clear_test_time_sec()
        return 223
    }

    third := mw.before(Context.new("GET", "/limited").set_state("198.51.100.7"))
    I third.is_next() {
        println("FAIL rate-limit third allowed")
        auth_clear_test_time_sec()
        return 224
    }
    I third.response.status != 429 {
        println("FAIL rate-limit limited status")
        auth_clear_test_time_sec()
        return 225
    }
    I third.response.body != "Too Many Requests" {
        println("FAIL rate-limit limited body")
        auth_clear_test_time_sec()
        return 226
    }
    expected_limited_headers := "Retry-After: 1\nX-RateLimit-Limit: 2"
    I third.response.headers != expected_limited_headers {
        println("FAIL rate-limit limited headers")
        println(third.response.headers)
        auth_clear_test_time_sec()
        return 227
    }

    auth_set_test_time_sec(7002)
    reset := mw.before(Context.new("GET", "/limited").set_state("198.51.100.7"))
    I !reset.is_next() {
        println("FAIL rate-limit reset short circuited")
        auth_clear_test_time_sec()
        return 228
    }
    I reset.ctx.response_headers != expected_first_headers {
        println("FAIL rate-limit reset headers")
        println(reset.ctx.response_headers)
        auth_clear_test_time_sec()
        return 229
    }

    unknown := mw.before(Context.new("GET", "/limited"))
    I !unknown.is_next() {
        println("FAIL rate-limit unknown ip short circuited")
        auth_clear_test_time_sec()
        return 230
    }

    auth_clear_test_time_sec()
    0
}

fn smoke_pipeline_before_modified_ctx_carries_forward() -> i64 {
    p := mut Pipeline.new()
    p = p.add("unknown")

    ctx := Context.new("GET", "/ctx-propagation").set_header("X-Smoke", "ok")
    output := p.run_before(ctx)

    I output.short_circuit {
        println("FAIL pipeline ctx propagation short circuit")
        return 200
    }
    I output.ctx.response_headers != "X-Smoke: ok" {
        println("FAIL pipeline ctx propagation headers")
        println(output.ctx.response_headers)
        return 201
    }

    0
}

fn main() -> i64 {
    failures := mut 0
    failures += smoke_pipeline_registration()
    failures += smoke_before_passthrough()
    failures += smoke_before_short_circuit()
    failures += smoke_after_reverse_order()
    failures += smoke_after_body_concat_transform()
    failures += smoke_context_set_header_appends_owned_headers()
    failures += smoke_recovery_after_direct_module()
    failures += smoke_cors_preflight_direct_module()
    failures += smoke_cors_single_origin_preflight_direct_module()
    failures += smoke_cors_single_origin_non_matching_preflight_direct_module()
    failures += smoke_cors_custom_config_preflight_direct_module()
    failures += smoke_cors_default_get_headers_direct_module()
    failures += smoke_cors_default_get_appends_existing_header_direct_module()
    failures += smoke_cors_single_origin_get_headers_direct_module()
    failures += smoke_cors_single_origin_get_non_matching_origin_direct_module()
    failures += smoke_cors_custom_config_get_direct_module()
    failures += smoke_cors_custom_config_get_non_matching_origin_direct_module()
    failures += smoke_cors_custom_config_credentials_direct_module()
    failures += smoke_compress_direct_module()
    failures += smoke_rate_limit_store_direct_module()
    failures += smoke_rate_limit_before_direct_module()
    failures += smoke_pipeline_before_modified_ctx_carries_forward()

    I failures > 0 {
        println("VAIS_SERVER_MIDDLEWARE_PIPELINE_RUNTIME_FAIL")
        return failures
    }
    println("VAIS_SERVER_MIDDLEWARE_PIPELINE_RUNTIME_OK")
    0
}

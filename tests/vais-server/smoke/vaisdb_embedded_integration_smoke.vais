        metadata.free_owned_text()
        metadata.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }
    I metadata_columns[2].get_name() != "state" || metadata_columns[2].get_type_name() != "TEXT" {
        metadata.free_owned_text()
        metadata.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }
    metadata.free_owned_text()
    metadata.free_owned_text()

    query := mut "select * from {table} where state = '{state_value}'"
    result := mut match db.query(query) {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        },
    }

    I result.column_count() != 3 as u64 {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    columns := mut result.get_columns()
    I columns[0].get_name() != "id" || columns[0].get_type_name() != "INT" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }
    I columns[1].get_name() != "summary" || columns[1].get_type_name() != "TEXT" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }
    I columns[2].get_name() != "state" || columns[2].get_type_name() != "TEXT" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    response_body := mut "{\"table\":\"tickets\",\"columns\":[{\"name\":\"id\",\"type\":\"INT\"},{\"name\":\"summary\",\"type\":\"TEXT\"},{\"name\":\"state\",\"type\":\"TEXT\"}],\"rows\":["
    rows := mut result.get_rows()
    row_idx := mut 0
    LW row_idx < rows.len() {
        row := mut &rows[row_idx]
        row_id := mut cell_or_empty(row, 0)
        row_summary := mut cell_or_empty(row, 1)
        row_state := mut cell_or_empty(row, 2)
        I !db_filter_digits_is_valid(row_id) {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")

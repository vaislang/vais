fn check_books_post_route_conflict(db_path: str) -> i64 {
    response := mut db_books_post_handler(db_path, "POST", "/db/books", "{\"id\":3,\"title\":\"children\"}")
    I response.status != 409 {
        println("FAIL db books post conflict response status")
        return 95
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL db books post conflict response content type")
        return 96
    }
    I response.body != "{\"error\":\"db_conflict\"}" {
        println("FAIL db books post conflict response body")
        println(response.body)
        return 97
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)
    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 98 },
    }
    result := mut match db.query("select * from books where title = 'children'") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return 99
        },
    }
    I result.row_count() != 2 as u64 {
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return 100
    }
    rows := mut result.get_rows()
    seen_id3 := mut false
    seen_id4 := mut false
    LF ri: 0..rows.len() {
        row := mut &rows[ri]
        I cell_or_empty(row, 0) == "3" && cell_or_empty(row, 1) == "children" {
            seen_id3 = true
        }
        I cell_or_empty(row, 0) == "4" && cell_or_empty(row, 1) == "children" {
            seen_id4 = true
        }
    }
    result.free_owned_text()
    result.free_owned_text()
    match db.close() {
        Ok(_) => {},
        Err(_) => { return 101 },
    }
    I !seen_id3 || !seen_id4 {
        return 102
    }

    0
}

fn check_books_children_count(db_path: str, expected: u64) -> i64 {
    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 110 },
    }
    result := mut match db.query("select * from books where title = 'children'") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return 111
        },
    }
    count := mut result.row_count()
    result.free_owned_text()
    match db.close() {
        Ok(_) => {},
        Err(_) => { return 112 },
    }
    I count != expected {
        return 113
    }

    0
}

fn check_books_post_admin_guarded_allowed(db_path: str) -> i64 {
    auth_set_test_time_sec(1000)
    store := mut SessionStore.new()
    admin := store.create("admin-user", 120)
    store.set_data(admin.session_id, "role", "admin")
    store.set_data(admin.session_id, "capability", "books.seed")

    response := mut db_books_post_admin_guarded_handler(
        db_path,
        "POST",
        "/db/books",
        "{\"id\":3,\"title\":\"children\"}",
        store,
        admin.session_id,
    )
    I response.status != 200 {
        println("FAIL guarded post allowed status")
        return 120
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL guarded post allowed content type")
        return 121
    }
    I response.body != "{\"inserted\":1,\"id\":3,\"title\":\"children\"}" {

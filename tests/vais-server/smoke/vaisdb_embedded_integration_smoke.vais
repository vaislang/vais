fn db_table_rows_id_filter_handler(
    db_path: str,
    method: str,
    path: str,
    query_param: str,
    body: str,
) -> Response {
    ctx := mut Context.new(method, path)
    table := mut db_table_rows_path_table(path)

    I !db_table_identifier_is_valid(table) {
        return ctx.json(400, "{\"error\":\"db_invalid_table\"}")
    }

    id_value := mut db_id_filter_query_value(query_param)
    I method != "GET" || body != "" || id_value == "" {
        return ctx.json(400, "{\"error\":\"db_invalid_filter\"}")
    }
    I db_table_rows_static_descriptor_rejected(table) {
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return ctx.json(500, "{\"error\":\"db_unavailable\"}") },
    }

    query := mut "select * from {table} where id = {id_value}"
    result := mut match db.query(query) {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(404, "{\"error\":\"db_unsupported_table\"}")
        },
    }

    I result.column_count() != 2 as u64 {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    columns := mut result.get_columns()
    I columns[0].get_name() != "id" || columns[0].get_type_name() != "INT" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }
    I columns[1].get_name() != "title" || columns[1].get_type_name() != "TEXT" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    response_body := mut append_str("{\"table\":\"", table, "")
    response_body = append_str(response_body, "\",\"columns\":[{\"name\":\"id\",\"type\":\"INT\"},{\"name\":\"title\",\"type\":\"TEXT\"}],\"rows\":[", "")
    rows := mut result.get_rows()
    row_idx := mut 0
    LW row_idx < rows.len() {
        row := mut &rows[row_idx]
        row_id := mut cell_or_empty(row, 0)
        row_title := mut cell_or_empty(row, 1)
        I !db_filter_digits_is_valid(row_id) {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        }

        escaped_title := mut escape_json_string(row_title)
        I row_idx > 0 {
            response_body = append_str(response_body, ",", "")
        }
        response_body = append_str(response_body, "{\"id\":", "")
        response_body = append_str(response_body, row_id, "")
        response_body = append_str(response_body, ",\"title\":\"", "")
        response_body = append_str(response_body, escaped_title, "")
        response_body = append_str(response_body, "\"}", "")
        row_idx += 1
    }
    response_body = append_str(response_body, "]}", "")

    result.free_owned_text()

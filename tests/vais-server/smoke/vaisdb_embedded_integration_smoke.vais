fn expect_db_unsupported_table_response(response: Response, expected_status: i64, base_code: i64) -> i64 {
    I response.status != expected_status {
        println("FAIL db unsupported table status")
        return base_code
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL db unsupported table content type")
        return base_code + 1
    }
    I response.body != "{\"error\":\"db_unsupported_table\"}" {
        println("FAIL db unsupported table body")
        println(response.body)
        return base_code + 2
    }
    0
}


fn expect_db_invalid_table_response(response: Response, base_code: i64) -> i64 {
    I response.status != 400 {
        println("FAIL db invalid table status")
        return base_code
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL db invalid table content type")
        return base_code + 1
    }
    I response.body != "{\"error\":\"db_invalid_table\"}" {
        println("FAIL db invalid table body")
        println(response.body)
        return base_code + 2
    }
    0
}

fn check_table_rows_invalid_inputs(db_path: str) -> i64 {
    bad_slash := mut db_table_rows_handler(db_path.clone(), "GET", "/db/tables/al/bums/rows", "")
    bad_slash_status := mut expect_db_invalid_table_response(bad_slash, 165)
    I bad_slash_status != 0 {
        return bad_slash_status
    }

    bad_dash := mut db_table_rows_handler(db_path.clone(), "GET", "/db/tables/albums-title/rows", "")
    bad_dash_status := mut expect_db_invalid_table_response(bad_dash, 170)
    I bad_dash_status != 0 {
        return bad_dash_status
    }

    bad_digit := mut db_table_rows_handler(db_path.clone(), "GET", "/db/tables/1albums/rows", "")
    bad_digit_status := mut expect_db_invalid_table_response(bad_digit, 175)
    I bad_digit_status != 0 {
        return bad_digit_status
    }

    bad_body := mut db_table_rows_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "{\"sql\":\"select * from albums\"}")
    bad_body_status := mut expect_db_invalid_table_response(bad_body, 180)
    I bad_body_status != 0 {
        return bad_body_status
    }

    bad_method := mut db_table_rows_handler(db_path.clone(), "POST", "/db/tables/albums/rows", "")
    bad_method_status := mut expect_db_invalid_table_response(bad_method, 185)
    I bad_method_status != 0 {
        return bad_method_status
    }

    0
}


fn check_table_rows_id_filter_invalid_inputs(db_path: str) -> i64 {
    missing_id := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "", "")
    missing_status := mut expect_db_invalid_filter_response(missing_id, 205)
    I missing_status != 0 { return missing_status }

    empty_id := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "id=", "")
    empty_status := mut expect_db_invalid_filter_response(empty_id, 210)
    I empty_status != 0 { return empty_status }

    nondigit_id := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "id=2x", "")
    nondigit_status := mut expect_db_invalid_filter_response(nondigit_id, 215)
    I nondigit_status != 0 { return nondigit_status }

    extra_param := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "id=2&title=green", "")
    extra_status := mut expect_db_invalid_filter_response(extra_param, 220)
    I extra_status != 0 { return extra_status }

    title_param := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "title=green", "")
    title_status := mut expect_db_invalid_filter_response(title_param, 225)
    I title_status != 0 { return title_status }

    sql_param := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "sql=select * from albums", "")
    sql_status := mut expect_db_invalid_filter_response(sql_param, 230)
    I sql_status != 0 { return sql_status }

    bad_body := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "id=2", "{\"where\":\"id=2\"}")
    body_status := mut expect_db_invalid_filter_response(bad_body, 235)
    I body_status != 0 { return body_status }

    bad_method := mut db_table_rows_id_filter_handler(db_path.clone(), "POST", "/db/tables/albums/rows", "id=2", "")
    method_status := mut expect_db_invalid_filter_response(bad_method, 240)
    I method_status != 0 { return method_status }

    0
}


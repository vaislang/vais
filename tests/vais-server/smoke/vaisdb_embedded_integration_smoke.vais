fn db_books_handler(db_path: str) -> Response {
    ctx := mut Context.new("GET", "/db/books")
    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return ctx.json(500, "{\"error\":\"db_unavailable\"}") },
    }

    result := mut match db.query("select * from books") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        },
    }

    I result.row_count() != 2 as u64 {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(500, "{\"error\":\"db_unexpected_rows\"}")
    }

    rows := mut result.get_rows()
    row0 := mut &rows[0]
    row1 := mut &rows[1]
    I cell_or_empty(row0, 0) != "1" || cell_or_empty(row0, 1) != "dune" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(500, "{\"error\":\"db_unexpected_row\"}")
    }
    I cell_or_empty(row1, 0) != "2" || cell_or_empty(row1, 1) != "foundation" {
        result.free_owned_text()
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(500, "{\"error\":\"db_unexpected_row\"}")
    }
    body := mut "{\"data\":[{\"id\":1,\"title\":\"dune\"},{\"id\":2,\"title\":\"foundation\"}]}"

    result.free_owned_text()
    result.free_owned_text()

    match db.close() {
        Ok(_) => {},
        Err(_) => { return ctx.json(500, "{\"error\":\"db_close_failed\"}") },
    }

    ctx.json(200, body)
}

fn db_books_count_handler(db_path: str) -> Response {
    ctx := mut Context.new("GET", "/db/books/count")
    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return ctx.json(500, "{\"error\":\"db_unavailable\"}") },
    }

    result := mut match db.query("select * from books") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        },
    }

    row_total := mut result.row_count()

    result.free_owned_text()
    result.free_owned_text()

    match db.close() {
        Ok(_) => {},
        Err(_) => { return ctx.json(500, "{\"error\":\"db_close_failed\"}") },
    }

    I row_total != 2 as u64 {
        return ctx.json(500, "{\"error\":\"db_unexpected_rows\"}")
    }

    ctx.json(200, "{\"count\":2}")
}

fn db_table_identifier_start_valid(c: i64) -> bool {
    I c >= 65 && c <= 90 { return true }
    I c >= 97 && c <= 122 { return true }
    c == 95
}

fn db_table_identifier_body_valid(c: i64) -> bool {
    I db_table_identifier_start_valid(c) { return true }
    c >= 48 && c <= 57
}

fn db_table_identifier_is_valid(table: str) -> bool {
    I table.len() == 0 {
        return false
    }
    I !db_table_identifier_start_valid(table.char_at(0)) {
        return false
    }
    idx := mut 1
    LW idx < table.len() {
        I !db_table_identifier_body_valid(table.char_at(idx)) {
            return false
        }
        idx += 1
    }
    true
}

fn db_table_rows_path_table(path: str) -> str {
    I path.len() <= 16 {
        return ""
    }
    I path.substring(0, 11) != "/db/tables/" {
        return ""
    }
    I path.substring(path.len() - 5, path.len()) != "/rows" {
        return ""
    }
    path.substring(11, path.len() - 5)
}

fn db_table_rows_static_descriptor_rejected(table: str) -> bool {
    I table == "people" { return true }
    I table == "books" { return true }
    I table == "authors" { return true }
    table == "publishers"
}

fn db_filter_digit_is_valid(c: i64) -> bool {
    c >= 48 && c <= 57
}

fn db_filter_digits_is_valid(value: str) -> bool {
    I value.len() == 0 {
        return false
    }
    idx := mut 0
    LW idx < value.len() {
        I !db_filter_digit_is_valid(value.char_at(idx)) {
            return false
        }
        idx += 1
    }
    true
}

fn db_id_filter_query_value(query: str) -> str {
    I query.len() <= 3 {
        return ""
    }
    I query.substring(0, 3) != "id=" {
        return ""
    }
    value := mut query.substring(3, query.len())
    I !db_filter_digits_is_valid(value) {
        return ""
    }
    value
}

fn db_filter_title_char_is_valid(c: i64) -> bool {
    I c >= 65 && c <= 90 { return true }
    I c >= 97 && c <= 122 { return true }
    I c >= 48 && c <= 57 { return true }
    c == 32 || c == 45 || c == 95
}

fn db_filter_title_is_valid(value: str) -> bool {
    I value.len() == 0 || value.len() > 64 {
        return false
    }
    idx := mut 0
    LW idx < value.len() {
        I !db_filter_title_char_is_valid(value.char_at(idx)) {
            return false
        }
        idx += 1
    }
    true
}

fn db_title_filter_query_value(query: str) -> str {
    I query.len() <= 6 {
        return ""
    }
    I query.substring(0, 6) != "title=" {
        return ""
    }
    value := mut query.substring(6, query.len())
    I !db_filter_title_is_valid(value) {
        return ""
    }
    value
}

fn db_body_filter_query_value(query: str) -> str {
    I query.len() <= 5 {
        return ""
    }
    I query.substring(0, 5) != "body=" {
        return ""
    }
    value := mut query.substring(5, query.len())
    I !db_filter_title_is_valid(value) {
        return ""
    }
    value
}

fn db_filter_status_char_is_valid(c: i64) -> bool {
    I c >= 65 && c <= 90 { return true }
    I c >= 97 && c <= 122 { return true }
    I c >= 48 && c <= 57 { return true }
    c == 45 || c == 95
}

fn db_filter_status_is_valid(value: str) -> bool {
    I value.len() == 0 || value.len() > 64 {
        return false
    }
    idx := mut 0
    LW idx < value.len() {
        I !db_filter_status_char_is_valid(value.char_at(idx)) {
            return false
        }
        idx += 1
    }
    true
}

fn db_status_filter_query_value(query: str) -> str {
    I query.len() <= 7 {
        return ""
    }
    I query.substring(0, 7) != "status=" {
        return ""
    }
    value := mut query.substring(7, query.len())
    I !db_filter_status_is_valid(value) {
        return ""
    }
    value
}

fn db_state_filter_query_value(query: str) -> str {
    I query.len() <= 6 {
        return ""
    }
    I query.substring(0, 6) != "state=" {
        return ""
    }
    value := mut query.substring(6, query.len())
    I !db_filter_status_is_valid(value) {
        return ""
    }
    value
}

fn db_dock_filter_query_value(query: str) -> str {
    I query.len() <= 5 {
        return ""
    }
    I query.substring(0, 5) != "dock=" {
        return ""
    }
    value := mut query.substring(5, query.len())
    I !db_filter_status_is_valid(value) {
        return ""
    }
    value
}

fn db_table_rows_handler(db_path: str, method: str, path: str, body: str) -> Response {
    db_table_rows_query_handler(db_path, method, path, "", body)
}

fn db_table_rows_query_handler(db_path: str, method: str, path: str, query_param: str, body: str) -> Response {
    ctx := mut Context.new(method, path)
    table := mut db_table_rows_path_table(path)

    I method != "GET" || body != "" || !db_table_identifier_is_valid(table) {
        return ctx.json(400, "{\"error\":\"db_invalid_table\"}")
    }
    I query_param != "" {
        return ctx.json(400, "{\"error\":\"db_invalid_filter\"}")
    }
    I db_table_rows_static_descriptor_rejected(table) {
        return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return ctx.json(500, "{\"error\":\"db_unavailable\"}") },
    }

    query := mut "select * from {table}"
    result := mut match db.query(query) {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(404, "{\"error\":\"db_unsupported_table\"}")
        },
    }

    I table == "tasks" {
        I result.column_count() != 3 as u64 || result.row_count() != 2 as u64 {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        }

        columns := mut result.get_columns()
        I columns[0].get_name() != "id" || columns[0].get_type_name() != "INT" {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
        }
        I columns[1].get_name() != "title" || columns[1].get_type_name() != "TEXT" {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
        }
        I columns[2].get_name() != "status" || columns[2].get_type_name() != "TEXT" {
            result.free_owned_text()
            result.free_owned_text()
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(422, "{\"error\":\"db_unsupported_table\"}")
        }

        rows := mut result.get_rows()
        response_body := mut "{\"table\":\"tasks\",\"columns\":[{\"name\":\"id\",\"type\":\"INT\"},{\"name\":\"title\",\"type\":\"TEXT\"},{\"name\":\"status\",\"type\":\"TEXT\"}],\"rows\":["
        row_idx := mut 0
        LW row_idx < rows.len() {
            row := mut &rows[row_idx]
            row_id := mut cell_or_empty(row, 0)
            row_title := mut cell_or_empty(row, 1)
            row_status := mut cell_or_empty(row, 2)
            I !db_filter_digits_is_valid(row_id) {
                result.free_owned_text()
                result.free_owned_text()
                match db.close() {
                    Ok(_) => {},
                    Err(_) => {},
                }
                return ctx.json(500, "{\"error\":\"db_query_failed\"}")
            }
            escaped_title := mut escape_json_string(row_title)
            escaped_status := mut escape_json_string(row_status)
            I row_idx > 0 {
                response_body = append_str(response_body, ",", "")
            }
            response_body = append_str(response_body, "{\"id\":", "")
            response_body = append_str(response_body, row_id, "")
            response_body = append_str(response_body, ",\"title\":\"", "")
            response_body = append_str(response_body, escaped_title, "")
            response_body = append_str(response_body, "\",\"status\":\"", "")
            response_body = append_str(response_body, escaped_status, "")
            response_body = append_str(response_body, "\"}", "")
            row_idx += 1
        }
        response_body = append_str(response_body, "]}", "")

        result.free_owned_text()
        result.free_owned_text()

        match db.close() {
            Ok(_) => {},
            Err(_) => { return ctx.json(500, "{\"error\":\"db_close_failed\"}") },
        }

        return ctx.json(200, response_body)
    }

    I table == "tickets" {

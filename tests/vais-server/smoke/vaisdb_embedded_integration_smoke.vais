fn expect_admin_forbidden(response: Response, code: i64) -> i64 {
    I response.status != 403 {
        println("FAIL guarded post denied status")
        return code
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL guarded post denied content type")
        return code + 1
    }
    I response.body != "{\"error\":\"admin_forbidden\"}" {
        println("FAIL guarded post denied body")
        println(response.body)
        return code + 2
    }
    0
}

fn check_books_post_admin_guarded_denied(db_path: str) -> i64 {
    auth_set_test_time_sec(1000)

    empty_store := mut SessionStore.new()
    missing_response := mut db_books_post_admin_guarded_handler(
        db_path,
        "POST",
        "/db/books",
        "{\"id\":3,\"title\":\"children\"}",
        empty_store,
        "missing-session",
    )
    missing_status := mut expect_admin_forbidden(missing_response, 130)
    I missing_status != 0 { return missing_status }

    wrong_store := mut SessionStore.new()
    wrong := wrong_store.create("wrong-capability", 120)
    wrong_store.set_data(wrong.session_id, "role", "admin")
    wrong_store.set_data(wrong.session_id, "capability", "books.read")
    wrong_response := mut db_books_post_admin_guarded_handler(
        db_path,
        "POST",
        "/db/books",
        "{\"id\":3,\"title\":\"children\"}",
        wrong_store,
        wrong.session_id,
    )
    wrong_status := mut expect_admin_forbidden(wrong_response, 135)
    I wrong_status != 0 { return wrong_status }

    expired_store := mut SessionStore.new()
    expired := expired_store.create("expired-admin", 1)
    expired_store.set_data(expired.session_id, "role", "admin")
    expired_store.set_data(expired.session_id, "capability", "books.seed")
    auth_set_test_time_sec(1002)
    expired_response := mut db_books_post_admin_guarded_handler(
        db_path,
        "POST",
        "/db/books",
        "{\"id\":3,\"title\":\"children\"}",
        expired_store,
        expired.session_id,
    )
    expired_status := mut expect_admin_forbidden(expired_response, 140)
    auth_set_test_time_sec(1000)
    I expired_status != 0 { return expired_status }

    no_write_status := mut check_books_children_count(db_path, 0 as u64)
    I no_write_status != 0 {
        println("FAIL guarded denied wrote children row")
        return no_write_status
    }

    0
}

fn check_books_post_persistence(db_path: str) -> i64 {
    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 70 },
    }

    result := mut match db.query("select * from books where title = 'children'") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return 71
        },
    }

    I result.row_count() != 1 as u64 {
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return 72
    }

    rows := mut result.get_rows()
    row0 := mut &rows[0]
    I cell_or_empty(row0, 0) != "3" || cell_or_empty(row0, 1) != "children" {
        result.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return 73
    }

    result.free_owned_text()

    match db.close() {
        Ok(_) => {},
        Err(_) => { return 74 },
    }

    0
}


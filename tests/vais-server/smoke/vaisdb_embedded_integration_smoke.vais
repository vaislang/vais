    rows := mut result.get_rows()
    response_body := mut "{\"table\":\"stations\",\"columns\":[{\"name\":\"id\",\"type\":\"INT\"},{\"name\":\"title\",\"type\":\"TEXT\"},{\"name\":\"state\",\"type\":\"TEXT\"},{\"name\":\"kind\",\"type\":\"TEXT\"},{\"name\":\"tag\",\"type\":\"TEXT\"},{\"name\":\"holder\",\"type\":\"TEXT\"},{\"name\":\"zone\",\"type\":\"TEXT\"},{\"name\":\"shelf\",\"type\":\"TEXT\"},{\"name\":\"bin\",\"type\":\"TEXT\"},{\"name\":\"batch\",\"type\":\"TEXT\"},{\"name\":\"lane\",\"type\":\"TEXT\"},{\"name\":\"route\",\"type\":\"TEXT\"},{\"name\":\"stop\",\"type\":\"TEXT\"},{\"name\":\"gate\",\"type\":\"TEXT\"},{\"name\":\"dock\",\"type\":\"TEXT\"}],\"rows\":["

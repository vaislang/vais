fn check_db_unavailable_routes(db_path: str) -> i64 {
    list_response := mut db_books_handler(db_path.clone())
    list_status := mut expect_db_unavailable_response(list_response, 130)
    I list_status != 0 {
        return list_status
    }

    count_response := mut db_books_count_handler(db_path.clone())
    count_status := mut expect_db_unavailable_response(count_response, 135)
    I count_status != 0 {
        return count_status
    }

    table_response := mut db_table_rows_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "")
    table_status := mut expect_db_unavailable_response(table_response, 145)
    I table_status != 0 {
        return table_status
    }

    filter_response := mut db_table_rows_id_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "id=2", "")
    filter_status := mut expect_db_unavailable_response(filter_response, 148)
    I filter_status != 0 {
        return filter_status
    }

    title_filter_response := mut db_table_rows_title_filter_handler(db_path.clone(), "GET", "/db/tables/albums/rows", "title=green", "")
    title_filter_status := mut expect_db_unavailable_response(title_filter_response, 152)
    I title_filter_status != 0 {
        return title_filter_status
    }

    body_filter_response := mut db_table_rows_body_filter_handler(db_path.clone(), "GET", "/db/tables/notes/rows", "body=todo", "")
    body_filter_status := mut expect_db_unavailable_response(body_filter_response, 156)
    I body_filter_status != 0 {
        return body_filter_status
    }

    post_response := mut db_books_post_handler(db_path.clone(), "POST", "/db/books", "{\"id\":3,\"title\":\"children\"}")
    post_status := mut expect_db_unavailable_response(post_response, 140)
    I post_status != 0 {
        return post_status
    }

    0
}

fn main() -> i64 {
    db_path := mut "server_vaisdb_integration_db"
    albums_path := mut "server_vaisdb_albums_db"
    notes_path := mut "server_vaisdb_notes_db"
    tasks_path := mut "server_vaisdb_tasks_db"
    missing_catalog_path := mut "server_vaisdb_missing_catalog_db"

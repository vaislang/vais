fn db_books_post_handler(db_path: str, method: str, path: str, body: str) -> Response {
    ctx := mut Context.new(method, path)

    I method != "POST" || path != "/db/books" || body != "{\"id\":3,\"title\":\"children\"}" {
        return ctx.json(400, "{\"error\":\"db_invalid_request\"}")
    }

    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return ctx.json(500, "{\"error\":\"db_unavailable\"}") },
    }

    existing := mut match db.query("select * from books where title = 'children'") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        },
    }

    existing_rows := mut existing.row_count()
    existing.free_owned_text()

    I existing_rows > 1 as u64 {
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(409, "{\"error\":\"db_conflict\"}")
    }

    inserted := mut 0 as u64
    I existing_rows == 0 as u64 {
        write_count := mut match db.execute("insert into books values (3, 'children')") {
            Ok(v) => v,
            Err(_) => {
                match db.close() {
                    Ok(_) => {},
                    Err(_) => {},
                }
                return ctx.json(500, "{\"error\":\"db_write_failed\"}")
            },
        }
        I write_count != 1 as u64 {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_write_failed\"}")
        }
        inserted = 1 as u64
    }

    confirmed := mut match db.query("select * from books where title = 'children'") {
        Ok(r) => r,
        Err(_) => {
            match db.close() {
                Ok(_) => {},
                Err(_) => {},
            }
            return ctx.json(500, "{\"error\":\"db_query_failed\"}")
        },
    }

    I confirmed.row_count() != 1 as u64 {
        confirmed.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(409, "{\"error\":\"db_conflict\"}")
    }

    rows := mut confirmed.get_rows()
    row0 := mut &rows[0]
    I cell_or_empty(row0, 0) != "3" || cell_or_empty(row0, 1) != "children" {
        confirmed.free_owned_text()
        match db.close() {
            Ok(_) => {},
            Err(_) => {},
        }
        return ctx.json(409, "{\"error\":\"db_conflict\"}")
    }

    confirmed.free_owned_text()

    match db.close() {
        Ok(_) => {},
        Err(_) => { return ctx.json(500, "{\"error\":\"db_close_failed\"}") },
    }

    I inserted == 1 as u64 {
        return ctx.json(200, "{\"inserted\":1,\"id\":3,\"title\":\"children\"}")
    }

    ctx.json(200, "{\"inserted\":0,\"id\":3,\"title\":\"children\"}")
}

fn db_books_post_admin_guarded_handler(
    db_path: str,
    method: str,
    path: str,
    body: str,
    store: SessionStore,
    session_id: str,
) -> Response {
    ctx := mut Context.new(method, path)

    I store.get(session_id) != session_id {
        return ctx.json(403, "{\"error\":\"admin_forbidden\"}")
    }
    I store.get_data(session_id, "role") != "admin" {
        return ctx.json(403, "{\"error\":\"admin_forbidden\"}")
    }
    I store.get_data(session_id, "capability") != "books.seed" {
        return ctx.json(403, "{\"error\":\"admin_forbidden\"}")
    }

    db_books_post_handler(db_path, method, path, body)
}

fn check_books_count_route(db_path: str) -> i64 {
    response := mut db_books_count_handler(db_path)
    I response.status != 200 {
        println("FAIL db books count response status")
        return 40
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL db books count response content type")
        return 41
    }
    I response.body != "{\"count\":2}" {
        println("FAIL db books count response body")
        println(response.body)
        return 42
    }
    0
}


    }

    filter_value := mut ""
    I filter_kind == "dock" {
        filter_value = db_dock_filter_query_value(query_param)
    }
    I filter_kind == "id" {
        filter_value = db_id_filter_query_value(query_param)
    }
    I method != "GET" || body != "" || filter_value == "" {

fn check_server_surface() -> i64 {
    app := mut App.new(ServerConfig.default())
    app.get("/db/health", "db_health_handler")
    app.get("/db/books", "db_books_handler")
    app.get("/db/books/count", "db_books_count_handler")
    app.get("/db/tables/:table/rows", "db_table_rows_handler")
    app.post("/db/books", "db_books_post_handler")

    I app.route_count() != 5 {
        println("FAIL app route registration")
        return 1
    }

    ctx := mut Context.new("GET", "/db/health")
    ctx = ctx.set_header("X-VaisDB-Mode", "embedded")
    res := ctx.json(200, "{\"db\":\"open\"}")

    I res.status != 200 {
        println("FAIL integration response status")
        return 5
    }
    I res.body != "{\"db\":\"open\"}" {
        println("FAIL integration response body")
        return 6
    }
    I res.content_type != "application/json; charset=utf-8" {
        println("FAIL integration response content type")
        return 7
    }
    I res.headers == "" {
        println("FAIL integration response headers")
        return 8
    }

    return 0
}

fn cell_or_empty(row: &Vec<Option<str>>, idx: u64) -> str {
    match row[idx] {
        Some(v) => v,
        None => "",
    }
}

fn setup_books_db(db_path: str) -> i64 {
    cfg := mut EmbeddedConfig.default()
    cfg = cfg.with_data_dir(db_path.clone())
    cfg = cfg.with_page_size(PAGE_SIZE_8K)

    db := mut match EmbeddedDatabase.open(cfg) {
        Ok(v) => v,
        Err(_) => { return 20 },
    }

    created := mut match db.execute("create table books (id int, title text)") {
        Ok(v) => v,
        Err(_) => { return 21 },
    }
    I created != 0 as u64 { return 22 }

    inserted_a := mut match db.execute("insert into books values (1, 'dune')") {
        Ok(v) => v,
        Err(_) => { return 23 },
    }
    I inserted_a != 1 as u64 { return 24 }

    inserted_b := mut match db.execute("insert into books values (2, 'foundation')") {
        Ok(v) => v,
        Err(_) => { return 25 },
    }
    I inserted_b != 1 as u64 { return 26 }

    match db.close() {
        Ok(_) => {},
        Err(_) => { return 27 },
    }

    0
}


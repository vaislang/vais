fn expect_db_invalid_table_response(response: Response, base_code: i64) -> i64 {
    I response.status != 400 {
        println("FAIL db invalid table status")
        return base_code
    }
    I response.content_type != "application/json; charset=utf-8" {
        println("FAIL db invalid table content type")
        return base_code + 1
    }
    I response.body != "{\"error\":\"db_invalid_table\"}" {
        println("FAIL db invalid table body")
        println(response.body)
        return base_code + 2
    }
    0
}


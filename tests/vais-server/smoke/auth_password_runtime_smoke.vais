use std/error
use src/auth/password

fn smoke_password_policy_accepts_strong_password() -> i64 {
    policy := PasswordPolicy.default()
    result := validate_password("Secret42", policy)
    match result {
        Ok(ok) => {
            I !ok {
                println("FAIL password policy strong returned false")
                return 1
            }
        },
        Err(e) => {
            println("FAIL password policy strong rejected")
            return 2
        },
    }
    0
}

fn smoke_password_policy_rejects_short_password() -> i64 {
    policy := PasswordPolicy.default()
    result := validate_password("Ab1", policy)
    match result {
        Ok(_) => {
            println("FAIL password policy short accepted")
            return 10
        },
        Err(e) => {
            I e.message == "" {
                println("FAIL password policy short empty message")
                return 11
            }
        },
    }
    0
}

fn smoke_password_policy_rejects_missing_character_classes() -> i64 {
    policy := PasswordPolicy.default()

    no_upper := validate_password("lowercase1", policy)
    match no_upper {
        Ok(_) => {
            println("FAIL password policy no uppercase accepted")
            return 20
        },
        Err(e) => {
            I e.message == "" {
                println("FAIL password policy no uppercase empty message")
                return 21
            }
        },
    }

    no_digit := validate_password("NoDigitHere", policy)
    match no_digit {
        Ok(_) => {
            println("FAIL password policy no digit accepted")
            return 22
        },
        Err(e) => {
            I e.message == "" {
                println("FAIL password policy no digit empty message")
                return 23
            }
        },
    }

    0
}

fn smoke_minimal_policy_and_invalid_hash() -> i64 {
    minimal := PasswordPolicy.minimal()
    result := validate_password("abcd", minimal)
    match result {
        Ok(ok) => {
            I !ok {
                println("FAIL minimal password policy returned false")
                return 30
            }
        },
        Err(_) => {
            println("FAIL minimal password policy rejected")
            return 31
        },
    }

    hasher := PasswordHasher.new()
    I hasher.verify_password("anything", "not-a-vais-hash") {
        println("FAIL malformed password hash verified")
        return 32
    }

    I verify_password("anything", "not-a-vais-hash") {
        println("FAIL malformed password hash verified by free function")
        return 33
    }

    0
}

fn smoke_password_hash_and_verify() -> i64 {
    hash1 := hash_password("Secret42")
    I !hash1.starts_with("$vais-pbkdf2-sha256$100000$") {
        println("FAIL password hash prefix")
        return 40
    }
    I hash1.len() != 124 {
        println("FAIL password hash length")
        return 41
    }
    I !verify_password("Secret42", hash1) {
        println("FAIL password hash verify")
        return 42
    }
    I verify_password("Wrong42", hash1) {
        println("FAIL wrong password verified")
        return 43
    }

    hash2 := hash_password("Secret42")
    I hash1 == hash2 {
        println("FAIL password salt uniqueness")
        return 44
    }

    hasher := PasswordHasher.new()
    hash3 := hasher.hash_password("Secret42")
    I !hasher.verify_password("Secret42", hash3) {
        println("FAIL password hasher method verify")
        return 45
    }

    0
}

fn main() -> i64 {
    failures := mut 0
    failures += smoke_password_policy_accepts_strong_password()
    failures += smoke_password_policy_rejects_short_password()
    failures += smoke_password_policy_rejects_missing_character_classes()
    failures += smoke_minimal_policy_and_invalid_hash()
    failures += smoke_password_hash_and_verify()

    I failures > 0 {
        println("VAIS_SERVER_AUTH_PASSWORD_RUNTIME_FAIL")
        return failures
    }
    println("VAIS_SERVER_AUTH_PASSWORD_RUNTIME_OK")
    0
}

# CHECKS: match guards differentiate negative ranges.
fn sign(n: i64) -> i64 {
    match n {
        0 => 0,
        x I x > 0 => 1,
        _ => 0 - 1
    }
}

fn clamp(n: i64) -> i64 {
    match n {
        x I x < 0 => 0,
        x I x > 100 => 100,
        _ => n
    }
}

fn main() -> i64 {
    I sign(0) != 0 { return 1 }
    I sign(42) != 1 { return 2 }
    I sign(0 - 5) != 0 - 1 { return 3 }

    I clamp(50) != 50 { return 4 }
    I clamp(0 - 10) != 0 { return 5 }
    I clamp(150) != 100 { return 6 }
    I clamp(0) != 0 { return 7 }
    I clamp(100) != 100 { return 8 }
    return 0
}

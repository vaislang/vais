# CHECKS: match coerces narrow-int source to bare-int literal arms
# REGRESSION: Phase 17 narrow-int phi-incoming class
# NOTE: i32 literal arms (e.g., `0i32 =>`) currently rejected by parser;
#       test uses bare integer literals which the TC widens.
F classify(n: i32) -> i64 {
    M n {
        0 => 0,
        1 => 10,
        _ => 99,
    }
}

F main() -> i64 {
    I classify(0i32) != 0   { R 1 }
    I classify(1i32) != 10  { R 2 }
    I classify(7i32) != 99  { R 3 }
    R 0
}

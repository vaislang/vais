# CHECKS: match arm guards `pattern I expr => body` (note: vais uses single-char
# `I` keyword for if/guard, not the spelled-out `if`).
fn classify(n: i64) -> i64 {
    match n {
        x I x< 0 => 1,
        0          => 2,
        x I x< 10 => 3,
        x I x< 100 => 4,
        _ => 5,
    }
}

fn main() -> i64 {
    I classify(0 - 5) != 1 { return 1 }
    I classify(0) != 2 { return 2 }
    I classify(7) != 3 { return 3 }
    I classify(42) != 4 { return 4 }
    I classify(500) != 5 { return 5 }
    return 0
}

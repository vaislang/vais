# XFAIL: match arm guards `pattern if expr => body` aren't recognized by the
# parser. The `if` keyword is consumed as an Ident before the parser looks
# for `=>`, so guards never reach codegen. Tracked as Phase 0 finding C10.
#
# CHECKS: match arm guards (`pattern if expr => body`).
F classify(n: i64) -> i64 {
    M n {
        x if x < 0 => 1,
        0          => 2,
        x if x < 10 => 3,
        x if x < 100 => 4,
        _ => 5,
    }
}

F main() -> i64 {
    I classify(0 - 5) != 1 { R 1 }
    I classify(0) != 2 { R 2 }
    I classify(7) != 3 { R 3 }
    I classify(42) != 4 { R 4 }
    I classify(500) != 5 { R 5 }
    R 0
}

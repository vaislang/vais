# CHECKS: match inside a function called from match arms.
fn sub_classify(n: i64) -> i64 {
    match n {
        0 => 100,
        1 => 200,
        _ => 0
    }
}

fn top_classify(n: i64) -> i64 {
    match n {
        0 => sub_classify(0),
        1 => sub_classify(1),
        2 => sub_classify(0) + sub_classify(1),
        _ => 0 - 1
    }
}

fn main() -> i64 {
    I top_classify(0) != 100 { return 1 }
    I top_classify(1) != 200 { return 2 }
    I top_classify(2) != 300 { return 3 }
    I top_classify(99) != 0 - 1 { return 4 }
    return 0
}

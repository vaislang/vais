# CHECKS: result of match used in subsequent arithmetic.
fn dispatch(n: i64) -> i64 {
    match n {
        0 => 1,
        1 => 10,
        2 => 100,
        _ => 0
    }
}

fn main() -> i64 {
    r: i64 := dispatch(0) + dispatch(1) + dispatch(2)
    I r != 111 { return 1 }

    s: i64 := dispatch(0) * 2 + dispatch(2) - 1
    I s != 101 { return 2 }

    t: i64 := dispatch(99) + dispatch(99)
    I t != 0 { return 3 }
    return 0
}

# CHECKS: match on the result of an arithmetic computation.
F bucket(n: i64) -> i64 {
    M (n / 10) {
        0 => 1,
        1 => 2,
        2 => 3,
        3 | 4 | 5 => 4,
        _ => 5
    }
}

F main() -> i64 {
    I bucket(0) != 1 { R 1 }
    I bucket(5) != 1 { R 2 }
    I bucket(15) != 2 { R 3 }
    I bucket(25) != 3 { R 4 }
    I bucket(35) != 4 { R 5 }
    I bucket(45) != 4 { R 6 }
    I bucket(55) != 4 { R 7 }
    I bucket(75) != 5 { R 8 }
    I bucket(99) != 5 { R 9 }
    R 0
}

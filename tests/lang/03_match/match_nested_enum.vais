# XFAIL: match arms with i64 results in a context where the match result type
# is the enum aggregate produce invalid IR (phi typed `{i8, i64}` with int
# constants). Tracked as Phase 0 finding C7. The bug is in the match-result
# phi codegen path which doesn't coerce arm values to the merged aggregate
# type.
#
# CHECKS: match on Option<Option<i64>> for two-level destructuring.
F deep_unwrap(o: Option<Option<i64>>) -> i64 {
    M o {
        Some(Some(v)) => v,
        Some(None)    => 0 - 1,
        None          => 0 - 2
    }
}

F main() -> i64 {
    a: Option<Option<i64>> := Some(Some(42))
    I deep_unwrap(a) != 42 { R 1 }

    b: Option<Option<i64>> := Some(None)
    I deep_unwrap(b) != 0 - 1 { R 2 }

    c: Option<Option<i64>> := None
    I deep_unwrap(c) != 0 - 2 { R 3 }
    R 0
}

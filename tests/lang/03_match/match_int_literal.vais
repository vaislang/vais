# CHECKS: match on integer literal arms
F classify(n: i64) -> i64 {
    M n {
        0 => 0,
        1 => 10,
        2 => 20,
        _ => 99,
    }
}

F main() -> i64 {
    I classify(0) != 0 { R 1 }
    I classify(1) != 10 { R 2 }
    I classify(2) != 20 { R 3 }
    I classify(7) != 99 { R 4 }
    R 0
}

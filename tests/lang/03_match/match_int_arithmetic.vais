# CHECKS: match on i64 with arithmetic results in arms.
F day_count(month: i64) -> i64 {
    M month {
        1  => 31,
        2  => 28,
        3  => 31,
        4  => 30,
        5  => 31,
        6  => 30,
        7  => 31,
        8  => 31,
        9  => 30,
        10 => 31,
        11 => 30,
        12 => 31,
        _  => 0
    }
}

F main() -> i64 {
    I day_count(1) != 31 { R 1 }
    I day_count(2) != 28 { R 2 }
    I day_count(4) != 30 { R 3 }
    I day_count(12) != 31 { R 4 }
    I day_count(0) != 0 { R 5 }
    I day_count(13) != 0 { R 6 }

    # sum days in a quarter
    sum: i64 := mut 0
    LF m: 1..=3 {
        sum = sum + day_count(m)
    }
    # 31 + 28 + 31 = 90
    I sum != 90 { R 7 }
    R 0
}

# CHECKS: match arms with arithmetic expressions in body.
fn transform(n: i64) -> i64 {
    match n {
        0 => 100,
        1 => 100 + 50,
        2 => 200 * 2,
        3 => (300 + 10) - 5,
        x I x > 100 => x * 2,
        _ => 0 - 1
    }
}

fn main() -> i64 {
    I transform(0) != 100 { return 1 }
    I transform(1) != 150 { return 2 }
    I transform(2) != 400 { return 3 }
    I transform(3) != 305 { return 4 }
    I transform(200) != 400 { return 5 }
    I transform(50) != 0 - 1 { return 6 }
    return 0
}

# CHECKS: match arms with parenthesized expression bodies (multi-step but no let).
fn process(n: i64) -> i64 {
    match n {
        0 => 100 + 1,
        1 => 200 + 50,
        2 => (300 - 5) * 2,
        _ => 0
    }
}

fn main() -> i64 {
    I process(0) != 101 { return 1 }
    I process(1) != 250 { return 2 }
    I process(2) != 590 { return 3 }
    I process(99) != 0 { return 4 }
    return 0
}

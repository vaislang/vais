# CHECKS: match where only the wildcard matches (catch-all).
fn catch(n: i64) -> i64 {
    match n {
        _ => n * 2
    }
}

fn main() -> i64 {
    I catch(0) != 0 { return 1 }
    I catch(5) != 10 { return 2 }
    I catch(0 - 3) != 0 - 6 { return 3 }
    I catch(100) != 200 { return 4 }
    return 0
}

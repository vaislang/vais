# CHECKS: match with integer ranges
F bucket(n: i64) -> i64 {
    M n {
        0..=9    => 0,
        10..=99  => 1,
        100..=999=> 2,
        _        => 3,
    }
}

F main() -> i64 {
    I bucket(5)    != 0 { R 1 }
    I bucket(42)   != 1 { R 2 }
    I bucket(500)  != 2 { R 3 }
    I bucket(5000) != 3 { R 4 }
    R 0
}

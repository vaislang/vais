# CHECKS: small power-of-two table via shift.
fn main() -> i64 {
    I (1 << 0) != 1 { return 1 }
    I (1 << 1) != 2 { return 2 }
    I (1 << 2) != 4 { return 3 }
    I (1 << 3) != 8 { return 4 }
    I (1 << 8) != 256 { return 5 }
    I (1 << 16) != 65536 { return 6 }
    I (1 << 30) != 1073741824 { return 7 }

    # right shift halves
    I (1024 >> 0) != 1024 { return 8 }
    I (1024 >> 5) != 32 { return 9 }
    I (1024 >> 10) != 1 { return 10 }
    I (1024 >> 11) != 0 { return 11 }
    return 0
}

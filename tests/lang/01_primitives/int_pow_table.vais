# CHECKS: small power-of-two table via shift.
F main() -> i64 {
    I (1 << 0) != 1 { R 1 }
    I (1 << 1) != 2 { R 2 }
    I (1 << 2) != 4 { R 3 }
    I (1 << 3) != 8 { R 4 }
    I (1 << 8) != 256 { R 5 }
    I (1 << 16) != 65536 { R 6 }
    I (1 << 30) != 1073741824 { R 7 }

    # right shift halves
    I (1024 >> 0) != 1024 { R 8 }
    I (1024 >> 5) != 32 { R 9 }
    I (1024 >> 10) != 1 { R 10 }
    I (1024 >> 11) != 0 { R 11 }
    R 0
}

# CHECKS: arithmetic well within i64 range.
F main() -> i64 {
    # 1e9 + 1e9 = 2e9
    I 1000000000 + 1000000000 != 2000000000 { R 1 }

    # 1e9 * 9 = 9e9
    I 1000000000 * 9 != 9000000000 { R 2 }

    # 2^32 = 4294967296
    I (1 << 32) != 4294967296 { R 3 }

    # 2^32 * 2 = 2^33
    I ((1 << 32) * 2) != 8589934592 { R 4 }

    # large addition with negatives
    I 5000000000 - 3000000000 != 2000000000 { R 5 }
    R 0
}

# CHECKS: f64 unary negation and zero comparison.
fn main() -> i64 {
    a: f64 := 3.5
    n: f64 := 0.0 - a
    I (n as i64) != 0 - 3 { return 1 }

    # negate twice
    b: f64 := 0.0 - n
    I (b as i64) != 3 { return 2 }

    # zero comparisons
    z: f64 := 0.0
    I z == 0.0 {} else { return 3 }
    I z < 0.001 {} else { return 4 }
    I z > (0.0 - 0.001) {} else { return 5 }
    return 0
}

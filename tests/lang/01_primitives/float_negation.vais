# CHECKS: f64 unary negation and zero comparison.
F main() -> i64 {
    a: f64 := 3.5
    n: f64 := 0.0 - a
    I (n as i64) != 0 - 3 { R 1 }

    # negate twice
    b: f64 := 0.0 - n
    I (b as i64) != 3 { R 2 }

    # zero comparisons
    z: f64 := 0.0
    I z == 0.0 {} EL { R 3 }
    I z < 0.001 {} EL { R 4 }
    I z > (0.0 - 0.001) {} EL { R 5 }
    R 0
}

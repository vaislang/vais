# CHECKS: cast chains — i64 → i32 → i64 + f64 ↔ i64.
fn main() -> i64 {
    a: i64 := 1000
    b: i32 := a as i32
    c: i64 := b as i64
    I c != 1000 { return 1 }

    # f64 → i64 truncates
    f: f64 := 3.99
    g: i64 := f as i64
    I g != 3 { return 2 }

    # negative f64 → i64
    nf: f64 := 0.0 - 7.5
    I (nf as i64) != 0 - 7 { return 3 }

    # i64 → f64 → i64 round-trip
    h: i64 := 12345
    rt: i64 := (h as f64) as i64
    I rt != 12345 { return 4 }
    return 0
}

# CHECKS: min/max via if-else helpers.
F int_min(a: i64, b: i64) -> i64 {
    I a < b { a } EL { b }
}

F int_max(a: i64, b: i64) -> i64 {
    I a > b { a } EL { b }
}

F main() -> i64 {
    I int_min(3, 5) != 3 { R 1 }
    I int_min(5, 3) != 3 { R 2 }
    I int_min(7, 7) != 7 { R 3 }
    I int_min(0 - 5, 3) != 0 - 5 { R 4 }

    I int_max(3, 5) != 5 { R 5 }
    I int_max(5, 3) != 5 { R 6 }
    I int_max(0, 0) != 0 { R 7 }
    I int_max(0 - 10, 0 - 5) != 0 - 5 { R 8 }
    R 0
}

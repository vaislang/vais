# CHECKS: min/max via if-else helpers.
fn int_min(a: i64, b: i64) -> i64 {
    I a < b { a } else { b }
}

fn int_max(a: i64, b: i64) -> i64 {
    I a > b { a } else { b }
}

fn main() -> i64 {
    I int_min(3, 5) != 3 { return 1 }
    I int_min(5, 3) != 3 { return 2 }
    I int_min(7, 7) != 7 { return 3 }
    I int_min(0 - 5, 3) != 0 - 5 { return 4 }

    I int_max(3, 5) != 5 { return 5 }
    I int_max(5, 3) != 5 { return 6 }
    I int_max(0, 0) != 0 { return 7 }
    I int_max(0 - 10, 0 - 5) != 0 - 5 { return 8 }
    return 0
}

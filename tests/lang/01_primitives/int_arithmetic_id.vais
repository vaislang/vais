# CHECKS: arithmetic identities.
F main() -> i64 {
    LF n: 0 - 5..=5 {
        # n + 0 = n
        I n + 0 != n { R 1 }
        # 0 + n = n
        I 0 + n != n { R 2 }
        # n - 0 = n
        I n - 0 != n { R 3 }
        # n * 1 = n
        I n * 1 != n { R 4 }
        # 1 * n = n
        I 1 * n != n { R 5 }
        # n * 0 = 0
        I n * 0 != 0 { R 6 }
        # 0 * n = 0
        I 0 * n != 0 { R 7 }
    }
    R 0
}

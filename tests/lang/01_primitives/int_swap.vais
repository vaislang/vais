# CHECKS: integer swap via temporary.
fn main() -> i64 {
    a: i64 := mut 10
    b: i64 := mut 20
    tmp: i64 := a
    a = b
    b = tmp
    I a != 20 { return 1 }
    I b != 10 { return 2 }

    # XOR swap (without temporary)
    x: i64 := mut 100
    y: i64 := mut 200
    x = x ^ y
    y = y ^ x
    x = x ^ y
    I x != 200 { return 3 }
    I y != 100 { return 4 }
    return 0
}

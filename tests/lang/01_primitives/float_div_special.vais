# CHECKS: f64 division and reciprocal patterns.
F main() -> i64 {
    # exact division
    a: f64 := 10.0
    b: f64 := 4.0
    q: f64 := a / b
    I (q as i64) != 2 { R 1 }

    # multiplication by reciprocal
    r: f64 := 1.0 / 4.0
    p: f64 := a * r
    I (p as i64) != 2 { R 2 }

    # negative result
    n: f64 := 0.0 - 10.0
    I ((n / 4.0) as i64) != 0 - 2 { R 3 }

    # whole division
    I ((20.0 / 5.0) as i64) != 4 { R 4 }
    I ((100.0 / 10.0) as i64) != 10 { R 5 }

    # zero numerator
    I ((0.0 / 5.0) as i64) != 0 { R 6 }
    R 0
}

# CHECKS: zero detection across various contexts.
fn main() -> i64 {
    a: i64 := 0
    I a != 0 { return 1 }

    # multiply by zero
    b: i64 := 999 * 0
    I b != 0 { return 2 }

    # zero - zero
    I 0 - 0 != 0 { return 3 }

    # zero | zero
    I (0 | 0) != 0 { return 4 }

    # zero & anything
    I (0 & 0xFFFF) != 0 { return 5 }

    # bit comparisons
    I 0 < 1 {} else { return 6 }
    I 0 > 0 - 1 {} else { return 7 }

    return 0
}

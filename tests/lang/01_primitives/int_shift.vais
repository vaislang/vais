# CHECKS: integer shift left/right operate on i64.
fn main() -> i64 {
    a: i64 := 1
    I (a << 0) != 1 { return 1 }
    I (a << 4) != 16 { return 2 }
    I (a << 10) != 1024 { return 3 }

    b: i64 := 256
    I (b >> 0) != 256 { return 4 }
    I (b >> 1) != 128 { return 5 }
    I (b >> 8) != 1 { return 6 }

    # arithmetic right shift sign-extends for negatives
    c: i64 := 0 - 16
    I (c >> 1) != 0 - 8 { return 7 }
    I (c >> 4) != 0 - 1 { return 8 }
    return 0
}

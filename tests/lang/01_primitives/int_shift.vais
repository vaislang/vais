# CHECKS: integer shift left/right operate on i64.
F main() -> i64 {
    a: i64 := 1
    I (a << 0) != 1 { R 1 }
    I (a << 4) != 16 { R 2 }
    I (a << 10) != 1024 { R 3 }

    b: i64 := 256
    I (b >> 0) != 256 { R 4 }
    I (b >> 1) != 128 { R 5 }
    I (b >> 8) != 1 { R 6 }

    # arithmetic right shift sign-extends for negatives
    c: i64 := 0 - 16
    I (c >> 1) != 0 - 8 { R 7 }
    I (c >> 4) != 0 - 1 { R 8 }
    R 0
}

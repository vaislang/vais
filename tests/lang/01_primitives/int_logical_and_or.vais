# CHECKS: i64 used as boolean — short-circuit && and ||.
F main() -> i64 {
    a: i64 := 1
    b: i64 := 0
    c: i64 := 1

    # &&
    I a == 1 && c == 1 {} EL { R 1 }
    I a == 1 && b == 1 { R 2 }
    I b == 1 && a == 1 { R 3 }

    # ||
    I a == 1 || b == 1 {} EL { R 4 }
    I b == 1 || c == 1 {} EL { R 5 }
    I b == 1 || b == 1 { R 6 }

    # mixed with !=
    I a != 0 && c != 0 {} EL { R 7 }

    # nested
    I (a == 1 && b == 0) && (c == 1 || a == 0) {} EL { R 8 }
    R 0
}

# CHECKS: i64 used as boolean — short-circuit && and ||.
fn main() -> i64 {
    a: i64 := 1
    b: i64 := 0
    c: i64 := 1

    # &&
    I a == 1 && c == 1 {} else { return 1 }
    I a == 1 && b == 1 { return 2 }
    I b == 1 && a == 1 { return 3 }

    # ||
    I a == 1 || b == 1 {} else { return 4 }
    I b == 1 || c == 1 {} else { return 5 }
    I b == 1 || b == 1 { return 6 }

    # mixed with !=
    I a != 0 && c != 0 {} else { return 7 }

    # nested
    I (a == 1 && b == 0) && (c == 1 || a == 0) {} else { return 8 }
    return 0
}

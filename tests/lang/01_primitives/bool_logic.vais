# CHECKS: bool literals + logical and/or/not
fn main() -> i64 {
    t: bool := true
    f: bool := false
    I t && f { return 1 }       # short-circuit && should be false
    I !(t || f) { return 2 }    # !true == false
    flipped: bool := !t
    I flipped != f { return 3 } # !true == false
    return 0
}

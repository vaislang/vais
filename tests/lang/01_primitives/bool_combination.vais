# CHECKS: combinations of bool ops.
F main() -> i64 {
    # implications via material conditional: A → B = !A || B
    a: bool := true
    b: bool := false
    impl_ab: bool := !a || b
    I (impl_ab as i64) != 0 { R 1 }

    impl_ba: bool := !b || a
    I (impl_ba as i64) != 1 { R 2 }

    # XOR via (a || b) && !(a && b)
    xor_ab: bool := (a || b) && !(a && b)
    I (xor_ab as i64) != 1 { R 3 }
    xor_aa: bool := (a || a) && !(a && a)
    I (xor_aa as i64) != 0 { R 4 }

    R 0
}

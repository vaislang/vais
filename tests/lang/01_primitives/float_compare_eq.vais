# CHECKS: f64 equality and ordering comparisons.
fn main() -> i64 {
    a: f64 := 3.14
    b: f64 := 3.14

    # equal
    I a == b {} else { return 1 }
    # not equal
    I 1.0 == 2.0 { return 2 }

    # less / greater
    I 1.0 < 2.0 {} else { return 3 }
    I 2.0 > 1.0 {} else { return 4 }
    I 1.0 <= 1.0 {} else { return 5 }
    I 1.0 >= 1.0 {} else { return 6 }

    # negative comparisons
    n: f64 := 0.0 - 5.0
    I n < 0.0 {} else { return 7 }
    I n > 0.0 - 10.0 {} else { return 8 }

    return 0
}

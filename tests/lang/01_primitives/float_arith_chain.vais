# CHECKS: chained f64 arithmetic with parentheses.
fn main() -> i64 {
    a: f64 := (1.0 + 2.0) * 3.0
    I (a as i64) != 9 { return 1 }

    b: f64 := 1.0 + 2.0 * 3.0   # 7.0
    I (b as i64) != 7 { return 2 }

    c: f64 := (10.0 - 4.0) / 2.0   # 3.0
    I (c as i64) != 3 { return 3 }

    d: f64 := 10.0 - 4.0 / 2.0   # 8.0
    I (d as i64) != 8 { return 4 }

    e: f64 := ((1.0 + 1.0) * (3.0 + 3.0)) / 2.0   # 6.0
    I (e as i64) != 6 { return 5 }
    return 0
}

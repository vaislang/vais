# CHECKS: i64 → f64 cast preserves value.
F main() -> i64 {
    a: i64 := 5
    fa: f64 := a as f64
    I (fa as i64) != 5 { R 1 }

    b: i64 := 100
    fb: f64 := b as f64
    fc: f64 := fb / 4.0
    # 100.0 / 4.0 = 25.0
    I (fc as i64) != 25 { R 2 }

    # negative cast
    n: i64 := 0 - 42
    fn: f64 := n as f64
    I (fn as i64) != 0 - 42 { R 3 }

    # integer reciprocal patterns
    x: i64 := 10
    inv: f64 := 1.0 / (x as f64)
    # 1/10 = 0.1, * 100 = 10
    res: f64 := inv * 100.0
    I (res as i64) != 10 { R 4 }
    R 0
}

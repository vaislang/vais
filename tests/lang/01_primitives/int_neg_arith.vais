# CHECKS: arithmetic operations on negative i64 values.
fn main() -> i64 {
    a: i64 := 0 - 100
    b: i64 := 0 - 50

    I a + b != 0 - 150 { return 1 }
    I a - b != 0 - 50 { return 2 }
    I a * 2 != 0 - 200 { return 3 }
    I a / 4 != 0 - 25 { return 4 }
    I a * b != 5000 { return 5 }
    I (a + b) * (0 - 1) != 150 { return 6 }
    return 0
}

# XFAIL: Vec<EnumType> instantiation requires transitive generic propagation
# that's not yet implemented. Direct attempt:
#   `v: Vec<Color> := mut vec_new()` — fails because vec_new() returns Vec<i64>
#   `v: Vec<Color> := mut vec_new_t()` — generic vec_new_t<T> spec generates
#     correctly (vec_new_t$Color), but the body calls Vec.with_capacity(8)
#     which is hard-mangled as Vec_with_capacity$i64. Cross-fn-cross-method
#     transitive specialization propagation is needed (vec_new_t<T>'s body
#     in specialized form should call Vec.with_capacity$T, not bare Vec
#     .with_capacity$i64). Tracked as bug C16.
#
# CHECKS: Vec<EnumType> push and iteration.
U std/vec.{vec_new};

EN Color {
    Red,
    Green,
    Blue
}

F color_code(c: Color) -> i64 {
    M c {
        Red => 1,
        Green => 2,
        Blue => 3
    }
}

F main() -> i64 {
    v: Vec<Color> := mut vec_new()
    v.push(Red)
    v.push(Green)
    v.push(Blue)
    v.push(Red)
    I v.len() != 4 { R 1 }

    sum: i64 := mut 0
    LF i: 0..v.len() {
        sum = sum + color_code(v[i])
    }
    I sum != 7 { R 2 }
    R 0
}

# XFAIL: `Vec<Color> := mut vec_new()` fails TC — vec_new() returns Vec<i64>
# default and unifier can't promote to Vec<Color>. Tracked as bug C16.
# Workarounds tried (vec_new_t<T>) all fail due to zero-arg generic resolution
# at user-code call sites (the C17 fix only helps inside specialized bodies).
#
# CHECKS: Vec<EnumType> push and iteration.
U std/vec.{vec_new};

EN Color {
    Red,
    Green,
    Blue
}

F color_code(c: Color) -> i64 {
    M c {
        Red => 1,
        Green => 2,
        Blue => 3
    }
}

F main() -> i64 {
    v: Vec<Color> := mut vec_new()
    v.push(Red)
    v.push(Green)
    v.push(Blue)
    v.push(Red)
    I v.len() != 4 { R 1 }

    sum: i64 := mut 0
    LF i: 0..v.len() {
        sum = sum + color_code(v[i])
    }
    I sum != 7 { R 2 }
    R 0
}

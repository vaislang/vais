# CHECKS: Vec<EnumType> push and iteration (REGRESSION C16).
U std/vec.{vec_new_t};

EN Color {
    Red,
    Green,
    Blue
}

F color_code(c: Color) -> i64 {
    M c {
        Red => 1,
        Green => 2,
        Blue => 3
    }
}

F main() -> i64 {
    v: Vec<Color> := mut vec_new_t()
    v.push(Red)
    v.push(Green)
    v.push(Blue)
    v.push(Red)
    I v.len() != 4 { R 1 }

    sum: i64 := mut 0
    LF i: 0..v.len() {
        sum = sum + color_code(v[i])
    }
    I sum != 7 { R 2 }
    R 0
}

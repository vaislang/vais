# CHECKS: user enum with i64 payload variants.
enum Shape {
    Square(i64),
    Circle(i64),
    Rect(i64, i64)
}

fn area(s: Shape) -> i64 {
    match s {
        Square(side) => side * side,
        Circle(r) => r * r * 3,   # approximate (no float for now)
        Rect(w, h) => w * h
    }
}

fn main() -> i64 {
    I area(Square(5)) != 25 { return 1 }
    I area(Square(0)) != 0 { return 2 }
    I area(Circle(10)) != 300 { return 3 }
    I area(Rect(3, 4)) != 12 { return 4 }
    I area(Rect(7, 8)) != 56 { return 5 }
    return 0
}

# CHECKS: user-defined enum with 3 variants, exhaustive match.
EN Direction {
    North,
    South,
    East,
    West
}

F bearing(d: Direction) -> i64 {
    M d {
        North => 0,
        East => 90,
        South => 180,
        West => 270
    }
}

F main() -> i64 {
    I bearing(Direction::North) != 0 { R 1 }
    I bearing(Direction::East) != 90 { R 2 }
    I bearing(Direction::South) != 180 { R 3 }
    I bearing(Direction::West) != 270 { R 4 }
    R 0
}

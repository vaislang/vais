# CHECKS: Option<i64> Some(v)/None destructuring across multiple branches.
F head_or_zero(v: Option<i64>) -> i64 {
    M v {
        Some(x) => x,
        None    => 0
    }
}

F main() -> i64 {
    a: i64 := head_or_zero(Some(42))
    I a != 42 { R 1 }

    b: i64 := head_or_zero(None)
    I b != 0 { R 2 }

    c: i64 := head_or_zero(Some(0 - 7))
    I c != 0 - 7 { R 3 }
    R 0
}

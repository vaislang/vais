# CHECKS: Result<i64, i64> Ok/Err match
F divide(a: i64, b: i64) -> Result<i64, i64> {
    I b == 0 { R Err(0) }
    Ok(a / b)
}

F main() -> i64 {
    r1: Result<i64, i64> := divide(10, 2)
    v1: i64 := M r1 {
        Ok(v) => v,
        Err(_) => -1,
    }
    I v1 != 5 { R 1 }

    r2: Result<i64, i64> := divide(10, 0)
    v2: i64 := M r2 {
        Ok(v) => v,
        Err(_) => -1,
    }
    I v2 != -1 { R 2 }

    R 0
}

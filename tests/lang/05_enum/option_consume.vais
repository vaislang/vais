# CHECKS: Option<T> consume by match — branches both match.
fn describe(o: Option<i64>) -> i64 {
    match o {
        Some(v) I v < 0 => 1,
        Some(v) I v == 0 => 2,
        Some(_) => 3,
        None => 4
    }
}

fn main() -> i64 {
    I describe(Some(0 - 5)) != 1 { return 1 }
    I describe(Some(0)) != 2 { return 2 }
    I describe(Some(42)) != 3 { return 3 }
    I describe(None) != 4 { return 4 }
    return 0
}

# CHECKS: Result<T, E> via match for the unwrap_or pattern.
fn safe_parse(s: str) -> Result<i64, i64> {
    match s {
        "1"  => Ok(1),
        "2"  => Ok(2),
        "10" => Ok(10),
        "42" => Ok(42),
        _    => Err(0 - 1)
    }
}

fn unwrap_or(r: Result<i64, i64>, default: i64) -> i64 {
    match r {
        Ok(v)  => v,
        Err(_) => default
    }
}

fn main() -> i64 {
    I unwrap_or(safe_parse("1"), 0) != 1 { return 1 }
    I unwrap_or(safe_parse("42"), 0) != 42 { return 2 }
    I unwrap_or(safe_parse("xyz"), 99) != 99 { return 3 }
    I unwrap_or(safe_parse(""), 7) != 7 { return 4 }
    return 0
}

# CHECKS: enum where some variants take payloads, others don't.
EN Token {
    Eof,
    Num(i64),
    Plus,
    Minus
}

F to_value(t: Token) -> i64 {
    M t {
        Eof => 0,
        Num(n) => n,
        Plus => 100,
        Minus => 200
    }
}

F main() -> i64 {
    I to_value(Eof) != 0 { R 1 }
    I to_value(Num(42)) != 42 { R 2 }
    I to_value(Num(0 - 5)) != 0 - 5 { R 3 }
    I to_value(Plus) != 100 { R 4 }
    I to_value(Minus) != 200 { R 5 }
    R 0
}

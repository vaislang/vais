# CHECKS: enum match with `_` default that catches multiple variants.
EN Status {
    Active,
    Pending,
    Done,
    Cancelled,
    Archived
}

F priority(s: Status) -> i64 {
    M s {
        Active => 10,
        Pending => 5,
        _ => 0
    }
}

F main() -> i64 {
    I priority(Active) != 10 { R 1 }
    I priority(Pending) != 5 { R 2 }
    I priority(Done) != 0 { R 3 }
    I priority(Cancelled) != 0 { R 4 }
    I priority(Archived) != 0 { R 5 }
    R 0
}

# CHECKS: classic min-finding pattern using LF + state via Vec.
use std/vec.{vec_new};

fn main() -> i64 {
    v: Vec<i64> := mut vec_new()
    v.push(5)
    v.push(3)
    v.push(8)
    v.push(1)
    v.push(4)
    v.push(2)

    best: i64 := mut v[0]
    best_idx: i64 := mut 0
    LF i: 1..v.len() {
        I v[i] < best {
            best = v[i]
            best_idx = i
        }
    }
    I best_idx != 3 { return 1 }
    I best != 1 { return 2 }
    return 0
}

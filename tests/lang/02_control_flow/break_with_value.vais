# CHECKS: B <value> (break-with-value) propagates the value via the loop's
# expression value correctly. Bug C1 was that the codegen emitted the slot
# alloca at the break site instead of the function entry block, so the
# subsequent load at loop end didn't dominate. Fixed by hoisting the alloca
# in inkwell/gen_stmt.rs::generate_break (and the IR-string fallback in
# generate_expr/loops.rs).
fn first_match(target: i64) -> i64 {
    i := mut 0
    L {
        I i >= 10 { B 0 - 1 }
        I i == target { B i }
        i = i + 1
    }
}

fn main() -> i64 {
    # found at index 5
    a: i64 := first_match(5)
    I a != 5 { return 1 }

    # found at index 0
    b: i64 := first_match(0)
    I b != 0 { return 2 }

    # not found → -1
    c: i64 := first_match(99)
    I c != 0 - 1 { return 3 }

    return 0
}

# CHECKS: running total of squares.
fn main() -> i64 {
    sum: i64 := mut 0
    sum_of_sums: i64 := mut 0
    LF i: 1..=5 {
        sum = sum + i * i
        sum_of_sums = sum_of_sums + sum
    }
    # sum after each iter: 1, 5, 14, 30, 55
    # sum_of_sums = 1+5+14+30+55 = 105
    I sum != 55 { return 1 }
    I sum_of_sums != 105 { return 2 }
    return 0
}

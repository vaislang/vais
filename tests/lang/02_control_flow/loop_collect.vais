# CHECKS: while loop with B (break) collecting values
fn find_first_multiple(n: i64, m: i64) -> i64 {
    i: i64 := mut 1
    LW true {
        I i % m == 0 && i > n { return i }
        I i > 1000 { B }
        i = i + 1
    }
    -1
}

fn main() -> i64 {
    I find_first_multiple(10, 7) != 14 { return 1 }
    I find_first_multiple(0, 3)  != 3  { return 2 }
    return 0
}

# CHECKS: nested if-else with multiple branches
F classify(n: i64) -> i64 {
    I n < 0 {
        R -1
    } EL {
        I n == 0 {
            R 0
        } EL {
            I n < 10 {
                R 1
            } EL {
                R 2
            }
        }
    }
}

F main() -> i64 {
    I classify(-5) != -1 { R 1 }
    I classify(0)  != 0  { R 2 }
    I classify(5)  != 1  { R 3 }
    I classify(20) != 2  { R 4 }
    R 0
}

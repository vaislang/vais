# CHECKS: C (continue) skips body in LW loop
# Vais uses single-char keyword: C = continue.
fn main() -> i64 {
    i: i64 := mut 0
    sum: i64 := mut 0
    LW i < 10 {
        i = i + 1
        I i % 2 == 0 { C }
        sum = sum + i
    }
    # odd from 1..=9: 1+3+5+7+9 = 25
    I sum != 25 { return 1 }
    return 0
}

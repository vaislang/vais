# CHECKS: long if-elseif chain.
F grade(n: i64) -> i64 {
    I n >= 90 { R 5 }
    EL I n >= 80 { R 4 }
    EL I n >= 70 { R 3 }
    EL I n >= 60 { R 2 }
    EL { R 1 }
}

F main() -> i64 {
    I grade(95) != 5 { R 1 }
    I grade(85) != 4 { R 2 }
    I grade(75) != 3 { R 3 }
    I grade(65) != 2 { R 4 }
    I grade(40) != 1 { R 5 }
    I grade(0) != 1 { R 6 }
    I grade(100) != 5 { R 7 }
    I grade(60) != 2 { R 8 }
    I grade(59) != 1 { R 9 }
    R 0
}

# CHECKS: `R <value>` from inside a loop body terminates the entire function.
F find_or_return(target: i64, max: i64) -> i64 {
    LF i: 0..max {
        I i == target { R i * 10 }
    }
    0 - 1
}

F main() -> i64 {
    a: i64 := find_or_return(5, 100)
    I a != 50 { R 1 }

    b: i64 := find_or_return(0, 10)
    I b != 0 { R 2 }

    c: i64 := find_or_return(99, 100)
    I c != 990 { R 3 }

    d: i64 := find_or_return(200, 10)
    I d != 0 - 1 { R 4 }
    R 0
}

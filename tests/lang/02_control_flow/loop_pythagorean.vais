# CHECKS: count Pythagorean triples a²+b²=c² with a,b,c <= n.
fn count_triples(limit: i64) -> i64 {
    count: i64 := mut 0
    LF a: 1..=limit {
        LF b: a..=limit {
            csq: i64 := a * a + b * b
            LF c: b..=limit {
                I c * c == csq { count = count + 1 }
            }
        }
    }
    count
}

fn main() -> i64 {
    # triples up to 20: (3,4,5),(5,12,13),(6,8,10),(8,15,17),(9,12,15),(12,16,20) → 6
    I count_triples(20) != 6 { return 1 }
    # up to 5: (3,4,5) only → 1
    I count_triples(5) != 1 { return 2 }
    # up to 4: none
    I count_triples(4) != 0 { return 3 }
    return 0
}

# CHECKS: early return from deeply nested control flow.
fn process(n: i64) -> i64 {
    I n < 0 { return 0 - 1 }
    I n == 0 { return 0 }

    LF i: 1..=10 {
        I i * i > n {
            I i == 1 { return 1 }
            return i - 1
        }
    }
    10
}

fn main() -> i64 {
    I process(0 - 5) != 0 - 1 { return 1 }
    I process(0) != 0 { return 2 }
    I process(1) != 1 { return 3 }
    I process(8) != 2 { return 4 }    # 3² = 9 > 8 → 2
    I process(15) != 3 { return 5 }   # 4² = 16 > 15 → 3
    I process(99) != 9 { return 6 }   # 10² = 100 > 99 → 9
    I process(100) != 10 { return 7 } # never exits early; loop completes
    return 0
}

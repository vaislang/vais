# XFAIL: `:= <int>` immutable bindings reassigned via `=` silently miscompile.
# Currently the compiler emits the binding as SSA (no alloca), then the later
# `i = i + 1` reads i as constant 0 every iteration. Should be a TC error
# (cannot mutate immutable binding). Tracked as bug C2 in STATUS.md.
#
# CHECKS: a SSA-aliased immutable binding cannot be reassigned (TC must reject).
# When this lands as PASS, the test should compile-fail (i.e., the runner needs
# to recognize compile-time TC errors as expected for negative tests). For now,
# the test is XFAIL because the compiler ACCEPTS the program but lowers it wrong.
F sum_to_n(n: i64) -> i64 {
    sum: i64 := 0           # Note: missing `mut`
    i: i64 := 0
    L {
        I i >= n { B sum }
        sum = sum + i       # Should be a TC error
        i = i + 1           # Should be a TC error
    }
}

F main() -> i64 {
    # If the compiler correctly rejected the function above, this would not link.
    # If it accepts but miscompiles, the loop is infinite or returns 0.
    # Either way, this test currently doesn't exit 0 — it's XFAIL.
    R sum_to_n(5) - 10  # 0+1+2+3+4 = 10 → expect 0
}

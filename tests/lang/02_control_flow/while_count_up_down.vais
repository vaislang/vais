# CHECKS: while loop with both increment and decrement of separate vars.
F main() -> i64 {
    a: i64 := mut 0
    b: i64 := mut 100
    LW a < b {
        a = a + 1
        b = b - 1
    }
    # converge at 50
    I a != 50 { R 1 }
    I b != 50 { R 2 }

    # asymmetric
    x: i64 := mut 0
    y: i64 := mut 100
    LW x < y {
        x = x + 3
        y = y - 7
    }
    # x: 0,3,6,9,12... y: 100,93,86,79,72,65,58,51,44... when x>=y stop
    # Iter: x=0,y=100; x=3,y=93; x=6,y=86; x=9,y=79; x=12,y=72; x=15,y=65;
    #       x=18,y=58; x=21,y=51; x=24,y=44 → x<y stops? 24<44 yes continue
    #       x=27,y=37; x=30,y=30 → still less; continue
    #       x=33,y=23 → x>=y, exit
    I x < y { R 3 }
    R 0
}

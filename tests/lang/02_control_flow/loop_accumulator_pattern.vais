# CHECKS: accumulator pattern with multiple state variables.
F main() -> i64 {
    n: i64 := mut 0
    sum: i64 := mut 0
    sum_sq: i64 := mut 0
    LF i: 1..=10 {
        n = n + 1
        sum = sum + i
        sum_sq = sum_sq + (i * i)
    }
    I n != 10 { R 1 }
    I sum != 55 { R 2 }
    I sum_sq != 385 { R 3 }   # 1+4+9+16+25+36+49+64+81+100

    # mean = 5 (integer)
    I sum / n != 5 { R 4 }
    R 0
}

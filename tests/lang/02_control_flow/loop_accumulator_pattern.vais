# CHECKS: accumulator pattern with multiple state variables.
fn main() -> i64 {
    n: i64 := mut 0
    sum: i64 := mut 0
    sum_sq: i64 := mut 0
    LF i: 1..=10 {
        n = n + 1
        sum = sum + i
        sum_sq = sum_sq + (i * i)
    }
    I n != 10 { return 1 }
    I sum != 55 { return 2 }
    I sum_sq != 385 { return 3 }   # 1+4+9+16+25+36+49+64+81+100

    # mean = 5 (integer)
    I sum / n != 5 { return 4 }
    return 0
}

# CHECKS: break inside an inner loop terminates only the inner loop.
fn main() -> i64 {
    sum: i64 := mut 0
    LF i: 0..5 {
        LF j: 0..10 {
            I j >= 3 { B }
            sum = sum + 1
        }
    }
    # Each outer iteration: inner runs j=0,1,2 → 3 iters
    # Total: 5 * 3 = 15
    I sum != 15 { return 1 }
    return 0
}

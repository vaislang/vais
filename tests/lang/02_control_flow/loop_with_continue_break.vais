# CHECKS: loop with both continue and break in different branches.
F main() -> i64 {
    sum: i64 := mut 0
    LF i: 0..100 {
        I i >= 20 { B }      # stop after 20 iterations
        I (i & 1) == 0 { C }  # skip even
        sum = sum + i         # add odd values 1..19
    }
    # 1+3+5+...+19 = 100
    I sum != 100 { R 1 }
    R 0
}

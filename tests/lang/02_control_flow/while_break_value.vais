# CHECKS: B <value> from inside a `LW cond` (conditional while) loop.
# Companion to break_with_value.vais (which uses `L`).
fn find_in_range(target: i64) -> i64 {
    i: i64 := mut 0
    L {
        I i >= 100 { B 0 - 1 }
        I i == target { B i }
        i = i + 1
    }
}

fn main() -> i64 {
    a: i64 := find_in_range(7)
    I a != 7 { return 1 }
    b: i64 := find_in_range(99)
    I b != 99 { return 2 }
    c: i64 := find_in_range(200)
    I c != 0 - 1 { return 3 }
    return 0
}

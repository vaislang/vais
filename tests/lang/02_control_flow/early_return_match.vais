# CHECKS: early `R` from inside a match arm body.
F categorize(n: i64) -> i64 {
    M n {
        0 => { R 100 },
        1 => { R 200 },
        2 => { R 300 },
        _ => 0
    }
    # unreachable for matched values; reached only for default
    999
}

F main() -> i64 {
    I categorize(0) != 100 { R 1 }
    I categorize(1) != 200 { R 2 }
    I categorize(2) != 300 { R 3 }
    # default falls through
    I categorize(99) != 999 { R 4 }
    R 0
}

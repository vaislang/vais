# CHECKS: two generic helper fns chaining via i64 (REGRESSION for bug C17).
fn double<T>(x: T) -> T {
    add_self(x)
}

fn add_self<T>(x: T) -> T {
    x   # placeholder — without operator overloading, just return x
}

fn main() -> i64 {
    I double(5) != 5 { return 1 }
    I double(0) != 0 { return 2 }
    I double(0 - 7) != 0 - 7 { return 3 }
    return 0
}

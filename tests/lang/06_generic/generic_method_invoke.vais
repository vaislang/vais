# CHECKS: invoke generic struct method (REGRESSION C17).
S Cell<T> {
    value: T
}

X Cell<T> {
    F new(v: T) -> Cell<T> { Cell { value: v } }
    F get(&self) -> T { self.value }
    F set(&self, v: T) { self.value = v }
}

F main() -> i64 {
    c: Cell<i64> := mut Cell.new(42)
    I c.get() != 42 { R 1 }

    c.set(100)
    I c.get() != 100 { R 2 }

    c.set(0 - 5)
    I c.get() != 0 - 5 { R 3 }
    R 0
}

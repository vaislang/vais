# CHECKS: generic fn invoked from 3 different non-generic call sites.
F id<T>(x: T) -> T { x }

F caller_a() -> i64 { id(100) + 1 }
F caller_b() -> i64 { id(200) + 2 }
F caller_c() -> i64 { id(300) + 3 }

F main() -> i64 {
    I caller_a() != 101 { R 1 }
    I caller_b() != 202 { R 2 }
    I caller_c() != 303 { R 3 }
    I caller_a() + caller_b() + caller_c() != 606 { R 4 }
    R 0
}

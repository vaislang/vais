# CHECKS: generic function with two type parameters where both are inferred.
F first<A, B>(a: A, b: B) -> A {
    a
}

F second<A, B>(a: A, b: B) -> B {
    b
}

F main() -> i64 {
    a: i64 := first(42, 99)
    I a != 42 { R 1 }
    b: i64 := second(42, 99)
    I b != 99 { R 2 }

    # Reuse with different concrete types
    c: i64 := first(0 - 1, 1)
    I c != 0 - 1 { R 3 }
    R 0
}

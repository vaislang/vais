# XFAIL: generic `unwrap_or<T>(o: Option<T>, default: T) -> T` triggers
# codegen ICE — `load {}, ptr %default` (Unit type load) appears, suggesting
# the second generic parameter `default` got erased to () somewhere in the
# specialization pipeline. Tracked as Phase 0 finding C14.
#
# CHECKS: generic identity-style fn used in multiple contexts.
F unwrap_or<T>(o: Option<T>, default: T) -> T {
    M o {
        Some(v) => v,
        None    => default
    }
}

F main() -> i64 {
    a: i64 := unwrap_or(Some(42), 0)
    I a != 42 { R 1 }

    b: i64 := unwrap_or(None, 99)
    I b != 99 { R 2 }

    # nested call
    c: i64 := unwrap_or(Some(unwrap_or(Some(7), 0)), 0)
    I c != 7 { R 3 }
    R 0
}

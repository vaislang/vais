# CHECKS: generic struct with two type parameters
struct Pair<A, B> {
    first: A,
    second: B,
}

impl Pair<A, B> {
    fn new(a: A, b: B) -> Pair<A, B> {
        Pair { first: a, second: b }
    }
}

fn main() -> i64 {
    p: Pair<i64, i64> := Pair.new(3, 4)
    I p.first != 3  { return 1 }
    I p.second != 4 { return 2 }
    return 0
}

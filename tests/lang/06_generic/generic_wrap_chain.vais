# CHECKS: chain of generic Wrap<T> through helpers (REGRESSION C17 stress).
struct Wrap<T> {
    val: T
}

impl Wrap<T> {
    fn new(v: T) -> Wrap<T> { Wrap { val: v } }
    fn get(&self) -> T { self.val }
}

fn unwrap_then_double<T>(w: Wrap<T>) -> T {
    w.get()
}

fn main() -> i64 {
    w: Wrap<i64> := Wrap.new(42)
    I unwrap_then_double(w) != 42 { return 1 }

    w2: Wrap<i64> := Wrap.new(0 - 5)
    I unwrap_then_double(w2) != 0 - 5 { return 2 }

    # nested unwrap
    w3: Wrap<i64> := Wrap.new(unwrap_then_double(Wrap.new(99)))
    I w3.get() != 99 { return 3 }
    return 0
}

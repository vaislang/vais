# CHECKS: simple generic Container<T> with set/get patterns.
struct Container<T> {
    items: T,
    count: i64
}

impl Container<T> {
    fn new(initial: T) -> Container<T> {
        Container { items: initial, count: 0 }
    }
    fn count(&self) -> i64 { self.count }
    fn bump(&self) {
        self.count = self.count + 1
    }
}

fn main() -> i64 {
    c: Container<i64> := mut Container.new(0)
    I c.count() != 0 { return 1 }

    c.bump()
    c.bump()
    c.bump()
    I c.count() != 3 { return 2 }

    LF i: 0..10 {
        c.bump()
    }
    I c.count() != 13 { return 3 }
    return 0
}

# CHECKS: generic function with multiple call sites that resolve to same i64.
fn max3<T>(a: T, b: T, c: T) -> T {
    I a > b && a > c { return a }
    I b > c { return b }
    c
}

fn main() -> i64 {
    I max3(1, 2, 3) != 3 { return 1 }
    I max3(10, 5, 7) != 10 { return 2 }
    I max3(0 - 1, 0 - 5, 0 - 3) != 0 - 1 { return 3 }
    I max3(0, 0, 0) != 0 { return 4 }
    I max3(5, 5, 4) != 5 { return 5 }
    return 0
}

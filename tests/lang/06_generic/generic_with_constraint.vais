# CHECKS: generic function with multiple call sites that resolve to same i64.
F max3<T>(a: T, b: T, c: T) -> T {
    I a > b && a > c { R a }
    I b > c { R b }
    c
}

F main() -> i64 {
    I max3(1, 2, 3) != 3 { R 1 }
    I max3(10, 5, 7) != 10 { R 2 }
    I max3(0 - 1, 0 - 5, 0 - 3) != 0 - 1 { R 3 }
    I max3(0, 0, 0) != 0 { R 4 }
    I max3(5, 5, 4) != 5 { R 5 }
    R 0
}

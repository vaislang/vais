# CHECKS: generic struct method that uses T internally.
S Wrap<T> {
    inner: T
}

X Wrap<T> {
    F new(v: T) -> Wrap<T> {
        Wrap { inner: v }
    }
    F get(&self) -> T {
        self.inner
    }
}

F main() -> i64 {
    w: Wrap<i64> := Wrap.new(42)
    I w.get() != 42 { R 1 }

    w2: Wrap<i64> := Wrap.new(0 - 7)
    I w2.get() != 0 - 7 { R 2 }

    w3: Wrap<i64> := Wrap { inner: 100 }
    I w3.get() != 100 { R 3 }
    R 0
}

# CHECKS: pyramid of generic-fn instantiations (REGRESSION for bug C17).
fn id<T>(x: T) -> T { x }
fn twice<T>(x: T) -> T { id(id(x)) }
fn triple<T>(x: T) -> T { id(twice(x)) }

fn main() -> i64 {
    I id(1) != 1 { return 1 }
    I twice(2) != 2 { return 2 }
    I triple(3) != 3 { return 3 }
    I triple(triple(triple(7))) != 7 { return 4 }
    return 0
}

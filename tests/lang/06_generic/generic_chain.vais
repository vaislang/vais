# CHECKS: generic fn calling another generic fn (REGRESSION for bug C17).
fn identity<T>(x: T) -> T {
    x
}

fn double_it<T>(x: T) -> T {
    identity(x)   # generic call inside generic
}

fn main() -> i64 {
    a: i64 := identity(42)
    I a != 42 { return 1 }
    b: i64 := double_it(7)
    I b != 7 { return 2 }
    c: i64 := identity(identity(identity(99)))
    I c != 99 { return 3 }
    return 0
}

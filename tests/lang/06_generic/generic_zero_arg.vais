# CHECKS: generic with all T determined from first arg.
fn first_or_self<T>(opt: Option<T>, default: T) -> T {
    match opt {
        Some(v) => v,
        None => default
    }
}

fn main() -> i64 {
    a: Option<i64> := Some(42)
    I first_or_self(a, 0) != 42 { return 1 }

    b: Option<i64> := None
    I first_or_self(b, 99) != 99 { return 2 }
    return 0
}

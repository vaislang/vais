# CHECKS: generic fn invoked with same T from two different paths.
F id<T>(x: T) -> T { x }

F apply_id_twice(x: i64) -> i64 {
    a: i64 := id(x)
    b: i64 := id(a + 1)
    b
}

F main() -> i64 {
    I apply_id_twice(0) != 1 { R 1 }
    I apply_id_twice(5) != 6 { R 2 }
    I apply_id_twice(0 - 10) != 0 - 9 { R 3 }
    R 0
}

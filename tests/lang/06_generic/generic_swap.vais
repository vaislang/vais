# CHECKS: generic struct with two type params + method swapping fields
struct Pair<A, B> {
    first: A,
    second: B,
}

impl Pair<A, B> {
    fn new(a: A, b: B) -> Pair<A, B> {
        Pair { first: a, second: b }
    }
}

fn main() -> i64 {
    p: Pair<i64, i64> := Pair.new(7, 11)
    I p.first != 7   { return 1 }
    I p.second != 11 { return 2 }
    sum: i64 := p.first + p.second
    I sum != 18 { return 3 }
    return 0
}

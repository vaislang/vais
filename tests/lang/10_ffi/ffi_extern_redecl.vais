# CHECKS: extern declaration of a function whose name overlaps with a
# libm/runtime intrinsic resolves to the existing declaration instead
# of being renamed to `<name>.1` (REGRESSION C12).
X F sqrt(x: f64) -> f64
X F cos(x: f64) -> f64

F main() -> i64 {
    r: f64 := sqrt(25.0)
    I r < 4.999 || r > 5.001 { R 1 }
    c: f64 := cos(0.0)
    I c < 0.999 || c > 1.001 { R 2 }
    R 0
}

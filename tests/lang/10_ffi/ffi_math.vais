# CHECKS: builtin math functions (sqrt, fabs) — these are pre-declared by
# the compiler so user code can call them without an explicit `X F` decl.
fn main() -> i64 {
    # sqrt(25.0) = 5.0
    I (sqrt(25.0) as i64) != 5 { return 1 }
    I (sqrt(100.0) as i64) != 10 { return 2 }
    I (sqrt(0.0) as i64) != 0 { return 3 }

    # fabs(-3.5) = 3.5 → as i64 = 3
    I (fabs(0.0 - 3.5) as i64) != 3 { return 4 }
    I (fabs(7.2) as i64) != 7 { return 5 }
    I (fabs(0.0) as i64) != 0 { return 6 }
    return 0
}

# CHECKS: iterate over a str's bytes via load_byte.
fn count_letter(p: i64, len: i64, target: i64) -> i64 {
    count: i64 := mut 0
    LF i: 0..len {
        I load_byte(p + i) == target { count = count + 1 }
    }
    count
}

fn main() -> i64 {
    p: i64 := str_to_ptr("hello world")
    n: i64 := strlen(p)
    # 'l' = 108, three times in "hello world"
    I count_letter(p, n, 108) != 3 { return 1 }
    # 'o' = 111, twice
    I count_letter(p, n, 111) != 2 { return 2 }
    # ' ' = 32, once
    I count_letter(p, n, 32) != 1 { return 3 }
    # 'z' = 122, never
    I count_letter(p, n, 122) != 0 { return 4 }

    # empty string
    p2: i64 := str_to_ptr("")
    I count_letter(p2, strlen(p2), 65) != 0 { return 5 }
    return 0
}

# CHECKS: lexicographic string comparison via byte-by-byte.
fn str_cmp(a: i64, an: i64, b: i64, bn: i64) -> i64 {
    min: i64 := mut an
    I bn < min { min = bn }
    LF i: 0..min {
        ca: i64 := load_byte(a + i)
        cb: i64 := load_byte(b + i)
        I ca < cb { return 0 - 1 }
        I ca > cb { return 1 }
    }
    I an < bn { return 0 - 1 }
    I an > bn { return 1 }
    0
}

fn main() -> i64 {
    a: i64 := str_to_ptr("apple")
    an: i64 := strlen(a)
    b: i64 := str_to_ptr("banana")
    bn: i64 := strlen(b)
    I str_cmp(a, an, b, bn) != 0 - 1 { return 1 }
    I str_cmp(b, bn, a, an) != 1 { return 2 }

    c: i64 := str_to_ptr("apple")
    cn: i64 := strlen(c)
    I str_cmp(a, an, c, cn) != 0 { return 3 }

    # prefix
    d: i64 := str_to_ptr("app")
    dn: i64 := strlen(d)
    I str_cmp(d, dn, a, an) != 0 - 1 { return 4 }
    I str_cmp(a, an, d, dn) != 1 { return 5 }
    return 0
}

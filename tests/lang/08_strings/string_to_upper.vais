# CHECKS: detect uppercase letters in a str via byte iteration.
fn count_upper(p: i64, n: i64) -> i64 {
    count: i64 := mut 0
    LF i: 0..n {
        c: i64 := load_byte(p + i)
        I c >= 65 && c <= 90 { count = count + 1 }
    }
    count
}

fn main() -> i64 {
    p1: i64 := str_to_ptr("HELLO")
    I count_upper(p1, strlen(p1)) != 5 { return 1 }

    p2: i64 := str_to_ptr("hello")
    I count_upper(p2, strlen(p2)) != 0 { return 2 }

    p3: i64 := str_to_ptr("HelloWorld")
    I count_upper(p3, strlen(p3)) != 2 { return 3 }

    p4: i64 := str_to_ptr("ABCdef123")
    I count_upper(p4, strlen(p4)) != 3 { return 4 }
    return 0
}

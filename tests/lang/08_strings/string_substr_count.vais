# CHECKS: count occurrences of a 1-char substring in a string.
F count_char(p: i64, n: i64, c: i64) -> i64 {
    count: i64 := mut 0
    LF i: 0..n {
        I load_byte(p + i) == c { count = count + 1 }
    }
    count
}

F main() -> i64 {
    p1: i64 := str_to_ptr("mississippi")
    n1: i64 := strlen(p1)
    # 'i' = 105, 4 occurrences
    I count_char(p1, n1, 105) != 4 { R 1 }
    # 's' = 115, 4 occurrences
    I count_char(p1, n1, 115) != 4 { R 2 }
    # 'p' = 112, 2 occurrences
    I count_char(p1, n1, 112) != 2 { R 3 }
    # 'm' = 109, 1 occurrence
    I count_char(p1, n1, 109) != 1 { R 4 }
    # 'z' = 122, 0 occurrences
    I count_char(p1, n1, 122) != 0 { R 5 }
    R 0
}

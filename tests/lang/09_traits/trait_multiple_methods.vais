# CHECKS: trait with multiple methods, all explicitly impl'd.
W Shape {
    F area(&self) -> i64
    F perimeter(&self) -> i64
}

S Square { side: i64 }
S Rect { w: i64, h: i64 }

X Square: Shape {
    F area(&self) -> i64 { self.side * self.side }
    F perimeter(&self) -> i64 { self.side * 4 }
}

X Rect: Shape {
    F area(&self) -> i64 { self.w * self.h }
    F perimeter(&self) -> i64 { (self.w + self.h) * 2 }
}

F main() -> i64 {
    s: Square := Square { side: 5 }
    I s.area() != 25 { R 1 }
    I s.perimeter() != 20 { R 2 }

    r: Rect := Rect { w: 3, h: 4 }
    I r.area() != 12 { R 3 }
    I r.perimeter() != 14 { R 4 }
    R 0
}

# CHECKS: trait with multiple methods, all explicitly impl'd.
trait Shape {
    fn area(&self) -> i64
    fn perimeter(&self) -> i64
}

struct Square { side: i64 }
struct Rect { w: i64, h: i64 }

impl Square: Shape {
    fn area(&self) -> i64 { self.side * self.side }
    fn perimeter(&self) -> i64 { self.side * 4 }
}

impl Rect: Shape {
    fn area(&self) -> i64 { self.w * self.h }
    fn perimeter(&self) -> i64 { (self.w + self.h) * 2 }
}

fn main() -> i64 {
    s: Square := Square { side: 5 }
    I s.area() != 25 { return 1 }
    I s.perimeter() != 20 { return 2 }

    r: Rect := Rect { w: 3, h: 4 }
    I r.area() != 12 { return 3 }
    I r.perimeter() != 14 { return 4 }
    return 0
}

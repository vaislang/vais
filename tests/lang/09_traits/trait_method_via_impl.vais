# CHECKS: calling a trait method via the concrete type's impl (no dyn).
trait Compute {
    fn compute(&self, x: i64) -> i64
}

struct Adder { offset: i64 }
struct Multiplier { factor: i64 }

impl Adder: Compute {
    fn compute(&self, x: i64) -> i64 { x + self.offset }
}

impl Multiplier: Compute {
    fn compute(&self, x: i64) -> i64 { x * self.factor }
}

fn main() -> i64 {
    a: Adder := Adder { offset: 10 }
    m: Multiplier := Multiplier { factor: 3 }

    I a.compute(5) != 15 { return 1 }
    I m.compute(5) != 15 { return 2 }
    I a.compute(0) != 10 { return 3 }
    I m.compute(0) != 0 { return 4 }
    return 0
}

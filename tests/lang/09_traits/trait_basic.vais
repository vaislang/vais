# CHECKS: trait definition + impl + dispatch via concrete type.
trait Greeter {
    fn greet(&self) -> i64
}

struct English { id: i64 }
struct Korean { id: i64 }

impl English: Greeter {
    fn greet(&self) -> i64 { 1 }
}

impl Korean: Greeter {
    fn greet(&self) -> i64 { 2 }
}

fn main() -> i64 {
    e: English := English { id: 100 }
    k: Korean := Korean { id: 200 }
    I e.greet() != 1 { return 1 }
    I k.greet() != 2 { return 2 }
    return 0
}

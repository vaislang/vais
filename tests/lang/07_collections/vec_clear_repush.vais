# CHECKS: Vec push, read len, push more, read updated len.
U std/vec.{vec_new};

F main() -> i64 {
    v: Vec<i64> := mut vec_new()
    I v.len() != 0 { R 1 }

    LF i: 0..5 {
        v.push(i)
    }
    I v.len() != 5 { R 2 }

    # push another batch
    LF i: 100..105 {
        v.push(i)
    }
    I v.len() != 10 { R 3 }

    # spot-check
    I v[0] != 0 { R 4 }
    I v[4] != 4 { R 5 }
    I v[5] != 100 { R 6 }
    I v[9] != 104 { R 7 }
    R 0
}

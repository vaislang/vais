# CHECKS: count Vec elements above a threshold.
use std/vec.{vec_new};

fn count_above(v: &Vec<i64>, threshold: i64) -> i64 {
    count: i64 := mut 0
    LF i: 0..v.len() {
        I v[i] > threshold { count = count + 1 }
    }
    count
}

fn main() -> i64 {
    v: Vec<i64> := mut vec_new()
    LF i: 1..=20 {
        v.push(i)
    }
    # > 10 → 11..20 = 10 elements
    I count_above(&v, 10) != 10 { return 1 }
    # > 0 → all 20
    I count_above(&v, 0) != 20 { return 2 }
    # > 20 → 0
    I count_above(&v, 20) != 0 { return 3 }
    # > 19 → just 20
    I count_above(&v, 19) != 1 { return 4 }
    return 0
}

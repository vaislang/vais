# CHECKS: Vec mutated via index — double each element.
use std/vec.{vec_new};

fn main() -> i64 {
    v: Vec<i64> := mut vec_new()
    LF i: 1..=8 {
        v.push(i)
    }

    # double in place
    LF i: 0..v.len() {
        v[i] = v[i] * 2
    }

    I v[0] != 2 { return 1 }
    I v[3] != 8 { return 2 }
    I v[7] != 16 { return 3 }

    sum: i64 := mut 0
    LF i: 0..v.len() {
        sum = sum + v[i]
    }
    # 2+4+6+8+10+12+14+16 = 72
    I sum != 72 { return 4 }
    return 0
}

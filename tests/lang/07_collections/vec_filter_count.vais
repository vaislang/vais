# CHECKS: count elements in Vec matching a predicate.
U std/vec.{vec_new};

F main() -> i64 {
    v: Vec<i64> := mut vec_new()
    LF i: 0..20 {
        v.push(i)
    }

    # count even
    even: i64 := mut 0
    LF i: 0..v.len() {
        I (v[i] & 1) == 0 { even = even + 1 }
    }
    I even != 10 { R 1 }

    # count > 10
    big: i64 := mut 0
    LF i: 0..v.len() {
        I v[i] > 10 { big = big + 1 }
    }
    I big != 9 { R 2 }   # 11..19 = 9 elements

    # count == 0
    zero: i64 := mut 0
    LF i: 0..v.len() {
        I v[i] == 0 { zero = zero + 1 }
    }
    I zero != 1 { R 3 }
    R 0
}

# CHECKS: array literal indexing and iteration via Vec (since `[T; N]` annotation
# rejects slice-typed literals — bug C15).
U std/vec.{vec_new};

F main() -> i64 {
    a: Vec<i64> := mut vec_new()
    a.push(10)
    a.push(20)
    a.push(30)
    a.push(40)
    a.push(50)

    I a[0] != 10 { R 1 }
    I a[2] != 30 { R 2 }
    I a[4] != 50 { R 3 }

    sum: i64 := mut 0
    LF i: 0..a.len() {
        sum = sum + a[i]
    }
    I sum != 150 { R 4 }
    R 0
}

# CHECKS: method returns a struct + chaining via temporary.
struct V2 { x: i64, y: i64 }

impl V2 {
    fn new(x: i64, y: i64) -> V2 { V2 { x: x, y: y } }
    fn flip(&self) -> V2 { V2 { x: self.y, y: self.x } }
    fn double(&self) -> V2 { V2 { x: self.x * 2, y: self.y * 2 } }
    fn sum(&self) -> i64 { self.x + self.y }
}

fn main() -> i64 {
    a: V2 := V2.new(3, 4)
    I a.sum() != 7 { return 1 }

    b: V2 := a.flip()
    I b.x != 4 { return 2 }
    I b.y != 3 { return 3 }

    c: V2 := a.double()
    I c.x != 6 { return 4 }
    I c.y != 8 { return 5 }
    I c.sum() != 14 { return 6 }
    return 0
}

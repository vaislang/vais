# CHECKS: associated constructor functions on structs (e.g., Point.origin()).
struct Point {
    x: i64,
    y: i64
}

impl Point {
    fn origin() -> Point {
        Point { x: 0, y: 0 }
    }

    fn new(x: i64, y: i64) -> Point {
        Point { x: x, y: y }
    }

    fn distance_squared(&self, other: Point) -> i64 {
        dx: i64 := self.x - other.x
        dy: i64 := self.y - other.y
        dx * dx + dy * dy
    }
}

fn main() -> i64 {
    o: Point := Point.origin()
    I o.x != 0 { return 1 }
    I o.y != 0 { return 2 }

    p: Point := Point.new(3, 4)
    I p.x != 3 { return 3 }
    I p.y != 4 { return 4 }

    # 3*3 + 4*4 = 25
    d: i64 := p.distance_squared(o)
    I d != 25 { return 5 }

    q: Point := Point.new(0 - 1, 0 - 2)
    # (0 - (0 - 1))^2 + (0 - (0 - 2))^2 = 1 + 4 = 5
    d2: i64 := o.distance_squared(q)
    I d2 != 5 { return 6 }
    return 0
}

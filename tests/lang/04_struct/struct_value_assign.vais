# CHECKS: struct used as a local + assignment (not via Vec — Vec<Struct>
#         specialization separately covered once standalone Vec<T>
#         construction syntax is finalized).
# REGRESSION: Phase 17 Wave 2a — struct value store path
struct Item {
    id: i64,
    score: i64,
}

fn main() -> i64 {
    a: Item := mut Item { id: 1, score: 100 }
    b: Item := mut Item { id: 2, score: 200 }
    I a.id != 1      { return 1 }
    I a.score != 100 { return 2 }
    I b.id != 2      { return 3 }
    I b.score != 200 { return 4 }
    # swap-like assignment
    a = b
    I a.id != 2      { return 5 }
    I a.score != 200 { return 6 }
    return 0
}

# CHECKS: static method (no self) callable via Type.method().
S Box {
    val: i64
}

X Box {
    F default_val() -> i64 { 42 }

    F new_with_default() -> Box {
        Box { val: Box.default_val() }
    }

    F new_zero() -> Box { Box { val: 0 } }
}

F main() -> i64 {
    I Box.default_val() != 42 { R 1 }

    a: Box := Box.new_with_default()
    I a.val != 42 { R 2 }

    b: Box := Box.new_zero()
    I b.val != 0 { R 3 }
    R 0
}

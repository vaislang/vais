# CHECKS: nested struct initialization passing structs as field values.
S Address {
    house: i64,
    zip: i64
}

S Person {
    age: i64,
    address: Address
}

F main() -> i64 {
    addr: Address := Address { house: 42, zip: 12345 }
    p: Person := Person { age: 30, address: addr }

    I p.age != 30 { R 1 }
    I p.address.house != 42 { R 2 }
    I p.address.zip != 12345 { R 3 }

    # construct inline
    p2: Person := Person {
        age: 25,
        address: Address { house: 100, zip: 99999 }
    }
    I p2.age != 25 { R 4 }
    I p2.address.house != 100 { R 5 }
    I p2.address.zip != 99999 { R 6 }
    R 0
}

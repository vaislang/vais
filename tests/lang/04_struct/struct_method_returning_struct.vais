# CHECKS: method returns the same struct type (immutable transform pattern).
struct Point {
    x: i64,
    y: i64
}

impl Point {
    fn translate(&self, dx: i64, dy: i64) -> Point {
        Point { x: self.x + dx, y: self.y + dy }
    }

    fn scale(&self, factor: i64) -> Point {
        Point { x: self.x * factor, y: self.y * factor }
    }
}

fn main() -> i64 {
    p: Point := Point { x: 10, y: 20 }
    q: Point := p.translate(5, 0 - 3)
    I q.x != 15 { return 1 }
    I q.y != 17 { return 2 }

    r: Point := q.scale(2)
    I r.x != 30 { return 3 }
    I r.y != 34 { return 4 }
    return 0
}

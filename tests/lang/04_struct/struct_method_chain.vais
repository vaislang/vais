# CHECKS: struct method that returns the struct (or modifies it via &mut self).
S Counter {
    count: i64
}

X Counter {
    F new() -> Counter {
        Counter { count: 0 }
    }

    F bump(&self) -> i64 {
        self.count = self.count + 1
        self.count
    }

    F get(&self) -> i64 {
        self.count
    }
}

F main() -> i64 {
    c: Counter := mut Counter.new()
    I c.get() != 0 { R 1 }

    I c.bump() != 1 { R 2 }
    I c.bump() != 2 { R 3 }
    I c.bump() != 3 { R 4 }
    I c.get() != 3 { R 5 }

    LF i: 0..7 {
        c.bump()
    }
    I c.get() != 10 { R 6 }
    R 0
}

# CHECKS: default constructor pattern.
S Buffer {
    capacity: i64,
    used: i64,
    flags: i64
}

X Buffer {
    F default() -> Buffer {
        Buffer { capacity: 64, used: 0, flags: 0 }
    }
    F is_empty(&self) -> i64 {
        I self.used == 0 { 1 } EL { 0 }
    }
    F is_full(&self) -> i64 {
        I self.used >= self.capacity { 1 } EL { 0 }
    }
    F free_space(&self) -> i64 {
        self.capacity - self.used
    }
}

F main() -> i64 {
    b: Buffer := mut Buffer.default()
    I b.capacity != 64 { R 1 }
    I b.is_empty() != 1 { R 2 }
    I b.is_full() != 0 { R 3 }
    I b.free_space() != 64 { R 4 }

    b.used = 32
    I b.is_empty() != 0 { R 5 }
    I b.is_full() != 0 { R 6 }
    I b.free_space() != 32 { R 7 }

    b.used = 64
    I b.is_full() != 1 { R 8 }
    I b.free_space() != 0 { R 9 }
    R 0
}

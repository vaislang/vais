# CHECKS: passing structs by value to functions, returning structs from functions.
struct Vec2 {
    x: i64,
    y: i64
}

fn new_vec(x: i64, y: i64) -> Vec2 {
    Vec2 { x: x, y: y }
}

fn dot(a: Vec2, b: Vec2) -> i64 {
    a.x * b.x + a.y * b.y
}

fn add(a: Vec2, b: Vec2) -> Vec2 {
    Vec2 { x: a.x + b.x, y: a.y + b.y }
}

fn main() -> i64 {
    a: Vec2 := new_vec(3, 4)
    I a.x != 3 { return 1 }
    I a.y != 4 { return 2 }

    b: Vec2 := new_vec(1, 2)
    # 3*1 + 4*2 = 11
    I dot(a, b) != 11 { return 3 }

    s: Vec2 := add(a, b)
    I s.x != 4 { return 4 }
    I s.y != 6 { return 5 }
    return 0
}

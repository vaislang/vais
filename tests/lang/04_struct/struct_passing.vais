# CHECKS: passing structs by value to functions, returning structs from functions.
S Vec2 {
    x: i64,
    y: i64
}

F new_vec(x: i64, y: i64) -> Vec2 {
    Vec2 { x: x, y: y }
}

F dot(a: Vec2, b: Vec2) -> i64 {
    a.x * b.x + a.y * b.y
}

F add(a: Vec2, b: Vec2) -> Vec2 {
    Vec2 { x: a.x + b.x, y: a.y + b.y }
}

F main() -> i64 {
    a: Vec2 := new_vec(3, 4)
    I a.x != 3 { R 1 }
    I a.y != 4 { R 2 }

    b: Vec2 := new_vec(1, 2)
    # 3*1 + 4*2 = 11
    I dot(a, b) != 11 { R 3 }

    s: Vec2 := add(a, b)
    I s.x != 4 { R 4 }
    I s.y != 6 { R 5 }
    R 0
}

# CHECKS: swap two fields of a struct in-place.
struct Box {
    a: i64,
    b: i64
}

impl Box {
    fn new(a: i64, b: i64) -> Box { Box { a: a, b: b } }
    fn swap(&self) {
        tmp: i64 := self.a
        self.a = self.b
        self.b = tmp
    }
    fn sum(&self) -> i64 { self.a + self.b }
    fn diff(&self) -> i64 { self.a - self.b }
}

fn main() -> i64 {
    b: Box := mut Box.new(10, 20)
    I b.a != 10 { return 1 }
    I b.diff() != 0 - 10 { return 2 }

    b.swap()
    I b.a != 20 { return 3 }
    I b.b != 10 { return 4 }
    I b.diff() != 10 { return 5 }
    I b.sum() != 30 { return 6 }

    b.swap()
    I b.a != 10 { return 7 }
    return 0
}

# CHECKS: pass struct by &ref/&mut to a method, mutate via field assign.
struct Stats { val: i64 }

impl Stats {
    fn bump(&self) {
        self.val = self.val + 1
    }
}

fn main() -> i64 {
    s: Stats := mut Stats { val: 10 }
    s.bump()
    s.bump()
    s.bump()
    I s.val != 13 { return 1 }
    return 0
}

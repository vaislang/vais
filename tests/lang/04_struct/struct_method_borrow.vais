# CHECKS: &self vs &mut self — read-only versus mutating methods.
struct Counter {
    n: i64
}

impl Counter {
    fn new() -> Counter { Counter { n: 0 } }
    fn bump(&self) -> i64 { self.n = self.n + 1; self.n }
    fn peek(&self) -> i64 { self.n }
    fn reset(&self) { self.n = 0 }
}

fn main() -> i64 {
    c: Counter := mut Counter.new()
    I c.peek() != 0 { return 1 }
    I c.bump() != 1 { return 2 }
    I c.bump() != 2 { return 3 }
    I c.bump() != 3 { return 4 }
    I c.peek() != 3 { return 5 }
    c.reset()
    I c.peek() != 0 { return 6 }
    return 0
}

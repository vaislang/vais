# CHECKS: struct with two related methods that share state.
S BankAccount {
    balance: i64,
    history_count: i64
}

X BankAccount {
    F new() -> BankAccount {
        BankAccount { balance: 0, history_count: 0 }
    }
    F deposit(&self, amount: i64) {
        self.balance = self.balance + amount
        self.history_count = self.history_count + 1
    }
    F withdraw(&self, amount: i64) -> i64 {
        I amount > self.balance { R 0 }
        self.balance = self.balance - amount
        self.history_count = self.history_count + 1
        1
    }
}

F main() -> i64 {
    a: BankAccount := mut BankAccount.new()
    I a.balance != 0 { R 1 }

    a.deposit(100)
    a.deposit(50)
    I a.balance != 150 { R 2 }
    I a.history_count != 2 { R 3 }

    I a.withdraw(80) != 1 { R 4 }
    I a.balance != 70 { R 5 }
    I a.history_count != 3 { R 6 }

    # overdraw fails
    I a.withdraw(200) != 0 { R 7 }
    I a.balance != 70 { R 8 }
    I a.history_count != 3 { R 9 }   # not bumped on failure
    R 0
}

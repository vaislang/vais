# CHECKS: assign to a mutable struct field via &self.
S Counter {
    value: i64
}

X Counter {
    F new(start: i64) -> Counter {
        Counter { value: start }
    }

    F set(&self, v: i64) -> i64 {
        self.value = v
        self.value
    }

    F bump(&self) -> i64 {
        self.value = self.value + 1
        self.value
    }
}

F main() -> i64 {
    c: Counter := mut Counter.new(10)
    I c.value != 10 { R 1 }

    I c.set(50) != 50 { R 2 }
    I c.value != 50 { R 3 }

    I c.bump() != 51 { R 4 }
    I c.bump() != 52 { R 5 }
    I c.value != 52 { R 6 }
    R 0
}

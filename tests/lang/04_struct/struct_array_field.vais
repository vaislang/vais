# CHECKS: struct field that is itself a fixed-size array.
# REGRESSION for bug C6: prior fix had two parts in inkwell:
# (1) `generate_index` now spills an ArrayValue to a tmp alloca before GEP'ing,
#     so `p.coords[i]` (where coords arrives as `[3 x i64]` from extractvalue)
#     no longer panics with "expected PointerValue".
# (2) `generate_struct_literal` now loads the array value when the field type
#     is an array and the supplied value is a pointer (`generate_array`
#     returns the alloca pointer), so `Point3D { coords: [10,20,30] }` no
#     longer fails IR verification with "ptr instead of [3 x i64]".
struct Point3D {
    coords: [i64; 3]
}

fn main() -> i64 {
    p: Point3D := Point3D { coords: [10, 20, 30] }
    I p.coords[0] != 10 { return 1 }
    I p.coords[1] != 20 { return 2 }
    I p.coords[2] != 30 { return 3 }
    sum: i64 := p.coords[0] + p.coords[1] + p.coords[2]
    I sum != 60 { return 4 }
    return 0
}

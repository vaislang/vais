# XFAIL: struct field of fixed-size array `[i64; 3]` triggers ICE — codegen
# tries to convert ArrayValue to PointerValue when accessing the field via
# extractvalue. Tracked as Phase 0 finding C6.
#
# CHECKS: struct field that is itself a fixed-size array.
S Point3D {
    coords: [i64; 3]
}

F main() -> i64 {
    p: Point3D := Point3D { coords: [10, 20, 30] }
    I p.coords[0] != 10 { R 1 }
    I p.coords[1] != 20 { R 2 }
    I p.coords[2] != 30 { R 3 }
    sum: i64 := p.coords[0] + p.coords[1] + p.coords[2]
    I sum != 60 { R 4 }
    R 0
}

# CHECKS: struct with bool field.
S Toggle {
    enabled: bool,
    count: i64
}

F main() -> i64 {
    t: Toggle := mut Toggle { enabled: true, count: 0 }
    I (t.enabled as i64) != 1 { R 1 }
    I t.count != 0 { R 2 }

    t.count = 5
    I t.count != 5 { R 3 }

    t.enabled = false
    I (t.enabled as i64) != 0 { R 4 }
    R 0
}

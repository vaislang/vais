# CHECKS: count distinct values in a Vec via O(n^2) scan.
use std/vec.{vec_new};

fn distinct_count(v: &Vec<i64>) -> i64 {
    count: i64 := mut 0
    LF i: 0..v.len() {
        is_first: i64 := mut 1
        LF j: 0..i {
            I v[j] == v[i] { is_first = 0 }
        }
        I is_first == 1 { count = count + 1 }
    }
    count
}

fn main() -> i64 {
    v: Vec<i64> := mut vec_new()
    v.push(1)
    v.push(2)
    v.push(3)
    v.push(1)
    v.push(2)
    # distinct = {1,2,3} → 3
    I distinct_count(&v) != 3 { return 1 }

    w: Vec<i64> := mut vec_new()
    w.push(7)
    w.push(7)
    w.push(7)
    I distinct_count(&w) != 1 { return 2 }

    e: Vec<i64> := mut vec_new()
    I distinct_count(&e) != 0 { return 3 }
    return 0
}

# CHECKS: count common elements between two Vec<i64> (O(n²)).
use std/vec.{vec_new};

fn intersect_count(a: &Vec<i64>, b: &Vec<i64>) -> i64 {
    count: i64 := mut 0
    LF i: 0..a.len() {
        LF j: 0..b.len() {
            I a[i] == b[j] { count = count + 1 B }
        }
    }
    count
}

fn main() -> i64 {
    a: Vec<i64> := mut vec_new()
    a.push(1)
    a.push(2)
    a.push(3)
    a.push(4)

    b: Vec<i64> := mut vec_new()
    b.push(3)
    b.push(4)
    b.push(5)
    b.push(6)
    # intersect: {3, 4} → 2
    I intersect_count(&a, &b) != 2 { return 1 }

    # disjoint
    c: Vec<i64> := mut vec_new()
    c.push(100)
    c.push(200)
    I intersect_count(&a, &c) != 0 { return 2 }

    # subset
    d: Vec<i64> := mut vec_new()
    d.push(1)
    d.push(2)
    I intersect_count(&a, &d) != 2 { return 3 }
    return 0
}

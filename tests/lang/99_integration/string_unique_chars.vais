# CHECKS: detect if all chars in a string are unique (O(n²) by byte).
fn all_unique(p: i64, n: i64) -> i64 {
    LF i: 0..n {
        ci: i64 := load_byte(p + i)
        LF j: i + 1..n {
            cj: i64 := load_byte(p + j)
            I ci == cj { return 0 }
        }
    }
    1
}

fn main() -> i64 {
    p1: i64 := str_to_ptr("abcde")
    I all_unique(p1, strlen(p1)) != 1 { return 1 }

    p2: i64 := str_to_ptr("abca")
    I all_unique(p2, strlen(p2)) != 0 { return 2 }

    p3: i64 := str_to_ptr("a")
    I all_unique(p3, 1) != 1 { return 3 }

    p4: i64 := str_to_ptr("")
    I all_unique(p4, 0) != 1 { return 4 }

    p5: i64 := str_to_ptr("hello")
    I all_unique(p5, strlen(p5)) != 0 { return 5 }
    return 0
}

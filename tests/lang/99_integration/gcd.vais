# CHECKS: Euclidean GCD using while + modulo
F gcd(a: i64, b: i64) -> i64 {
    x: i64 := mut a
    y: i64 := mut b
    LW y != 0 {
        t: i64 := y
        y = x % y
        x = t
    }
    x
}

F main() -> i64 {
    I gcd(24, 36) != 12 { R 1 }
    I gcd(100, 75) != 25 { R 2 }
    I gcd(13, 17) != 1   { R 3 }
    I gcd(0, 5)   != 5   { R 4 }
    R 0
}

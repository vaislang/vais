# CHECKS: Collatz conjecture step count for several seeds.
F collatz_steps(n: i64) -> i64 {
    steps: i64 := mut 0
    cur: i64 := mut n
    L {
        I cur <= 1 { B steps }
        I (cur & 1) == 0 {
            cur = cur / 2
        } EL {
            cur = cur * 3 + 1
        }
        steps = steps + 1
    }
}

F main() -> i64 {
    # Known: Collatz(1)=0, (2)=1, (3)=7, (6)=8, (27)=111
    I collatz_steps(1) != 0 { R 1 }
    I collatz_steps(2) != 1 { R 2 }
    I collatz_steps(3) != 7 { R 3 }
    I collatz_steps(6) != 8 { R 4 }
    I collatz_steps(27) != 111 { R 5 }
    R 0
}

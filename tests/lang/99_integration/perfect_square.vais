# CHECKS: detect perfect squares via sqrt-ish search.
F is_perfect_square(n: i64) -> i64 {
    I n < 0 { R 0 }
    I n == 0 { R 1 }
    i: i64 := mut 1
    LW i * i <= n {
        I i * i == n { R 1 }
        i = i + 1
    }
    0
}

F main() -> i64 {
    I is_perfect_square(0) != 1 { R 1 }
    I is_perfect_square(1) != 1 { R 2 }
    I is_perfect_square(4) != 1 { R 3 }
    I is_perfect_square(9) != 1 { R 4 }
    I is_perfect_square(100) != 1 { R 5 }
    I is_perfect_square(2) != 0 { R 6 }
    I is_perfect_square(3) != 0 { R 7 }
    I is_perfect_square(99) != 0 { R 8 }
    I is_perfect_square(10000) != 1 { R 9 }
    I is_perfect_square(0 - 5) != 0 { R 10 }
    R 0
}

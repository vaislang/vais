# CHECKS: byte-wise sum of a string (simple hash).
F byte_sum(p: i64, n: i64) -> i64 {
    s: i64 := mut 0
    LF i: 0..n {
        s = s + load_byte(p + i)
    }
    s
}

F main() -> i64 {
    p1: i64 := str_to_ptr("a")
    I byte_sum(p1, 1) != 97 { R 1 }

    p2: i64 := str_to_ptr("abc")
    # 97+98+99 = 294
    I byte_sum(p2, 3) != 294 { R 2 }

    p3: i64 := str_to_ptr("hello")
    # 104+101+108+108+111 = 532
    I byte_sum(p3, 5) != 532 { R 3 }

    p4: i64 := str_to_ptr("")
    I byte_sum(p4, 0) != 0 { R 4 }
    R 0
}

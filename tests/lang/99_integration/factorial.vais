# CHECKS: iterative factorial
fn factorial(n: i64) -> i64 {
    result: i64 := mut 1
    i: i64 := mut 1
    LW i <= n {
        result = result * i
        i = i + 1
    }
    result
}

fn main() -> i64 {
    I factorial(0) != 1   { return 1 }
    I factorial(5) != 120 { return 2 }
    I factorial(7) != 5040{ return 3 }
    return 0
}

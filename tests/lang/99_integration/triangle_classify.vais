# CHECKS: triangle classification via match-on-bool patterns.
F classify(a: i64, b: i64, c: i64) -> i64 {
    I a == b && b == c { R 1 }    # equilateral
    I a == b || b == c || a == c { R 2 }  # isoceles
    3   # scalene
}

F main() -> i64 {
    I classify(5, 5, 5) != 1 { R 1 }
    I classify(3, 3, 5) != 2 { R 2 }
    I classify(5, 3, 3) != 2 { R 3 }
    I classify(3, 5, 3) != 2 { R 4 }
    I classify(3, 4, 5) != 3 { R 5 }
    I classify(7, 8, 9) != 3 { R 6 }
    R 0
}

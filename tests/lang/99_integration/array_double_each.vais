# CHECKS: build a transformed Vec by doubling each element.
U std/vec.{vec_new};

F double_all(v: &Vec<i64>) -> Vec<i64> {
    out: Vec<i64> := mut vec_new()
    LF i: 0..v.len() {
        out.push(v[i] * 2)
    }
    out
}

F main() -> i64 {
    v: Vec<i64> := mut vec_new()
    v.push(1)
    v.push(2)
    v.push(3)
    v.push(4)
    v.push(5)

    d: Vec<i64> := double_all(&v)
    I d.len() != 5 { R 1 }
    I d[0] != 2 { R 2 }
    I d[2] != 6 { R 3 }
    I d[4] != 10 { R 4 }

    # original unchanged
    I v[0] != 1 { R 5 }
    I v[4] != 5 { R 6 }
    R 0
}

# CHECKS: Gregorian leap year rule.
fn is_leap(year: i64) -> i64 {
    I (year % 4) != 0 { return 0 }
    I (year % 100) != 0 { return 1 }
    I (year % 400) == 0 { return 1 }
    0
}

fn main() -> i64 {
    I is_leap(2000) != 1 { return 1 }   # divisible by 400
    I is_leap(2004) != 1 { return 2 }   # divisible by 4 but not 100
    I is_leap(1900) != 0 { return 3 }   # divisible by 100 but not 400
    I is_leap(2001) != 0 { return 4 }
    I is_leap(2024) != 1 { return 5 }
    I is_leap(2100) != 0 { return 6 }
    I is_leap(2400) != 1 { return 7 }
    return 0
}

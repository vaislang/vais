# CHECKS: split a Vec at an index — return both halves' lengths.
U std/vec.{vec_new};

F first_half_len(v: &Vec<i64>, idx: i64) -> i64 {
    I idx > v.len() { v.len() } EL { idx }
}

F second_half_len(v: &Vec<i64>, idx: i64) -> i64 {
    I idx > v.len() { 0 } EL { v.len() - idx }
}

F main() -> i64 {
    v: Vec<i64> := mut vec_new()
    LF i: 0..10 {
        v.push(i)
    }

    I first_half_len(&v, 3) != 3 { R 1 }
    I second_half_len(&v, 3) != 7 { R 2 }

    I first_half_len(&v, 0) != 0 { R 3 }
    I second_half_len(&v, 0) != 10 { R 4 }

    I first_half_len(&v, 10) != 10 { R 5 }
    I second_half_len(&v, 10) != 0 { R 6 }

    # past end
    I first_half_len(&v, 20) != 10 { R 7 }
    I second_half_len(&v, 20) != 0 { R 8 }
    R 0
}

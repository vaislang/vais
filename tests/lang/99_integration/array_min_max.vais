# CHECKS: min and max in single pass.
U std/vec.{vec_new};

F main() -> i64 {
    v: Vec<i64> := mut vec_new()
    v.push(5)
    v.push(0 - 3)
    v.push(10)
    v.push(1)
    v.push(0 - 7)
    v.push(8)

    min: i64 := mut v[0]
    max: i64 := mut v[0]
    LF i: 1..v.len() {
        I v[i] < min { min = v[i] }
        I v[i] > max { max = v[i] }
    }
    I min != 0 - 7 { R 1 }
    I max != 10 { R 2 }
    I max - min != 17 { R 3 }
    R 0
}

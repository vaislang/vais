# CHECKS: concatenate 3 Vec<i64> into one.
use std/vec.{vec_new};

fn main() -> i64 {
    a: Vec<i64> := mut vec_new()
    a.push(1)
    a.push(2)

    b: Vec<i64> := mut vec_new()
    b.push(10)
    b.push(20)
    b.push(30)

    c: Vec<i64> := mut vec_new()
    c.push(100)

    out: Vec<i64> := mut vec_new()
    LF i: 0..a.len() { out.push(a[i]) }
    LF i: 0..b.len() { out.push(b[i]) }
    LF i: 0..c.len() { out.push(c[i]) }

    I out.len() != 6 { return 1 }
    I out[0] != 1 { return 2 }
    I out[1] != 2 { return 3 }
    I out[2] != 10 { return 4 }
    I out[4] != 30 { return 5 }
    I out[5] != 100 { return 6 }

    sum: i64 := mut 0
    LF i: 0..out.len() {
        sum = sum + out[i]
    }
    # 1+2+10+20+30+100 = 163
    I sum != 163 { return 7 }
    return 0
}

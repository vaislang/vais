# CHECKS: detect strings containing only ASCII alphanumeric.
fn is_alnum(c: i64) -> i64 {
    I c >= 48 && c <= 57 { return 1 }
    I c >= 65 && c <= 90 { return 1 }
    I c >= 97 && c <= 122 { return 1 }
    0
}

fn all_alnum(p: i64, n: i64) -> i64 {
    LF i: 0..n {
        I is_alnum(load_byte(p + i)) == 0 { return 0 }
    }
    1
}

fn main() -> i64 {
    p1: i64 := str_to_ptr("Hello123")
    I all_alnum(p1, strlen(p1)) != 1 { return 1 }

    p2: i64 := str_to_ptr("hello world")
    I all_alnum(p2, strlen(p2)) != 0 { return 2 }

    p3: i64 := str_to_ptr("test!")
    I all_alnum(p3, strlen(p3)) != 0 { return 3 }

    p4: i64 := str_to_ptr("")
    I all_alnum(p4, 0) != 1 { return 4 }
    return 0
}

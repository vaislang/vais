# CHECKS: sum of absolute values.
use std/vec.{vec_new};

fn abs(n: i64) -> i64 {
    I n < 0 { 0 - n } else { n }
}

fn abs_sum(v: &Vec<i64>) -> i64 {
    s: i64 := mut 0
    LF i: 0..v.len() {
        s = s + abs(v[i])
    }
    s
}

fn main() -> i64 {
    v: Vec<i64> := mut vec_new()
    v.push(0 - 3)
    v.push(5)
    v.push(0 - 1)
    v.push(2)
    v.push(0 - 7)
    # |3| + |5| + |1| + |2| + |7| = 18
    I abs_sum(&v) != 18 { return 1 }

    e: Vec<i64> := mut vec_new()
    I abs_sum(&e) != 0 { return 2 }

    z: Vec<i64> := mut vec_new()
    z.push(0)
    z.push(0)
    I abs_sum(&z) != 0 { return 3 }
    return 0
}

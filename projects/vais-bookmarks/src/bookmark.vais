# bookmark.vais - Bookmark data model and store

# External C functions for memory and string operations
impl fn malloc(size: i64) -> i64
impl fn free(ptr: i64) -> i64
impl fn time(ptr: i64) -> i64
impl fn strcmp(a: str, b: str) -> i64
impl fn strlen(s: str) -> i64
impl fn strstr(haystack: str, needle: str) -> i64
impl fn strcpy(dest: i64, src: str) -> i64
impl fn sprintf(buf: i64, fmt: str) -> i64

# Bookmark structure
struct Bookmark {
    id: i64,
    title: str,
    url: str,
    tags: str,
    created_at: i64,
    updated_at: i64
}

# Bookmark store (in-memory database)
struct BookmarkStore {
    items_ptr: i64,    # Pointer to array of Bookmark*
    count: i64,
    capacity: i64,
    next_id: i64
}

# Create a new bookmark
fn bookmark_new(id: i64, title: str, url: str, tags: str) -> Bookmark {
    C timestamp := time(0)
    return Bookmark {
        id: id,
        title: title,
        url: url,
        tags: tags,
        created_at: timestamp,
        updated_at: timestamp
    }
}

# Initialize a new bookmark store
fn store_new() -> BookmarkStore {
    C capacity := 100
    C items_ptr := malloc(capacity * 8)  # Array of pointers (8 bytes each)
    return BookmarkStore {
        items_ptr: items_ptr,
        count: 0,
        capacity: capacity,
        next_id: 1
    }
}

# Add a bookmark to the store
fn store_add(store: BookmarkStore, title: str, url: str, tags: str) -> i64 {
    I store.count >= store.capacity {
        return 0  # Store is full
    }

    C id := store.next_id
    C bookmark := bookmark_new(id, title, url, tags)

    # Allocate memory for the bookmark
    C bm_ptr := malloc(48)  # sizeof(Bookmark)

    # Store bookmark (simplified - in real impl would copy struct)
    C array_ptr := store.items_ptr + (store.count * 8)

    # Update store
    store.count := store.count + 1
    store.next_id := store.next_id + 1

    return id
}

# Get bookmark by ID
fn store_get(store: BookmarkStore, id: i64) -> i64 {
    C i := 0
    L i < store.count {
        # In real impl: would retrieve actual bookmark from items_ptr[i]
        # For now, return pointer if ID matches
        I i + 1 == id {
            C ptr := store.items_ptr + (i * 8)
            return ptr
        }
        i := i + 1
    }
    return 0  # Not found
}

# Update bookmark
fn store_update(store: BookmarkStore, id: i64, title: str, url: str, tags: str) -> i64 {
    C i := 0
    L i < store.count {
        I i + 1 == id {
            # Update timestamp
            C timestamp := time(0)
            # In real impl: would update bookmark fields
            return 1  # Success
        }
        i := i + 1
    }
    return 0  # Not found
}

# Delete bookmark
fn store_delete(store: BookmarkStore, id: i64) -> i64 {
    C i := 0
    L i < store.count {
        I i + 1 == id {
            # Shift remaining items left
            C j := i
            L j < store.count - 1 {
                # Copy pointer from j+1 to j
                j := j + 1
            }
            store.count := store.count - 1
            return 1  # Success
        }
        i := i + 1
    }
    return 0  # Not found
}

# Search bookmarks by query (title, url, or tags)
fn store_search(store: BookmarkStore, query: str) -> i64 {
    # Return count of matches (simplified)
    I strlen(query) == 0 {
        return store.count
    }

    C matches := 0
    C i := 0
    L i < store.count {
        # In real impl: would check if query matches title/url/tags
        matches := matches + 1
        i := i + 1
    }

    return matches
}

# Get all bookmarks count
fn store_count(store: BookmarkStore) -> i64 {
    return store.count
}

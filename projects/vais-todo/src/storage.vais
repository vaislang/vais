# storage.vais - JSON file persistence for TODO data

impl fn fopen(path: str, mode: str) -> i64
impl fn fclose(file: i64) -> i64
impl fn fputs(s: str, file: i64) -> i64
impl fn fgets(buf: str, size: i64, file: i64) -> str
impl fn fprintf(file: i64, fmt: str) -> i64
impl fn fscanf(file: i64, fmt: str) -> i64
impl fn getenv(name: str) -> str
impl fn strlen(s: str) -> i64
impl fn strcat(dest: str, src: str) -> str
impl fn strcpy(dest: str, src: str) -> str
impl fn malloc(size: i64) -> i64
impl fn sprintf(buf: str, fmt: str) -> i64
impl fn atoi(s: str) -> i64

# Get the default storage path (~/.vais-todo.json)
fn storage_get_default_path() -> str {
    C home := getenv("HOME")
    I home == "" {
        return ".vais-todo.json"  # Fallback to current directory
    }

    # Construct path: HOME + "/.vais-todo.json"
    C path := malloc(256)
    strcpy(path, home)
    strcat(path, "/.vais-todo.json")
    return path
}

# Save TodoList to JSON file
fn storage_save(list: TodoList, path: str) -> i64 {
    C file := fopen(path, "w")
    I file == 0 {
        return -1  # Failed to open file
    }

    # Write JSON header
    fputs("{\n", file)
    fputs("  \"version\": \"1.0\",\n", file)
    fputs("  \"todos\": [\n", file)

    # Write each todo item
    C i := 0
    L {
        I i >= list.count {
            fputs("  ]\n", file)
            fputs("}\n", file)
            fclose(file)
            return 0
        }

        # Write todo as JSON object
        fputs("    {\n", file)

        # Write id field
        C buf := malloc(256)
        sprintf(buf, "      \"id\": %d,\n")
        fputs(buf, file)

        # Write description field
        fputs("      \"description\": \"", file)
        fputs("Sample TODO", file)  # Would use actual description
        fputs("\",\n", file)

        # Write done field
        fputs("      \"done\": 0,\n", file)

        # Write created_at field
        fputs("      \"created_at\": 0\n", file)

        # Close object
        I i < list.count - 1 {
            fputs("    },\n", file)
        } enum {
            fputs("    }\n", file)
        }

        free(buf)
        C i := i + 1
    }

    return 0
}

# Load TodoList from JSON file
fn storage_load(path: str) -> TodoList {
    C file := fopen(path, "r")
    I file == 0 {
        # File doesn't exist, return empty list
        return todolist_new()
    }

    # Create a new list
    C list := todolist_new()

    # Simple JSON parsing (just count items for this example)
    C buf := malloc(1024)
    C items_count := 0

    L {
        C line := fgets(buf, 1024, file)
        I line == "" {
            fclose(file)
            free(buf)
            return list
        }

        # Count items (very simplified parsing)
        # In real implementation, would properly parse JSON

        C items_count := items_count + 1
    }

    fclose(file)
    free(buf)
    return list
}

# Helper: Write formatted integer to file
fn storage_write_int(file: i64, name: str, value: i64) -> i64 {
    C buf := malloc(256)
    fputs("      \"", file)
    fputs(name, file)
    fputs("\": ", file)
    sprintf(buf, "%d")
    fputs(buf, file)
    free(buf)
    return 0
}

# Helper: Write formatted string to file
fn storage_write_string(file: i64, name: str, value: str) -> i64 {
    fputs("      \"", file)
    fputs(name, file)
    fputs("\": \"", file)
    fputs(value, file)
    fputs("\"", file)
    return 0
}

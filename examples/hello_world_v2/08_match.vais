# Hello World #8: match expression on integer
fn grade(score: i64) -> i64 {
    match score {
        90..=100 => 4,    # A
        80..=89  => 3,    # B
        70..=79  => 2,    # C
        60..=69  => 1,    # D
        _        => 0,    # F
    }
}

fn main() -> i64 {
    return grade(85)    # exit 3 (B)
}

# Hello World #9: Result<T, E> + match
fn safe_div(a: i64, b: i64) -> Result<i64, i64> {
    I b == 0 { return Err(0) }
    Ok(a / b)
}

fn main() -> i64 {
    r: Result<i64, i64> := safe_div(20, 4)
    out: i64 := match r {
        Ok(v)  => v,
        Err(_) => 99,
    }
    return out    # exit 5
}

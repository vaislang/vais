# Hello World #4: Option<T> + match expression
fn find_factor(n: i64) -> Option<i64> {
    I n % 2 == 0 { return Some(2) }
    I n % 3 == 0 { return Some(3) }
    I n % 5 == 0 { return Some(5) }
    None
}

fn main() -> i64 {
    result: i64 := match find_factor(15) {
        Some(f) => f,    # 15 % 3 == 0 → returns Some(3)
        None    => 0,
    }
    return result    # exit 3
}

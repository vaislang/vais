# Test 13: Boolean values
F test_booleans() -> i64 {
    obj := obj_new()
    obj_set(obj, str_to_ptr("enabled"), 7, val_bool(1))
    obj_set(obj, str_to_ptr("disabled"), 8, val_bool(0))
    v := val_object(obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 10 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}

# Test 14: Null handling (null → empty string in TOML)
F test_null_handling() -> i64 {
    obj := obj_new()
    obj_set(obj, str_to_ptr("value"), 5, val_null())
    v := val_object(obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 0 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}

# Main: Run all tests and accumulate score
F main() -> i64 {
    score := 0
    score = score + test_simple_object()
    score = score + test_nested_object()
    score = score + test_array_values()
    score = score + test_array_of_tables()
    score = score + test_empty()
    score = score + test_escapes()
    score = score + test_negative()
    score = score + test_deeply_nested()
    score = score + test_json_parse()
    score = score + test_non_object_root()
    score = score + test_stringify()
    score = score + test_mixed_types()
    score = score + test_booleans()
    score = score + test_null_handling()
    # Expected: 3+3+3+3+2+2+2+3+2+2+2+3+2+2 = 34
    score
}

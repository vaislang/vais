}

# Test 8: Deeply nested object (a.b.c.d=42)
F test_deeply_nested() -> i64 {
    d_obj := obj_new()
    obj_set(d_obj, str_to_ptr("d"), 1, val_int(42))
    c_obj := obj_new()
    obj_set(c_obj, str_to_ptr("c"), 1, val_object(d_obj))
    b_obj := obj_new()
    obj_set(b_obj, str_to_ptr("b"), 1, val_object(c_obj))
    a_obj := obj_new()
    obj_set(a_obj, str_to_ptr("a"), 1, val_object(b_obj))

    v := val_object(a_obj)
    toml := convert_to_toml(v)

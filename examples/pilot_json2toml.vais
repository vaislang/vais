# pilot_json2toml.vais — JSON to TOML Converter
# Phase 76 Pilot Project A: 1,000+ LOC CLI tool
#
# Features:
# - JSON parser (null, bool, integer, string, array, object)
# - TOML generator (string, integer, boolean, array, inline table, [table] sections)
# - Conversion logic: JSON value tree → TOML string output
# - Error handling: invalid JSON, type mismatches
# - Memory management: explicit malloc/free
#
# Usage:
#   echo '{"name":"Alice","age":30}' | ./pilot_json2toml
#
# Exit codes:
#   0 = success
#   1 = JSON parse error
#   2 = conversion error
#   3 = memory allocation error

# =====================================================
# Low-level memory helpers
# =====================================================

F strlen_ptr(s: i64) -> i64 {
    strlen_rec(s, 0)
}

F strlen_rec(s: i64, idx: i64) -> i64 {
    I load_byte(s + idx) == 0 { idx }
    EL { strlen_rec(s, idx + 1) }
}

F mem_zero(ptr: i64, count: i64, idx: i64) -> i64 {
    I idx >= count { 0 } EL {
        store_i64(ptr + idx * 8, 0)
        mem_zero(ptr, count, idx + 1)
    }
}

F copy_bytes(dst: i64, src: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        store_byte(dst + idx, load_byte(src + idx))
        copy_bytes(dst, src, len, idx + 1)
    }
}

# =====================================================
# Dynamic buffer (growable byte buffer)
# =====================================================

# Buffer struct layout: [data: i64, len: i64, cap: i64]
F buf_new() -> i64 {
    cap := 256
    b := malloc(24)
    store_i64(b, malloc(cap))    # data
    store_i64(b + 8, 0)          # len
    store_i64(b + 16, cap)       # cap
    b
}

F buf_data(b: i64) -> i64 { load_i64(b) }
F buf_len(b: i64) -> i64 { load_i64(b + 8) }
F buf_cap(b: i64) -> i64 { load_i64(b + 16) }

F buf_grow(b: i64) -> i64 {
    old_cap := buf_cap(b)
    new_cap := old_cap * 2
    new_data := malloc(new_cap)
    old_data := buf_data(b)
    old_len := buf_len(b)
    copy_bytes(new_data, old_data, old_len, 0)
    free(old_data)
    store_i64(b, new_data)
    store_i64(b + 16, new_cap)
    0
}

F buf_ensure(b: i64, needed: i64) -> i64 {
    I buf_len(b) + needed >= buf_cap(b) {
        buf_grow(b)
        buf_ensure(b, needed)
    } EL { 0 }
}

F buf_push_byte(b: i64, c: i64) -> i64 {
    buf_ensure(b, 1)
    data := buf_data(b)
    len := buf_len(b)
    store_byte(data + len, c)
    store_i64(b + 8, len + 1)
    0
}

F buf_push_str(b: i64, s: i64, slen: i64) -> i64 {
    buf_push_str_rec(b, s, slen, 0)
}

F buf_push_str_rec(b: i64, s: i64, slen: i64, idx: i64) -> i64 {
    I idx >= slen { 0 } EL {
        buf_push_byte(b, load_byte(s + idx))
        buf_push_str_rec(b, s, slen, idx + 1)
    }
}

F buf_push_cstr(b: i64, s: i64) -> i64 {
    buf_push_str(b, s, strlen_ptr(s))
}

F buf_to_cstr(b: i64) -> i64 {
    buf_push_byte(b, 0)
    data := buf_data(b)
    # Detach data from buffer
    store_i64(b, 0)
    data
}

F buf_free(b: i64) -> i64 {
    data := buf_data(b)
    I data != 0 { free(data) }
    free(b)
    0
}

# =====================================================
# Integer to string conversion
# =====================================================

F i64_to_str(n: i64) -> i64 {
    I n == 0 {
        buf := malloc(2)
        store_byte(buf, 48)
        store_byte(buf + 1, 0)
        R buf
    }
    # Handle negative
    is_neg := I n < 0 { 1 } EL { 0 }
    abs_n := I is_neg == 1 { 0 - n } EL { n }
    # Count digits
    digits := count_digits(abs_n, 0)
    total := digits + is_neg
    buf := malloc(total + 1)
    store_byte(buf + total, 0)
    # Fill digits from right
    fill_digits(buf, abs_n, total - 1)
    I is_neg == 1 { store_byte(buf, 45) }  # '-'
    buf
}

F count_digits(n: i64, acc: i64) -> i64 {
    I n == 0 { acc }
    EL { count_digits(n / 10, acc + 1) }
}

F fill_digits(buf: i64, n: i64, pos: i64) -> i64 {
    I n == 0 { 0 }
    EL {
        digit := n % 10
        store_byte(buf + pos, digit + 48)
        fill_digits(buf, n / 10, pos - 1)
    }
}

# =====================================================
# Hash table for JSON objects
# =====================================================

# Hash string using djb2
F hash_str(s: i64, len: i64) -> i64 {
    hash_str_rec(s, len, 0, 5381)
}

F hash_str_rec(s: i64, len: i64, idx: i64, h: i64) -> i64 {
    I idx >= len { h } EL {
        c := load_byte(s + idx)
        new_h := h * 33 + c
        abs_h := I new_h < 0 { 0 - new_h } EL { new_h }
        hash_str_rec(s, len, idx + 1, abs_h)
    }
}

# String equality
F str_eq(a: i64, b: i64, len: i64) -> i64 {
    str_eq_rec(a, b, len, 0)
}

F str_eq_rec(a: i64, b: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 1 }
    EL I load_byte(a + idx) != load_byte(b + idx) { 0 }
    EL { str_eq_rec(a, b, len, idx + 1) }
}

# Object layout: [buckets: i64, size: i64, cap: i64]
# Entry layout: [key: i64, key_len: i64, value: i64, next: i64]
F obj_new() -> i64 {
    cap := 16
    buckets := malloc(cap * 8)
    mem_zero(buckets, cap, 0)
    obj := malloc(24)
    store_i64(obj, buckets)
    store_i64(obj + 8, 0)
    store_i64(obj + 16, cap)
    obj
}

F obj_set(obj: i64, key: i64, key_len: i64, value: i64) -> i64 {
    buckets := load_i64(obj)
    cap := load_i64(obj + 16)
    h := hash_str(key, key_len) % cap
    entry := malloc(32)
    key_copy := malloc(key_len + 1)
    copy_bytes(key_copy, key, key_len, 0)
    store_byte(key_copy + key_len, 0)
    store_i64(entry, key_copy)
    store_i64(entry + 8, key_len)
    store_i64(entry + 16, value)
    store_i64(entry + 24, load_i64(buckets + h * 8))
    store_i64(buckets + h * 8, entry)
    size := load_i64(obj + 8) + 1
    store_i64(obj + 8, size)
    0
}

F obj_get(obj: i64, key: i64, key_len: i64) -> i64 {
    buckets := load_i64(obj)
    cap := load_i64(obj + 16)
    h := hash_str(key, key_len) % cap
    head := load_i64(buckets + h * 8)
    obj_get_rec(head, key, key_len)
}

F obj_get_rec(node: i64, key: i64, key_len: i64) -> i64 {
    I node == 0 { 0 }
    EL {
        e_key := load_i64(node)
        e_key_len := load_i64(node + 8)
        I e_key_len == key_len && str_eq(e_key, key, key_len) == 1 {
            load_i64(node + 16)
        } EL {
            obj_get_rec(load_i64(node + 24), key, key_len)
        }
    }
}

# Collect all keys from object (returns array of entries for ordered iteration)
# Returns: [entries_ptr: i64, count: i64]
F obj_collect_entries(obj: i64) -> i64 {
    size := load_i64(obj + 8)
    cap := load_i64(obj + 16)
    buckets := load_i64(obj)
    entries := malloc(size * 8)
    result := malloc(16)
    store_i64(result, entries)
    store_i64(result + 8, 0)  # current count
    obj_collect_buckets(buckets, cap, 0, result)
    result
}

F obj_collect_buckets(buckets: i64, cap: i64, idx: i64, result: i64) -> i64 {
    I idx >= cap { 0 } EL {
        entry := load_i64(buckets + idx * 8)
        obj_collect_chain(entry, result)
        obj_collect_buckets(buckets, cap, idx + 1, result)
    }
}

F obj_collect_chain(node: i64, result: i64) -> i64 {
    I node == 0 { 0 } EL {
        entries := load_i64(result)
        count := load_i64(result + 8)
        store_i64(entries + count * 8, node)
        store_i64(result + 8, count + 1)
        obj_collect_chain(load_i64(node + 24), result)
    }
}

# =====================================================
# Dynamic array
# =====================================================

# Array layout: [data: i64, len: i64, cap: i64]
F arr_new() -> i64 {
    cap := 8
    a := malloc(24)
    store_i64(a, malloc(cap * 8))
    store_i64(a + 8, 0)
    store_i64(a + 16, cap)
    a
}

F arr_push(a: i64, value: i64) -> i64 {
    len := load_i64(a + 8)
    cap := load_i64(a + 16)
    I len >= cap {
        new_cap := cap * 2
        new_data := malloc(new_cap * 8)
        old_data := load_i64(a)
        copy_arr_data(new_data, old_data, len, 0)
        free(old_data)
        store_i64(a, new_data)
        store_i64(a + 16, new_cap)
    }
    data := load_i64(a)
    store_i64(data + len * 8, value)
    store_i64(a + 8, len + 1)
    0
}

F copy_arr_data(dst: i64, src: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        store_i64(dst + idx * 8, load_i64(src + idx * 8))
        copy_arr_data(dst, src, len, idx + 1)
    }
}

F arr_len(a: i64) -> i64 { load_i64(a + 8) }
F arr_get(a: i64, idx: i64) -> i64 { load_i64(load_i64(a) + idx * 8) }

# =====================================================
# JSON Value type
# =====================================================
# Value layout: [tag: i64, data: i64, extra: i64]
# Tags: 0=null, 1=bool, 2=int, 3=string(data=ptr,extra=len), 4=array, 5=object

C TAG_NULL: i64 = 0
C TAG_BOOL: i64 = 1
C TAG_INT: i64 = 2
C TAG_STRING: i64 = 3
C TAG_ARRAY: i64 = 4
C TAG_OBJECT: i64 = 5

F val_new(tag: i64, data: i64, extra: i64) -> i64 {
    v := malloc(24)
    store_i64(v, tag)
    store_i64(v + 8, data)
    store_i64(v + 16, extra)
    v
}

F val_tag(v: i64) -> i64 {
    I v == 0 { 0 } EL { load_i64(v) }
}

F val_data(v: i64) -> i64 { load_i64(v + 8) }
F val_extra(v: i64) -> i64 { load_i64(v + 16) }

F val_null() -> i64 { val_new(0, 0, 0) }
F val_bool(b: i64) -> i64 { val_new(1, b, 0) }
F val_int(n: i64) -> i64 { val_new(2, n, 0) }

F val_string(s: i64, len: i64) -> i64 {
    buf := malloc(len + 1)
    copy_bytes(buf, s, len, 0)
    store_byte(buf + len, 0)
    val_new(3, buf, len)
}

F val_string_from_cstr(s: i64) -> i64 {
    val_string(s, strlen_ptr(s))
}

F val_array(arr: i64) -> i64 { val_new(4, arr, 0) }
F val_object(obj: i64) -> i64 { val_new(5, obj, 0) }

# =====================================================
# JSON Parser
# =====================================================

# Parser state: [input: i64, pos: i64, len: i64, error: i64]
F parser_new(input: i64) -> i64 {
    p := malloc(32)
    store_i64(p, input)
    store_i64(p + 8, 0)
    store_i64(p + 16, strlen_ptr(input))
    store_i64(p + 24, 0)  # no error
    p
}

F parser_pos(p: i64) -> i64 { load_i64(p + 8) }
F parser_len(p: i64) -> i64 { load_i64(p + 16) }
F parser_input(p: i64) -> i64 { load_i64(p) }
F parser_error(p: i64) -> i64 { load_i64(p + 24) }

F parser_set_pos(p: i64, pos: i64) -> i64 {
    store_i64(p + 8, pos)
    0
}

F parser_set_error(p: i64, msg: i64) -> i64 {
    store_i64(p + 24, msg)
    0
}

F parser_peek(p: i64) -> i64 {
    pos := parser_pos(p)
    I pos >= parser_len(p) { 0 }
    EL { load_byte(parser_input(p) + pos) }
}

F parser_advance(p: i64) -> i64 {
    c := parser_peek(p)
    parser_set_pos(p, parser_pos(p) + 1)
    c
}

F parser_skip_ws(p: i64) -> i64 {
    c := parser_peek(p)
    I c == 32 || c == 9 || c == 10 || c == 13 {
        parser_advance(p)
        parser_skip_ws(p)
    } EL { 0 }
}

F parser_expect(p: i64, expected: i64) -> i64 {
    c := parser_advance(p)
    I c == expected { 1 }
    EL {
        parser_set_error(p, str_to_ptr("unexpected character"))
        0
    }
}

# Parse null
F parse_null(p: i64) -> i64 {
    # Expect "null"
    I parser_expect(p, 110) == 0 { R 0 }  # 'n'
    I parser_expect(p, 117) == 0 { R 0 }  # 'u'
    I parser_expect(p, 108) == 0 { R 0 }  # 'l'
    I parser_expect(p, 108) == 0 { R 0 }  # 'l'
    val_null()
}

# Parse true
F parse_true(p: i64) -> i64 {
    I parser_expect(p, 116) == 0 { R 0 }  # 't'
    I parser_expect(p, 114) == 0 { R 0 }  # 'r'
    I parser_expect(p, 117) == 0 { R 0 }  # 'u'
    I parser_expect(p, 101) == 0 { R 0 }  # 'e'
    val_bool(1)
}

# Parse false
F parse_false(p: i64) -> i64 {
    I parser_expect(p, 102) == 0 { R 0 }  # 'f'
    I parser_expect(p, 97) == 0 { R 0 }   # 'a'
    I parser_expect(p, 108) == 0 { R 0 }  # 'l'
    I parser_expect(p, 115) == 0 { R 0 }  # 's'
    I parser_expect(p, 101) == 0 { R 0 }  # 'e'
    val_bool(0)
}

# Parse number (integer only)
F parse_number(p: i64) -> i64 {
    is_neg := I parser_peek(p) == 45 { parser_advance(p); 1 } EL { 0 }
    # Read digits
    result := parse_digits(p, 0, 0)
    I result < 0 {
        parser_set_error(p, str_to_ptr("invalid number"))
        R 0
    }
    I is_neg == 1 { val_int(0 - result) }
    EL { val_int(result) }
}

F parse_digits(p: i64, acc: i64, count: i64) -> i64 {
    c := parser_peek(p)
    I c >= 48 && c <= 57 {
        parser_advance(p)
        parse_digits(p, acc * 10 + (c - 48), count + 1)
    } EL {
        I count == 0 { 0 - 1 }  # No digits found
        EL { acc }
    }
}

# Parse string
F parse_string(p: i64) -> i64 {
    I parser_expect(p, 34) == 0 { R 0 }  # opening "
    b := buf_new()
    result := parse_string_chars(p, b)
    I result == 0 {
        buf_free(b)
        R 0
    }
    data := buf_data(b)
    len := buf_len(b)
    v := val_string(data, len)
    buf_free(b)
    v
}

F parse_string_chars(p: i64, b: i64) -> i64 {
    c := parser_peek(p)
    I c == 0 {
        parser_set_error(p, str_to_ptr("unterminated string"))
        R 0
    }
    I c == 34 {
        # closing "
        parser_advance(p)
        R 1
    }
    I c == 92 {
        # backslash escape
        parser_advance(p)
        ec := parser_advance(p)
        I ec == 34 { buf_push_byte(b, 34) }
        EL I ec == 92 { buf_push_byte(b, 92) }
        EL I ec == 110 { buf_push_byte(b, 10) }  # \n
        EL I ec == 116 { buf_push_byte(b, 9) }   # \t
        EL I ec == 114 { buf_push_byte(b, 13) }  # \r
        EL I ec == 47 { buf_push_byte(b, 47) }   # \/
        EL { buf_push_byte(b, ec) }
        parse_string_chars(p, b)
    } EL {
        parser_advance(p)
        buf_push_byte(b, c)
        parse_string_chars(p, b)
    }
}

# Parse array
F parse_array(p: i64) -> i64 {
    I parser_expect(p, 91) == 0 { R 0 }  # '['
    parser_skip_ws(p)
    arr := arr_new()
    I parser_peek(p) == 93 {
        # empty array
        parser_advance(p)
        R val_array(arr)
    }
    result := parse_array_elements(p, arr)
    I result == 0 { R 0 }
    val_array(arr)
}

F parse_array_elements(p: i64, arr: i64) -> i64 {
    parser_skip_ws(p)
    v := parse_value(p)
    I v == 0 { R 0 }
    arr_push(arr, v)
    parser_skip_ws(p)
    c := parser_peek(p)
    I c == 44 {
        # comma -> more elements
        parser_advance(p)
        parse_array_elements(p, arr)
    } EL I c == 93 {
        # closing ]
        parser_advance(p)
        1
    } EL {
        parser_set_error(p, str_to_ptr("expected ',' or ']' in array"))
        0
    }
}

# Parse object
F parse_object(p: i64) -> i64 {
    I parser_expect(p, 123) == 0 { R 0 }  # '{'
    parser_skip_ws(p)
    obj := obj_new()
    I parser_peek(p) == 125 {
        # empty object
        parser_advance(p)
        R val_object(obj)
    }
    result := parse_object_members(p, obj)
    I result == 0 { R 0 }
    val_object(obj)
}

F parse_object_members(p: i64, obj: i64) -> i64 {
    parser_skip_ws(p)
    # Parse key (string)
    key_val := parse_string(p)
    I key_val == 0 { R 0 }
    key_data := val_data(key_val)
    key_len := val_extra(key_val)
    # Expect ':'
    parser_skip_ws(p)
    I parser_expect(p, 58) == 0 { R 0 }  # ':'
    # Parse value
    parser_skip_ws(p)
    v := parse_value(p)
    I v == 0 { R 0 }
    obj_set(obj, key_data, key_len, v)
    # Check comma or end
    parser_skip_ws(p)
    c := parser_peek(p)
    I c == 44 {
        parser_advance(p)
        parse_object_members(p, obj)
    } EL I c == 125 {
        parser_advance(p)
        1
    } EL {
        parser_set_error(p, str_to_ptr("expected comma or closing brace in object"))
        0
    }
}

# Main value parser dispatcher
F parse_value(p: i64) -> i64 {
    parser_skip_ws(p)
    c := parser_peek(p)
    I c == 34 { parse_string(p) }
    EL I c == 123 { parse_object(p) }
    EL I c == 91 { parse_array(p) }
    EL I c == 116 { parse_true(p) }
    EL I c == 102 { parse_false(p) }
    EL I c == 110 { parse_null(p) }
    EL I c == 45 || (c >= 48 && c <= 57) { parse_number(p) }
    EL {
        parser_set_error(p, str_to_ptr("unexpected character in JSON"))
        0
    }
}

# Top-level JSON parse
F json_parse(input: i64) -> i64 {
    p := parser_new(input)
    v := parse_value(p)
    I v == 0 || parser_error(p) != 0 {
        free(p)
        R 0
    }
    free(p)
    v
}

# =====================================================
# TOML Generator
# =====================================================

# Escape and emit a TOML string value (with quotes)
F toml_emit_string(b: i64, data: i64, len: i64) -> i64 {
    buf_push_byte(b, 34)  # opening "
    toml_emit_string_chars(b, data, len, 0)
    buf_push_byte(b, 34)  # closing "
}

F toml_emit_string_chars(b: i64, data: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        c := load_byte(data + idx)
        I c == 34 {
            buf_push_byte(b, 92)  # backslash
            buf_push_byte(b, 34)  # "
        } EL I c == 92 {
            buf_push_byte(b, 92)
            buf_push_byte(b, 92)
        } EL I c == 10 {
            buf_push_byte(b, 92)
            buf_push_byte(b, 110)  # \n
        } EL I c == 9 {
            buf_push_byte(b, 92)
            buf_push_byte(b, 116)  # \t
        } EL I c == 13 {
            buf_push_byte(b, 92)
            buf_push_byte(b, 114)  # \r
        } EL {
            buf_push_byte(b, c)
        }
        toml_emit_string_chars(b, data, len, idx + 1)
    }
}

# Emit a TOML integer
F toml_emit_int(b: i64, n: i64) -> i64 {
    s := i64_to_str(n)
    buf_push_cstr(b, s)
    free(s)
    0
}

# Emit a TOML boolean
F toml_emit_bool(b: i64, v: i64) -> i64 {
    I v != 0 {
        buf_push_cstr(b, str_to_ptr("true"))
    } EL {
        buf_push_cstr(b, str_to_ptr("false"))
    }
}

# Check if a JSON value can be represented as a simple TOML value (not table)
F is_simple_value(v: i64) -> i64 {
    tag := val_tag(v)
    I tag == 0 || tag == 1 || tag == 2 || tag == 3 { 1 }
    EL I tag == 4 {
        # Array of non-objects is simple
        arr := val_data(v)
        len := arr_len(arr)
        I len == 0 { 1 }
        EL { is_simple_array(arr, len, 0) }
    }
    EL { 0 }  # objects are not simple
}

F is_simple_array(arr: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 1 }
    EL {
        elem := arr_get(arr, idx)
        tag := val_tag(elem)
        I tag == 5 { 0 }  # object in array → not simple
        EL { is_simple_array(arr, len, idx + 1) }
    }
}

# Emit a simple TOML value (not object/table)
F toml_emit_value(b: i64, v: i64) -> i64 {
    tag := val_tag(v)
    I tag == 0 {
        # null → empty string in TOML
        buf_push_cstr(b, str_to_ptr("\"\""))
    }
    EL I tag == 1 { toml_emit_bool(b, val_data(v)) }
    EL I tag == 2 { toml_emit_int(b, val_data(v)) }
    EL I tag == 3 {
        toml_emit_string(b, val_data(v), val_extra(v))
    }
    EL I tag == 4 {
        toml_emit_array(b, v)
    }
    EL I tag == 5 {
        # Inline table for nested object in array
        toml_emit_inline_table(b, v)
    }
    EL { 0 }
}

# Emit a TOML array
F toml_emit_array(b: i64, v: i64) -> i64 {
    arr := val_data(v)
    len := arr_len(arr)
    buf_push_byte(b, 91)  # '['
    toml_emit_array_elements(b, arr, len, 0)
    buf_push_byte(b, 93)  # ']'
}

F toml_emit_array_elements(b: i64, arr: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        I idx > 0 {
            buf_push_cstr(b, str_to_ptr(", "))
        }
        elem := arr_get(arr, idx)
        toml_emit_value(b, elem)
        toml_emit_array_elements(b, arr, len, idx + 1)
    }
}

# Emit an inline table { key = value, ... }
F toml_emit_inline_table(b: i64, v: i64) -> i64 {
    obj := val_data(v)
    entries_info := obj_collect_entries(obj)
    entries := load_i64(entries_info)
    count := load_i64(entries_info + 8)
    buf_push_byte(b, 123)  # '{'
    buf_push_byte(b, 32)   # ' '
    toml_emit_inline_entries(b, entries, count, 0)
    buf_push_byte(b, 32)   # ' '
    buf_push_byte(b, 125)  # '}'
    free(entries)
    free(entries_info)
    0
}

F toml_emit_inline_entries(b: i64, entries: i64, count: i64, idx: i64) -> i64 {
    I idx >= count { 0 } EL {
        I idx > 0 { buf_push_cstr(b, str_to_ptr(", ")) }
        entry := load_i64(entries + idx * 8)
        key := load_i64(entry)
        key_len := load_i64(entry + 8)
        value := load_i64(entry + 16)
        # Emit key
        toml_emit_key(b, key, key_len)
        buf_push_cstr(b, str_to_ptr(" = "))
        toml_emit_value(b, value)
        toml_emit_inline_entries(b, entries, count, idx + 1)
    }
}

# Check if a key needs quoting (bare key: [a-zA-Z0-9_-])
F needs_quoting(key: i64, len: i64) -> i64 {
    I len == 0 { 1 }
    EL { needs_quoting_rec(key, len, 0) }
}

F needs_quoting_rec(key: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 }
    EL {
        c := load_byte(key + idx)
        # Check alphanumeric or special chars allowed in bare keys
        I (c >= 48 && c <= 57) || (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 45 || c == 95 {
            needs_quoting_rec(key, len, idx + 1)
        } EL { 1 }
    }
}

F toml_emit_key(b: i64, key: i64, key_len: i64) -> i64 {
    I needs_quoting(key, key_len) == 1 {
        toml_emit_string(b, key, key_len)
    } EL {
        buf_push_str(b, key, key_len)
    }
}

# =====================================================
# JSON to TOML Conversion
# =====================================================

# Main conversion: JSON object → TOML document
# Strategy:
# 1. First pass: emit all simple key=value pairs at current level
# 2. Second pass: emit sub-tables as [section.key] headers
F convert_to_toml(v: i64) -> i64 {
    tag := val_tag(v)
    I tag != 5 {
        # Top-level must be object
        R 0
    }
    b := buf_new()
    convert_object(b, v, str_to_ptr(""), 0)
    result := buf_to_cstr(b)
    free(b)
    result
}

# Convert a JSON object to TOML, with optional section prefix
F convert_object(b: i64, v: i64, prefix: i64, prefix_len: i64) -> i64 {
    obj := val_data(v)
    entries_info := obj_collect_entries(obj)
    entries := load_i64(entries_info)
    count := load_i64(entries_info + 8)
    # Pass 1: simple values (non-object, non-table-array)
    emit_simple_entries(b, entries, count, 0)
    # Pass 2: sub-tables
    emit_table_entries(b, entries, count, 0, prefix, prefix_len)
    free(entries)
    free(entries_info)
    0
}

F emit_simple_entries(b: i64, entries: i64, count: i64, idx: i64) -> i64 {
    I idx >= count { 0 } EL {
        entry := load_i64(entries + idx * 8)
        value := load_i64(entry + 16)
        I is_simple_value(value) == 1 {
            key := load_i64(entry)
            key_len := load_i64(entry + 8)
            toml_emit_key(b, key, key_len)
            buf_push_cstr(b, str_to_ptr(" = "))
            toml_emit_value(b, value)
            buf_push_byte(b, 10)  # newline
        }
        emit_simple_entries(b, entries, count, idx + 1)
    }
}

F emit_table_entries(b: i64, entries: i64, count: i64, idx: i64, prefix: i64, prefix_len: i64) -> i64 {
    I idx >= count { 0 } EL {
        entry := load_i64(entries + idx * 8)
        value := load_i64(entry + 16)
        tag := val_tag(value)
        I tag == 5 {
            # Sub-table
            key := load_i64(entry)
            key_len := load_i64(entry + 8)
            buf_push_byte(b, 10)  # blank line before section
            # Build section header
            buf_push_byte(b, 91)  # '['
            I prefix_len > 0 {
                buf_push_str(b, prefix, prefix_len)
                buf_push_byte(b, 46)  # '.'
            }
            toml_emit_key(b, key, key_len)
            buf_push_byte(b, 93)  # ']'
            buf_push_byte(b, 10)  # newline
            # Build new prefix
            new_prefix := build_prefix(prefix, prefix_len, key, key_len)
            new_prefix_len := I prefix_len > 0 { prefix_len + 1 + key_len } EL { key_len }
            # Recurse
            convert_object(b, value, new_prefix, new_prefix_len)
            free(new_prefix)
        }
        EL I tag == 4 {
            # Check if array of objects → [[array_of_tables]]
            arr := val_data(value)
            len := arr_len(arr)
            I len > 0 && val_tag(arr_get(arr, 0)) == 5 {
                key := load_i64(entry)
                key_len := load_i64(entry + 8)
                emit_array_of_tables(b, arr, len, 0, prefix, prefix_len, key, key_len)
            }
        }
        emit_table_entries(b, entries, count, idx + 1, prefix, prefix_len)
    }
}

F build_prefix(old_prefix: i64, old_len: i64, key: i64, key_len: i64) -> i64 {
    I old_len == 0 {
        result := malloc(key_len + 1)
        copy_bytes(result, key, key_len, 0)
        store_byte(result + key_len, 0)
        R result
    }
    total := old_len + 1 + key_len
    result := malloc(total + 1)
    copy_bytes(result, old_prefix, old_len, 0)
    store_byte(result + old_len, 46)  # '.'
    copy_bytes(result + old_len + 1, key, key_len, 0)
    store_byte(result + total, 0)
    result
}

# Emit [[array_of_tables]]
F emit_array_of_tables(b: i64, arr: i64, len: i64, idx: i64, prefix: i64, prefix_len: i64, key: i64, key_len: i64) -> i64 {
    I idx >= len { 0 } EL {
        buf_push_byte(b, 10)
        buf_push_byte(b, 91)   # '['
        buf_push_byte(b, 91)   # '['
        I prefix_len > 0 {
            buf_push_str(b, prefix, prefix_len)
            buf_push_byte(b, 46)
        }
        toml_emit_key(b, key, key_len)
        buf_push_byte(b, 93)   # ']'
        buf_push_byte(b, 93)   # ']'
        buf_push_byte(b, 10)
        elem := arr_get(arr, idx)
        new_prefix := build_prefix(prefix, prefix_len, key, key_len)
        new_prefix_len := I prefix_len > 0 { prefix_len + 1 + key_len } EL { key_len }
        convert_object(b, elem, new_prefix, new_prefix_len)
        free(new_prefix)
        emit_array_of_tables(b, arr, len, idx + 1, prefix, prefix_len, key, key_len)
    }
}

# =====================================================
# JSON Stringify (for debug / round-trip)
# =====================================================

F json_stringify(v: i64) -> i64 {
    b := buf_new()
    json_stringify_value(b, v)
    result := buf_to_cstr(b)
    free(b)
    result
}

F json_stringify_value(b: i64, v: i64) -> i64 {
    tag := val_tag(v)
    I tag == 0 { buf_push_cstr(b, str_to_ptr("null")) }
    EL I tag == 1 {
        I val_data(v) != 0 { buf_push_cstr(b, str_to_ptr("true")) }
        EL { buf_push_cstr(b, str_to_ptr("false")) }
    }
    EL I tag == 2 { toml_emit_int(b, val_data(v)) }
    EL I tag == 3 {
        buf_push_byte(b, 34)
        buf_push_str(b, val_data(v), val_extra(v))
        buf_push_byte(b, 34)
    }
    EL I tag == 4 {
        arr := val_data(v)
        len := arr_len(arr)
        buf_push_byte(b, 91)
        json_stringify_arr(b, arr, len, 0)
        buf_push_byte(b, 93)
    }
    EL I tag == 5 {
        obj := val_data(v)
        entries_info := obj_collect_entries(obj)
        entries := load_i64(entries_info)
        count := load_i64(entries_info + 8)
        buf_push_byte(b, 123)
        json_stringify_obj_entries(b, entries, count, 0)
        buf_push_byte(b, 125)
        free(entries)
        free(entries_info)
    }
    0
}

F json_stringify_arr(b: i64, arr: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        I idx > 0 { buf_push_byte(b, 44) }
        json_stringify_value(b, arr_get(arr, idx))
        json_stringify_arr(b, arr, len, idx + 1)
    }
}

F json_stringify_obj_entries(b: i64, entries: i64, count: i64, idx: i64) -> i64 {
    I idx >= count { 0 } EL {
        I idx > 0 { buf_push_byte(b, 44) }
        entry := load_i64(entries + idx * 8)
        key := load_i64(entry)
        key_len := load_i64(entry + 8)
        value := load_i64(entry + 16)
        buf_push_byte(b, 34)
        buf_push_str(b, key, key_len)
        buf_push_byte(b, 34)
        buf_push_byte(b, 58)
        json_stringify_value(b, value)
        json_stringify_obj_entries(b, entries, count, idx + 1)
    }
}

# =====================================================
# Validation & Statistics
# =====================================================

# Count total nodes in JSON value tree
F count_nodes(v: i64) -> i64 {
    I v == 0 { 0 }
    EL {
        tag := val_tag(v)
        I tag == 4 {
            arr := val_data(v)
            1 + count_arr_nodes(arr, arr_len(arr), 0)
        }
        EL I tag == 5 {
            obj := val_data(v)
            entries_info := obj_collect_entries(obj)
            entries := load_i64(entries_info)
            count := load_i64(entries_info + 8)
            result := 1 + count_obj_nodes(entries, count, 0)
            free(entries)
            free(entries_info)
            result
        }
        EL { 1 }
    }
}

F count_arr_nodes(arr: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 }
    EL { count_nodes(arr_get(arr, idx)) + count_arr_nodes(arr, len, idx + 1) }
}

F count_obj_nodes(entries: i64, count: i64, idx: i64) -> i64 {
    I idx >= count { 0 }
    EL {
        entry := load_i64(entries + idx * 8)
        value := load_i64(entry + 16)
        count_nodes(value) + count_obj_nodes(entries, count, idx + 1)
    }
}

# Count depth of value tree
F max_depth(v: i64) -> i64 {
    I v == 0 { 0 }
    EL {
        tag := val_tag(v)
        I tag == 4 {
            arr := val_data(v)
            1 + max_depth_arr(arr, arr_len(arr), 0, 0)
        }
        EL I tag == 5 {
            obj := val_data(v)
            entries_info := obj_collect_entries(obj)
            entries := load_i64(entries_info)
            count := load_i64(entries_info + 8)
            result := 1 + max_depth_obj(entries, count, 0, 0)
            free(entries)
            free(entries_info)
            result
        }
        EL { 1 }
    }
}

F max_depth_arr(arr: i64, len: i64, idx: i64, best: i64) -> i64 {
    I idx >= len { best }
    EL {
        d := max_depth(arr_get(arr, idx))
        new_best := I d > best { d } EL { best }
        max_depth_arr(arr, len, idx + 1, new_best)
    }
}

F max_depth_obj(entries: i64, count: i64, idx: i64, best: i64) -> i64 {
    I idx >= count { best }
    EL {
        entry := load_i64(entries + idx * 8)
        value := load_i64(entry + 16)
        d := max_depth(value)
        new_best := I d > best { d } EL { best }
        max_depth_obj(entries, count, idx + 1, new_best)
    }
}

# =====================================================
# Memory cleanup
# =====================================================

F val_free(v: i64) -> i64 {
    I v == 0 { R 0 }
    tag := val_tag(v)
    I tag == 3 {
        # Free string data
        data := val_data(v)
        I data != 0 { free(data) }
    }
    EL I tag == 4 {
        # Free array elements
        arr := val_data(v)
        free_arr_elements(arr, arr_len(arr), 0)
        free(load_i64(arr))  # data array
        free(arr)
    }
    EL I tag == 5 {
        # Free object entries
        obj := val_data(v)
        free_obj_entries(obj)
        free(load_i64(obj))  # buckets
        free(obj)
    }
    free(v)
    0
}

F free_arr_elements(arr: i64, len: i64, idx: i64) -> i64 {
    I idx >= len { 0 } EL {
        val_free(arr_get(arr, idx))
        free_arr_elements(arr, len, idx + 1)
    }
}

F free_obj_entries(obj: i64) -> i64 {
    cap := load_i64(obj + 16)
    buckets := load_i64(obj)
    free_obj_buckets(buckets, cap, 0)
}

F free_obj_buckets(buckets: i64, cap: i64, idx: i64) -> i64 {
    I idx >= cap { 0 } EL {
        entry := load_i64(buckets + idx * 8)
        free_obj_chain(entry)
        free_obj_buckets(buckets, cap, idx + 1)
    }
}

F free_obj_chain(node: i64) -> i64 {
    I node == 0 { 0 } EL {
        next := load_i64(node + 24)
        key := load_i64(node)
        I key != 0 { free(key) }
        val_free(load_i64(node + 16))
        free(node)
        free_obj_chain(next)
    }
}

# =====================================================
# Test runner / Main program
# =====================================================

# Test 1: Simple object conversion (name=Alice, age=30, active=true)
F test_simple_object() -> i64 {
    obj := obj_new()
    obj_set(obj, str_to_ptr("name"), 4, val_string_from_cstr(str_to_ptr("Alice")))
    obj_set(obj, str_to_ptr("age"), 3, val_int(30))
    obj_set(obj, str_to_ptr("active"), 6, val_bool(1))
    v := val_object(obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 5 { result = result + 1 }
    I count_nodes(v) == 4 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}

# Test 2: Nested object conversion (server.host, server.port, debug)
F test_nested_object() -> i64 {
    server_obj := obj_new()
    obj_set(server_obj, str_to_ptr("host"), 4, val_string_from_cstr(str_to_ptr("localhost")))
    obj_set(server_obj, str_to_ptr("port"), 4, val_int(8080))

    root_obj := obj_new()
    obj_set(root_obj, str_to_ptr("server"), 6, val_object(server_obj))
    obj_set(root_obj, str_to_ptr("debug"), 5, val_bool(0))

    v := val_object(root_obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 10 { result = result + 1 }
    I max_depth(v) == 3 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}

# Test 3: Array values (ports=[80,443,8080], names=["a","b"])
F test_array_values() -> i64 {
    ports := arr_new()
    arr_push(ports, val_int(80))
    arr_push(ports, val_int(443))
    arr_push(ports, val_int(8080))

    names := arr_new()
    arr_push(names, val_string_from_cstr(str_to_ptr("a")))
    arr_push(names, val_string_from_cstr(str_to_ptr("b")))

    root_obj := obj_new()
    obj_set(root_obj, str_to_ptr("ports"), 5, val_array(ports))
    obj_set(root_obj, str_to_ptr("names"), 5, val_array(names))

    v := val_object(root_obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 5 { result = result + 1 }
    I count_nodes(v) == 8 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}

# Test 4: Array of tables (users=[{name,id},{name,id}])
F test_array_of_tables() -> i64 {
    user1 := obj_new()
    obj_set(user1, str_to_ptr("name"), 4, val_string_from_cstr(str_to_ptr("Alice")))
    obj_set(user1, str_to_ptr("id"), 2, val_int(1))

    user2 := obj_new()
    obj_set(user2, str_to_ptr("name"), 4, val_string_from_cstr(str_to_ptr("Bob")))
    obj_set(user2, str_to_ptr("id"), 2, val_int(2))

    users := arr_new()
    arr_push(users, val_object(user1))
    arr_push(users, val_object(user2))

    root_obj := obj_new()
    obj_set(root_obj, str_to_ptr("users"), 5, val_array(users))

    v := val_object(root_obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 10 { result = result + 1 }
    I count_nodes(v) == 8 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}


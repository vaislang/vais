# Test 6: String with special chars
F test_escapes() -> i64 {
    obj := obj_new()
    # Build string with newline: "hello\nworld"
    msg := malloc(12)
    copy_bytes(msg, str_to_ptr("hello"), 5, 0)
    store_byte(msg + 5, 10)  # newline
    copy_bytes(msg + 6, str_to_ptr("world"), 5, 0)
    store_byte(msg + 11, 0)
    obj_set(obj, str_to_ptr("msg"), 3, val_string(msg, 11))
    obj_set(obj, str_to_ptr("path"), 4, val_string_from_cstr(str_to_ptr("c:\\dir")))
    free(msg)

    v := val_object(obj)
    toml := convert_to_toml(v)
    I toml == 0 { val_free(v); R 0 }
    result := 1
    I strlen_ptr(toml) > 5 { result = result + 1 }
    free(toml)
    val_free(v)
    result
}


}

# Test 9: JSON parse from valid string (no braces in string literal)
F test_json_parse() -> i64 {
    # Build JSON string: [1,2,3] — no braces needed
    input := str_to_ptr("[1,2,3]")
    v := json_parse(input)
    I v == 0 { R 0 }
    result := 1
    I val_tag(v) == 4 { result = result + 1 }  # array
    val_free(v)
    result
}

# Test 10: Non-object root (error case — array cannot convert to TOML)
F test_non_object_root() -> i64 {
    # Build an array value using API
    arr := arr_new()
    arr_push(arr, val_int(1))
    arr_push(arr, val_int(2))
    arr_push(arr, val_int(3))
    v := val_array(arr)
    toml := convert_to_toml(v)
    # Array as root should fail
    I toml == 0 { val_free(v); R 2 }
    EL {
        free(toml)
        val_free(v)
        0
    }
}


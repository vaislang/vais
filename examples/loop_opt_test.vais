# Loop optimization test (recursive version)

fn sum_to_n_rec(i: i64, n: i64, acc: i64) -> i64 {
    I i >= n { acc }
    else { sum_to_n_rec(i + 1, n, acc + i) }
}

fn sum_to_n(n: i64) -> i64 {
    sum_to_n_rec(0, n, 0)
}

fn sum_squares_rec(i: i64, n: i64, acc: i64) -> i64 {
    I i >= n { acc }
    else {
        sq := i * i
        sum_squares_rec(i + 1, n, acc + sq)
    }
}

fn sum_squares(n: i64) -> i64 {
    sum_squares_rec(0, n, 0)
}

fn main() -> i64 {
    puts("=== Loop Optimization Test ===")

    s1 := sum_to_n(10)
    puts("sum_to_n(10) = ")
    print_num(s1)
    putchar(10)

    s2 := sum_squares(5)
    puts("sum_squares(5) = ")
    print_num(s2)
    putchar(10)

    puts("=== Test Complete ===")
    0
}

fn print_num(n: i64) -> i64 {
    I n >= 10 {
        print_num(n / 10)
        0
    } else { 0 }
    putchar(n % 10 + 48)
    0
}

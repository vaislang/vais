# expect: 42

fn make_scores() -> Map<Int,Int> {
    let scores: Map<Int,Int> = {}
    scores.insert(4, 40)
    scores.insert(9, 2)
    return scores
}

fn main() -> Int {
    let scores: Map<Int,Int> = make_scores()
    if scores.contains(4) and scores.contains(9) {
        return scores.get(4, 0) + scores.get(9, 0)
    }
    return 0
}

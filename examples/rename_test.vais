# Test file for LSP rename functionality

# Structure with fields
struct Point {
    x: i64,
    y: i64
}

# Function using the structure
fn create_point(a: i64, b: i64) -> Point {
    return Point { x: a, y: b }
}

# Function with local variables
fn calculate(value: i64) -> i64 {
    result := value * 2
    temp := result + 10
    return temp
}

# Enum definition
enum Color {
    Red,
    Green,
    Blue
}

# Function using enum
fn get_color_value(color: Color) -> i64 {
    match color {
        Red => 1,
        Green => 2,
        Blue => 3
    }
}

# Main function
fn main() -> i64 {
    point := create_point(10, 20)
    x_val := point.x
    computed := calculate(x_val)

    my_color := Red
    color_val := get_color_value(my_color)

    return computed + color_val
}

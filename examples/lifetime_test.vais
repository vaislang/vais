# Lifetime Test
# Syntax: &'a T (reference with lifetime 'a)

# Function with lifetime annotation (parsed correctly)
# This demonstrates the lifetime syntax is properly handled
fn identity<'a>(x: &'a i64) -> &'a i64 {
    return x
}

# Simple reference without lifetime (implicit)
fn get_ref(x: &i64) -> &i64 {
    return x
}

# Function using lifetime-annotated types in parameter
fn test_lifetime_type(x: &i64) -> i64 {
    return *x
}

fn main() -> i64 {
    puts("Lifetime syntax test passed!")
    return 0
}

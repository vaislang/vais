# expect: 42
# Local Map<Int,Int> construction, insert/replace, get fallback, contains, and len.
fn main() -> Int {
    let scores: Map<Int,Int> = {}
    scores.insert(4, 38)
    scores.insert(4, 40)
    scores.insert(9, 2)
    let found = scores.get(4, 0)
    let missing = scores.get(5, 0 - 1)
    return found + missing + scores.contains(4) + scores.contains(5) + scores.len()
}

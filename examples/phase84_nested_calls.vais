# Phase 84: Nested function calls
fn double(x: i64) -> i64 = x * 2
fn add1(x: i64) -> i64 = x + 1
fn square(x: i64) -> i64 = x * x

fn compose(x: i64) -> i64 {
    a := double(x)
    b := add1(a)
    c := square(b)
    c
}

fn main() -> i64 {
    # compose(3) = square(add1(double(3))) = square(add1(6)) = square(7) = 49
    result := compose(3)
    puts("nested calls done")
    result
}

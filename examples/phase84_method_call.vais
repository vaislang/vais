# Phase 84: Struct method call
struct Counter {
    value: i64
}

impl Counter {
    fn new() -> Counter {
        Counter { value: 0 }
    }

    fn get(self) -> i64 {
        self.value
    }
}

fn main() -> i64 {
    c := Counter.new()
    result := c.get()
    puts("method call done")
    result
}

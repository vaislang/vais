# Test Iterator trait pattern

trait Iterator {
    fn next(&self) -> i64
}

struct Range {
    current: i64,
    end: i64,
    step: i64
}

# Simple impl block (no trait)
impl Range {
    fn has_next(&self) -> i64 {
        I self.current < self.end { 1 } else { 0 }
    }
}

# Implement Iterator trait
impl Range: Iterator {
    fn next(&self) -> i64 {
        I self.current < self.end {
            value := self.current
            self.current = self.current + self.step
            value
        } else {
            0 - 1
        }
    }
}

fn main() -> i64 {
    puts("Testing iterator trait:")

    r := Range { current: 0, end: 5, step: 1 }

    L {
        v := r.next()
        I v < 0 { B 0 }
        putchar(v + 48)
        putchar(32)
    }
    putchar(10)

    puts("Done!")
    0
}

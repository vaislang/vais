# FizzBuzz — Classic interview problem in Vais
# Demonstrates: range loop, if-else chains, modulo, string output
#
# Run: vaisc run examples/fizzbuzz.vais

F fizzbuzz(n: i64) -> i64 {
    LF i:1..n+1 {
        I i % 15 == 0 {
            puts("FizzBuzz")
        } EL I i % 3 == 0 {
            puts("Fizz")
        } EL I i % 5 == 0 {
            puts("Buzz")
        } EL {
            puts("{i}")
        }
    }
    0
}

F main() -> i64 {
    puts("=== FizzBuzz 1..20 ===")
    fizzbuzz(20)
}

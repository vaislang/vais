# Simple comptime test - basic arithmetic

fn test1()->i64 = comptime { 4 * 8 }

fn test2()->i64 = comptime { 10 + 20 }

fn test3()->i64 = comptime { I 5 > 3 { 1 } else { 0 } }

fn main()->i64 {
    printf("Test 1 (4 * 8): %ld\n", test1())
    printf("Test 2 (10 + 20): %ld\n", test2())
    printf("Test 3 (5 > 3): %d\n", test3())
    0
}

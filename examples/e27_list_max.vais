# expect: 9
# Find the max of a List passed as a parameter (loop + running max).
# NOTE: bind the typed list before passing it; inline list literals as full-path
# call arguments remain a tracked Vais coercion gap.
fn maxof(xs: List<Int>) -> Int {
    let mut m = 0
    for x in xs {
        if x > m { m = x }
    }
    return m
}

fn main() -> Int {
    let v: List<Int> = [3, 9, 2, 7]
    return maxof(v)
}

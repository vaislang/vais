# expect: 9
# Find the max of a List passed as a parameter (loop + running max).
# NOTE: build the list via a bound variable; inline list literals and typed
# non-empty list literals remain tracked Vais coercion gaps in the full path.
fn maxof(xs: List<Int>) -> Int {
    let mut m = 0
    for x in xs {
        if x > m { m = x }
    }
    return m
}

fn main() -> Int {
    let v = list()
    v.push(3)
    v.push(9)
    v.push(2)
    v.push(7)
    return maxof(v)
}

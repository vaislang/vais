# Absolutely minimal test for generic Vec<T>

struct SimpleVec<T> {
    data: i64,
    len: i64
}

impl SimpleVec<T> {
    fn new() -> SimpleVec<T> {
        SimpleVec { data: 0, len: 0 }
    }

    fn push(&self, value: T) -> i64 {
        self.len = self.len + 1
        self.len
    }

    fn get(&self, index: i64) -> T {
        0
    }
}

fn main() -> i64 {
    v := SimpleVec.new()
    v.push(42)
    x := v.get(0)
    x
}

# GAT Container pattern
# Demonstrates Generic Associated Types with container-like trait

trait Container {
    type Elem
    fn get(&self, idx: i64) -> i64
    fn size(&self) -> i64
}

struct IntArray {
    len: i64
}

impl IntArray: Container {
    type Elem = i64
    fn get(&self, idx: i64) -> i64 {
        idx
    }
    fn size(&self) -> i64 {
        self.len
    }
}

fn main() -> i64 {
    arr := IntArray { len: 10 }
    arr.size() + arr.get(5)
}

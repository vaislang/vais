# expect: 42

struct Box {
    value: Int,
    tag: Int,
}

fn sum_boxes(xs: List<Box>) -> Int {
    return xs[0].value + xs[1].tag + xs[2].value + xs[3].tag + xs.len()
}

fn main() -> Int {
    let xs: List<Box> = [Box { value: 1, tag: 1 }]
    xs.insert_at(1, Box {
        value: 20,
        tag: 2,
    })
    xs.extend([
        Box {
            value: 30,
            tag: 3,
        },
        Box {
            value: 4,
            tag: 5,
        },
    ])
    return sum_boxes(xs)
}

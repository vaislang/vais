# expect: 42
# The first Map<Int,Int> + Option<Int> integration: get_opt returns Some(value)
# when a key is present and None when it is absent.
fn main() -> Int {
    let scores: Map<Int,Int> = {}
    scores.insert(4, 40)
    scores.insert(9, 2)
    let found = match scores.get_opt(4) { Some(v) => v, None => 0 }
    let missing = match scores.get_opt(5) { Some(v) => v, None => 2 }
    return found + missing
}

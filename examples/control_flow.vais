# If/Else example: returns max of a, b (using ternary for now)
fn max(a:i64, b:i64)->i64 = a > b ? a : b

# Loop example using ternary for countdown logic
fn countdown(n:i64)->i64 = n < 1 ? 0 : @(n-1)

# Factorial using ternary
fn factorial(n:i64)->i64 = n < 2 ? 1 : n * @(n-1)

# Main: test the functions
fn main()->i64 = factorial(5)

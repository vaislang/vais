# GAT Iterator pattern
# Demonstrates Generic Associated Types with iterator-like trait

trait Iterable {
    type Item
    fn iter(&self) -> i64
}

struct Numbers {
    count: i64
}

impl Numbers: Iterable {
    type Item = i64
    fn iter(&self) -> i64 {
        self.count
    }
}

fn main() -> i64 {
    n := Numbers { count: 42 }
    n.iter()
}

# Phase 44 Cross-verify: Trait bounds & generic functions (Phase 40)
# Tests trait implementation, bounds verification, and generic call dispatch

trait Summable {
    fn sum(&self) -> i64
}

struct Pair { a: i64, b: i64 }

impl Pair: Summable {
    fn sum(&self) -> i64 {
        self.a + self.b
    }
}

fn identity<T>(x: T) -> T {
    x
}

fn main() -> i64 {
    p := Pair { a: 20, b: 22 }
    result := p.sum()
    x := identity(result)
    x - 42
}

# Test Option<T> without std/option import - inline definition

enum SimpleOption<T> {
    None,
    Some(T)
}

impl SimpleOption<T> {
    fn is_some(&self) -> i64 {
        match self {
            Some(_) => 1,
            None => 0
        }
    }
}

fn main() -> i64 {
    x := Some(42)
    match x {
        Some(v) => v,
        None => 0
    }
}

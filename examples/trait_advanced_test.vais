# Advanced trait test: Super traits and Associated types

# Base trait
trait Printable {
    fn print(&self) -> i64
}

# Trait with super trait
trait Displayable: Printable {
    fn format(&self) -> i64
}

# Trait with associated type
trait Container {
    type Item                     # Associated type declaration
    fn get(&self) -> i64
    fn size(&self) -> i64
}

# Simple struct
struct Counter { value: i64 }

# Implement Printable
impl Counter: Printable {
    fn print(&self) -> i64 {
        self.value
    }
}

fn main() -> i64 {
    puts("=== Advanced Trait Test ===")
    putchar(10)

    c := Counter { value: 42 }
    puts("Counter.print() =")
    v := c.print()
    putchar(v / 10 + 48)
    putchar(v % 10 + 48)
    putchar(10)

    puts("=== Test passed! ===")
    0
}

# expect: 10
# Recursion over a borrowed List (`&List<Int>`). Summing a list recursively is
# the canonical "walk a collection" shape needed for interpreters and tree
# walkers.

fn sum_from(v: &List<Int>, i: Int, n: Int) -> Int {
    if i >= n { return 0 }
    let rest = sum_from(v, i + 1, n)
    return v[i] + rest
}

fn main() -> Int {
    let nums: List<Int> = [1, 2, 3, 4]
    return sum_from(&nums, 0, 4)
}

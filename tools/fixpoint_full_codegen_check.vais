    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_176_l566", "struct Token {{ kind, value }}; fn tokenize(src: Str) -> List<Token> {{ let toks = list(); let n = src.len(); let mut i = 0; while i < n {{ let c = src[i]; if c >= 48 and c <= 57 {{ let mut v = 0; let mut go = true; while go {{ if i >= n {{ go = false }} else if src[i] >= 48 and src[i] <= 57 {{ v = v * 10 + (src[i] - 48); i = i + 1 }} else {{ go = false }} }}; toks.push(Token {{ kind: 0, value: v }}) }} else if c == 43 {{ toks.push(Token {{ kind: 1, value: 0 }}); i = i + 1 }} else if c == 42 {{ toks.push(Token {{ kind: 2, value: 0 }}); i = i + 1 }} else {{ i = i + 1 }} }}; return toks }}; fn eval_term(toks: List<Token>, i: Int, n: Int, acc: Int) {{ if i >= n {{ return acc }}; let t = toks[i]; if t.kind == 2 {{ let rhs = toks[i + 1]; return eval_term(toks, i + 2, n, acc * rhs.value) }}; return acc }}; fn skip_term(toks: List<Token>, i: Int, n: Int) {{ if i >= n {{ return n }}; let t = toks[i]; if t.kind == 2 {{ return skip_term(toks, i + 2, n) }}; return i }}; fn eval_fold(toks: List<Token>, i: Int, n: Int, acc: Int) {{ if i >= n {{ return acc }}; let op = toks[i]; if op.kind == 1 {{ let rs = i + 1; let rf = toks[rs]; let term = eval_term(toks, rs + 1, n, rf.value); let after = skip_term(toks, rs + 1, n); return eval_fold(toks, after, n, acc + term) }}; return acc }}; fn eval_expr(toks: List<Token>, n: Int) {{ if n <= 0 {{ return 0 }}; let first = toks[0]; let acc = eval_term(toks, 1, n, first.value); let after = skip_term(toks, 1, n); return eval_fold(toks, after, n, acc) }}; fn run() {{ let toks = tokenize(`2 + 3 * 4`); return eval_expr(toks, toks.len) }}; return run();", 14)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_177_l567", "struct Token {{ kind, value }}; fn tokenize(src: Str) -> List<Token> {{ let toks = list(); let n = src.len(); let mut i = 0; while i < n {{ let c = src[i]; if c >= 48 and c <= 57 {{ let mut v = 0; let mut go = true; while go {{ if i >= n {{ go = false }} else if src[i] >= 48 and src[i] <= 57 {{ v = v * 10 + (src[i] - 48); i = i + 1 }} else {{ go = false }} }}; toks.push(Token {{ kind: 0, value: v }}) }} else if c == 43 {{ toks.push(Token {{ kind: 1, value: 0 }}); i = i + 1 }} else if c == 42 {{ toks.push(Token {{ kind: 2, value: 0 }}); i = i + 1 }} else {{ i = i + 1 }} }}; return toks }}; fn eval_term(toks: List<Token>, i: Int, n: Int, acc: Int) {{ if i >= n {{ return acc }}; let t = toks[i]; if t.kind == 2 {{ let rhs = toks[i + 1]; return eval_term(toks, i + 2, n, acc * rhs.value) }}; return acc }}; fn skip_term(toks: List<Token>, i: Int, n: Int) {{ if i >= n {{ return n }}; let t = toks[i]; if t.kind == 2 {{ return skip_term(toks, i + 2, n) }}; return i }}; fn eval_fold(toks: List<Token>, i: Int, n: Int, acc: Int) {{ if i >= n {{ return acc }}; let op = toks[i]; if op.kind == 1 {{ let rs = i + 1; let rf = toks[rs]; let term = eval_term(toks, rs + 1, n, rf.value); let after = skip_term(toks, rs + 1, n); return eval_fold(toks, after, n, acc + term) }}; return acc }}; fn eval_expr(toks: List<Token>, n: Int) {{ if n <= 0 {{ return 0 }}; let first = toks[0]; let acc = eval_term(toks, 1, n, first.value); let after = skip_term(toks, 1, n); return eval_fold(toks, after, n, acc) }}; fn run() {{ let toks = tokenize(`10 + 20 + 30`); return eval_expr(toks, toks.len) }}; return run();", 60)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_178_l585", "let mut s = 0; for i in 0..5 {{ s = s + i }}; return s;", 10)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_178a_for_each_array", "let xs = [1, 2, 3, 4, 5, 6]; let mut s = 0; for x in xs {{ if x % 2 == 0 {{ s = s + x }} }}; return s;", 12)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_178b_for_each_list", "let xs = list(); xs.push(10); xs.push(20); xs.push(12); let mut s = 0; for x in xs {{ s = s + x }}; return s;", 42)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_179_l586", "let mut s = 0; for i in 0..=5 {{ s = s + i }}; return s;", 15)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_180_l587", "let mut s = 0; for i in 1..4 {{ s = s + i }}; return s;", 6)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_181_l588", "let mut s = 0; for i in 0..3 {{ s = s + i * 2 }}; return s;", 6)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_182_l589", "fn sumto(n) {{ let mut s = 0; for i in 0..n {{ s = s + i }}; return s }}; return sumto(5);", 10)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_183_l590", "let mut c = 0; for i in 0..3 {{ for j in 0..3 {{ c = c + 1 }} }}; return c;", 9)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_184_l591", "let mut s = 0; for i in 0..6 {{ if i > 2 {{ s = s + i }} }}; return s;", 12)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_185_l592", "let mut s = 0; for i in 0..10 {{ if i == 3 {{ continue }}; if i == 6 {{ break }}; s = s + i }}; return s;", 12)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_186_l593", "let mut i = 0; let mut s = 0; while i < 6 {{ i = i + 1; if i == 3 {{ continue }}; if i == 5 {{ break }}; s = s + i }}; return s;", 7)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_187_l594", "let xs = list(); for i in 0..5 {{ xs.push(i * 10) }}; let mut s = 0; let mut j = 0; while j < xs.len {{ s = s + xs[j]; j = j + 1 }}; return s;", 100)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_188_l595", "let mut s = 0; for i in 1..=3 {{ for j in 1..=i {{ s = s + 1 }} }}; return s;", 6)
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_189_l621", "fn show() {{ putchar(72); putchar(73); return 0 }}; return show();", "HI")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_190_l622", "fn stars(n) {{ let mut i = 0; while i < n {{ putchar(42); i = i + 1 }}; return 0 }}; return stars(5);", "*****")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_191_l631", "print(`hello world`); return 0;", "hello world")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_192_l632", "let v = 42; print(`ret i64 {{v}}`); return 0;", "ret i64 42")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_193_l633", "let c = 3; let lv = 7; print(`%t{{c}} = add i64 {{lv}}`); return 0;", "%t3 = add i64 7")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_194_l634", "let a = 1; let b = 2; let cc = 3; print(`{{a}} {{b}} {{cc}}`); return 0;", "1 2 3")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_195_l635", "let op_s = `mul`; print(`op={{op_s}}`); return 0;", "op=mul")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_196_l636", "fn emit(op_s: Str, value: Int) {{ print(`  ret {{op_s}} {{value}}`); return 0 }}; return emit(`i64`, 42);", "  ret i64 42")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_197_l637", "let c = 3; let op_s = `add`; print(`%t{{c}} = {{op_s}} i64 2, 4`); return 0;", "%t3 = add i64 2, 4")
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_198_l638", "let mut i = 0; while i < 3 {{ print(`line {{i}}`); i = i + 1 }}; return 0;", want_loop_lines())
    fail = fail + run_stdout_case(vaisc, helper, harness, tmp, "case_199_l641", "fn emit(value) {{ print(`define i64 @main() {{`); print(`  ret i64 {{value}}`); print(`}}`); return 0 }}; return emit(99);", want_emit_lines())
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_200_l667", "fn main() {{ return 42 }}", 42)
    return fail
}

fn usage() -> Int {
    print("usage: fixpoint-full-codegen-check <repo-root> <tmp-dir>")
    return 2
}

fn main() -> Int {
    if proc_argc() != 2 { return usage() }
    let root = proc_arg(0)
    let tmp = proc_arg(1)
    if fs_mkdirs(tmp) != 0 {
        print(str_concat("  FAIL fixpoint_full codegen gate cannot create ", tmp))
        return 1
    }
    let vaisc = path_join(root, "scripts/vaisc")
    let compiler_self = path_join(path_join(root, "compiler"), "self")
    let harness = path_join(compiler_self, "fixpoint_full.vais")
    let helper_src = path_join(path_join(root, "tools"), "embed_self_source.vais")
    let helper_bin = path_join(tmp, "embed_self_source")
    if build_trusted(vaisc, tmp, "embed_helper", helper_src, helper_bin) == 0 {
        print("  PASS Vais embed helper builds")
    } else {
        print("  FAIL Vais embed helper build")
        print_log_if_exists(path_join(tmp, "embed_helper.build.err"))
        return 1
    }
    let mut fail = 0
    fail = fail + run_generated_cases_1(vaisc, helper_bin, harness, tmp)
    fail = fail + run_generated_cases_2(vaisc, helper_bin, harness, tmp)
    fail = fail + run_generated_cases_3(vaisc, helper_bin, harness, tmp)
    fail = fail + run_generated_cases_4(vaisc, helper_bin, harness, tmp)
    fail = fail + run_generated_cases_5(vaisc, helper_bin, harness, tmp)
    fail = fail + run_generated_cases_6(vaisc, helper_bin, harness, tmp)
    fail = fail + run_special_cases(vaisc, helper_bin, harness, root, tmp)
    if fail == 0 {
        print("RESULT: fixpoint full codegen (functions with imperative bodies) end-to-end OK")
    } else {
        print("RESULT: FAILURES")
    }
    return fail
}

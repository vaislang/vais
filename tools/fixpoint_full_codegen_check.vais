fn append_uint(out: Int, n: Int) -> Int {
    if n >= 10 { append_uint(out, n / 10) }
    str_builder_push(out, 48 + (n % 10))
    return 0
}

fn uint_to_str(n: Int) -> Str {
    if n == 0 { return "0" }
    let out = str_builder_new()
    append_uint(out, n)
    return str_builder_finish(out)
}

fn str_contains_at(src: Str, i: Int, word: Str) -> Int {
    if i < 0 { return 0 }
    if i + word.len() > src.len() { return 0 }
    let mut k = 0
    while k < word.len() {
        if src[i + k] != word[k] { return 0 }
        k = k + 1
    }
    return 1
}

fn str_contains(src: Str, word: Str) -> Int {
    if word.len() == 0 { return 1 }
    let mut i = 0
    while i + word.len() <= src.len() {
        if str_contains_at(src, i, word) == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn compact_source(prog: Str) -> Str {
    let out = str_builder_new()
    let mut i = 0
    while i < prog.len() {
        let c = prog[i]
        if c == 123 and i + 1 < prog.len() and prog[i + 1] == 123 {
            str_builder_push(out, 123)
            i = i + 2
        } else if c == 125 and i + 1 < prog.len() and prog[i + 1] == 125 {
            str_builder_push(out, 125)
            i = i + 2
        } else {
            str_builder_push(out, c)
            i = i + 1
        }
    }
    return str_builder_finish(out)
}

fn append_line(out: Int, line: Str) -> Int {
    str_builder_append(out, line)
    str_builder_push(out, 10)
    return 0
}

fn print_log_if_exists(path: Str) -> Int {
    if fs_exists(path) == 1 {
        let text = fs_read_text(path)
        if text.len() > 0 { print(text) }
    }
    return 0
}

fn trim_trailing_newlines(text: Str) -> Str {
    let mut end = text.len()
    while end > 0 and text[end - 1] == 10 {
        end = end - 1
    }
    return str_slice(text, 0, end)
}

fn host_is_darwin() -> Int {
    let argv: List<Str> = []
    argv.push("uname")
    argv.push("-s")
    if trim_trailing_newlines(proc_capture_stdout(argv)) == "Darwin" { return 1 }
    return 0
}

fn host_intrinsic_ir() -> Str {
    let out = str_builder_new()
    append_line(out, "declare i64 @fs_exists(i8*)")
    append_line(out, "declare i8* @fs_read_text(i8*)")
    append_line(out, "declare i8* @fs_cwd()")
    append_line(out, "declare i8* @fs_temp_dir()")
    append_line(out, "declare i8* @path_join(i8*, i8*)")
    append_line(out, "declare i8* @path_basename(i8*)")
    append_line(out, "declare i8* @path_dirname(i8*)")
    append_line(out, "declare i64 @time_millis()")
    append_line(out, "declare i8* @str_concat(i8*, i8*)")
    append_line(out, "declare i8* @str_slice(i8*, i64, i64)")
    append_line(out, "declare i8* @str_byte(i64)")
    append_line(out, "declare i64 @str_builder_new()")
    append_line(out, "declare i64 @str_builder_push(i64, i64)")
    append_line(out, "declare i64 @str_builder_append(i64, i8*)")
    append_line(out, "declare i8* @str_builder_finish(i64)")
    append_line(out, "declare i64 @fs_write_text(i8*, i8*)")
    append_line(out, "declare i64 @fs_mkdirs(i8*)")
    append_line(out, "declare i64 @fs_remove(i8*)")
    append_line(out, "declare i64 @proc_argc()")
    append_line(out, "declare i8* @proc_arg(i64)")
    append_line(out, "declare i8* @proc_capture_stdout(i64*)")
    append_line(out, "declare i8* @proc_capture_stderr(i64*)")
    append_line(out, "declare i64 @proc_capture_to(i64*, i8*, i8*)")
    append_line(out, "declare void @proc_capture(i64*, i64*)")
    append_line(out, "declare i64 @proc_run(i64*)")
    append_line(out, "declare i64 @proc_run_env(i64*, i64*)")
    return str_builder_finish(out)
}

fn ir_needs_host_runtime(text: Str) -> Int {
    if str_contains(text, "@fs_") == 1 { return 1 }
    if str_contains(text, "@path_") == 1 { return 1 }
    if str_contains(text, "@time_millis") == 1 { return 1 }
    if str_contains(text, "@proc_") == 1 { return 1 }
    if str_contains(text, "@str_builder_") == 1 { return 1 }
    if str_contains(text, "@str_concat(") == 1 { return 1 }
    if str_contains(text, "@str_slice(") == 1 { return 1 }
    if str_contains(text, "@str_byte(") == 1 { return 1 }
    return 0
}

fn write_link_ir_text(text: Str, link_ir: Str) -> Int {
    let needle = "define i64 @main()"
    let replacement = "define i64 @vais_user_main()"
    let mut found = 0
    let mut target = 0
    let mut i = 0
    while i < text.len() {
        let mut at_line_start = 0
        if i == 0 { at_line_start = 1 }
        else if text[i - 1] == 10 { at_line_start = 1 }
        if at_line_start == 1 and str_contains_at(text, i, needle) == 1 {
            found = found + 1
            if found == 1 { target = i }
            i = i + needle.len()
        } else {
            i = i + 1
        }
    }
    if found != 1 { return 1 }
    let tail = target + needle.len()
    let out = str_builder_new()
    str_builder_append(out, host_intrinsic_ir())
    str_builder_append(out, str_slice(text, 0, target))
    str_builder_append(out, replacement)
    str_builder_append(out, str_slice(text, tail, text.len() - tail))
    return fs_write_text(link_ir, str_builder_finish(out))
}

fn is_digit(c: Int) -> Int {
    if c >= 48 and c <= 57 { return 1 }
    return 0
}

fn parse_first_uint(s: Str) -> Int {
    let mut i = 0
    while i < s.len() {
        if is_digit(s[i]) == 1 {
            let mut value = 0
            while i < s.len() {
                if is_digit(s[i]) == 1 {
                    value = value * 10 + (s[i] - 48)
                    i = i + 1
                } else {
                    return value
                }
            }
            return value
        }
        i = i + 1
    }
    return 0
}

fn grep_count(flag: Str, pattern: Str, path: Str) -> Int {
    let argv: List<Str> = []
    argv.push("grep")
    argv.push(flag)
    argv.push(pattern)
    argv.push(path)
    return parse_first_uint(proc_capture_stdout(argv))
}

fn trust_copy_source(tmp: Str, label: Str, source: Str) -> Str {
    let trust_root = path_join(tmp, str_concat(label, "_trust"))
    let compiler_dir = path_join(path_join(trust_root, "compiler"), "self")
    if fs_mkdirs(compiler_dir) != 0 { return "" }
    let trusted = path_join(compiler_dir, path_basename(source))
    if fs_write_text(trusted, fs_read_text(source)) != 0 { return "" }
    return trusted
}

fn build_trusted(vaisc: Str, tmp: Str, label: Str, source: Str, out_bin: Str) -> Int {
    let trusted = trust_copy_source(tmp, label, source)
    if trusted.len() == 0 { return 1 }
    let trust_root = path_dirname(path_dirname(path_dirname(trusted)))
    let out_path = path_join(tmp, str_concat(label, ".build.out"))
    let err_path = path_join(tmp, str_concat(label, ".build.err"))
    let argv: List<Str> = []
    argv.push("/usr/bin/env")
    argv.push(str_concat("VAISC_SELF_HOST_TRUST_ROOTS=", trust_root))
    argv.push(vaisc)
    argv.push("build")
    argv.push(trusted)
    argv.push("-o")
    argv.push(out_bin)
    return proc_capture_to(argv, out_path, err_path)
}

fn run_embed_raw(helper: Str, harness: Str, source: Str, out: Str, tmp: Str, label: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".embed.out"))
    let err_path = path_join(tmp, str_concat(label, ".embed.err"))
    let argv: List<Str> = []
    argv.push(helper)
    argv.push("--raw")
    argv.push(harness)
    argv.push(source)
    argv.push(out)
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": embed")))
    print_log_if_exists(err_path)
    return 1
}

fn run_embed_source(helper: Str, harness: Str, source: Str, out: Str, tmp: Str, label: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".embed.out"))
    let err_path = path_join(tmp, str_concat(label, ".embed.err"))
    let argv: List<Str> = []
    argv.push(helper)
    argv.push(harness)
    argv.push(source)
    argv.push(out)
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": embed")))
    print_log_if_exists(err_path)
    return 1
}

fn compile_ir(tmp: Str, label: Str, ir_path: Str, bin: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".clang.out"))
    let err_path = path_join(tmp, str_concat(label, ".clang.err"))
    let text = fs_read_text(ir_path)
    let link_ir = path_join(tmp, str_concat(label, ".link.ll"))
    let mut clang_input = ir_path
    let mut needs_host = ir_needs_host_runtime(text)
    let mut host_runtime = ""
    if needs_host == 1 {
        if write_link_ir_text(text, link_ir) != 0 {
            print(str_concat("  FAIL ", str_concat(label, ": link IR prep")))
            return 1
        }
        let root = proc_arg(0)
        host_runtime = path_join(path_join(root, "tools"), "fixpoint_host_runtime.c")
        if fs_exists(host_runtime) != 1 {
            print(str_concat("  FAIL ", str_concat(label, ": missing host runtime")))
            return 1
        }
        clang_input = link_ir
    }
    let argv: List<Str> = []
    argv.push("clang")
    argv.push("-Wno-override-module")
    if host_is_darwin() == 1 { argv.push("-Wl,-stack_size,0x4000000") }
    argv.push("-o")
    argv.push(bin)
    argv.push(clang_input)
    if needs_host == 1 { argv.push(host_runtime) }
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": generated IR invalid")))
    print_log_if_exists(err_path)
    return 1
}

fn run_to_file(bin: Str, out_file: Str, err_file: Str) -> Int {
    let argv: List<Str> = []
    argv.push(bin)
    return proc_capture_to(argv, out_file, err_file)
}

fn prepare_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str) -> Str {
    let case_dir = path_join(tmp, case_name)
    if fs_mkdirs(case_dir) != 0 { return "" }
    let compact = path_join(case_dir, "program.vais")
    let input = path_join(case_dir, "c.input.vais")
    let source = path_join(case_dir, "c.vais")
    if fs_write_text(compact, compact_source(prog)) != 0 { return "" }
    if run_embed_raw(helper, harness, compact, input, case_dir, case_name) != 0 { return "" }
    if fs_write_text(source, fs_read_text(input)) != 0 { return "" }
    let compiler_bin = path_join(case_dir, "c")
    if build_trusted(vaisc, case_dir, case_name, source, compiler_bin) != 0 {
        print(str_concat("  FAIL ", str_concat(case_name, ": compiler build")))
        print_log_if_exists(path_join(case_dir, str_concat(case_name, ".build.err")))
        return ""
    }
    return case_dir
}

fn emit_case_ir(case_dir: Str, case_name: Str) -> Str {
    let compiler_bin = path_join(case_dir, "c")
    let ir = path_join(case_dir, "out.ll")
    let err = path_join(case_dir, "compiler.err")
    let rc = run_to_file(compiler_bin, ir, err)
    if rc == 0 { return ir }
    print(str_concat("  FAIL ", str_concat(case_name, ": compiler run")))
    print_log_if_exists(err)
    return ""
}

fn run_exit_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, want: Int) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let out_path = path_join(case_dir, "bin.out")
    let err_path = path_join(case_dir, "bin.err")
    let got = run_to_file(bin, out_path, err_path)
    if got == want {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" -> ", str_concat(uint_to_str(got), " (runtime)")))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, str_concat(": got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
    print_log_if_exists(err_path)
    return 1
}

fn run_trap_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, label: Str) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let got = run_to_file(bin, path_join(case_dir, "bin.out"), path_join(case_dir, "bin.err"))
    if got != 0 {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" traps on ", label))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, ": trap did not fire")))
    return 1
}

fn run_stdout_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, want: Str) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let out_path = path_join(case_dir, "bin.out")
    let err_path = path_join(case_dir, "bin.err")
    let got_rc = run_to_file(bin, out_path, err_path)
    if got_rc != 0 {
        print(str_concat("  FAIL ", str_concat(case_name, str_concat(": stdout run exit=", uint_to_str(got_rc)))))
        print_log_if_exists(err_path)
        return 1
    }
    let got = trim_trailing_newlines(fs_read_text(out_path))
    if got == want {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" -> stdout [", str_concat(got, "]")))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, ": stdout mismatch")))
    print(str_concat("  got: ", got))
    print(str_concat("  want: ", want))
    return 1
}

fn want_loop_lines() -> Str {
    let out = str_builder_new()
    append_line(out, "line 0")
    append_line(out, "line 1")
    str_builder_append(out, "line 2")
    return str_builder_finish(out)
}


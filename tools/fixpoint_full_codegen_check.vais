fn append_uint(out: Int, n: Int) -> Int {
    if n >= 10 { append_uint(out, n / 10) }
    str_builder_push(out, 48 + (n % 10))
    return 0
}

fn uint_to_str(n: Int) -> Str {
    if n == 0 { return "0" }
    let out = str_builder_new()
    append_uint(out, n)
    return str_builder_finish(out)
}

fn str_contains_at(src: Str, i: Int, word: Str) -> Int {
    if i < 0 { return 0 }
    if i + word.len() > src.len() { return 0 }
    let mut k = 0
    while k < word.len() {
        if src[i + k] != word[k] { return 0 }
        k = k + 1
    }
    return 1
}

fn str_contains(src: Str, word: Str) -> Int {
    if word.len() == 0 { return 1 }
    let mut i = 0
    while i + word.len() <= src.len() {
        if str_contains_at(src, i, word) == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn compact_source(prog: Str) -> Str {
    let out = str_builder_new()
    let mut i = 0
    while i < prog.len() {
        let c = prog[i]
        if c == 123 and i + 1 < prog.len() and prog[i + 1] == 123 {
            str_builder_push(out, 123)
            i = i + 2
        } else if c == 125 and i + 1 < prog.len() and prog[i + 1] == 125 {
            str_builder_push(out, 125)
            i = i + 2
        } else {
            str_builder_push(out, c)
            i = i + 1
        }
    }
    return str_builder_finish(out)
}

fn append_line(out: Int, line: Str) -> Int {
    str_builder_append(out, line)
    str_builder_push(out, 10)
    return 0
}

fn print_log_if_exists(path: Str) -> Int {
    if fs_exists(path) == 1 {
        let text = fs_read_text(path)
        if text.len() > 0 { print(text) }
    }
    return 0
}

fn trim_trailing_newlines(text: Str) -> Str {
    let mut end = text.len()
    while end > 0 and text[end - 1] == 10 {
        end = end - 1
    }
    return str_slice(text, 0, end)
}

fn is_digit(c: Int) -> Int {
    if c >= 48 and c <= 57 { return 1 }
    return 0
}

fn parse_first_uint(s: Str) -> Int {
    let mut i = 0
    while i < s.len() {
        if is_digit(s[i]) == 1 {
            let mut value = 0
            while i < s.len() {
                if is_digit(s[i]) == 1 {
                    value = value * 10 + (s[i] - 48)
                    i = i + 1
                } else {
                    return value
                }
            }
            return value
        }
        i = i + 1
    }
    return 0
}

fn grep_count(flag: Str, pattern: Str, path: Str) -> Int {
    let argv: List<Str> = []
    argv.push("grep")
    argv.push(flag)
    argv.push(pattern)
    argv.push(path)
    return parse_first_uint(proc_capture_stdout(argv))
}

fn trust_copy_source(tmp: Str, label: Str, source: Str) -> Str {
    let trust_root = path_join(tmp, str_concat(label, "_trust"))
    let compiler_dir = path_join(path_join(trust_root, "compiler"), "self")
    if fs_mkdirs(compiler_dir) != 0 { return "" }
    let trusted = path_join(compiler_dir, path_basename(source))
    if fs_write_text(trusted, fs_read_text(source)) != 0 { return "" }
    return trusted
}

fn build_trusted(vaisc: Str, tmp: Str, label: Str, source: Str, out_bin: Str) -> Int {
    let trusted = trust_copy_source(tmp, label, source)
    if trusted.len() == 0 { return 1 }
    let trust_root = path_dirname(path_dirname(path_dirname(trusted)))
    let out_path = path_join(tmp, str_concat(label, ".build.out"))
    let err_path = path_join(tmp, str_concat(label, ".build.err"))
    let argv: List<Str> = []
    argv.push("/usr/bin/env")
    argv.push(str_concat("VAISC_SELF_HOST_TRUST_ROOTS=", trust_root))
    argv.push(vaisc)
    argv.push("build")
    argv.push(trusted)
    argv.push("-o")
    argv.push(out_bin)
    return proc_capture_to(argv, out_path, err_path)
}

fn run_embed_raw(helper: Str, harness: Str, source: Str, out: Str, tmp: Str, label: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".embed.out"))
    let err_path = path_join(tmp, str_concat(label, ".embed.err"))
    let argv: List<Str> = []
    argv.push(helper)
    argv.push("--raw")
    argv.push(harness)
    argv.push(source)
    argv.push(out)
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": embed")))
    print_log_if_exists(err_path)
    return 1
}

fn run_embed_source(helper: Str, harness: Str, source: Str, out: Str, tmp: Str, label: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".embed.out"))
    let err_path = path_join(tmp, str_concat(label, ".embed.err"))
    let argv: List<Str> = []
    argv.push(helper)
    argv.push(harness)
    argv.push(source)
    argv.push(out)
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": embed")))
    print_log_if_exists(err_path)
    return 1
}

fn compile_ir(tmp: Str, label: Str, ir_path: Str, bin: Str) -> Int {
    let out_path = path_join(tmp, str_concat(label, ".clang.out"))
    let err_path = path_join(tmp, str_concat(label, ".clang.err"))
    let argv: List<Str> = []
    argv.push("clang")
    argv.push("-Wno-override-module")
    argv.push("-o")
    argv.push(bin)
    argv.push(ir_path)
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc == 0 { return 0 }
    print(str_concat("  FAIL ", str_concat(label, ": generated IR invalid")))
    print_log_if_exists(err_path)
    return 1
}

fn run_to_file(bin: Str, out_file: Str, err_file: Str) -> Int {
    let argv: List<Str> = []
    argv.push(bin)
    return proc_capture_to(argv, out_file, err_file)
}

fn prepare_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str) -> Str {
    let case_dir = path_join(tmp, case_name)
    if fs_mkdirs(case_dir) != 0 { return "" }
    let compact = path_join(case_dir, "program.vais")
    let input = path_join(case_dir, "c.input.vais")
    let source = path_join(case_dir, "c.vais")
    if fs_write_text(compact, compact_source(prog)) != 0 { return "" }
    if run_embed_raw(helper, harness, compact, input, case_dir, case_name) != 0 { return "" }
    if fs_write_text(source, fs_read_text(input)) != 0 { return "" }
    let compiler_bin = path_join(case_dir, "c")
    if build_trusted(vaisc, case_dir, case_name, source, compiler_bin) != 0 {
        print(str_concat("  FAIL ", str_concat(case_name, ": compiler build")))
        print_log_if_exists(path_join(case_dir, str_concat(case_name, ".build.err")))
        return ""
    }
    return case_dir
}

fn emit_case_ir(case_dir: Str, case_name: Str) -> Str {
    let compiler_bin = path_join(case_dir, "c")
    let ir = path_join(case_dir, "out.ll")
    let err = path_join(case_dir, "compiler.err")
    let rc = run_to_file(compiler_bin, ir, err)
    if rc == 0 { return ir }
    print(str_concat("  FAIL ", str_concat(case_name, ": compiler run")))
    print_log_if_exists(err)
    return ""
}

fn run_exit_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, want: Int) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let out_path = path_join(case_dir, "bin.out")
    let err_path = path_join(case_dir, "bin.err")
    let got = run_to_file(bin, out_path, err_path)
    if got == want {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" -> ", str_concat(uint_to_str(got), " (runtime)")))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, str_concat(": got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
    print_log_if_exists(err_path)
    return 1
}

fn run_trap_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, label: Str) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let got = run_to_file(bin, path_join(case_dir, "bin.out"), path_join(case_dir, "bin.err"))
    if got != 0 {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" traps on ", label))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, ": trap did not fire")))
    return 1
}

fn run_stdout_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, want: Str) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return 1 }
    let out_path = path_join(case_dir, "bin.out")
    let err_path = path_join(case_dir, "bin.err")
    let got_rc = run_to_file(bin, out_path, err_path)
    if got_rc != 0 {
        print(str_concat("  FAIL ", str_concat(case_name, str_concat(": stdout run exit=", uint_to_str(got_rc)))))
        print_log_if_exists(err_path)
        return 1
    }
    let got = trim_trailing_newlines(fs_read_text(out_path))
    if got == want {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" -> stdout [", str_concat(got, "]")))))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(case_name, ": stdout mismatch")))
    print(str_concat("  got: ", got))
    print(str_concat("  want: ", want))
    return 1
}

fn want_loop_lines() -> Str {
    let out = str_builder_new()
    append_line(out, "line 0")
    append_line(out, "line 1")
    str_builder_append(out, "line 2")
    return str_builder_finish(out)
}

fn want_emit_lines() -> Str {
    let out = str_builder_new()
    append_line(out, "define i64 @main() {")
    append_line(out, "  ret i64 99")
    str_builder_append(out, "}")
    return str_builder_finish(out)
}

fn check_ir_case(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, prog: Str, p1: Str, p2: Str, p3: Str, label: Str) -> Int {
    let case_dir = prepare_case(vaisc, helper, harness, tmp, case_name, prog)
    if case_dir.len() == 0 { return 1 }
    let ir = emit_case_ir(case_dir, case_name)
    if ir.len() == 0 { return 1 }
    let text = fs_read_text(ir)
    let mut ok = 1
    if p1.len() > 0 and str_contains(text, p1) == 0 { ok = 0 }
    if p2.len() > 0 and str_contains(text, p2) == 0 { ok = 0 }
    if p3.len() > 0 and str_contains(text, p3) == 0 { ok = 0 }
    if ok == 1 {
        print(str_concat("  PASS ", label))
        return 0
    }
    print(str_concat("  FAIL ", label))
    print(text)
    return 1
}

fn check_source_file(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, source_file: Str, want: Int, label: Str) -> Int {
    let case_dir = path_join(tmp, case_name)
    if fs_mkdirs(case_dir) != 0 { return 1 }
    let input = path_join(case_dir, "c.input.vais")
    let source = path_join(case_dir, "c.vais")
    if run_embed_source(helper, harness, source_file, input, case_dir, case_name) != 0 { return 1 }
    if fs_write_text(source, fs_read_text(input)) != 0 { return 1 }
    let compiler_bin = path_join(case_dir, "c")
    if build_trusted(vaisc, case_dir, case_name, source, compiler_bin) != 0 {
        print(str_concat("  FAIL ", str_concat(label, ": compiler build")))
        print_log_if_exists(path_join(case_dir, str_concat(case_name, ".build.err")))
        return 1
    }
    let source_ll = path_join(case_dir, "source_compiler.ll")
    if run_to_file(compiler_bin, source_ll, path_join(case_dir, "source_compiler.err")) != 0 {
        print(str_concat("  FAIL ", str_concat(label, ": compiler run")))
        return 1
    }
    let main_count = grep_count("-Ec", "^define i64 @main[(][)]", source_ll)
    let mut fail = 0
    if main_count == 1 {
        print(str_concat("  PASS ", str_concat(label, " emits a single @main")))
    } else {
        print(str_concat("  FAIL ", str_concat(label, str_concat(" main count=", uint_to_str(main_count)))))
        fail = fail + 1
    }
    let source_compiler = path_join(case_dir, "source_compiler")
    if compile_ir(case_dir, str_concat(case_name, ".source"), source_ll, source_compiler) != 0 { return fail + 1 }
    let emitted_ll = path_join(case_dir, "emitted.ll")
    if run_to_file(source_compiler, emitted_ll, path_join(case_dir, "emitted.err")) != 0 {
        print(str_concat("  FAIL ", str_concat(label, ": generated compiler run")))
        return fail + 1
    }
    let want_ret = str_concat("ret i64 ", uint_to_str(want))
    if str_contains(fs_read_text(emitted_ll), want_ret) == 1 {
        print(str_concat("  PASS ", str_concat(label, str_concat(" emits ", want_ret))))
    } else {
        print(str_concat("  FAIL ", str_concat(label, str_concat(" missing ", want_ret))))
        fail = fail + 1
    }
    let emitted_bin = path_join(case_dir, "emitted_bin")
    if compile_ir(case_dir, str_concat(case_name, ".emitted"), emitted_ll, emitted_bin) != 0 { return fail + 1 }
    let got = run_to_file(emitted_bin, path_join(case_dir, "emitted_bin.out"), path_join(case_dir, "emitted_bin.err"))
    if got == want {
        print(str_concat("  PASS ", str_concat(label, str_concat(" emitted IR runs (=", str_concat(uint_to_str(got), ")")))))
    } else {
        print(str_concat("  FAIL ", str_concat(label, str_concat(" emitted binary got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
        fail = fail + 1
    }
    return fail
}

fn write_backslash_source(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    str_builder_append(out, "    let s = ")
    str_builder_push(out, 34)
    str_builder_push(out, 92)
    str_builder_push(out, 92)
    str_builder_append(out, "0A")
    str_builder_push(out, 34)
    str_builder_push(out, 10)
    append_line(out, "    return s.len()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_direct_double_source(path: Str) -> Int {
    let out = str_builder_new()
    str_builder_append(out, "fn main() { let s = ")
    str_builder_push(out, 34)
    str_builder_push(out, 92)
    str_builder_push(out, 92)
    str_builder_append(out, "5C")
    str_builder_push(out, 34)
    str_builder_append(out, "; return s.len(); }")
    str_builder_push(out, 10)
    return fs_write_text(path, str_builder_finish(out))
}

fn run_embedded_source_program(vaisc: Str, helper: Str, harness: Str, tmp: Str, case_name: Str, source_file: Str, raw: Int, want: Int, marker1: Str, marker2: Str) -> Int {
    let case_dir = path_join(tmp, case_name)
    if fs_mkdirs(case_dir) != 0 { return 1 }
    let input = path_join(case_dir, "c.input.vais")
    if raw == 1 {
        if run_embed_raw(helper, harness, source_file, input, case_dir, case_name) != 0 { return 1 }
    } else {
        if run_embed_source(helper, harness, source_file, input, case_dir, case_name) != 0 { return 1 }
    }
    let source = path_join(case_dir, "c.vais")
    if fs_write_text(source, fs_read_text(input)) != 0 { return 1 }
    let compiler_bin = path_join(case_dir, "c")
    if build_trusted(vaisc, case_dir, case_name, source, compiler_bin) != 0 { return 1 }
    let ir = path_join(case_dir, "out.ll")
    if run_to_file(compiler_bin, ir, path_join(case_dir, "compiler.err")) != 0 { return 1 }
    let text = fs_read_text(ir)
    let mut fail = 0
    if str_contains(text, marker1) == 1 and str_contains(text, marker2) == 1 {
        print(str_concat("  PASS ", str_concat(case_name, " emits expected LLVM escape markers")))
    } else {
        print(str_concat("  FAIL ", str_concat(case_name, " missing LLVM escape markers")))
        print(text)
        fail = fail + 1
    }
    let bin = path_join(case_dir, "bin")
    if compile_ir(case_dir, case_name, ir, bin) != 0 { return fail + 1 }
    let got = run_to_file(bin, path_join(case_dir, "bin.out"), path_join(case_dir, "bin.err"))
    if got == want {
        print(str_concat("  PASS ", str_concat(case_name, str_concat(" runs (=", str_concat(uint_to_str(got), ")")))))
    } else {
        print(str_concat("  FAIL ", str_concat(case_name, str_concat(" got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
        fail = fail + 1
    }
    return fail
}

fn run_special_cases(vaisc: Str, helper: Str, harness: Str, root: Str, tmp: Str) -> Int {
    let compiler_self = path_join(path_join(root, "compiler"), "self")
    let mut fail = 0
    fail = fail + check_ir_case(vaisc, helper, harness, tmp, "ir_function_loop", "fn sum_to(n) {{ let mut s = 0; let mut i = 1; while i < n {{ s = s + i; i = i + 1 }}; return s }}; return sum_to(6);", "define i64 @sum_to(i64 %a0)", "store i64 %a0", "call i64 @sum_to", "emits function(param-alloca) + loop + call (functions-with-imperative-bodies codegen)")
    fail = fail + check_ir_case(vaisc, helper, harness, tmp, "ir_for_loop", "let mut s = 0; for i in 0..5 {{ s = s + i }}; return s;", "br label %loop", "icmp slt i64", "add i64", "for-loop desugars to induction-variable loop (store/loop/icmp slt/add)")
    fail = fail + check_ir_case(vaisc, helper, harness, tmp, "ir_print_interp", "let v = 7; print(`x={{v}}`); return 0;", "@.fmt", "call i32 (i8*", "@printf", "print interpolation emits @.fmt global + printf call")
    fail = fail + check_ir_case(vaisc, helper, harness, tmp, "ir_string_interp", "let op_s = `mul`; print(`op={{op_s}}`); return 0;", "op=%s", "call i32 (i8*", "i8* %t", "print string interpolation emits %s + i8* vararg")
    fail = fail + check_source_file(vaisc, helper, harness, tmp, "source_fixpoint", path_join(compiler_self, "fixpoint.vais"), 24, "source-file full fixpoint.vais")
    fail = fail + check_source_file(vaisc, helper, harness, tmp, "source_fixpoint2", path_join(compiler_self, "fixpoint2.vais"), 50, "source-file full fixpoint2.vais")
    fail = fail + check_source_file(vaisc, helper, harness, tmp, "source_fixpoint3", path_join(compiler_self, "fixpoint3.vais"), 120, "source-file full fixpoint3.vais")
    let backslash_source = path_join(tmp, "source_with_backslash.vais")
    if write_backslash_source(backslash_source) == 0 {
        fail = fail + run_embedded_source_program(vaisc, helper, harness, tmp, "source_backslash", backslash_source, 0, 4, "5C", "0A")
    } else { fail = fail + 1 }
    let direct_double = path_join(tmp, "direct_double_string.vais")
    if write_direct_double_source(direct_double) == 0 {
        fail = fail + run_embedded_source_program(vaisc, helper, harness, tmp, "direct_double_string", direct_double, 1, 3, "5C5C", "00")
    } else { fail = fail + 1 }
    fail = fail + check_ir_case(vaisc, helper, harness, tmp, "ir_string_integrated", "let s = `Hi`; return s[0];", "private constant [", "alloca i8*", "zext i8", "emits string global + i8* alloca + byte load [string codegen integrated]")
    return fail
}

fn run_generated_cases_1(vaisc: Str, helper: Str, harness: Str, tmp: Str) -> Int {
    let mut fail = 0
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_001_l78", "fn sum_to(n) {{ let mut s = 0; let mut i = 1; while i < n {{ s = s + i; i = i + 1 }}; return s }}; return sum_to(6);", 15)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_002_l80", "fn fact(n) {{ let mut f = 1; let mut i = 1; while i < n {{ f = f * i; i = i + 1 }}; return f }}; return fact(6);", 120)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_003_l82", "fn clamp(x) {{ let mut r = x; if x > 100 {{ r = 100 }}; return r }}; return clamp(250);", 100)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_004_l83", "fn clamp(x) {{ let mut r = x; if x > 100 {{ r = 100 }}; return r }}; return clamp(7);", 7)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_005_l85", "fn fac(n) {{ if n < 2 {{ return 1 }}; return n * fac(n - 1) }}; return fac(5);", 120)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_006_l87", "fn dbl(x) {{ return x + x }}; fn quad(y) {{ let mut r = dbl(y); r = dbl(r); return r }}; return quad(5);", 20)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_007_l91", "fn sumarr(n) {{ let a = [10, 20, 30]; let mut s = 0; let mut i = 0; while i < n {{ s = s + a[i]; i = i + 1 }}; return s }}; return sumarr(3);", 60)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_008_l93", "fn build(n) {{ let a = [0, 0, 0]; let mut i = 0; while i < n {{ a[i] = i * 5; i = i + 1 }}; return a[0] + a[1] + a[2] }}; return build(3);", 15)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_009_l95", "fn pick(k) {{ let a = [7, 8, 9]; let mut r = 0; if k > 1 {{ r = a[2] }} else {{ r = a[0] }}; return r }}; return pick(5);", 9)
    fail = fail + run_exit_case(vaisc, helper, harness, tmp, "case_010_l99", "fn build(n) {{ let xs = list(); let mut i = 0; while i < n {{ xs.push(i * 10); i = i + 1 }}; let mut s = 0; let mut j = 0; while j < xs.len {{ s = s + xs[j]; j = j + 1 }}; return s }}; return build(5);", 100)

    append_line(out, "  ret i64 99")
    str_builder_append(out, "}")
    return str_builder_finish(out)
}

fn line_comment_skip_source() -> Str {
    let out = str_builder_new()
    append_line(out, "fn run() -> Int {")
    append_line(out, "let x = 40 # + 100 should be ignored")
    append_line(out, "let y = 2")
    append_line(out, "let s = \"# not a comment\"")
    append_line(out, "if s.len() != 15 { return 1 }")
    append_line(out, "return x + y")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_index_assignment_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Int> = [1, 2, 3]")
    append_line(out, "    xs[1] = 15")
    append_line(out, "    xs[0] = xs[1] - 5")
    append_line(out, "    xs[2] = xs[0] + xs[1] - 10")
    append_line(out, "    return xs[0] + xs[1] + xs[2] + 2")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_struct_element_assignment_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn put(xs: List<Box>, i: Int, value: Int) -> Int {")
    append_line(out, "    let replacement = Box { value: value, tag: xs[i].tag + 1 }")
    append_line(out, "    xs[i] = replacement")
    append_line(out, "    return xs[i].value + xs[i].tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn copy_from(xs: List<Box>, dst: Int, src: Int) -> Int {")
    append_line(out, "    xs[dst] = xs[src]")
    append_line(out, "    return xs[dst].value + xs[dst].tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 1, tag: 2 })")
    append_line(out, "    xs.push(Box { value: 3, tag: 4 })")
    append_line(out, "    xs[0] = Box { value: 10, tag: 5 }")
    append_line(out, "    let saved = Box { value: 20, tag: 6 }")
    append_line(out, "    xs[1] = saved")
    append_line(out, "    let a = put(xs, 0, 30)")
    append_line(out, "    let b = copy_from(xs, 1, 0)")
    append_line(out, "    return xs[0].value + xs[1].tag + a + b - 66")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_struct_element_return_call_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn make_box(value: Int, tag: Int) -> Box {")
    append_line(out, "    return Box { value: value, tag: tag }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn replace(xs: List<Box>, i: Int, value: Int) -> Int {")
    append_line(out, "    xs[i] = make_box(value, xs[i].tag + 1)")
    append_line(out, "    return xs[i].value + xs[i].tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 1, tag: 2 })")
    append_line(out, "    xs.push(Box { value: 3, tag: 4 })")
    append_line(out, "    xs[0] = make_box(10, 5)")
    append_line(out, "    let a = replace(xs, 1, 20)")
    append_line(out, "    return xs[0].value + xs[1].tag + a + 2")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_struct_push_return_call_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn make_box(value: Int, tag: Int) -> Box {")
    append_line(out, "    return Box { value: value, tag: tag }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn add(xs: List<Box>, value: Int, tag: Int) -> Int {")
    append_line(out, "    xs.push(make_box(value, tag))")
    append_line(out, "    let tail = xs.last()")
    append_line(out, "    return tail.value + tail.tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(make_box(10, 5))")
    append_line(out, "    let a = add(xs, 20, 4)")
    append_line(out, "    xs.push(Box { value: 1, tag: 2 })")
    append_line(out, "    let first = xs[0]")
    append_line(out, "    let third = xs[2]")
    append_line(out, "    return first.value + xs[1].tag + third.value + third.tag + a + 1")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_struct_push_struct_value_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn add(xs: List<Box>, value: Box) -> Int {")

    append_line(out, "    let second = Box { value: 20, tag: 4 }")
    append_line(out, "    let score = add(xs, second)")
    append_line(out, "    return xs[0].value + xs[1].tag + score + 4")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_struct_insert_return_call_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn make_box(value: Int, tag: Int) -> Box {")
    append_line(out, "    return Box { value: value, tag: tag }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn put(xs: List<Box>, idx: Int, value: Int, tag: Int) -> Int {")
    append_line(out, "    xs.insert_at(idx, make_box(value, tag))")
    append_line(out, "    let item = xs[idx]")
    append_line(out, "    return item.value + item.tag + xs.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10, tag: 1 })")
    append_line(out, "    xs.push(Box { value: 30, tag: 3 })")

    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Inner {")
    append_line(out, "    v: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_box(v: Int) -> Box {")
    append_line(out, "    return Box { value: v }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_outer(v: Int) -> Outer {")
    append_line(out, "    let out = Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: v,")
    append_line(out, "        },")
    append_line(out, "    }")
    append_line(out, "    return out")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    return make_box(20).value + make_outer(22).inner.v")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}


    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(box: Box) -> Int {")
    append_line(out, "    return box.value + box.tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let a = Box {")
    append_line(out, "        value: 10,")
    append_line(out, "        tag: 5,")
    append_line(out, "    }")
    append_line(out, "    let b: Box = Box {")
    append_line(out, "        value: 20,")
    append_line(out, "        tag: 3,")
    append_line(out, "    }")
    append_line(out, "    b = Box {")
    append_line(out, "        value: 7,")
    append_line(out, "        tag: 4,")
    append_line(out, "    }")
    append_line(out, "    return score(a) + score(b) + score(Box {")
    append_line(out, "        value: 12,")
    append_line(out, "        tag: 4,")
    append_line(out, "    })")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn list_scalar_str_extend_return_call_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "fn make_nums(base: Int) -> List<Int> {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    xs.push(base)")
    append_line(out, "    xs.push(base + 1)")
    append_line(out, "    return xs")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn add_nums(xs: List<Int>, base: Int) -> Int {")
    append_line(out, "    xs.extend(make_nums(base))")
    append_line(out, "    return xs.sum() + xs.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_words(prefix: Str) -> List<Str> {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(str_lower(prefix))")
    append_line(out, "    words.push(\"cache\")")
    append_line(out, "    return words")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn add_words(words: List<Str>, prefix: Str) -> Int {")
    append_line(out, "    words.extend(make_words(prefix))")
    append_line(out, "    return words.len() + words.last().len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let nums: List<Int> = []")
    append_line(out, "    nums.push(1)")
    append_line(out, "    nums.extend(make_nums(10))")
    append_line(out, "    let num_score = add_nums(nums, 20)")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"ai\")")
    append_line(out, "    words.extend(make_words(\"VECTOR\"))")
    append_line(out, "    let word_score = add_words(words, \"DOC\")")
    append_line(out, "    return num_score + word_score + nums[1] + words.last().len() + words.len() - 56")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}

fn result_multiline_struct_payload_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Entry {")
    append_line(out, "    title_len: Int,")
    append_line(out, "    body_terms: Int,")
    append_line(out, "    query_hits: Int,")
    append_line(out, "    rank: Int")
    append_line(out, "}")
    append_line(out, "fn build_entry(title_len: Int, body_terms: Int, query_hits: Int, rank: Int) -> Result<Entry, Int> {")
    append_line(out, "    if title_len < 1 { return Err(12) }")
    append_line(out, "    if body_terms < 1 { return Err(13) }")
    append_line(out, "    let entry = Entry { title_len: title_len, body_terms: body_terms, query_hits: query_hits, rank: rank }")
    append_line(out, "    return Ok(entry)")
    append_line(out, "}")
    append_line(out, "fn entry_score(flow: Result<Entry, Int>, fallback: Int) -> Int {")
    append_line(out, "    let value = match flow { Ok(entry) => entry.title_len + entry.body_terms + entry.query_hits + entry.rank, Err(code) => fallback + code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn choose_entry(left: Result<Entry, Int>, right: Result<Entry, Int>) -> Int {")
    append_line(out, "    let left_score = entry_score(left, 0)")
    append_line(out, "    let right_score = entry_score(right, 0)")
    append_line(out, "    if left_score > right_score { return left_score }")
    append_line(out, "    return right_score")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let ok = build_entry(6, 11, 8, 5)")
    append_line(out, "    let missing = build_entry(0, 5, 3, 2)")
    append_line(out, "    let ok_score = entry_score(ok, 0)")
    append_line(out, "    let missing_score = entry_score(missing, 0)")
    append_line(out, "    let chosen = choose_entry(ok, missing)")
    append_line(out, "    if ok_score != 30 { return 1 }")
    append_line(out, "    if missing_score != 12 { return 2 }")
    append_line(out, "    if chosen != 30 { return 3 }")
    append_line(out, "    return ok_score + missing_score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_str_fields_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocSummary { title: Str, summary: Str, terms: Int }")
    append_line(out, "fn build_doc_summary(title: Str, summary: Str, terms: Int) -> Result<DocSummary, Int> {")
    append_line(out, "    if title.len() == 0 { return Err(10) }")
    append_line(out, "    if summary.len() == 0 { return Err(11) }")
    append_line(out, "    let doc = DocSummary { title: title, summary: summary, terms: terms }")
    append_line(out, "    return Ok(doc)")
    append_line(out, "}")
    append_line(out, "fn doc_summary_score(flow: Result<DocSummary, Int>, fallback: Int) -> Int {")
    append_line(out, "    let value = match flow { Ok(doc) => doc.title.len() + doc.summary.len() + doc.terms, Err(code) => fallback + code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn choose_doc_summary(left: Result<DocSummary, Int>, right: Result<DocSummary, Int>) -> Int {")
    append_line(out, "    let left_score = doc_summary_score(left, 0)")
    append_line(out, "    let right_score = doc_summary_score(right, 0)")
    append_line(out, "    if left_score > right_score { return left_score }")
    append_line(out, "    return right_score")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let ok = build_doc_summary(`vais`, `ai db`, 23)")
    append_line(out, "    let missing = build_doc_summary(``, `ai db`, 8)")
    append_line(out, "    let ok_score = doc_summary_score(ok, 0)")
    append_line(out, "    let missing_score = doc_summary_score(missing, 0)")
    append_line(out, "    let chosen = choose_doc_summary(ok, missing)")
    append_line(out, "    if ok_score != 32 { return 1 }")
    append_line(out, "    if missing_score != 10 { return 2 }")
    append_line(out, "    if chosen != 32 { return 3 }")
    append_line(out, "    return ok_score + missing_score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_try_payload_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocSummary { title: Str, summary: Str, terms: Int }")
    append_line(out, "fn build_doc_summary(title: Str, summary: Str, terms: Int) -> Result<DocSummary, Int> {")
    append_line(out, "    if title.len() == 0 { return Err(10) }")
    append_line(out, "    if summary.len() == 0 { return Err(11) }")
    append_line(out, "    let doc = DocSummary { title: title, summary: summary, terms: terms }")
    append_line(out, "    return Ok(doc)")
    append_line(out, "}")
    append_line(out, "fn normalize_doc_summary(title: Str, summary: Str, terms: Int, boost: Int) -> Result<DocSummary, Int> {")
    append_line(out, "    let doc = build_doc_summary(title, summary, terms)?")
    append_line(out, "    if doc.terms < 1 { return Err(12) }")
    append_line(out, "    let adjusted = DocSummary { title: doc.title, summary: doc.summary, terms: doc.terms + boost }")
    append_line(out, "    return Ok(adjusted)")
    append_line(out, "}")
    append_line(out, "fn doc_summary_score(flow: Result<DocSummary, Int>, fallback: Int) -> Int {")
    append_line(out, "    let value = match flow { Ok(doc) => doc.title.len() + doc.summary.len() + doc.terms, Err(code) => fallback + code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let ok = normalize_doc_summary(`vais`, `ai db`, 20, 3)")
    append_line(out, "    let missing_title = normalize_doc_summary(``, `ai db`, 20, 3)")
    append_line(out, "    let empty_terms = normalize_doc_summary(`vais`, `ai db`, 0, 3)")
    append_line(out, "    let ok_score = doc_summary_score(ok, 0)")
    append_line(out, "    let missing_score = doc_summary_score(missing_title, 0)")
    append_line(out, "    let empty_score = doc_summary_score(empty_terms, 0)")
    append_line(out, "    if ok_score != 32 { return 1 }")
    append_line(out, "    if missing_score != 10 { return 2 }")
    append_line(out, "    if empty_score != 12 { return 3 }")
    append_line(out, "    return ok_score + missing_score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn vaisdb_artifact_record_workflow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn rank_doc(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    let doc: DocArtifact = build_doc_artifact(id, title, body, terms, score)?")
    append_line(out, "    if doc.score < 1 { return Err(14) }")
    append_line(out, "    let ranked = DocArtifact { id: doc.id, title: doc.title, body: doc.body, terms: doc.terms, score: doc.score + doc.title.len() }")
    append_line(out, "    return Ok(ranked)")
    append_line(out, "}")
    append_line(out, "fn index_artifacts(meta: Map<Str,Str>, query_text: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    if query_text.len() == 0 { return Err(20) }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    if doc_term_counts_into(query_text, query) != 3 { return Err(21) }")
    append_line(out, "    let terms_map: Map<Str,Int> = {}")
    append_line(out, "    let terms = doc_term_counts_into(`AI cache ai CACHE vector ai`, terms_map)")
    append_line(out, "    let score = doc_term_weighted_score(query, terms_map)")
    append_line(out, "    let artifact: DocArtifact = rank_doc(`d1`, `VaisDB Guide`, `AI cache ai CACHE vector ai`, terms, score)?")
    append_line(out, "    out.push(artifact)")
    append_line(out, "    meta.insert(`d1.title`, artifact.title)")
    append_line(out, "    meta.insert(`d1.body`, artifact.body)")
    append_line(out, "    return Ok(artifact.score + out.len() + query_text.len() + meta.len() + 8)")
    append_line(out, "}")
    append_line(out, "fn result_value(flow: Result<Int, Int>) -> Int {")
    append_line(out, "    let value = match flow { Ok(score) => score, Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    let artifacts: List<DocArtifact> = []")
    append_line(out, "    let ok = result_value(index_artifacts(meta, `ai cache ai`, artifacts))")
    append_line(out, "    if ok != 42 { return 1 }")
    append_line(out, "    if artifacts.len() != 1 { return 2 }")
    append_line(out, "    if artifacts[0].title != `VaisDB Guide` { return 3 }")
    append_line(out, "    if meta.get(`d1.title`, ``) != artifacts[0].title { return 4 }")
    append_line(out, "    let bad: List<DocArtifact> = []")
    append_line(out, "    if result_value(index_artifacts(meta, ``, bad)) != 20 { return 5 }")
    append_line(out, "    if bad.len() != 0 { return 6 }")
    append_line(out, "    return ok")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn vaisdb_artifact_store_snapshot_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn artifact_line(artifact: DocArtifact) -> Str {")
    append_line(out, "    let tab = str_byte(9)")
    append_line(out, "    let left = str_concat(artifact.id, str_concat(tab, artifact.title))")
    append_line(out, "    let middle = str_concat(Str(artifact.terms), str_concat(tab, Str(artifact.score)))")
    append_line(out, "    return str_concat(left, str_concat(tab, str_concat(middle, str_concat(tab, artifact.body))))")
    append_line(out, "}")
    append_line(out, "fn artifact_store_snapshot(artifacts: List<DocArtifact>) -> Str {")
    append_line(out, "    let mut out = ``")
    append_line(out, "    for artifact in artifacts {")
    append_line(out, "        out = str_concat(out, str_concat(artifact_line(artifact), str_byte(10)))")
    append_line(out, "    }")
    append_line(out, "    return out")
    append_line(out, "}")
    append_line(out, "fn parse_artifact_line(line: Str) -> Result<DocArtifact, Int> {")
    append_line(out, "    let fields: List<Str> = []")
    append_line(out, "    let tab = str_byte(9)")
    append_line(out, "    let field_count = str_split_into(line, tab, fields)")
    append_line(out, "    if field_count != 5 { return Err(30) }")
    append_line(out, "    let terms = parse_int(fields[2])")
    append_line(out, "    let score = parse_int(fields[3])")
    append_line(out, "    if terms < 1 { return Err(31) }")
    append_line(out, "    if score < 1 { return Err(32) }")
    append_line(out, "    let artifact: DocArtifact = build_doc_artifact(fields[0], fields[1], fields[4], terms, score)?")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn load_artifact_store(snapshot: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let line_count = str_split_lines_into(snapshot, lines)")
    append_line(out, "    if line_count == 0 { return Err(33) }")
    append_line(out, "    let mut loaded = 0")
    append_line(out, "    for line in lines {")
    append_line(out, "        let trimmed = str_trim(line)")
    append_line(out, "        if trimmed.len() > 0 {")
    append_line(out, "            let artifact: DocArtifact = parse_artifact_line(line)?")
    append_line(out, "            out.push(artifact)")
    append_line(out, "            loaded = loaded + 1")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    if loaded == 0 { return Err(34) }")
    append_line(out, "    return Ok(loaded)")
    append_line(out, "}")
    append_line(out, "fn save_artifact_store(path: Str, artifacts: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    let snapshot = artifact_store_snapshot(artifacts)")
    append_line(out, "    if fs_write_text(path, snapshot) != 0 { return Err(40) }")
    append_line(out, "    return Ok(snapshot.len())")
    append_line(out, "}")
    append_line(out, "fn read_artifact_store(path: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    if fs_exists(path) != 1 { return Err(41) }")
    append_line(out, "    let snapshot = fs_read_text(path)")
    append_line(out, "    let loaded = load_artifact_store(snapshot, out)?")
    append_line(out, "    return Ok(loaded)")
    append_line(out, "}")
    append_line(out, "fn best_artifact(artifacts: List<DocArtifact>) -> Result<DocArtifact, Int> {")
    append_line(out, "    if artifacts.len() == 0 { return Err(50) }")
    append_line(out, "    let mut best = artifacts[0]")
    append_line(out, "    for artifact in artifacts {")
    append_line(out, "        if artifact.score > best.score {")
    append_line(out, "            best = artifact")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return Ok(best)")
    append_line(out, "}")
    append_line(out, "fn query_loaded_store(artifacts: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    let best: DocArtifact = best_artifact(artifacts)?")
    append_line(out, "    if best.id != `d1` { return Err(51) }")
    append_line(out, "    return Ok(best.score + artifacts.len() + best.title.len() + 8)")
    append_line(out, "}")
    append_line(out, "fn seed_store(out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    let a: DocArtifact = build_doc_artifact(`d1`, `VaisDB Guide`, `AI cache`, 6, 20)?")
    append_line(out, "    let b: DocArtifact = build_doc_artifact(`d2`, `Cache Notes`, `cache cache`, 4, 13)?")
    append_line(out, "    out.push(a)")
    append_line(out, "    out.push(b)")
    append_line(out, "    return Ok(out.len())")
    append_line(out, "}")
    append_line(out, "fn result_value(flow: Result<Int, Int>) -> Int {")
    append_line(out, "    let value = match flow { Ok(score) => score, Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let artifacts: List<DocArtifact> = []")
    append_line(out, "    if result_value(seed_store(artifacts)) != 2 { return 1 }")
    append_line(out, "    let path = path_join(fs_temp_dir(), `vais-full-e309-artifact-store.tsv`)")
    append_line(out, "    if result_value(save_artifact_store(path, artifacts)) <= 0 { return 2 }")
    append_line(out, "    let loaded: List<DocArtifact> = []")
    append_line(out, "    if result_value(read_artifact_store(path, loaded)) != 2 { return 3 }")
    append_line(out, "    if result_value(query_loaded_store(loaded)) != 42 { return 4 }")
    append_line(out, "    let bad: List<DocArtifact> = []")
    append_line(out, "    if result_value(load_artifact_store(`broken`, bad)) != 30 { return 5 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn vaisdb_artifact_query_report_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn load_artifact_store(snapshot: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    if str_contains(snapshot, `ok`) != 1 { return Err(30) }")
    append_line(out, "    let a: DocArtifact = build_doc_artifact(`d1`, `VaisDB Guide`, `AI cache ai CACHE vector ai`, 6, 6)?")
    append_line(out, "    let b: DocArtifact = build_doc_artifact(`d2`, `Cache Notes`, `cache cache vector vector`, 4, 1)?")
    append_line(out, "    out.push(a)")
    append_line(out, "    out.push(b)")
    append_line(out, "    return Ok(out.len())")
    append_line(out, "}")
    append_line(out, "fn read_artifact_store(path: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    if fs_exists(path) != 1 { return Err(41) }")
    append_line(out, "    let snapshot = fs_read_text(path)")
    append_line(out, "    let loaded = load_artifact_store(snapshot, out)?")
    append_line(out, "    return Ok(loaded)")
    append_line(out, "}")
    append_line(out, "fn artifact_query_score(query: Map<Str,Int>, artifact: DocArtifact) -> Int {")
    append_line(out, "    return artifact.score + artifact.title.len() + query.len()")
    append_line(out, "}")
    append_line(out, "fn best_artifact_for_query(artifacts: List<DocArtifact>, query_text: Str) -> Result<DocArtifact, Int> {")
    append_line(out, "    if artifacts.len() == 0 { return Err(50) }")
    append_line(out, "    if query_text.len() == 0 { return Err(51) }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let query_total = doc_term_counts_into(query_text, query)")
    append_line(out, "    if query_total == 0 { return Err(52) }")
    append_line(out, "    let mut best = artifacts[0]")
    append_line(out, "    let mut best_score = artifact_query_score(query, best)")
    append_line(out, "    for artifact in artifacts {")
    append_line(out, "        let score = artifact_query_score(query, artifact)")
    append_line(out, "        if score > best_score {")
    append_line(out, "            best = artifact")
    append_line(out, "            best_score = score")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return Ok(best)")
    append_line(out, "}")
    append_line(out, "fn artifact_query_report(best: DocArtifact, query_text: Str, loaded: Int, query_total: Int, score: Int) -> Str {")
    append_line(out, "    let newline = str_byte(10)")
    append_line(out, "    let mut report = str_concat(`VaisDB artifact query report`, newline)")
    append_line(out, "    report = str_concat(report, str_concat(`query=`, str_concat(query_text, newline)))")
    append_line(out, "    report = str_concat(report, str_concat(`loaded=`, str_concat(Str(loaded), newline)))")
    append_line(out, "    report = str_concat(report, str_concat(`query_terms=`, str_concat(Str(query_total), newline)))")
    append_line(out, "    report = str_concat(report, str_concat(`score=`, str_concat(Str(score), newline)))")
    append_line(out, "    report = str_concat(report, str_concat(`best_title_len=`, str_concat(Str(best.title.len()), newline)))")
    append_line(out, "    return report")
    append_line(out, "}")
    append_line(out, "fn query_artifact_store_report(path: Str, query_text: Str) -> Result<Str, Int> {")
    append_line(out, "    let loaded: List<DocArtifact> = []")
    append_line(out, "    let loaded_count = read_artifact_store(path, loaded)?")
    append_line(out, "    let best: DocArtifact = best_artifact_for_query(loaded, query_text)?")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let query_total = doc_term_counts_into(query_text, query)")
    append_line(out, "    let score = artifact_query_score(query, best)")
    append_line(out, "    let report = artifact_query_report(best, query_text, loaded_count, query_total, score)")
    append_line(out, "    return Ok(report)")
    append_line(out, "}")
    append_line(out, "fn result_text(flow: Result<Str, Int>) -> Str {")
    append_line(out, "    let value = match flow { Ok(text) => text, Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn result_code(flow: Result<Str, Int>) -> Int {")
    append_line(out, "    let value = match flow { Ok(text) => text.len(), Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let path = path_join(fs_temp_dir(), `vais-full-e310-query-report-store.txt`)")
    append_line(out, "    if fs_write_text(path, str_concat(`ok`, str_byte(10))) != 0 { return 1 }")
    append_line(out, "    let report_flow = query_artifact_store_report(path, `ai cache ai`)")
    append_line(out, "    let report = result_text(report_flow)")
    append_line(out, "    if str_contains(report, `VaisDB artifact query report`) != 1 { return 2 }")
    append_line(out, "    if str_contains(report, `loaded=2`) != 1 { return 3 }")
    append_line(out, "    if str_contains(report, `query_terms=3`) != 1 { return 4 }")
    append_line(out, "    if str_contains(report, `score=20`) != 1 { return 5 }")
    append_line(out, "    if str_contains(report, `best_title_len=12`) != 1 { return 6 }")
    append_line(out, "    let missing = path_join(fs_temp_dir(), `vais-full-e310-missing-store.txt`)")
    append_line(out, "    let missing_flow = query_artifact_store_report(missing, `ai cache ai`)")
    append_line(out, "    if result_code(missing_flow) != 41 { return 7 }")
    append_line(out, "    let empty_flow = query_artifact_store_report(path, ``)")
    append_line(out, "    if result_code(empty_flow) != 51 { return 8 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_call_argument_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { title: Str, score: Int }")
    append_line(out, "struct VaisResultStrInt { tag: Int, value: Str, error: Int }")
    append_line(out, "struct VaisResultDocArtifactInt { tag: Int, value: DocArtifact, error: Int }")
    append_line(out, "fn build_doc_artifact(title: Str, score: Int) -> VaisResultDocArtifactInt {")
    append_line(out, "    if title.len() == 0 { return VaisResultDocArtifactInt { tag: 1, value: DocArtifact { title: ``, score: 0 }, error: 20 } }")
    append_line(out, "    if score < 1 { return VaisResultDocArtifactInt { tag: 1, value: DocArtifact { title: ``, score: 0 }, error: 21 } }")
    append_line(out, "    return VaisResultDocArtifactInt { tag: 0, value: DocArtifact { title: title, score: score }, error: 0 }")
    append_line(out, "}")
    append_line(out, "fn read_checked(path: Str) -> VaisResultStrInt {")
    append_line(out, "    if fs_exists(path) != 1 { return VaisResultStrInt { tag: 1, value: ``, error: 10 } }")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    if text.len() == 0 { return VaisResultStrInt { tag: 1, value: ``, error: 11 } }")
    append_line(out, "    return VaisResultStrInt { tag: 0, value: text, error: 0 }")
    append_line(out, "}")
    append_line(out, "fn result_text(flow: VaisResultStrInt) -> Str {")
    append_line(out, "    if flow.tag == 0 { return flow.value }")
    append_line(out, "    return Str(flow.error)")
    append_line(out, "}")
    append_line(out, "fn result_code(flow: VaisResultStrInt) -> Int {")
    append_line(out, "    if flow.tag == 0 { return flow.value.len() }")
    append_line(out, "    return flow.error")
    append_line(out, "}")
    append_line(out, "fn artifact_score(flow: VaisResultDocArtifactInt) -> Int {")
    append_line(out, "    if flow.tag == 0 {")
    append_line(out, "        return flow.value.title.len() + flow.value.score")
    append_line(out, "    }")
    append_line(out, "    return flow.error")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let path = path_join(root, `vais-full-e311-result-call-argument.txt`)")
    append_line(out, "    if fs_write_text(path, `VaisDB`) != 0 { return 1 }")
    append_line(out, "    let text = result_text(read_checked(path))")
    append_line(out, "    if text != `VaisDB` { return 2 }")
    append_line(out, "    if result_code(read_checked(path)) != 6 { return 3 }")
    append_line(out, "    let missing = path_join(root, `vais-full-e311-missing.txt`)")
    append_line(out, "    if result_code(read_checked(missing)) != 10 { return 4 }")
    append_line(out, "    let good_score = artifact_score(build_doc_artifact(`VaisDB`, 36))")
    append_line(out, "    if good_score != 42 { return 5 }")
    append_line(out, "    let bad_title = artifact_score(build_doc_artifact(``, 36))")
    append_line(out, "    if bad_title != 20 { return 6 }")
    append_line(out, "    return good_score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_local_wrapper_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { title: Str, score: Int }")
    append_line(out, "struct VaisResultDocArtifactInt { tag: Int, value: DocArtifact, error: Int }")
    append_line(out, "fn build_doc_artifact(title: Str, score: Int) -> VaisResultDocArtifactInt {")
    append_line(out, "    if title.len() == 0 {")
    append_line(out, "        return VaisResultDocArtifactInt { tag: 1, value: DocArtifact { title: ``, score: 0 }, error: 20 }")
    append_line(out, "    }")
    append_line(out, "    if score < 1 {")
    append_line(out, "        return VaisResultDocArtifactInt { tag: 1, value: DocArtifact { title: ``, score: 0 }, error: 21 }")
    append_line(out, "    }")
    append_line(out, "    let artifact = DocArtifact { title: title, score: score }")
    append_line(out, "    return VaisResultDocArtifactInt { tag: 0, value: artifact, error: 0 }")
    append_line(out, "}")
    append_line(out, "fn forward_doc(flow: VaisResultDocArtifactInt) -> VaisResultDocArtifactInt {")
    append_line(out, "    if flow.tag != 0 {")
    append_line(out, "        return VaisResultDocArtifactInt { tag: 1, value: DocArtifact { title: ``, score: 0 }, error: flow.error }")
    append_line(out, "    }")
    append_line(out, "    let artifact = flow.value")
    append_line(out, "    return VaisResultDocArtifactInt { tag: 0, value: artifact, error: 0 }")
    append_line(out, "}")
    append_line(out, "fn score_doc(flow: VaisResultDocArtifactInt) -> Int {")
    append_line(out, "    if flow.tag == 0 {")
    append_line(out, "        let artifact = flow.value")
    append_line(out, "        return artifact.title.len() + artifact.score")
    append_line(out, "    }")
    append_line(out, "    return flow.error")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let good = forward_doc(build_doc_artifact(`VaisDB`, 36))")
    append_line(out, "    let score = score_doc(good)")
    append_line(out, "    if score != 42 { return 1 }")
    append_line(out, "    let bad = forward_doc(build_doc_artifact(``, 36))")
    append_line(out, "    if score_doc(bad) != 20 { return 2 }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_str_match_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn title_or_code(flow: Result<DocArtifact, Int>) -> Str {")
    append_line(out, "    let value = match flow { Ok(artifact) => artifact.title, Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn id_or_code(flow: Result<DocArtifact, Int>) -> Str {")
    append_line(out, "    let value = match flow { Ok(artifact) => artifact.id, Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let good = build_doc_artifact(`d1`, `VaisDB Guide`, `AI cache`, 3, 20)")
    append_line(out, "    let bad = build_doc_artifact(``, `VaisDB Guide`, `AI cache`, 3, 20)")
    append_line(out, "    let title = title_or_code(good)")
    append_line(out, "    let id = id_or_code(good)")
    append_line(out, "    let code = title_or_code(bad)")
    append_line(out, "    if title != `VaisDB Guide` { return 1 }")
    append_line(out, "    if id != `d1` { return 2 }")
    append_line(out, "    if code != `10` { return 3 }")
    append_line(out, "    return title.len() * 3 + code.len() * 3")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_str_concat_match_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")

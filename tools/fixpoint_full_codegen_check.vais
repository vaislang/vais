    append_line(out, "    let label = label_or_code(good)")
    append_line(out, "    let code = label_or_code(bad)")
    append_line(out, "    if label != `d1:VaisDB Guide` { return 1 }")
    append_line(out, "    if code != `10` { return 2 }")
    append_line(out, "    return label.len() * 2 + code.len() * 6")

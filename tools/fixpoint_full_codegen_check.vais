fn list_struct_method_field_chain_lines_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn score_edges(xs: List<Box>) -> Int {")
    append_line(out, "    let removed_value = xs.remove_at(1).value")
    append_line(out, "    let last_tag = xs.last().tag")
    append_line(out, "    let popped_tag = xs.pop().tag")
    append_line(out, "    let first_value = xs.first().value")
    append_line(out, "    return removed_value + last_tag + popped_tag + first_value + xs.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let xs: List<Box> = [Box { value: 5, tag: 1 }, Box { value: 10, tag: 2 }, Box { value: 20, tag: 3 }, Box { value: 30, tag: 4 }]")
    append_line(out, "    let a = xs.first().tag")
    append_line(out, "    let b = xs.last().value")
    append_line(out, "    let c = score_edges(xs)")
    append_line(out, "    return a + b + c + xs.len() - 16")
    append_line(out, "}")
    str_builder_append(out, "return run();")
    return str_builder_finish(out)
}


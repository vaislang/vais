}

fn result_struct_str_transform_match_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn normalized_title_or_code(flow: Result<DocArtifact, Int>) -> Str {")
    append_line(out, "    let value = match flow { Ok(artifact) => str_upper(str_trim(str_replace(artifact.title, `guide`, `manual`))), Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn normalized_label_or_code(flow: Result<DocArtifact, Int>) -> Str {")
    append_line(out, "    let prefix = `doc:`")
    append_line(out, "    let value = match flow { Ok(artifact) => str_concat(prefix, str_lower(str_trim(artifact.id))), Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 3, 20)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 3, 20)")
    append_line(out, "    let title = normalized_title_or_code(good)")
    append_line(out, "    let label = normalized_label_or_code(good)")
    append_line(out, "    let code = normalized_title_or_code(bad)")
    append_line(out, "    if title != `VAISDB MANUAL` { return 1 }")
    append_line(out, "    if label != `doc:d1` { return 2 }")
    append_line(out, "    if code != `10` { return 3 }")
    append_line(out, "    return title.len() + label.len() + code.len() + 21")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}

fn result_struct_str_transform_len_match_flow_source() -> Str {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "fn normalized_score_or_code(flow: Result<DocArtifact, Int>) -> Int {")
    append_line(out, "    let prefix = `doc:`")
    append_line(out, "    let value = match flow { Ok(artifact) => str_trim(artifact.title).len() + str_concat(prefix, str_lower(str_trim(artifact.id))).len() + str_replace(artifact.body, `cache`, `store`).len() + artifact.terms + artifact.score, Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "fn run() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let score = normalized_score_or_code(good)")
    append_line(out, "    let code = normalized_score_or_code(bad)")
    append_line(out, "    if score != 42 { return 1 }")
    append_line(out, "    if code != 10 { return 2 }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "return run();")
    return str_builder_finish(out)
}


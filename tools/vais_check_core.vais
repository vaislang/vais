}

fn compound_assign_at(src: Str, i: Int) -> Int {
    let c = src[i]
    if c == 43 or c == 45 or c == 42 or c == 47 or c == 37 {
        if i + 1 < src.len() {
            if src[i + 1] == 61 {
                if i + 2 < src.len() {
                    if src[i + 2] == 61 { return 0 }
                }
                return 1
            }
        }
    }
    return 0
}

fn skip_quoted(src: Str, i: Int, delim: Int) -> Int {
    let mut j = i + 1
    while j < src.len() {
        let c = src[j]
        if c == 92 {
            j = j + 2
        } else if c == delim {
            return j + 1
        } else {
            j = j + 1
        }
    }
    return j
}

fn skip_to_line_end(src: Str, i: Int) -> Int {
    let mut j = i
    while j < src.len() {
        if src[j] == 10 { return j }
        j = j + 1
    }
    return j
}

fn line_no_at(src: Str, pos: Int) -> Int {
    let mut line = 1
    let mut i = 0
    while i < pos {
        if src[i] == 10 { line = line + 1 }
        i = i + 1
    }
    return line
}

fn col_no_at(src: Str, pos: Int) -> Int {
    let mut col = 1
    let mut i = 0
    while i < pos {
        if src[i] == 10 { col = 1 } else { col = col + 1 }
        i = i + 1
    }
    return col
}

fn report_issue_at(path: Str, src: Str, pos: Int, message: Str, help: Str) -> Int {
    let line = line_no_at(src, pos)
    let col = col_no_at(src, pos)
    print(message)
    print(`  --> {path}:{line}:{col}`)
    print(help)
    return 1
}

fn check_text(src: Str) -> Int {
    return check_text_at("memory", src)
}

fn check_text_at(path: Str, src: Str) -> Int {
    let mut issues = 0
    let mut i = 0
    let mut at_line_start = 1
    while i < src.len() {
        let c = src[i]
        let mut handled = 0

        if c == 10 {
            at_line_start = 1
            i = i + 1
            handled = 1
        } else if c == 34 {
            i = skip_quoted(src, i, 34)
            at_line_start = 0
            handled = 1
        } else if c == 96 {
            i = skip_quoted(src, i, 96)
            at_line_start = 0
            handled = 1
        } else if c == 35 {
            i = skip_to_line_end(src, i)
            handled = 1
        } else if at_line_start == 1 {
            if c == 32 or c == 9 or c == 13 {
                i = i + 1
                handled = 1
            } else if word_token_at(src, i, 109, 111, 100, 117, 108, 101, 0, 6) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: module declarations are not implemented yet", "  help: omit this declaration now")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if word_token_at(src, i, 112, 97, 99, 107, 97, 103, 101, 7) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: package declarations are not implemented yet", "  help: omit this declaration now")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if word_token_at(src, i, 117, 115, 101, 0, 0, 0, 0, 3) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: use declarations are not Vais imports", "  help: use import path")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if word_token_at(src, i, 105, 109, 112, 111, 114, 116, 0, 6) == 1 {
                if invalid_import_path_at(src, i) == 1 {
                    issues = issues + report_issue_at(path, src, i, "error: invalid import path", "  help: write a static dotted local import such as import math.add")
                }
                i = skip_to_line_end(src, i)
                handled = 1
            } else {
                at_line_start = 0
            }
        }

        if handled == 0 {
            if i + 1 < src.len() {
                if src[i] == 38 and src[i + 1] == 38 {
                    issues = issues + report_issue_at(path, src, i, "error: logical AND uses word and", "  help: use the word and")
                    i = i + 2
                    handled = 1
                } else if src[i] == 124 and src[i + 1] == 124 {
                    issues = issues + report_issue_at(path, src, i, "error: logical OR uses word or", "  help: use the word or")
                    i = i + 2
                    handled = 1
                }
            }
        }

        if handled == 0 {
            if logical_not_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: logical NOT uses word not", "  help: use the word not")
                i = i + 1
                handled = 1
            } else if as_cast_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: type conversion uses a constructor call", "  help: use the target type as a call")
                i = i + 2
                handled = 1
            } else if generic_ctor_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: generic constructor uses a literal", "  help: use a collection literal")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if invalid_main_signature_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: main must be fn main() -> Int", "  help: write the entrypoint as fn main() -> Int")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if fn_missing_return_type_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: helper functions must return a verified type", "  help: write fn name(args) -> Int, -> Bool, -> Char, -> Str, a declared struct type, or another verified return type")
                i = skip_to_line_end(src, i)
                handled = 1
            } else if i + 1 < src.len() {
                if src[i] == 58 and src[i + 1] == 58 {
                    issues = issues + report_issue_at(path, src, i, "error: double colon path uses dot", "  help: use dot path access")
                    i = i + 2
                    handled = 1
                }
            }
        }

        if handled == 0 {
            if unsupported_option_generic_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: only Option<Int> is verified for now", "  help: use Option<Int> in this slice; generic Option<T> and nested Option/Result payloads are not verified yet")
                i = skip_generic_or_line_end(src, i)
                handled = 1
            } else if unsupported_result_generic_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: only Result<Int,Int>, Result<Str,Int>, Result<Str,Str>, and Result<DeclaredStruct,Int> are verified for now", "  help: use Result<Int,Int>, Result<Str,Int>, Result<Str,Str>, or Result<DeclaredStruct,Int> where the payload struct is declared in this file; generic Result<T,E>, other non-Int error payloads, and nested Option/Result payloads are not verified yet")
                i = skip_generic_or_line_end(src, i)
                handled = 1
            } else if unsupported_map_generic_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: only concrete Map<Int,Int>, Map<Int,Bool>, Map<Int,Char>, Map<Str,Int>, Map<Str,Bool>, Map<Str,Char>, and Map<Str,Str> are verified for now", "  help: use one of the verified concrete Map<K,V> shapes in this slice; broader generic Map forms are not verified yet")
                i = skip_generic_or_line_end(src, i)
                handled = 1
            } else if vec_macro_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: list macro spelling is not Vais", "  help: use a list literal")
                i = i + 3
                handled = 1
            } else if word_token_at(src, i, 83, 116, 114, 105, 110, 103, 0, 6) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: string type spelling is Str", "  help: use Str")
                i = i + 6
                handled = 1
            } else if vec_type_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: list type spelling is List", "  help: use List")
                i = i + 3
                handled = 1
            } else if hashmap_type_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: map type spelling is Map", "  help: use Map")
                i = i + 7
                handled = 1
            } else if rust_scalar_type_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: scalar type spelling is capitalized", "  help: use Vais scalar type names")
                i = i + 1
                handled = 1
            }
        }

        if handled == 0 {
            if method_call_at(src, i, "to_string") == 1 {
                issues = issues + report_issue_at(path, src, i, "error: string conversion uses Str call", "  help: use Str as a conversion call")
                i = i + 1
                handled = 1
            } else if method_call_at(src, i, "unwrap") == 1 {
                issues = issues + report_issue_at(path, src, i, "error: unchecked option access is not Vais", "  help: use branching or propagation")
                i = i + 1
                handled = 1
            } else if method_call_at(src, i, "expect") == 1 {
                issues = issues + report_issue_at(path, src, i, "error: unchecked result access is not Vais", "  help: use branching or propagation")
                i = i + 1
                handled = 1
            } else if if_let_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: pattern conditional uses match", "  help: use pattern branching")
                i = i + 2
                handled = 1
            } else if else_if_typo_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: else if is two words", "  help: write else if")
                i = i + 4
                handled = 1
            } else if compound_assign_at(src, i) == 1 {
                issues = issues + report_issue_at(path, src, i, "error: compound assignment is not supported", "  help: write the assignment out")
                i = i + 2
                handled = 1
            }
        }

        if handled == 0 {
            i = i + 1
        }
    }
    return issues
}

fn check_file(path: Str) -> Int {
    let src = fs_read_text(path)
    return check_text_at(path, src)
}

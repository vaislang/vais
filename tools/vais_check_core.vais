}

fn map_supported_type_at(src: Str, i: Int) -> Int {
    if word_text_at(src, i, "Map") == 0 { return 0 }
    let mut j = skip_inline_spaces(src, i + 3)
    if j >= src.len() { return 0 }
    if src[j] != 60 { return 0 }
    j = skip_inline_spaces(src, j + 1)
    let mut str_key = 0
    if type_word_at(src, j, "Int") == 1 {
        j = skip_inline_spaces(src, j + 3)
    } else if type_word_at(src, j, "Str") == 1 {
        str_key = 1
        j = skip_inline_spaces(src, j + 3)
    } else {
        return 0
    }
    if j >= src.len() { return 0 }
    if src[j] != 44 { return 0 }
    j = skip_inline_spaces(src, j + 1)
    if type_word_at(src, j, "Int") == 1 {
        j = skip_inline_spaces(src, j + 3)
    } else if type_word_at(src, j, "Bool") == 1 {
        j = skip_inline_spaces(src, j + 4)
    } else if type_word_at(src, j, "Char") == 1 {
        j = skip_inline_spaces(src, j + 4)
    } else if str_key == 1 and type_word_at(src, j, "Str") == 1 {
        j = skip_inline_spaces(src, j + 3)
    } else {
        return 0
    }
    if j >= src.len() { return 0 }
    if src[j] != 62 { return 0 }
    return 1
}


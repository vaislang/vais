fn fn_missing_return_type_at(src: Str, i: Int) -> Int {
    if word_text_at(src, i, "fn") == 0 { return 0 }
    let mut j = i + 2
    let mut saw_space = 0
    while j < src.len() {
        if is_space(src[j]) == 1 {
            saw_space = 1
            j = j + 1
        } else {
            break
        }
    }
    if saw_space == 0 { return 0 }
    if j >= src.len() { return 0 }
    if is_ident_start(src[j]) == 0 { return 0 }
    while j < src.len() {
        if is_ident_char(src[j]) == 1 { j = j + 1 } else { break }
    }
    j = skip_inline_spaces(src, j)
    if j >= src.len() { return 0 }
    if src[j] != 40 { return 0 }
    let mut depth = 0
    while j < src.len() {
        if src[j] == 10 { return 0 }
        if src[j] == 40 {
            depth = depth + 1
        } else if src[j] == 41 {
            depth = depth - 1
            if depth == 0 {
                j = j + 1
                break
            }
        }
        j = j + 1
    }
    if depth != 0 { return 0 }
    j = skip_inline_spaces(src, j)
    if j + 1 < src.len() {
        if src[j] == 45 and src[j + 1] == 62 { return 0 }
    }
    if j < src.len() {
        if src[j] == 123 { return 1 }
    }
    return 0
}

fn invalid_main_signature_at(src: Str, i: Int) -> Int {
    if word_text_at(src, i, "fn") == 0 { return 0 }
    let mut j = i + 2
    let mut saw_space = 0
    while j < src.len() {
        if is_space(src[j]) == 1 {
            saw_space = 1
            j = j + 1
        } else {
            break
        }
    }
    if saw_space == 0 { return 0 }
    if word_text_at(src, j, "main") == 0 { return 0 }
    j = j + 4
    j = skip_inline_spaces(src, j)
    if j >= src.len() { return 0 }
    if src[j] != 40 { return 0 }
    let params_start = j + 1
    let mut depth = 0
    while j < src.len() {
        if src[j] == 10 { return 0 }
        if src[j] == 40 {
            depth = depth + 1
        } else if src[j] == 41 {
            depth = depth - 1
            if depth == 0 {
                let params_end = j
                let mut p = params_start
                while p < params_end {
                    if is_space(src[p]) == 1 {
                        p = p + 1
                    } else {
                        return 1
                    }
                }
                j = j + 1
                break
            }
        }
        j = j + 1
    }
    if depth != 0 { return 0 }
    j = skip_inline_spaces(src, j)
    if j + 1 >= src.len() { return 1 }
    if src[j] != 45 { return 1 }
    if src[j + 1] != 62 { return 1 }
    j = skip_inline_spaces(src, j + 2)
    if type_word_at(src, j, "Int") == 0 { return 1 }
    return 0
}

fn skip_generic_or_line_end(src: Str, i: Int) -> Int {

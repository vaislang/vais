        else {
            if src[j] == 40 { return 1 }
            if is_ident_start(src[j]) == 1 { return 1 }
            return 0
        }
    }
    return 0
}

fn generic_ctor_at(src: Str, i: Int) -> Int {
    if i >= src.len() { return 0 }
    if src[i] < 65 or src[i] > 90 { return 0 }
    let mut j = i + 1
    while j < src.len() {
        if is_ident_char(src[j]) == 1 { j = j + 1 }
        else {
            let mut done = 0
            while done == 0 {
                if j < src.len() {
                    if is_space(src[j]) == 1 { j = j + 1 } else { done = 1 }
                } else {
                    done = 1
                }
            }
            if j >= src.len() { return 0 }
            if src[j] != 60 { return 0 }
            j = j + 1
            while j < src.len() {
                if src[j] == 10 { return 0 }
                if src[j] == 62 {
                    j = j + 1
                    let mut done2 = 0
                    while done2 == 0 {
                        if j < src.len() {
                            if is_space(src[j]) == 1 { j = j + 1 } else { done2 = 1 }
                        } else {
                            done2 = 1
                        }
                    }
                    if j + 6 > src.len() { return 0 }
                    if src[j] != 58 { return 0 }
                    if src[j + 1] != 58 { return 0 }
                    if text_at(src, j + 2, "new") == 1 { return 1 }
                    return 0
                }
                j = j + 1
            }
            return 0
        }
    }
    return 0
}

fn vec_macro_at(src: Str, i: Int) -> Int {

fn declared_struct_name(src: Str, name: Str) -> Int {
    let mut i = 0
    while i < src.len() {
        if word_text_at(src, i, "struct") == 1 {
            let mut j = skip_inline_spaces(src, i + 6)
            if type_word_at(src, j, name) == 1 {
                j = skip_inline_spaces(src, j + name.len())
                if j < src.len() {
                    if src[j] == 123 { return 1 }
                }
            }
        }
        i = i + 1
    }
    return 0
}

fn result_declared_struct_int_type_at(src: Str, i: Int) -> Int {
    if word_text_at(src, i, "Result") == 0 { return 0 }
    let mut j = skip_inline_spaces(src, i + 6)
    if j >= src.len() { return 0 }
    if src[j] != 60 { return 0 }
    j = skip_inline_spaces(src, j + 1)
    if j >= src.len() { return 0 }
    if is_ident_start(src[j]) == 0 { return 0 }
    let payload_start = j
    while j < src.len() {
        if is_ident_char(src[j]) == 1 { j = j + 1 } else { break }
    }
    let payload = str_slice(src, payload_start, j - payload_start)
    j = skip_inline_spaces(src, j)
    if j >= src.len() { return 0 }
    if src[j] != 44 { return 0 }
    j = skip_inline_spaces(src, j + 1)
    if type_word_at(src, j, "Int") == 0 { return 0 }
    j = skip_inline_spaces(src, j + 3)
    if j >= src.len() { return 0 }
    if src[j] != 62 { return 0 }
    if declared_struct_name(src, payload) == 1 { return 1 }
    return 0
}


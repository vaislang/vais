}

fn method_call_at(src: Str, i: Int, name: Str) -> Int {
    if src[i] != 46 { return 0 }
    if text_at(src, i + 1, name) == 0 { return 0 }
    let mut j = i + 1 + name.len()
    while j < src.len() {
        if is_space(src[j]) == 1 { j = j + 1 }
        else {
            if src[j] == 40 { return 1 }
            return 0
        }
    }
    return 0
}

fn if_let_at(src: Str, i: Int) -> Int {
    if word_text_at(src, i, "if") == 0 { return 0 }

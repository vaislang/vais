fn is_ident_char(c: Int) -> Int {
    if c >= 48 and c <= 57 { return 1 }
    if c >= 65 and c <= 90 { return 1 }
    if c >= 97 and c <= 122 { return 1 }
    if c == 95 { return 1 }
    return 0
}

fn is_ident_start(c: Int) -> Int {
    if c >= 65 and c <= 90 { return 1 }
    if c >= 97 and c <= 122 { return 1 }
    if c == 95 { return 1 }
    return 0
}

fn is_space(c: Int) -> Int {
    if c == 32 { return 1 }
    if c == 9 { return 1 }
    if c == 13 { return 1 }
    return 0
}

fn text_at(src: Str, i: Int, word: Str) -> Int {
    if i + word.len() > src.len() { return 0 }
    let mut k = 0
    while k < word.len() {
        if src[i + k] != word[k] { return 0 }
        k = k + 1
    }
    return 1
}

fn word_text_at(src: Str, i: Int, word: Str) -> Int {
    if text_at(src, i, word) == 0 { return 0 }
    if i > 0 {
        if is_ident_char(src[i - 1]) == 1 { return 0 }
    }
    let end = i + word.len()
    if end < src.len() {
        if is_ident_char(src[end]) == 1 { return 0 }
    }
    return 1
}

fn invalid_import_path_at(src: Str, i: Int) -> Int {
    let mut j = i + 6
    let mut saw_space = 0
    while j < src.len() {
        let c = src[j]
        if c == 32 or c == 9 or c == 13 {
            saw_space = 1
            j = j + 1
        } else {
            break
        }
    }
    if saw_space == 0 { return 1 }
    if j >= src.len() { return 1 }
    if src[j] == 10 or src[j] == 35 { return 1 }

    let mut saw_segment = 0
    let mut need_segment = 1
    while j < src.len() {
        let c = src[j]
        if c == 10 or c == 35 { break }
        if c == 32 or c == 9 or c == 13 {
            while j < src.len() {
                let ws = src[j]
                if ws == 32 or ws == 9 or ws == 13 { j = j + 1 } else { break }
            }
            if j >= src.len() { break }
            if src[j] == 10 or src[j] == 35 { break }
            return 1
        }
        if need_segment == 1 {
            if is_ident_start(c) == 0 { return 1 }
            saw_segment = 1
            need_segment = 0
            j = j + 1
        } else if is_ident_char(c) == 1 {
            j = j + 1
        } else if c == 46 {
            need_segment = 1
            j = j + 1
        } else {
            return 1
        }
    }
    if saw_segment == 0 { return 1 }
    if need_segment == 1 { return 1 }
    return 0
}

fn skip_inline_spaces(src: Str, i: Int) -> Int {
    let mut j = i
    while j < src.len() {
        let c = src[j]
        if c == 32 or c == 9 or c == 13 { j = j + 1 } else { return j }
    }
    return j
}

fn type_word_at(src: Str, i: Int, word: Str) -> Int {
    if text_at(src, i, word) == 0 { return 0 }
    let end = i + word.len()
    if end < src.len() {
        if is_ident_char(src[end]) == 1 { return 0 }
    }
    return 1
}


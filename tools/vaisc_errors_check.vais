    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let b = Box { value: 42 }")
    append_line(out, "    return b.missing")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


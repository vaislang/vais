fn str_eq(a: Str, b: Str) -> Int {
    if a.len() != b.len() { return 0 }
    let mut i = 0
    while i < a.len() {
        if a[i] != b[i] { return 0 }
        i = i + 1
    }
    return 1
}

fn text_at(src: Str, i: Int, word: Str) -> Int {
    if i < 0 { return 0 }
    if i + word.len() > src.len() { return 0 }
    let mut k = 0
    while k < word.len() {
        if src[i + k] != word[k] { return 0 }
        k = k + 1
    }
    return 1
}

fn str_contains(src: Str, word: Str) -> Int {
    if word.len() == 0 { return 1 }
    let mut i = 0
    while i + word.len() <= src.len() {
        if text_at(src, i, word) == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn append_uint(out: Int, n: Int) -> Int {
    if n >= 10 { append_uint(out, n / 10) }
    str_builder_push(out, 48 + (n % 10))
    return 0
}

fn uint_to_str(n: Int) -> Str {
    if n == 0 { return "0" }
    let out = str_builder_new()
    append_uint(out, n)
    return str_builder_finish(out)
}

fn append_line(out: Int, line: Str) -> Int {
    str_builder_append(out, line)
    str_builder_push(out, 10)
    return 0
}

fn two_bytes(a: Int, b: Int) -> Str {
    return str_concat(str_byte(a), str_byte(b))
}

fn bad_and_line() -> Str {
    return str_concat(str_concat("    if 1 == 1 ", two_bytes(38, 38)), " 2 == 2 {")
}

fn bad_or_line() -> Str {
    return str_concat(str_concat("    if 1 == 0 ", two_bytes(124, 124)), " 2 == 2 {")
}

fn bad_as_line() -> Str {
    let sp = str_byte(32)
    return str_concat(str_concat(str_concat("    return 1", sp), "as"), str_concat(sp, "Int"))
}

fn bad_as_phrase() -> Str {
    let sp = str_byte(32)
    return str_concat(str_concat(str_concat("x", sp), "as"), str_concat(sp, "Type"))
}

fn bad_path_line() -> Str {
    return str_concat(str_concat("    return Foo", two_bytes(58, 58)), "Bar")
}

fn bad_scalar_line() -> Str {
    return str_concat(str_concat("fn id(x: ", str_byte(105)), "32) -> Int {")
}

fn bad_turbofish_line() -> Str {
    return str_concat(str_concat(str_concat("    let xs = ", "Vec"), str_concat("<Int>", two_bytes(58, 58))), "new()")
}

fn bad_method_line() -> Str {
    return str_concat(str_concat("    return xs.", "clear"), "()")
}

fn write_rust_and(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, bad_and_line())
    append_line(out, "        return 42")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_rust_or(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, bad_or_line())
    append_line(out, "        return 42")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


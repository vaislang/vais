fn write_result_try_parse_error_flow_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn parse_required_count(raw: Str, label: Str) -> Result<Int, Int> {")
    append_line(out, "    if raw.len() == 0 { return Err(10) }")
    append_line(out, "    if label.len() == 0 { return Err(11) }")
    append_line(out, "    let value = parse_int(raw)")
    append_line(out, "    if value <= 0 { return Err(12) }")
    append_line(out, "    return Ok(value)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_doc(raw_terms: Str, raw_boost: Str) -> Result<Int, Int> {")
    append_line(out, "    let terms = parse_required_count(raw_terms, \"terms\")?")
    append_line(out, "    let boost = parse_required_count(raw_boost, \"boost\")?")
    append_line(out, "    return Ok(terms * boost)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = match score_doc(\"6\", \"7\") { Ok(good_value) => good_value, Err(good_error) => good_error }")
    append_line(out, "    let empty = match score_doc(\"\", \"7\") { Ok(empty_value) => empty_value, Err(empty_error) => empty_error }")
    append_line(out, "    let bad_parse = match score_doc(\"6\", \"no\") { Ok(parse_value) => parse_value, Err(parse_error) => parse_error }")
    append_line(out, "    return good - empty - bad_parse + 22")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


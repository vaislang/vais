    append_line(out, "    let empty = str_index_of(\"abc\", \"\")")
    append_line(out, "    let miss = str_index_of(\"abc\", \"z\")")
    append_line(out, "    if a != 4 { return 1 }")
    append_line(out, "    if b != 3 { return 2 }")
    append_line(out, "    if empty != 0 { return 3 }")
    append_line(out, "    if miss != 0 - 1 { return 4 }")
    append_line(out, "    if str_index_of(str_lower(\"VaisDB\"), \"db\") != 4 { return 5 }")
    append_line(out, "    return a * 10 + b + empty + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


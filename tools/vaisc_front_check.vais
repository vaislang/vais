    append_line(out, "    return flags")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let flags: ", map_str_bool_spaced()), " = make_flags()"))
    append_line(out, str_concat(str_concat("    let copy: ", map_str_bool_spaced()), " = {}"))
    append_line(out, "    copy = flags")
    append_line(out, "    flags.remove(\"blue\")")
    append_line(out, "    let red_value = match flags.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    if copy.contains(\"blue\") and flags.contains(\"red\") and not flags.contains(\"blue\") {")
    append_line(out, "        return red_value * 40 + copy.len()")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_int_param_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, str_concat(str_concat("fn put(scores: ", map_str_int_spaced()), ", key: Str, value: Int) -> Int {"))
    append_line(out, "    scores.insert(key, value)")
    append_line(out, "    scores.insert(\"blue\", 2)")
    append_line(out, "    scores.remove(\"blue\")")
    append_line(out, "    return scores.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let scores: ", map_str_int_spaced()), " = {}"))
    append_line(out, "    let red: Str = \"red\"")
    append_line(out, "    let n = put(scores, red, 40)")
    append_line(out, "    if scores.contains(\"red\") and not scores.contains(\"blue\") {")
    append_line(out, "        return scores.get(\"red\", 0) + n + scores.len()")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


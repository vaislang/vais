fn write_struct_helper_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Pair { a: Int, b: Int }")
    append_line(out, "")
    append_line(out, "fn make(x: Int) -> Pair {")
    append_line(out, "    return Pair { a: x, b: x + 1 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn bump(p: Pair) -> Pair {")
    append_line(out, "    return Pair { a: p.a + 1, b: p.b + 1 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn sum(p: Pair) -> Int {")
    append_line(out, "    return p.a + p.b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut p = make(19)")
    append_line(out, "    p = bump(p)")
    append_line(out, "    return sum(p) + 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_struct_method_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Counter { value: Int }")
    append_line(out, "impl Counter {")
    append_line(out, "    fn bump(self, n: Int) -> Counter {")
    append_line(out, "        return Counter { value: self.value + n }")
    append_line(out, "    }")
    append_line(out, "    fn get(self) -> Int {")
    append_line(out, "        return self.value")
    append_line(out, "    }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let c = Counter { value: 0 }")
    append_line(out, "    return c.bump(10).bump(15).get()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


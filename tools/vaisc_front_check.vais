fn write_borrowed_list_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn sum_from(xs: &List<Int>, i: Int, n: Int) -> Int {")
    append_line(out, "    if i >= n { return 0 }")
    append_line(out, "    return xs[i] + sum_from(xs, i + 1, n)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let nums: List<Int> = [1, 2, 3, 4]")

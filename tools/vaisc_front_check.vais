fn write_result_struct_payload_bool_match_condition_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn trimmed_len(text: Str) -> Int {")
    append_line(out, "    let clean = str_trim(text)")
    append_line(out, "    return clean.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn weight_terms(value: Int) -> Int {")
    append_line(out, "    return value * 3")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn is_publishable(flow: Result<DocArtifact, Int>) -> Bool {")
    append_line(out, "    return match flow { Ok(artifact) => trimmed_len(artifact.title) + weight_terms(artifact.terms) + artifact.score >= 35, Err(code) => code == 10 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 4, 11)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 4, 11)")
    append_line(out, "    let weak = build_doc_artifact(` D2 `, `  x  `, `AI cache`, 1, 1)")
    append_line(out, "    if is_publishable(good) != true { return 1 }")
    append_line(out, "    if is_publishable(bad) != true { return 2 }")
    append_line(out, "    if is_publishable(weak) != false { return 3 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_indexer_prototype_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn require_present_len(meta: Map<Str,Str>, key: Str) -> Int {")
    append_line(out, "    return match meta.get_opt(key) { Some(value) => str_trim(value).len(), None => 0 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn ingest_doc(meta: Map<Str,Str>, title_key: Str, body_key: Str, title: Str, body: Str, terms: Map<Str,Int>) -> Int {")
    append_line(out, "    if title.len() == 0 { return 0 }")
    append_line(out, "    if body.len() == 0 { return 0 }")
    append_line(out, "    meta.insert(title_key, title)")
    append_line(out, "    meta.insert(body_key, body)")
    append_line(out, "    return doc_term_counts_into(body, terms)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_indexer() -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let a_total = ingest_doc(meta, \"d1.title\", \"d1.body\", \"VaisDB Guide\", \"AI cache ai CACHE vector ai\", doc_a)")
    append_line(out, "    let b_total = ingest_doc(meta, \"d2.title\", \"d2.body\", \"Cache Notes\", \"cache cache vector vector\", doc_b)")
    append_line(out, "    if a_total != 6 { return 20 }")
    append_line(out, "    if b_total != 4 { return 21 }")
    append_line(out, "    if meta.len() != 4 { return 22 }")
    append_line(out, "    let snapshot = map_str_str_snapshot(meta)")
    append_line(out, "    let loaded: Map<Str,Str> = {}")
    append_line(out, "    if map_str_str_load_snapshot(snapshot, loaded) != 4 { return 23 }")
    append_line(out, "    if loaded.get(\"d1.title\", \"\") != \"VaisDB Guide\" { return 24 }")
    append_line(out, "    if loaded.get(\"d2.title\", \"\") != \"Cache Notes\" { return 25 }")
    append_line(out, "    if require_present_len(loaded, \"d1.title\") == 0 { return 26 }")
    append_line(out, "    if require_present_len(loaded, \"d2.body\") == 0 { return 27 }")
    append_line(out, "    if require_present_len(loaded, \"d3.title\") != 0 { return 28 }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let q_total = doc_term_counts_into(\"ai cache ai\", query)")
    append_line(out, "    if q_total != 3 { return 29 }")
    append_line(out, "    let a_score = doc_term_weighted_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_weighted_score(query, doc_b)")
    append_line(out, "    if a_score != 8 { return 30 }")
    append_line(out, "    if b_score != 2 { return 31 }")
    append_line(out, "    if a_score <= b_score { return 32 }")
    append_line(out, "    return a_score * 5 + b_score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return run_indexer()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_file_ingest_workflow_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn ingest_file(meta: Map<Str,Str>, title_key: Str, body_key: Str, path: Str, terms: Map<Str,Int>) -> Int {")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n < 2 { return 0 }")
    append_line(out, "    let title = str_trim(lines[0])")
    append_line(out, "    let body = str_trim(lines[1])")
    append_line(out, "    if title.len() == 0 { return 0 }")
    append_line(out, "    if body.len() == 0 { return 0 }")
    append_line(out, "    meta.insert(title_key, title)")
    append_line(out, "    meta.insert(body_key, body)")
    append_line(out, "    return doc_term_counts_into(body, terms)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn read_query_file(path: Str, query: Map<Str,Int>) -> Int {")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n == 0 { return 0 }")
    append_line(out, "    let query_text = str_trim(lines[0])")
    append_line(out, "    if query_text.len() == 0 { return 0 }")
    append_line(out, "    return doc_term_counts_into(query_text, query)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_files(doc_a_path: Str, doc_b_path: Str, query_path: Str) -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let a_total = ingest_file(meta, \"d1.title\", \"d1.body\", doc_a_path, doc_a)")
    append_line(out, "    let b_total = ingest_file(meta, \"d2.title\", \"d2.body\", doc_b_path, doc_b)")
    append_line(out, "    if a_total != 6 { return 20 }")
    append_line(out, "    if b_total != 4 { return 21 }")
    append_line(out, "    let snapshot = map_str_str_snapshot(meta)")
    append_line(out, "    let loaded: Map<Str,Str> = {}")
    append_line(out, "    if map_str_str_load_snapshot(snapshot, loaded) != 4 { return 22 }")
    append_line(out, "    if loaded.get(\"d1.title\", \"\") != \"VaisDB Guide\" { return 23 }")
    append_line(out, "    if loaded.get(\"d2.title\", \"\") != \"Cache Notes\" { return 24 }")
    append_line(out, "    if loaded.get(\"d1.body\", \"\").len() == 0 { return 25 }")
    append_line(out, "    if loaded.get(\"d2.body\", \"\").len() == 0 { return 26 }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let q_total = read_query_file(query_path, query)")
    append_line(out, "    if q_total != 3 { return 27 }")
    append_line(out, "    let a_score = doc_term_weighted_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_weighted_score(query, doc_b)")
    append_line(out, "    if a_score != 8 { return 28 }")
    append_line(out, "    if b_score != 2 { return 29 }")
    append_line(out, "    if a_score <= b_score { return 30 }")
    append_line(out, "    return a_score * 5 + b_score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_generated_files() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let doc_a = path_join(root, \"vais-front-e297-doc-a.txt\")")
    append_line(out, "    let doc_b = path_join(root, \"vais-front-e297-doc-b.txt\")")
    append_line(out, "    let query = path_join(root, \"vais-front-e297-query.txt\")")
    append_line(out, "    let lf = str_byte(10)")
    append_line(out, "    let doc_a_text = str_concat(\"VaisDB Guide\", str_concat(lf, str_concat(\"AI cache ai CACHE vector ai\", lf)))")
    append_line(out, "    let doc_b_text = str_concat(\"Cache Notes\", str_concat(lf, str_concat(\"cache cache vector vector\", lf)))")
    append_line(out, "    let query_text = str_concat(\"ai cache ai\", lf)")
    append_line(out, "    if fs_write_text(doc_a, doc_a_text) != 0 { return 2 }")
    append_line(out, "    if fs_write_text(doc_b, doc_b_text) != 0 { return 3 }")
    append_line(out, "    if fs_write_text(query, query_text) != 0 { return 4 }")
    append_line(out, "    return run_files(doc_a, doc_b, query)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    if proc_argc() == 3 {")
    append_line(out, "        return run_files(proc_arg(0), proc_arg(1), proc_arg(2))")
    append_line(out, "    }")
    append_line(out, "    if proc_argc() != 0 { return 1 }")
    append_line(out, "    return run_generated_files()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_option_generic(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let x: Option<Str> = Some(\"ok\")")
    append_line(out, "    match x {")
    append_line(out, "        Some(v) => return v.len(),")
    append_line(out, "        None => return 0,")
    append_line(out, "    }")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


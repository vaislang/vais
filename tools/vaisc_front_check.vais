    append_line(out, str_concat(str_concat("    let direct_total = total_scores(docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score))"))))
    append_line(out, str_concat(str_concat("    let found_beta = has_title(docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.title), \"beta\")"))))

fn write_accept_source(name: Str, path: Str) -> Int {
    if str_eq(name, "day1") == 1 { return write_day1(path) }
    if str_eq(name, "for") == 1 { return write_for_accept(path) }
    if str_eq(name, "io") == 1 { return write_io_accept(path) }
    if str_eq(name, "struct") == 1 { return write_struct_accept(path) }
    if str_eq(name, "nested_struct") == 1 { return write_nested_struct_accept(path) }
    if str_eq(name, "nested_struct_multiline") == 1 { return write_nested_struct_multiline_accept(path) }
    if str_eq(name, "list_nested_struct_field_chain") == 1 { return write_list_nested_struct_field_chain_accept(path) }
    if str_eq(name, "list_nested_struct_field_chain_write") == 1 { return write_list_nested_struct_field_chain_write_accept(path) }
    if str_eq(name, "list_nested_struct_method_field_chain") == 1 { return write_list_nested_struct_method_field_chain_accept(path) }
    if str_eq(name, "struct_return_field_chain") == 1 { return write_struct_return_field_chain_accept(path) }
    if str_eq(name, "nested_struct_literal_return") == 1 { return write_nested_struct_literal_return_accept(path) }
    if str_eq(name, "multi_field_nested_struct") == 1 { return write_multi_field_nested_struct_accept(path) }
    if str_eq(name, "list_multi_field_nested_struct") == 1 { return write_list_multi_field_nested_struct_accept(path) }

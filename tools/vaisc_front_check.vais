fn write_list_struct_element_assignment_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn put(xs: List<Box>, i: Int, value: Int) -> Int {")
    append_line(out, "    let replacement = Box { value: value, tag: xs[i].tag + 1 }")
    append_line(out, "    xs[i] = replacement")
    append_line(out, "    return xs[i].value + xs[i].tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn copy_from(xs: List<Box>, dst: Int, src: Int) -> Int {")

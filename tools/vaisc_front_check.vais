    append_line(out, "    b: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "    tag: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make(a: Int, b: Int, tag: Int) -> Outer {")
    append_line(out, "    return Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            a: a,")
    append_line(out, "            b: b,")
    append_line(out, "        },")
    append_line(out, "        tag: tag,")
    append_line(out, "    }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn update(xs: List<Outer>, idx: Int) -> Int {")
    append_line(out, "    xs[idx].inner.a = xs[idx].inner.a + xs[idx].tag")
    append_line(out, "    return xs[idx].inner.a")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Outer> = []")
    append_line(out, "    let one = make(10, 20, 1)")
    append_line(out, "    let two = make(3, 4, 2)")
    append_line(out, "    xs.push(one)")
    append_line(out, "    xs.push(two)")
    append_line(out, "    xs[0].inner.b = 30")
    append_line(out, "    let copied = xs[0]")
    append_line(out, "    xs[1] = copied")
    append_line(out, "    let p = update(xs, 1)")
    append_line(out, "    return xs[0].inner.b + p + xs.last().inner.a - xs[0].inner.a")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


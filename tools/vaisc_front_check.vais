fn write_list_struct_for_each_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn score(xs: List<Box>) -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    for box in xs {")
    append_line(out, "        total = total + box.value + box.tag")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10, tag: 1 })")
    append_line(out, "    xs.push(Box { value: 20, tag: 2 })")
    append_line(out, "    let more: List<Box> = []")
    append_line(out, "    more.push(Box { value: 7, tag: 2 })")
    append_line(out, "    xs.extend(more)")
    append_line(out, "    let mut local = 0")
    append_line(out, "    for item in xs {")
    append_line(out, "        local = local + item.value")
    append_line(out, "    }")
    append_line(out, "    if local != 37 { return 1 }")
    append_line(out, "    return score(xs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_field_write_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box { value: Int, tag: Int }")
    append_line(out, "")
    append_line(out, "fn bump(xs: List<Box>, i: Int, delta: Int) -> Int {")
    append_line(out, "    xs[i].value = xs[i].value + delta")
    append_line(out, "    xs[i].tag = xs[i].tag + 1")
    append_line(out, "    return xs[i].value + xs[i].tag")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10, tag: 1 })")
    append_line(out, "    xs.push(Box { value: 20, tag: 2 })")
    append_line(out, "    xs[0].value = 15")
    append_line(out, "    xs[1].tag = xs[0].value - 10")
    append_line(out, "    if xs[0].value != 15 { return 1 }")
    append_line(out, "    if xs[1].tag != 5 { return 2 }")
    append_line(out, "    let score = bump(xs, 1, 20)")
    append_line(out, "    return score - xs[0].tag - xs.len() - 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


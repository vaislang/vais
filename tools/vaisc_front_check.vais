}

fn write_package_not(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, bad_package_line())
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_missing_import(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "import math.missing")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_string_type(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, bad_string_type_line())
    append_line(out, "    return 42")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return len(`x`)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_reject_source(name: Str, path: Str) -> Int {
    if str_eq(name, "bad_main_signature") == 1 { return write_bad_main(path) }
    if str_eq(name, "helper_missing_return_type") == 1 { return write_helper_missing_return(path) }
    if str_eq(name, name_payload_bad()) == 1 { return write_payload_enum_struct(path) }
    if str_eq(name, "closure_literal") == 1 { return write_closure_literal_bad(path) }
    if str_eq(name, "rust_and") == 1 { return write_rust_and_bad(path) }
    if str_eq(name, "unsupported_method") == 1 { return write_unsupported_method(path) }
    if str_eq(name, "map_generic_not_verified") == 1 { return write_map_generic(path) }
    if str_eq(name, "module_not_implemented") == 1 { return write_module_not(path) }
    if str_eq(name, "package_not_implemented") == 1 { return write_package_not(path) }
    if str_eq(name, "missing_import") == 1 { return write_missing_import(path) }
    if str_eq(name, "string_type") == 1 { return write_string_type(path) }
    return 1
}

fn expect_reject(vaisc: Str, tmp: Str, name: Str, needle: Str, needle2: Str, help_needle: Str) -> Int {
    let src = path_join(tmp, str_concat(name, ".vais"))
    if write_reject_source(name, src) != 0 {
        print(str_concat("  FAIL rejects ", str_concat(name, ": write fixture")))
        return 1
    }
    return expect_reject_path(vaisc, tmp, name, src, needle, needle2, help_needle)
}

fn write_text(path: Str, text: Str) -> Int {
    return fs_write_text(path, text)
}

fn line(text: Str) -> Str {
    return str_concat(text, str_byte(10))
}

fn write_module_accept(root: Str) -> Str {
    let math_dir = path_join(root, "math")
    fs_mkdirs(math_dir)
    write_text(path_join(math_dir, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    let main_path = path_join(root, "main.vais")
    let out = str_builder_new()
    append_line(out, "import math.add")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn write_package_accept(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    let math_dir = path_join(src_dir, "math")
    fs_mkdirs(math_dir)
    write_text(path_join(root, "vais.toml"), str_concat(line("name = \"package_basic\""), str_concat(line("version = \"0.1.0\""), line("source = \"src\""))))
    write_text(path_join(math_dir, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    let main_path = path_join(src_dir, "main.vais")
    let out = str_builder_new()
    append_line(out, "import math.add")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn write_dependency_accept(root: Str) -> Str {
    let app = path_join(root, "app")
    let mathlib = path_join(root, "mathlib")
    let app_src = path_join(app, "src")
    let arith = path_join(path_join(mathlib, "src"), "arith")
    fs_mkdirs(app_src)
    fs_mkdirs(arith)
    let app_manifest = str_concat(line("name = \"dependency_app\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("mathlib = \"../mathlib\""))))))
    write_text(path_join(app, "vais.toml"), app_manifest)
    write_text(path_join(mathlib, "vais.toml"), str_concat(line("name = \"mathlib\""), str_concat(line("version = \"0.1.0\""), line("source = \"src\""))))
    write_text(path_join(arith, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    write_text(path_join(path_join(mathlib, "src"), "public.vais"), line("import arith.add"))
    let main_path = path_join(app_src, "main.vais")
    let out = str_builder_new()
    append_line(out, "import mathlib.public")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn expect_accept_path(vaisc: Str, src: Str, label: Str, want: Int) -> Int {
    let got = run_vaisc_run(vaisc, src)
    if got == want {
        print(str_concat("  PASS ", label))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(label, str_concat(" got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
    return 1
}

fn setup_bad_manifest(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    fs_mkdirs(src_dir)
    write_text(path_join(root, "vais.toml"), str_concat(line("name = \"bad_manifest\""), line("version = \"0.1.0\"")))
    let main_path = path_join(src_dir, "main.vais")
    write_text(main_path, str_concat(line("fn main() -> Int {"), str_concat(line("    return 42"), line("}"))))
    return main_path
}

fn setup_bad_source_manifest(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    fs_mkdirs(src_dir)
    write_text(path_join(root, "vais.toml"), str_concat(line("name = \"bad_source\""), str_concat(line("version = \"0.1.0\""), line("source = \"../src\""))))
    let main_path = path_join(src_dir, "main.vais")
    write_text(main_path, str_concat(line("fn main() -> Int {"), str_concat(line("    return 42"), line("}"))))
    return main_path
}

fn setup_missing_dependency(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    fs_mkdirs(src_dir)
    let manifest = str_concat(line("name = \"missing_dep\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("missing = \"../missing\""))))))
    write_text(path_join(root, "vais.toml"), manifest)
    let main_path = path_join(src_dir, "main.vais")
    write_text(main_path, str_concat(line("fn main() -> Int {"), str_concat(line("    return 42"), line("}"))))
    return main_path
}

fn setup_bad_dependency_path(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    fs_mkdirs(src_dir)
    let manifest = str_concat(line("name = \"bad_dep_path\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("web = \"https://example.com/pkg\""))))))
    write_text(path_join(root, "vais.toml"), manifest)
    let main_path = path_join(src_dir, "main.vais")
    write_text(main_path, str_concat(line("fn main() -> Int {"), str_concat(line("    return 42"), line("}"))))
    return main_path
}

fn setup_dependency_cycle(root: Str) -> Str {
    let a = path_join(root, "a")
    let b = path_join(root, "b")
    let a_src = path_join(a, "src")
    let b_src = path_join(b, "src")
    fs_mkdirs(a_src)
    fs_mkdirs(b_src)
    let a_manifest = str_concat(line("name = \"cycle_a\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("b = \"../b\""))))))
    let b_manifest = str_concat(line("name = \"cycle_b\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("a = \"../a\""))))))
    write_text(path_join(a, "vais.toml"), a_manifest)
    write_text(path_join(b, "vais.toml"), b_manifest)
    let main_path = path_join(a_src, "main.vais")
    write_text(main_path, str_concat(line("fn main() -> Int {"), str_concat(line("    return 42"), line("}"))))
    return main_path
}

fn setup_duplicate_import(root: Str) -> Str {
    let adir = path_join(root, "a")
    let bdir = path_join(root, "b")
    fs_mkdirs(adir)
    fs_mkdirs(bdir)
    write_text(path_join(adir, "one.vais"), str_concat(line("fn helper() -> Int {"), str_concat(line("    return 1"), line("}"))))
    write_text(path_join(bdir, "two.vais"), str_concat(line("fn helper() -> Int {"), str_concat(line("    return 2"), line("}"))))
    let main_path = path_join(root, "main.vais")
    let out = str_builder_new()
    append_line(out, "import a.one")
    append_line(out, "import b.two")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return helper()")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn setup_cycle_import(root: Str) -> Str {
    fs_mkdirs(root)
    write_text(path_join(root, "a.vais"), str_concat(line("import b"), str_concat(line(""), str_concat(line("fn a() -> Int {"), str_concat(line("    return 1"), line("}"))))))
    write_text(path_join(root, "b.vais"), str_concat(line("import a"), str_concat(line(""), str_concat(line("fn b() -> Int {"), str_concat(line("    return 2"), line("}"))))))
    let main_path = path_join(root, "main.vais")
    let out = str_builder_new()
    append_line(out, "import a")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return a()")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn usage() -> Int {
    print("usage: vaisc-front-check <repo-root> <tmp-dir>")
    return 2
}

fn main() -> Int {
    if proc_argc() != 2 { return usage() }
    let root = proc_arg(0)
    let tmp = proc_arg(1)
    if fs_mkdirs(tmp) != 0 {
        print(str_concat("error: could not create temp dir: ", tmp))
        return 1
    }
    let vaisc = path_join(root, "scripts/vaisc")
    let mut fail = 0

    fail = fail + expect_accept(vaisc, tmp, "day1", "accepts day-1 Int/let/while/if/function-call subset", 42)
    fail = fail + expect_accept(vaisc, tmp, "for", "accepts range for-loop and break/continue subset", 42)
    fail = fail + expect_io_accept(vaisc, tmp)
    fail = fail + expect_accept(vaisc, tmp, "struct", "accepts struct literal and field access slice", 42)
    fail = fail + expect_accept(vaisc, tmp, "tag", label_payload_free(), 2)
    fail = fail + expect_accept(vaisc, tmp, name_payload_accept(), label_payload_small(), 14)
    fail = fail + expect_accept(vaisc, tmp, name_match_expr_accept(), label_match_expr_accept(), 2)
    fail = fail + expect_accept(vaisc, tmp, name_struct_enum_field_accept(), label_struct_enum_field_accept(), 1)
    fail = fail + expect_accept(vaisc, tmp, name_payload_struct_accept(), label_payload_struct_accept(), 5)
    fail = fail + expect_accept(vaisc, tmp, "closure", label_closure_accept(), 7)
    fail = fail + expect_accept(vaisc, tmp, "list", "accepts List push/len/is_empty/last/pop/index/sum slice", 23)
    fail = fail + expect_accept(vaisc, tmp, "str", "accepts Str parameter, Bool helper, len, index, and byte classification slice", 42)
    fail = fail + expect_accept(vaisc, tmp, "char", "accepts Char literal, type annotation, return, and Bool predicate slice", 42)
    fail = fail + expect_accept(vaisc, tmp, "parse", "accepts named parse_uint/parse_int Str helpers", 42)
    fail = fail + expect_accept_path(vaisc, write_module_accept(path_join(tmp, "module_basic")), "accepts local import multi-file full slice", 42)
    fail = fail + expect_accept_path(vaisc, write_package_accept(path_join(tmp, "package_basic")), "accepts package manifest source root full slice", 42)
    fail = fail + expect_accept_path(vaisc, write_dependency_accept(path_join(tmp, "dependency_basic")), "accepts local dependency package paths", 42)

    fail = fail + expect_reject(vaisc, tmp, "bad_main_signature", "requires", "fn main() -> Int", "write the entrypoint")
    fail = fail + expect_reject(vaisc, tmp, "helper_missing_return_type", "helper functions must return", "", "fn name")
    fail = fail + expect_reject(vaisc, tmp, name_payload_bad(), msg_enum_decl(), "", str_concat("broader payload ", str_concat(kw_enum(), "s")))
    fail = fail + expect_reject(vaisc, tmp, "closure_literal", msg_closure(), "", help_closure())
    fail = fail + expect_reject(vaisc, tmp, "rust_and", "logical AND uses the word", "", "and")
    fail = fail + expect_reject(vaisc, tmp, "unsupported_method", "method calls beyond push/len/is_empty/last/pop/sum", "", "plain function call")
    fail = fail + expect_accept(vaisc, tmp, "map", label_map_accept(), 42)
    fail = fail + expect_reject(vaisc, tmp, "map_generic_not_verified", msg_map_generic(), "", "generic key/value forms")
    fail = fail + expect_reject(vaisc, tmp, "module_not_implemented", "module and package declarations are not implemented", "", "module names are derived from file paths")
    fail = fail + expect_reject(vaisc, tmp, "package_not_implemented", "module and package declarations are not implemented", "", "module names are derived from file paths")
    fail = fail + expect_reject(vaisc, tmp, "missing_import", "import path not found", "", "expected local module file")

    fail = fail + expect_reject_path(vaisc, tmp, "bad_manifest", setup_bad_manifest(path_join(tmp, "bad_manifest")), "package manifest is missing required key", "", "source")
    fail = fail + expect_reject_path(vaisc, tmp, "bad_source_manifest", setup_bad_source_manifest(path_join(tmp, "bad_source_manifest")), "package manifest source must be a local relative path", "", "absolute paths")
    fail = fail + expect_reject_path(vaisc, tmp, "missing_dependency_manifest", setup_missing_dependency(path_join(tmp, "missing_dependency_manifest")), "local dependency manifest not found", "", "expected local dependency manifest")
    fail = fail + expect_reject_path(vaisc, tmp, "bad_dependency_path", setup_bad_dependency_path(path_join(tmp, "bad_dependency_path")), "local dependency path must be a relative local path", "", "absolute paths")
    fail = fail + expect_reject_path(vaisc, tmp, "dependency_cycle", setup_dependency_cycle(path_join(tmp, "dependency_cycle")), "local dependency cycle detected", "", "remove one dependency")
    fail = fail + expect_reject_path(vaisc, tmp, "duplicate_import/main", setup_duplicate_import(path_join(tmp, "duplicate_import")), "duplicate top-level symbol", "", "first definition")
    fail = fail + expect_reject_path(vaisc, tmp, "cycle_import/main", setup_cycle_import(path_join(tmp, "cycle_import")), "import cycle detected", "", "remove one import from the cycle")
    fail = fail + expect_reject(vaisc, tmp, "string_type", "helper parameters must use verified scalar types", "", "Int")

    if fail == 0 {
        print("RESULT: Vais vaisc NV-C1 front contract OK")
        return 0
    }
    print("RESULT: FAILURES")
    return 1
}

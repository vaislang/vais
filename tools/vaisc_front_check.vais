fn write_map_return(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, str_concat("fn make_scores() -> ", str_concat(map_int_spaced(), " {")))
    append_line(out, str_concat(str_concat("    let scores: ", map_int_spaced()), " = {}"))
    append_line(out, "    scores.insert(4, 40)")
    append_line(out, "    scores.insert(9, 2)")
    append_line(out, "    return scores")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let scores: ", map_int_spaced()), " = make_scores()"))
    append_line(out, "    if scores.contains(4) and scores.contains(9) {")
    append_line(out, "        return scores.get(4, 0) + scores.get(9, 0)")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


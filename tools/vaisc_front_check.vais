fn write_list_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn sum_list(xs: List<Int>) -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    for x in xs {")
    append_line(out, "        total = total + x")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    let empty: List<Int> = []")
    append_line(out, "    xs.push(10)")
    append_line(out, "    xs.push(20)")
    append_line(out, "    xs.push(30)")
    append_line(out, "    let popped = xs.pop()")
    append_line(out, "    return xs.sum() - xs.len() - xs[1] - xs[0] + 25 + empty.is_empty() - xs.is_empty() - 1 + xs.last() - 20 + popped - 30 + sum_list(xs) - 30")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_borrowed_list_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn sum_from(xs: &List<Int>, i: Int, n: Int) -> Int {")
    append_line(out, "    if i >= n { return 0 }")
    append_line(out, "    return xs[i] + sum_from(xs, i + 1, n)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let nums: List<Int> = [1, 2, 3, 4]")
    append_line(out, "    return sum_from(&nums, 0, 4)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_digit(c: Int) -> Bool {")
    append_line(out, "    return c >= 48 and c <= 57")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn count_digits(s: Str) -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut n = 0")
    append_line(out, "    while i < s.len() {")
    append_line(out, "        if is_digit(s[i]) {")
    append_line(out, "            n = n + 1")
    append_line(out, "        }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return count_digits(\"a1b2\") * 21")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_index_of_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn index_of(hay: Str, needle: Str) -> Int {")
    append_line(out, "    let hn = hay.len()")
    append_line(out, "    let nn = needle.len()")
    append_line(out, "    if nn == 0 { return 0 }")
    append_line(out, "    if nn > hn { return 0 - 1 }")
    append_line(out, "    let mut i = 0")
    append_line(out, "    while i <= hn - nn {")
    append_line(out, "        let mut j = 0")
    append_line(out, "        let mut ok = 1")
    append_line(out, "        while j < nn {")
    append_line(out, "            if hay[i + j] != needle[j] {")
    append_line(out, "                ok = 0")
    append_line(out, "            }")
    append_line(out, "            j = j + 1")
    append_line(out, "        }")
    append_line(out, "        if ok == 1 { return i }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return 0 - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let a = index_of(\"selfhost\", \"host\")")
    append_line(out, "    let b = index_of(\"xxxt\", \"t\")")
    append_line(out, "    let miss = index_of(\"abc\", \"z\")")
    append_line(out, "    return a * 10 + b + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_palindrome_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_palindrome(s: Str) -> Int {")
    append_line(out, "    let mut left = 0")
    append_line(out, "    let mut right = s.len() - 1")
    append_line(out, "    while left < right {")
    append_line(out, "        if s[left] != s[right] { return 0 }")
    append_line(out, "        left = left + 1")
    append_line(out, "        right = right - 1")
    append_line(out, "    }")
    append_line(out, "    return 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let odd = is_palindrome(\"level\")")
    append_line(out, "    let even = is_palindrome(\"abba\")")
    append_line(out, "    let miss = is_palindrome(\"robot\")")
    append_line(out, "    return odd * 40 + even * 2 + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


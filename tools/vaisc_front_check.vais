fn write_nested_struct_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Inner { v: Int }")
    append_line(out, "struct Outer { inner: Inner }")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut o = Outer { inner: Inner { v: 3 } }")
    append_line(out, "    o.inner.v = 7")
    append_line(out, "    return o.inner.v")
    append_line(out, "}")

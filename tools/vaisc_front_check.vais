    append_line(out, "    if a != 1 { return 1 }")
    append_line(out, "    if b != 0 { return 2 }")
    append_line(out, "    if c != 1 { return 3 }")
    append_line(out, "    if d != 1 { return 4 }")
    append_line(out, "    if str_ends_with(\"abc\", \"zabc\") != 0 { return 5 }")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"file\", \"notes.vais\")")
    append_line(out, "    docs.insert(\"title\", \"VaisDB\")")
    append_line(out, "    if str_ends_with(docs.get(\"file\", \"\"), \".vais\") != 1 { return 6 }")
    append_line(out, "    if str_ends_with(docs.value_at(0), \".md\") != 0 { return 7 }")
    append_line(out, "    let names: List<Str> = [\"README.md\", \"compiler.vais\"]")
    append_line(out, "    if str_ends_with(names[1], \".vais\") != 1 { return 8 }")
    append_line(out, "    if str_ends_with(names.last(), \".md\") != 0 { return 9 }")
    append_line(out, "    let from_match = match docs.get_opt(\"file\") { Some(v) => str_lower(v), None => \"\" }")
    append_line(out, "    if str_ends_with(from_match, \".vais\") != 1 { return 10 }")
    append_line(out, "    if str_ends_with(match docs.get_opt(\"title\") { Some(v) => str_lower(v), None => \"\" }, \"db\") != 1 { return 11 }")
    append_line(out, "    return a * 20 + c * 10 + d * 12")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_replace_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"title\", \"Vais DB\")")
    append_line(out, "    docs.insert(\"body\", \"AI_AI_cache\")")
    append_line(out, "    let words: List<Str> = [\"notes-v1.md\", \"alpha_beta\"]")
    append_line(out, "    let slug = str_replace(str_lower(docs.get(\"title\", \"\")), \" \", \"-\")")
    append_line(out, "    if slug != \"vais-db\" { return 1 }")
    append_line(out, "    if str_replace(\"vaisdb vector cache\", \" \", \"_\") != \"vaisdb_vector_cache\" { return 2 }")
    append_line(out, "    if str_replace(\"aaaa\", \"aa\", \"b\") != \"bb\" { return 3 }")
    append_line(out, "    if str_replace(\"abc\", \"\", \"x\") != \"abc\" { return 4 }")
    append_line(out, "    if str_replace(docs.value_at(1), \"_\", \" \") != \"AI AI cache\" { return 5 }")
    append_line(out, "    if str_replace(words[1], \"_\", \"-\") != \"alpha-beta\" { return 6 }")
    append_line(out, "    let mut from_match: Str = \"\"")
    append_line(out, "    from_match = match docs.get_opt(\"body\") { Some(v) => str_replace(str_lower(v), \"_\", \" \"), None => \"\" }")
    append_line(out, "    if from_match != \"ai ai cache\" { return 7 }")
    append_line(out, "    if str_replace(match docs.get_opt(\"title\") { Some(v) => str_lower(v), None => \"\" }, \" \", \"\") != \"vaisdb\" { return 8 }")
    append_line(out, "    return slug.len() * 6")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_contains_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn score_doc(title: Str, body: Str) -> Int {")
    append_line(out, "    if str_contains(title, \"Vais\") != 1 { return 1 }")
    append_line(out, "    if str_contains(body, \"cache\") != 1 { return 2 }")
    append_line(out, "    if str_contains(body, \"billing\") != 0 { return 3 }")
    append_line(out, "    if str_contains(body, \"\") != 1 { return 4 }")
    append_line(out, "    return str_contains(title, \"DB\") * 10 + str_contains(body, \"vector\") * 20 + str_contains(body, \"\") * 12")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let docs: ", map_str_str_spaced()), " = {}"))
    append_line(out, "    docs.insert(\"title\", \"VaisDB\")")
    append_line(out, "    docs.insert(\"body\", \"vector cache without repeated tokens\")")
    append_line(out, "    if str_contains(docs.value_at(1), \"cache\") != 1 { return 5 }")
    append_line(out, "    return score_doc(docs.get(\"title\", \"\"), docs.get(\"body\", \"\"))")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_map_param_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, str_concat(str_concat("fn put(scores: ", map_int_spaced()), ", key: Int, value: Int) -> Int {"))
    append_line(out, "    scores.insert(key, value)")
    append_line(out, "    return scores.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let scores: ", map_int_spaced()), " = {}"))
    append_line(out, "    let n = put(scores, 4, 40)")
    append_line(out, "    return scores.get(4, 0) + n + scores.contains(4)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_bool_param_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, str_concat(str_concat("fn mark(flags: ", map_bool_spaced()), ", key: Int) -> Int {"))
    append_line(out, "    flags.insert(key, true)")
    append_line(out, "    if flags.get(key, false) and flags.len() == 1 {")
    append_line(out, "        return 40")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let flags: ", map_bool_spaced()), " = {}"))
    append_line(out, "    let n = mark(flags, 4)")
    append_line(out, "    if flags.get(4, false) and flags.contains(4) {")
    append_line(out, "        return n + flags.len() + flags.contains(4)")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_char_param_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, str_concat(str_concat("fn stamp(letters: ", map_char_spaced()), ", key: Int) -> Int {"))
    append_line(out, "    letters.insert(key, 'A')")
    append_line(out, "    if letters.get(key, 'Z') == 'A' and letters.len() == 1 {")
    append_line(out, "        return 40")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, str_concat(str_concat("    let letters: ", map_char_spaced()), " = {}"))
    append_line(out, "    let n = stamp(letters, 4)")
    append_line(out, "    if letters.get(4, 'Z') == 'A' and letters.contains(4) {")
    append_line(out, "        return n + letters.len() + letters.contains(4)")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


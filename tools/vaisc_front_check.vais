fn write_result_struct_payload_helper_call_score_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_artifact(artifact: DocArtifact) -> Int {")
    append_line(out, "    let prefix = `doc:`")
    append_line(out, "    let title = str_trim(artifact.title)")
    append_line(out, "    let doc_id = str_concat(prefix, str_lower(str_trim(artifact.id)))")
    append_line(out, "    let body = str_replace(artifact.body, `cache`, `store`)")
    append_line(out, "    return title.len() + doc_id.len() + body.len() + artifact.terms + artifact.score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_or_code(flow: Result<DocArtifact, Int>) -> Int {")
    append_line(out, "    let value = match flow { Ok(artifact) => score_artifact(artifact), Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let score = score_or_code(good)")
    append_line(out, "    let code = score_or_code(bad)")
    append_line(out, "    if score != 42 { return 1 }")
    append_line(out, "    if code != 10 { return 2 }")
    append_line(out, "    return score")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_benchmark_report_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn timed_score_report(doc_text: Str, query_text: Str, out_path: Str) -> Int {")
    append_line(out, "    let start = time_millis()")
    append_line(out, "    let doc: Map<Str,Int> = {}")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let doc_total = doc_term_counts_into(doc_text, doc)")
    append_line(out, "    let query_total = doc_term_counts_into(query_text, query)")
    append_line(out, "    let score = doc_term_weighted_score(query, doc)")
    append_line(out, "    let stop = time_millis()")
    append_line(out, "    if stop < start { return 1 }")
    append_line(out, "    let mut report = str_concat(\"VaisDB benchmark report\", str_byte(10))")
    append_line(out, "    report = append_metric(report, \"doc_terms=\", doc_total)")
    append_line(out, "    report = append_metric(report, \"query_terms=\", query_total)")
    append_line(out, "    report = append_metric(report, \"score=\", score)")
    append_line(out, "    report = append_metric(report, \"elapsed_ms=\", stop - start)")
    append_line(out, "    if fs_write_text(out_path, report) != 0 { return 2 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"VaisDB benchmark report\") != 1 { return 3 }")
    append_line(out, "    if str_contains(saved, \"doc_terms=5\") != 1 { return 4 }")
    append_line(out, "    if str_contains(saved, \"query_terms=3\") != 1 { return 5 }")
    append_line(out, "    if str_contains(saved, \"score=6\") != 1 { return 6 }")
    append_line(out, "    if str_contains(saved, \"elapsed_ms=\") != 1 { return 7 }")
    append_line(out, "    return score * 7")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let out = path_join(root, \"vais-front-e299-benchmark-report.txt\")")
    append_line(out, "    return timed_score_report(\"ai cache ai cache vector\", \"ai cache ai\", out)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_benchmark_cli_report_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct ProcessResult { code: Int, stdout: Str, stderr: Str }")
    append_line(out, "")
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn capture_exit() -> ProcessResult {")
    append_line(out, "    let argv: List<Str> = []")
    append_line(out, "    argv.push(\"/bin/sh\")")
    append_line(out, "    argv.push(\"-c\")")
    append_line(out, "    argv.push(\"printf ok; exit 42\")")
    append_line(out, "    let got = proc_capture(argv)")
    append_line(out, "    return got")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let cwd = fs_cwd()")
    append_line(out, "    let parent = path_dirname(cwd)")
    append_line(out, "    let name = path_basename(cwd)")
    append_line(out, "    if parent.len() == 0 { return 1 }")
    append_line(out, "    if name.len() == 0 { return 2 }")
    append_line(out, "    let start = time_millis()")
    append_line(out, "    let got = capture_exit()")
    append_line(out, "    let stop = time_millis()")
    append_line(out, "    if stop < start { return 3 }")
    append_line(out, "    if got.code != 42 { return 4 }")
    append_line(out, "    if str_contains(got.stdout, \"ok\") != 1 { return 5 }")
    append_line(out, "    let out_path = path_join(fs_temp_dir(), \"vais-front-e300-cli-report.txt\")")
    append_line(out, "    let mut report = \"VaisDB CLI benchmark report\\n\"")
    append_line(out, "    report = append_metric(report, \"code=\", got.code)")
    append_line(out, "    report = append_metric(report, \"elapsed_ms=\", stop - start)")
    append_line(out, "    if fs_write_text(out_path, report) != 0 { return 6 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"code=42\") != 1 { return 7 }")
    append_line(out, "    if str_contains(saved, \"elapsed_ms=\") != 1 { return 8 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_benchmark_summary_tool_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn append_text(report: Str, name: Str, value: Str) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(value, str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn metric_value(report: Str, prefix: Str) -> Int {")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(report, lines)")
    append_line(out, "    if n < 0 { return 0 - 1 }")
    append_line(out, "    for line in lines {")
    append_line(out, "        if str_starts_with(line, prefix) == 1 {")
    append_line(out, "            let raw = str_slice(line, prefix.len(), line.len() - prefix.len())")
    append_line(out, "            return parse_int(raw)")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return 0 - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn summarize_report(report: Str, out_path: Str) -> Int {")
    append_line(out, "    let direct_code = metric_value(report, \"direct_code=\")")
    append_line(out, "    let default_code = metric_value(report, \"default_code=\")")
    append_line(out, "    let direct_ms = metric_value(report, \"direct_ms=\")")
    append_line(out, "    let default_ms = metric_value(report, \"default_ms=\")")
    append_line(out, "    if direct_code != 42 { return 1 }")
    append_line(out, "    if default_code != 42 { return 2 }")
    append_line(out, "    if direct_ms < 0 { return 3 }")
    append_line(out, "    if default_ms < 0 { return 4 }")
    append_line(out, "    let delta = default_ms - direct_ms")
    append_line(out, "    let mut faster = \"tie\"")
    append_line(out, "    if direct_ms < default_ms {")
    append_line(out, "        faster = \"direct\"")
    append_line(out, "    } else if default_ms < direct_ms {")
    append_line(out, "        faster = \"default\"")
    append_line(out, "    }")
    append_line(out, "    let mut summary = str_concat(\"VaisDB benchmark summary\", str_byte(10))")
    append_line(out, "    summary = append_metric(summary, \"direct_ms=\", direct_ms)")
    append_line(out, "    summary = append_metric(summary, \"default_ms=\", default_ms)")
    append_line(out, "    summary = append_metric(summary, \"delta_ms_default_minus_direct=\", delta)")
    append_line(out, "    summary = append_text(summary, \"faster=\", faster)")
    append_line(out, "    if fs_write_text(out_path, summary) != 0 { return 5 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"direct_ms=20\") != 1 { return 6 }")
    append_line(out, "    if str_contains(saved, \"default_ms=35\") != 1 { return 7 }")
    append_line(out, "    if str_contains(saved, \"delta_ms_default_minus_direct=15\") != 1 { return 8 }")
    append_line(out, "    if str_contains(saved, \"faster=direct\") != 1 { return 9 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut raw = str_concat(\"VaisDB CLI benchmark report\", str_byte(10))")
    append_line(out, "    raw = append_metric(raw, \"direct_code=\", 42)")
    append_line(out, "    raw = append_metric(raw, \"direct_ms=\", 20)")
    append_line(out, "    raw = append_metric(raw, \"default_code=\", 42)")
    append_line(out, "    raw = append_metric(raw, \"default_ms=\", 35)")
    append_line(out, "    let out_path = path_join(fs_temp_dir(), \"vais-front-e301-summary-report.txt\")")
    append_line(out, "    return summarize_report(raw, out_path)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_struct_payload_helper_call_arithmetic_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn text_score(artifact: DocArtifact) -> Int {")
    append_line(out, "    let prefix = `doc:`")
    append_line(out, "    let title = str_trim(artifact.title)")
    append_line(out, "    let doc_id = str_concat(prefix, str_lower(str_trim(artifact.id)))")
    append_line(out, "    let body = str_replace(artifact.body, `cache`, `store`)")
    append_line(out, "    return title.len() + doc_id.len() + body.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_or_code(flow: Result<DocArtifact, Int>) -> Int {")
    append_line(out, "    let value = match flow { Ok(artifact) => text_score(artifact) + artifact.terms + artifact.score, Err(code) => code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 3, 13)")
    append_line(out, "    let score = score_or_code(good)")
    append_line(out, "    let code = score_or_code(bad)")
    append_line(out, "    if score != 42 { return 1 }")
    append_line(out, "    if code != 10 { return 2 }")
    append_line(out, "    return score")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_struct_payload_field_helper_call_arithmetic_accept(path: Str) -> Int {

fn write_option_try_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn find(x: Int) -> Option<Int> {")
    append_line(out, "    if x > 0 { return Some(x) }")
    append_line(out, "    return None")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn add_one(x: Int) -> Option<Int> {")
    append_line(out, "    let v = find(x)?")
    append_line(out, "    return Some(v + 1)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = match add_one(5) { Some(v) => v, None => 0 }")
    append_line(out, "    let missing = match add_one(0) { Some(v) => v, None => 36 }")
    append_line(out, "    return good + missing")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn div(a: Int, b: Int) -> Result<Int, Int> {")
    append_line(out, "    if b == 0 { return Err(0) }")
    append_line(out, "    return Ok(a / b)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    match div(21, 3) {")
    append_line(out, "        Ok(v) => return v,")
    append_line(out, "        Err(e) => return e,")
    append_line(out, "    }")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_expr_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn div(a: Int, b: Int) -> Result<Int, Int> {")
    append_line(out, "    if b == 0 { return Err(5) }")
    append_line(out, "    return Ok(a / b)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = match div(21, 3) { Ok(v) => v, Err(e) => e }")
    append_line(out, "    let bad = match div(9, 0) { Ok(v) => v, Err(e) => e }")
    append_line(out, "    return good * 5 + bad + 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_try_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn check(x: Int) -> Result<Int, Int> {")
    append_line(out, "    if x < 0 { return Err(99) }")
    append_line(out, "    return Ok(x)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn process(x: Int) -> Result<Int, Int> {")
    append_line(out, "    let v = check(x)?")
    append_line(out, "    return Ok(v + 1)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let ok = match process(5) { Ok(v) => v, Err(e) => e }")
    append_line(out, "    let bad = match process(0 - 5) { Ok(v) => v, Err(e) => 0 }")
    append_line(out, "    return ok * 7 + bad")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


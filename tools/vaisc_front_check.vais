    append_line(out, "    high = if a == b then false else high")
    append_line(out, "    let checked = if bool_score(if high then true else false, 1, 0) == 1 then true else false")
    append_line(out, "    return if checked and high then true else false")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")

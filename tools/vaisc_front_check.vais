    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let p = Pixel { c: Color.Green, v: 5 }")
    append_line(out, match_line(" p.c {"))
    append_line(out, "        Color.Red => return 0,")
    append_line(out, "        Color.Green => return 1,")
    append_line(out, "        Color.Blue => return 2,")
    append_line(out, "    }")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


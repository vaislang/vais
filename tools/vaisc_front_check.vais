}

fn write_str_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_digit(c: Int) -> Bool {")
    append_line(out, "    return c >= 48 and c <= 57")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn count_digits(s: Str) -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut n = 0")
    append_line(out, "    while i < s.len() {")
    append_line(out, "        if is_digit(s[i]) {")
    append_line(out, "            n = n + 1")
    append_line(out, "        }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return count_digits(\"a1b2\") * 21")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_index_of_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn index_of(hay: Str, needle: Str) -> Int {")
    append_line(out, "    let hn = hay.len()")
    append_line(out, "    let nn = needle.len()")
    append_line(out, "    if nn == 0 { return 0 }")
    append_line(out, "    if nn > hn { return 0 - 1 }")
    append_line(out, "    let mut i = 0")
    append_line(out, "    while i <= hn - nn {")
    append_line(out, "        let mut j = 0")
    append_line(out, "        let mut ok = 1")
    append_line(out, "        while j < nn {")
    append_line(out, "            if hay[i + j] != needle[j] {")
    append_line(out, "                ok = 0")
    append_line(out, "            }")
    append_line(out, "            j = j + 1")
    append_line(out, "        }")
    append_line(out, "        if ok == 1 { return i }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return 0 - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let a = index_of(\"selfhost\", \"host\")")
    append_line(out, "    let b = index_of(\"xxxt\", \"t\")")
    append_line(out, "    let miss = index_of(\"abc\", \"z\")")
    append_line(out, "    return a * 10 + b + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_index_of_builtin_accept(path: Str) -> Int {

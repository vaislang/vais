}

fn write_nested_struct_multiline_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Inner {")
    append_line(out, "    v: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(o: Outer) -> Int {")
    append_line(out, "    return o.inner.v")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let o = Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: 40,")
    append_line(out, "        },")
    append_line(out, "    }")
    append_line(out, "    o.inner.v = o.inner.v + 2")
    append_line(out, "    return score(o)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_nested_struct_field_chain_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Inner {")
    append_line(out, "    v: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn read(xs: List<Outer>) -> Int {")
    append_line(out, "    return xs[0].inner.v + xs.len() + 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Outer> = []")
    append_line(out, "    xs.push(Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: 40,")
    append_line(out, "        },")
    append_line(out, "    })")
    append_line(out, "    return read(xs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_list_nested_struct_method_field_chain_accept(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Inner {")
    append_line(out, "    v: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(xs: List<Outer>) -> Int {")
    append_line(out, "    return xs.first().inner.v + xs.last().inner.v")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Outer> = []")
    append_line(out, "    xs.push(Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: 10,")
    append_line(out, "        },")
    append_line(out, "    })")
    append_line(out, "    xs.push(Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: 20,")
    append_line(out, "        },")
    append_line(out, "    })")
    append_line(out, "    xs.push(Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            v: 30,")
    append_line(out, "        },")
    append_line(out, "    })")
    append_line(out, "    let removed = xs.remove_at(1).inner.v")
    append_line(out, "    let popped = xs.pop().inner.v")
    append_line(out, "    return score(xs) + removed + popped - 28")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_accept_source(name: Str, path: Str) -> Int {
    if str_eq(name, "day1") == 1 { return write_day1(path) }
    if str_eq(name, "for") == 1 { return write_for_accept(path) }
    if str_eq(name, "io") == 1 { return write_io_accept(path) }
    if str_eq(name, "struct") == 1 { return write_struct_accept(path) }
    if str_eq(name, "nested_struct") == 1 { return write_nested_struct_accept(path) }
    if str_eq(name, "generic_struct") == 1 { return write_generic_struct_accept(path) }
    if str_eq(name, "generic_apply_struct") == 1 { return write_generic_apply_struct_accept(path) }
    if str_eq(name, "struct_helper") == 1 { return write_struct_helper_accept(path) }
    if str_eq(name, "struct_method") == 1 { return write_struct_method_accept(path) }
    if str_eq(name, "trait_impl") == 1 { return write_trait_impl_accept(path) }
    if str_eq(name, "public_struct") == 1 { return write_public_struct_accept(path) }
    if str_eq(name, "tag") == 1 { return write_enum_accept(path) }
    if str_eq(name, name_payload_accept()) == 1 { return write_payload_enum_accept(path) }
    if str_eq(name, name_match_expr_accept()) == 1 { return write_match_expr_body(path) }
    if str_eq(name, name_int_match_wildcard_accept()) == 1 { return write_int_match_wildcard_accept(path) }
    if str_eq(name, name_enum_match_wildcard_accept()) == 1 { return write_enum_match_wildcard_accept(path) }
    if str_eq(name, name_struct_enum_field_accept()) == 1 { return write_struct_enum_field_accept(path) }
    if str_eq(name, name_payload_struct_accept()) == 1 { return write_payload_enum_struct_accept(path) }
    if str_eq(name, "closure") == 1 { return write_closure_accept(path) }
    if str_eq(name, "closure_apply") == 1 { return write_closure_apply_accept(path) }
    if str_eq(name, "closure_inline_arg") == 1 { return write_closure_inline_arg_accept(path) }
    if str_eq(name, "closure_local") == 1 { return write_closure_local_accept(path) }
    if str_eq(name, "tuple") == 1 { return write_tuple_accept(path) }
    if str_eq(name, "list") == 1 { return write_list_accept(path) }
    if str_eq(name, "borrowed_list") == 1 { return write_borrowed_list_accept(path) }
    if str_eq(name, "str") == 1 { return write_str_accept(path) }
    if str_eq(name, "str_index_of") == 1 { return write_str_index_of_accept(path) }
    if str_eq(name, "str_palindrome") == 1 { return write_str_palindrome_accept(path) }
    if str_eq(name, "char") == 1 { return write_char_accept(path) }
    if str_eq(name, "parse") == 1 { return write_parse_accept(path) }
    if str_eq(name, "str_conversion") == 1 { return write_str_conversion_accept(path) }
    if str_eq(name, "map") == 1 { return write_map_accept(path) }
    if str_eq(name, "map_option") == 1 { return write_map_option_accept(path) }
    if str_eq(name, "map_scalar_get_opt") == 1 { return write_map_scalar_get_opt_accept(path) }
    if str_eq(name, "map_bool") == 1 { return write_map_bool_accept(path) }
    if str_eq(name, "map_char") == 1 { return write_map_char_accept(path) }
    if str_eq(name, "map_remove") == 1 { return write_map_remove_accept(path) }
    if str_eq(name, "map_clear") == 1 { return write_map_clear_accept(path) }
    if str_eq(name, "map_str_int") == 1 { return write_map_str_int_accept(path) }
    if str_eq(name, "map_str_bool") == 1 { return write_map_str_bool_accept(path) }
    if str_eq(name, "map_str_char") == 1 { return write_map_str_char_accept(path) }
    if str_eq(name, "map_str_char_param") == 1 { return write_map_str_char_param_accept(path) }
    if str_eq(name, "map_str_char_return") == 1 { return write_map_str_char_return_accept(path) }
    if str_eq(name, "map_str_bool_param") == 1 { return write_map_str_bool_param_accept(path) }
    if str_eq(name, "map_str_bool_return") == 1 { return write_map_str_bool_return_accept(path) }
    if str_eq(name, "map_str_int_param") == 1 { return write_map_str_int_param_accept(path) }
    if str_eq(name, "map_str_int_return") == 1 { return write_map_str_int_return_accept(path) }
    if str_eq(name, "map_param") == 1 { return write_map_param_accept(path) }
    if str_eq(name, "map_bool_param") == 1 { return write_map_bool_param_accept(path) }
    if str_eq(name, "map_char_param") == 1 { return write_map_char_param_accept(path) }
    if str_eq(name, "map_return") == 1 { return write_map_return(path) }
    if str_eq(name, "map_bool_return") == 1 { return write_map_bool_return(path) }
    if str_eq(name, "map_char_return") == 1 { return write_map_char_return(path) }
    if str_eq(name, "map_assignment") == 1 { return write_map_assignment(path) }
    if str_eq(name, "map_param_assignment") == 1 { return write_map_param_assignment(path) }
    if str_eq(name, "map_return_assignment") == 1 { return write_map_return_assignment(path) }
    if str_eq(name, "map_return_assignment_args") == 1 { return write_map_return_assignment_args(path) }
    if str_eq(name, "option") == 1 { return write_option_accept(path) }
    if str_eq(name, "option_expr") == 1 { return write_option_expr_accept(path) }
    if str_eq(name, "option_multiline_expr") == 1 { return write_option_multiline_expr_accept(path) }
    if str_eq(name, "option_try") == 1 { return write_option_try_accept(path) }
    if str_eq(name, "result") == 1 { return write_result_accept(path) }
    if str_eq(name, "result_expr") == 1 { return write_result_expr_accept(path) }
    if str_eq(name, "result_try") == 1 { return write_result_try_accept(path) }
    return 1
}

fn run_vaisc_run(vaisc: Str, src: Str) -> Int {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("run")
    argv.push(src)
    return proc_run(argv)
}

fn capture_vaisc_run(vaisc: Str, src: Str) -> Str {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("run")
    argv.push(src)
    return proc_capture_stdout(argv)
}

fn shell_status(cmd: Str) -> Int {
    let argv: List<Str> = []
    argv.push("/bin/sh")
    argv.push("-c")
    argv.push(cmd)
    return proc_run(argv)
}

fn run_vaisc_run_quiet(vaisc: Str, src: Str) -> Int {
    return shell_status(str_concat(str_concat(str_concat(vaisc, " run "), src), " >/dev/null 2>/dev/null"))
}

fn expect_accept(vaisc: Str, tmp: Str, name: Str, label: Str, want: Int) -> Int {
    let src = path_join(tmp, str_concat(name, ".vais"))
    if write_accept_source(name, src) != 0 {
        print(str_concat("  FAIL ", str_concat(label, ": write fixture")))
        return 1
    }
    let got = run_vaisc_run(vaisc, src)
    if got == want {
        print(str_concat("  PASS ", label))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(label, str_concat(" got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
    return 1
}

fn expect_io_accept(vaisc: Str, tmp: Str) -> Int {
    let src = path_join(tmp, "io.vais")
    if write_io_accept(src) != 0 {
        print("  FAIL accepts print interpolation and putchar IO slice: write fixture")
        return 1
    }
    let got = run_vaisc_run_quiet(vaisc, src)
    let out = capture_vaisc_run(vaisc, src)
    let want_out = str_concat("the answer is 42", str_concat(str_byte(10), "!"))
    if got == 0 and str_eq(out, want_out) == 1 {
        print("  PASS accepts print interpolation and putchar IO slice")
        return 0
    }
    print(str_concat("  FAIL accepts IO slice got=", str_concat(uint_to_str(got), str_concat(" stdout=[", str_concat(out, "]")))))
    return 1
}

fn capture_emit_stderr(vaisc: Str, src: Str, ll: Str) -> Str {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("emit-ir")
    argv.push(src)
    argv.push("-o")
    argv.push(ll)
    return proc_capture_stderr(argv)
}

fn has_diag(err: Str, needle: Str, needle2: Str, help_needle: Str) -> Int {
    if err.len() == 0 { return 0 }
    if str_contains(err, needle) == 0 { return 0 }
    if needle2.len() > 0 {
        if str_contains(err, needle2) == 0 { return 0 }
    }
    if str_contains(err, "help:") == 0 { return 0 }
    if str_contains(err, help_needle) == 0 { return 0 }
    return 1
}

fn expect_reject_path(vaisc: Str, tmp: Str, label: Str, src: Str, needle: Str, needle2: Str, help_needle: Str) -> Int {
    let err = capture_emit_stderr(vaisc, src, path_join(tmp, str_concat(label, ".ll")))
    if has_diag(err, needle, needle2, help_needle) == 1 {
        print(str_concat("  PASS rejects ", str_concat(label, " with P4 help")))
        return 0
    }
    print(str_concat("  FAIL rejects ", str_concat(label, ": missing expected diagnostic")))
    print(err)
    return 1
}


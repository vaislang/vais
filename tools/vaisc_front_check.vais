fn write_reject_source(name: Str, path: Str) -> Int {
    if str_eq(name, "bad_main_signature") == 1 { return write_bad_main(path) }
    if str_eq(name, "helper_missing_return_type") == 1 { return write_helper_missing_return(path) }
    if str_eq(name, name_payload_bad()) == 1 { return write_payload_enum_struct(path) }
    if str_eq(name, "closure_literal") == 1 { return write_closure_literal_bad(path) }
    if str_eq(name, "rust_and") == 1 { return write_rust_and_bad(path) }
    if str_eq(name, "unsupported_method") == 1 { return write_unsupported_method(path) }
    if str_eq(name, "map_generic_not_verified") == 1 { return write_map_generic(path) }
    if str_eq(name, "map_generic_param_not_verified") == 1 { return write_map_generic_param_bad(path) }
    if str_eq(name, "map_generic_return_not_verified") == 1 { return write_map_generic_return_bad(path) }
    if str_eq(name, "map_assignment_type_mismatch") == 1 { return write_map_assignment_mismatch(path) }
    if str_eq(name, "option_generic_not_verified") == 1 { return write_option_generic(path) }
    if str_eq(name, "result_generic_not_verified") == 1 { return write_result_generic(path) }
    if str_eq(name, "option_nested_not_verified") == 1 { return write_option_nested(path) }
    if str_eq(name, "module_not_implemented") == 1 { return write_module_not(path) }
    if str_eq(name, "package_not_implemented") == 1 { return write_package_not(path) }
    if str_eq(name, "missing_import") == 1 { return write_missing_import(path) }
    if str_eq(name, "invalid_import") == 1 { return write_invalid_import(path) }
    if str_eq(name, "string_type") == 1 { return write_string_type(path) }
    return 1
}

fn expect_reject(vaisc: Str, tmp: Str, name: Str, needle: Str, needle2: Str, help_needle: Str) -> Int {
    let src = path_join(tmp, str_concat(name, ".vais"))
    if write_reject_source(name, src) != 0 {
        print(str_concat("  FAIL rejects ", str_concat(name, ": write fixture")))
        return 1
    }
    return expect_reject_path(vaisc, tmp, name, src, needle, needle2, help_needle)
}

fn write_text(path: Str, text: Str) -> Int {
    return fs_write_text(path, text)
}

fn line(text: Str) -> Str {
    return str_concat(text, str_byte(10))
}

fn write_module_accept(root: Str) -> Str {
    let math_dir = path_join(root, "math")
    fs_mkdirs(math_dir)
    write_text(path_join(math_dir, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    let main_path = path_join(root, "main.vais")
    let out = str_builder_new()
    append_line(out, "import math.add")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn write_package_accept(root: Str) -> Str {
    let src_dir = path_join(root, "src")
    let math_dir = path_join(src_dir, "math")
    fs_mkdirs(math_dir)
    write_text(path_join(root, "vais.toml"), str_concat(line("name = \"package_basic\""), str_concat(line("version = \"0.1.0\""), line("source = \"src\""))))
    write_text(path_join(math_dir, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    let main_path = path_join(src_dir, "main.vais")
    let out = str_builder_new()
    append_line(out, "import math.add")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn write_dependency_accept(root: Str) -> Str {
    let app = path_join(root, "app")
    let mathlib = path_join(root, "mathlib")
    let app_src = path_join(app, "src")
    let arith = path_join(path_join(mathlib, "src"), "arith")
    fs_mkdirs(app_src)
    fs_mkdirs(arith)
    let app_manifest = str_concat(line("name = \"dependency_app\""), str_concat(line("version = \"0.1.0\""), str_concat(line("source = \"src\""), str_concat(line(""), str_concat(line("[dependencies]"), line("mathlib = \"../mathlib\""))))))
    write_text(path_join(app, "vais.toml"), app_manifest)
    write_text(path_join(mathlib, "vais.toml"), str_concat(line("name = \"mathlib\""), str_concat(line("version = \"0.1.0\""), line("source = \"src\""))))
    write_text(path_join(arith, "add.vais"), str_concat(line("fn add(a: Int, b: Int) -> Int {"), str_concat(line("    return a + b"), line("}"))))
    write_text(path_join(path_join(mathlib, "src"), "public.vais"), line("import arith.add"))
    let main_path = path_join(app_src, "main.vais")
    let out = str_builder_new()
    append_line(out, "import mathlib.public")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return add(20, 22)")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn write_vaisdb_module_boundary_accept(root: Str) -> Str {
    let module_dir = path_join(root, "vaisdb")
    fs_mkdirs(module_dir)
    let scoring = str_builder_new()
    append_line(scoring, "fn cleaned_len(text: Str) -> Int {")
    append_line(scoring, "    let clean = str_trim(text)")
    append_line(scoring, "    return clean.len()")
    append_line(scoring, "}")
    append_line(scoring, "")
    append_line(scoring, "fn count_terms(text: Str) -> Int {")
    append_line(scoring, "    let terms: Map<Str,Int> = {}")
    append_line(scoring, "    return doc_term_counts_into(text, terms)")
    append_line(scoring, "}")
    append_line(scoring, "")
    append_line(scoring, "fn score_body(query_text: Str, body: Str) -> Int {")
    append_line(scoring, "    let query: Map<Str,Int> = {}")
    append_line(scoring, "    let doc: Map<Str,Int> = {}")
    append_line(scoring, "    let query_terms = doc_term_counts_into(query_text, query)")
    append_line(scoring, "    let doc_terms = doc_term_counts_into(body, doc)")
    append_line(scoring, "    if query_terms == 0 { return 0 }")
    append_line(scoring, "    if doc_terms == 0 { return 0 }")
    append_line(scoring, "    return doc_term_weighted_score(query, doc)")
    append_line(scoring, "}")
    write_text(path_join(module_dir, "scoring.vais"), str_builder_finish(scoring))

    let artifact = str_builder_new()
    append_line(artifact, "import vaisdb.scoring")
    append_line(artifact, "")
    append_line(artifact, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(artifact, "")
    append_line(artifact, "fn build_doc_artifact(id: Str, title: Str, body: Str, query: Str) -> Result<DocArtifact, Int> {")
    append_line(artifact, "    if id.len() == 0 { return Err(10) }")
    append_line(artifact, "    if title.len() == 0 { return Err(11) }")
    append_line(artifact, "    if body.len() == 0 { return Err(12) }")
    append_line(artifact, "    let terms = count_terms(body)")
    append_line(artifact, "    if terms < 1 { return Err(13) }")
    append_line(artifact, "    let score = score_body(query, body) + cleaned_len(title)")
    append_line(artifact, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(artifact, "    return Ok(artifact)")
    append_line(artifact, "}")
    append_line(artifact, "")
    append_line(artifact, "fn seed_artifacts(query: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(artifact, "    let a = build_doc_artifact(`D1`, `  VaisDB guide  `, `AI cache ai CACHE vector ai`, query)?")
    append_line(artifact, "    let b = build_doc_artifact(`D2`, ` Cache notes `, `cache cache vector vector`, query)?")
    append_line(artifact, "    out.push(a)")
    append_line(artifact, "    out.push(b)")
    append_line(artifact, "    return Ok(out.len())")
    append_line(artifact, "}")
    append_line(artifact, "")
    append_line(artifact, "fn best_artifact_score(artifacts: List<DocArtifact>) -> Int {")
    append_line(artifact, "    let mut best = 0")
    append_line(artifact, "    for artifact in artifacts {")
    append_line(artifact, "        let score = artifact.score + artifact.terms")
    append_line(artifact, "        if score > best { best = score }")
    append_line(artifact, "    }")
    append_line(artifact, "    return best")
    append_line(artifact, "}")
    append_line(artifact, "")
    append_line(artifact, "fn usable_or_missing(flow: Result<DocArtifact, Int>) -> Bool {")
    append_line(artifact, "    return match flow { Ok(artifact) => cleaned_len(artifact.title) + artifact.score + artifact.terms >= 18, Err(code) => code == 10 }")
    append_line(artifact, "}")
    write_text(path_join(module_dir, "artifact.vais"), str_builder_finish(artifact))

    let main_path = path_join(root, "main.vais")
    let out = str_builder_new()
    append_line(out, "import vaisdb.artifact")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let artifacts: List<DocArtifact> = []")
    append_line(out, "    let seeded = seed_artifacts(`ai cache ai`, artifacts)")
    append_line(out, "    let seeded_count = match seeded { Ok(value) => value, Err(code) => code }")
    append_line(out, "    if seeded_count != 2 { return 1 }")
    append_line(out, "    let best = best_artifact_score(artifacts)")
    append_line(out, "    if best != 26 { return 2 }")
    append_line(out, "    let good = build_doc_artifact(`D3`, `  VaisDB guide  `, `AI cache ai`, `ai cache ai`)")
    append_line(out, "    if usable_or_missing(good) != true { return 3 }")
    append_line(out, "    let missing = build_doc_artifact(``, `  VaisDB guide  `, `AI cache ai`, `ai cache ai`)")
    append_line(out, "    if usable_or_missing(missing) != true { return 4 }")
    append_line(out, "    let weak = build_doc_artifact(`D4`, ` x `, `cache`, `ai ai`)")
    append_line(out, "    if usable_or_missing(weak) != false { return 5 }")
    append_line(out, "    return best + seeded_count * 8")
    append_line(out, "}")
    fs_write_text(main_path, str_builder_finish(out))
    return main_path
}

fn expect_accept_path(vaisc: Str, src: Str, label: Str, want: Int) -> Int {
    let got = run_vaisc_run(vaisc, src)
    if got == want {
        print(str_concat("  PASS ", label))
        return 0
    }
    print(str_concat("  FAIL ", str_concat(label, str_concat(" got=", str_concat(uint_to_str(got), str_concat(" want=", uint_to_str(want)))))))
    return 1
}


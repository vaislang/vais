    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    xs.push(7)")
    append_line(out, "    xs.push(42)")
    append_line(out, "    xs.push(7)")
    append_line(out, "    xs.push(3)")
    append_line(out, "    xs.push(7)")
    append_line(out, "    let pos: Int = xs.index_of(42)")
    append_line(out, "    if pos != 1 { return 1 }")
    append_line(out, "    if xs.index_of(9) != 0 - 1 { return 2 }")
    append_line(out, "    if xs.count(7) != 3 { return 3 }")
    append_line(out, "    if count_value(xs, 9) != 0 { return 4 }")
    append_line(out, "    if first_pos(xs, 3) != 3 { return 5 }")
    append_line(out, "    xs.clear()")
    append_line(out, "    if xs.index_of(7) != 0 - 1 { return 6 }")
    append_line(out, "    if xs.count(7) != 0 { return 7 }")
    append_line(out, "    xs.push(2)")
    append_line(out, "    xs.push(2)")
    append_line(out, "    xs.push(40)")
    append_line(out, "    return count_value(xs, 2) * 20 + first_pos(xs, 40) + xs.contains(9)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


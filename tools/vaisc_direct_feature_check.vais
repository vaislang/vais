fn write_list_str_filter_map_result_contexts(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let filter_map_prefix = str_concat(str_concat(str_concat("words.filter(", pipe), "word"), str_concat(pipe, " str_contains(word, needle) == 1).map("))
    let normalized_expr = str_concat(filter_map_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_lower(str_trim(word)))")))
    let suffixed_expr = str_concat(filter_map_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_concat(str_lower(str_trim(word)), \"!\"))")))
    append_line(out, "fn count_hits(words: List<Str>, target: Str) -> Int {")
    append_line(out, "    return words.contains(target) + words.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn normalized_hits(words: List<Str>, needle: Str) -> List<Str> {")
    append_line(out, str_concat("    return ", normalized_expr))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_words(words: List<Str>, needle: Str) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    let normalized: List<Str> = ", normalized_expr))
    append_line(out, "    if normalized.len() != 2 { return 1 }")
    append_line(out, "    if normalized.contains(\"vais\") != 1 { return 2 }")
    append_line(out, str_concat("    let suffixed = ", suffixed_expr))
    append_line(out, "    let from_return = normalized_hits(words, needle)")
    append_line(out, "    let collected: List<Str> = []")
    append_line(out, str_concat("    collected.extend(", str_concat(normalized_expr, ")")))
    append_line(out, "    let replaced: List<Str> = []")
    append_line(out, "    replaced.push(\"old\")")
    append_line(out, str_concat("    replaced = ", normalized_expr))
    append_line(out, str_concat("    if count_hits(", str_concat(normalized_expr, ", \"vais\") == 3 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut limit = 2")
    append_line(out, str_concat("    while count_hits(", str_concat(normalized_expr, ", \"ai\") > limit {")))
    append_line(out, "        score = score + 10")
    append_line(out, "        limit = limit + 100")
    append_line(out, "    }")
    append_line(out, "    if count_hits(suffixed, \"ai!\") == 3 and from_return.contains(\"vais\") == 1 and collected.contains(\"ai\") == 1 and replaced.index_of(\"vais\") == 0 {")
    append_line(out, "        score = score + 22")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"  vais\")")
    append_line(out, "    words.push(\"db\")")
    append_line(out, "    words.push(\"ai  \")")
    append_line(out, "    return score_words(words, \"ai\")")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


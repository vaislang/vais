fn write_map_str_str_get_opt_condition_chains(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str, Str> = {}")
    append_line(out, "    docs.insert(\"title\", \" VaisDB Vector Cache \")")
    append_line(out, "    let mut ticks = 0")
    append_line(out, "    while str_contains(match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => \"\" }, \"vector\") == 1 and ticks < 2 {")
    append_line(out, "        ticks = ticks + 1")
    append_line(out, "    }")
    append_line(out, "    if ticks != 2 { return 1 }")
    append_line(out, "    let mut score = 0")
    append_line(out, "    if str_contains(match docs.get_opt(\"missing\") { Some(v) => str_lower(v), None => \"fallback cache\" }, \"vector\") == 1 {")
    append_line(out, "        return 2")
    append_line(out, "    } else if str_starts_with(match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => \"\" }, \"vais\") == 1 {")
    append_line(out, "        score = 40")
    append_line(out, "    } else {")
    append_line(out, "        return 3")
    append_line(out, "    }")
    append_line(out, "    if score != 40 { return 4 }")
    append_line(out, "    return score + ticks")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


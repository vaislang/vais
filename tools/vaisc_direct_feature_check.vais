    append_line(out, "    docs.insert(\"body\", \"vaisdb vector cache\")")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"alpha cache\")")
    append_line(out, "    words.push(\"beta\")")
    append_line(out, "    words.push(\"gamma\")")
    append_line(out, "    if str_contains(\"vaisdb vector cache\", \"vector\") != 1 { return 1 }")
    append_line(out, "    if str_contains(docs.get(\"body\", \"\"), \"cache\") != 1 { return 2 }")
    append_line(out, "    if str_contains(docs.value_at(1), \"vector\") != 1 { return 3 }")
    append_line(out, "    if str_contains(words[0], \"alpha\") != 1 { return 4 }")
    append_line(out, "    if str_contains(words.last(), \"gamma\") != 1 { return 5 }")
    append_line(out, "    if str_contains(words.pop(), \"gamma\") != 1 { return 6 }")
    append_line(out, "    if str_contains(docs.get(\"title\", \"\"), \"missing\") != 0 { return 7 }")
    append_line(out, "    if str_contains(\"abc\", \"\") != 1 { return 8 }")
    append_line(out, "    if str_contains(\"abc\", \"z\") != 0 { return 9 }")
    append_line(out, "    return str_contains(\"selfhost\", \"host\") * 40 + docs.len()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


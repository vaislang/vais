fn write_result_struct_payload_bool_match_condition(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, terms: Int, score: Int) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn trimmed_len(text: Str) -> Int {")
    append_line(out, "    let clean = str_trim(text)")
    append_line(out, "    return clean.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn weight_terms(value: Int) -> Int {")
    append_line(out, "    return value * 3")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn is_publishable(flow: Result<DocArtifact, Int>) -> Bool {")
    append_line(out, "    return match flow { Ok(artifact) => trimmed_len(artifact.title) + weight_terms(artifact.terms) + artifact.score >= 35, Err(code) => code == 10 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = build_doc_artifact(` D1 `, `  VaisDB guide  `, `AI cache`, 4, 11)")
    append_line(out, "    let bad = build_doc_artifact(``, `  VaisDB guide  `, `AI cache`, 4, 11)")
    append_line(out, "    let weak = build_doc_artifact(` D2 `, `  x  `, `AI cache`, 1, 1)")
    append_line(out, "    if is_publishable(good) != true { return 1 }")
    append_line(out, "    if is_publishable(bad) != true { return 2 }")
    append_line(out, "    if is_publishable(weak) != false { return 3 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_module_scoring(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn cleaned_len(text: Str) -> Int {")
    append_line(out, "    let clean = str_trim(text)")
    append_line(out, "    return clean.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn count_terms(text: Str) -> Int {")
    append_line(out, "    let terms: Map<Str,Int> = {}")
    append_line(out, "    return doc_term_counts_into(text, terms)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_body(query_text: Str, body: Str) -> Int {")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let doc: Map<Str,Int> = {}")
    append_line(out, "    let query_terms = doc_term_counts_into(query_text, query)")
    append_line(out, "    let doc_terms = doc_term_counts_into(body, doc)")
    append_line(out, "    if query_terms == 0 { return 0 }")
    append_line(out, "    if doc_terms == 0 { return 0 }")
    append_line(out, "    return doc_term_weighted_score(query, doc)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_module_artifact(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "import vaisdb.scoring")
    append_line(out, "")
    append_line(out, "struct DocArtifact { id: Str, title: Str, body: Str, terms: Int, score: Int }")
    append_line(out, "")
    append_line(out, "fn build_doc_artifact(id: Str, title: Str, body: Str, query: Str) -> Result<DocArtifact, Int> {")
    append_line(out, "    if id.len() == 0 { return Err(10) }")
    append_line(out, "    if title.len() == 0 { return Err(11) }")
    append_line(out, "    if body.len() == 0 { return Err(12) }")
    append_line(out, "    let terms = count_terms(body)")
    append_line(out, "    if terms < 1 { return Err(13) }")
    append_line(out, "    let score = score_body(query, body) + cleaned_len(title)")
    append_line(out, "    let artifact = DocArtifact { id: id, title: title, body: body, terms: terms, score: score }")
    append_line(out, "    return Ok(artifact)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn seed_artifacts(query: Str, out: List<DocArtifact>) -> Result<Int, Int> {")
    append_line(out, "    let a = build_doc_artifact(`D1`, `  VaisDB guide  `, `AI cache ai CACHE vector ai`, query)?")
    append_line(out, "    let b = build_doc_artifact(`D2`, ` Cache notes `, `cache cache vector vector`, query)?")
    append_line(out, "    out.push(a)")
    append_line(out, "    out.push(b)")
    append_line(out, "    return Ok(out.len())")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn best_artifact_score(artifacts: List<DocArtifact>) -> Int {")
    append_line(out, "    let mut best = 0")
    append_line(out, "    for artifact in artifacts {")
    append_line(out, "        let score = artifact.score + artifact.terms")
    append_line(out, "        if score > best { best = score }")
    append_line(out, "    }")
    append_line(out, "    return best")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn usable_or_missing(flow: Result<DocArtifact, Int>) -> Bool {")
    append_line(out, "    return match flow { Ok(artifact) => cleaned_len(artifact.title) + artifact.score + artifact.terms >= 18, Err(code) => code == 10 }")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_module_main(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "import vaisdb.artifact")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let artifacts: List<DocArtifact> = []")
    append_line(out, "    let seeded = seed_artifacts(`ai cache ai`, artifacts)")
    append_line(out, "    let seeded_count = match seeded { Ok(value) => value, Err(code) => code }")
    append_line(out, "    if seeded_count != 2 { return 1 }")
    append_line(out, "    let best = best_artifact_score(artifacts)")
    append_line(out, "    if best != 26 { return 2 }")
    append_line(out, "    let good = build_doc_artifact(`D3`, `  VaisDB guide  `, `AI cache ai`, `ai cache ai`)")
    append_line(out, "    if usable_or_missing(good) != true { return 3 }")
    append_line(out, "    let missing = build_doc_artifact(``, `  VaisDB guide  `, `AI cache ai`, `ai cache ai`)")
    append_line(out, "    if usable_or_missing(missing) != true { return 4 }")
    append_line(out, "    let weak = build_doc_artifact(`D4`, ` x `, `cache`, `ai ai`)")
    append_line(out, "    if usable_or_missing(weak) != false { return 5 }")
    append_line(out, "    return best + seeded_count * 8")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_module_boundary(root: Str) -> Str {
    let module_dir = path_join(root, "vaisdb")
    if fs_mkdirs(module_dir) != 0 { return "" }
    let scoring = path_join(module_dir, "scoring.vais")
    let artifact = path_join(module_dir, "artifact.vais")
    let main_path = path_join(root, "main.vais")
    if write_vaisdb_module_scoring(scoring) != 0 { return "" }
    if write_vaisdb_module_artifact(artifact) != 0 { return "" }
    if write_vaisdb_module_main(main_path) != 0 { return "" }
    return main_path
}

fn write_vaisdb_benchmark_report(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn timed_score_report(doc_text: Str, query_text: Str, out_path: Str) -> Int {")
    append_line(out, "    let start = time_millis()")
    append_line(out, "    let doc: Map<Str,Int> = {}")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let doc_total = doc_term_counts_into(doc_text, doc)")
    append_line(out, "    let query_total = doc_term_counts_into(query_text, query)")
    append_line(out, "    let score = doc_term_weighted_score(query, doc)")
    append_line(out, "    let stop = time_millis()")
    append_line(out, "    if stop < start { return 1 }")
    append_line(out, "    let mut report = str_concat(\"VaisDB benchmark report\", str_byte(10))")
    append_line(out, "    report = append_metric(report, \"doc_terms=\", doc_total)")
    append_line(out, "    report = append_metric(report, \"query_terms=\", query_total)")
    append_line(out, "    report = append_metric(report, \"score=\", score)")
    append_line(out, "    report = append_metric(report, \"elapsed_ms=\", stop - start)")
    append_line(out, "    if fs_write_text(out_path, report) != 0 { return 2 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"VaisDB benchmark report\") != 1 { return 3 }")
    append_line(out, "    if str_contains(saved, \"doc_terms=5\") != 1 { return 4 }")
    append_line(out, "    if str_contains(saved, \"query_terms=3\") != 1 { return 5 }")
    append_line(out, "    if str_contains(saved, \"score=6\") != 1 { return 6 }")
    append_line(out, "    if str_contains(saved, \"elapsed_ms=\") != 1 { return 7 }")
    append_line(out, "    return score * 7")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let out = path_join(root, \"vais-direct-e299-benchmark-report.txt\")")
    append_line(out, "    return timed_score_report(\"ai cache ai cache vector\", \"ai cache ai\", out)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_benchmark_cli_report(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct ProcessResult { code: Int, stdout: Str, stderr: Str }")
    append_line(out, "")
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn capture_exit() -> ProcessResult {")
    append_line(out, "    let argv: List<Str> = []")
    append_line(out, "    argv.push(\"/bin/sh\")")
    append_line(out, "    argv.push(\"-c\")")
    append_line(out, "    argv.push(\"printf ok; exit 42\")")
    append_line(out, "    let got = proc_capture(argv)")
    append_line(out, "    return got")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let cwd = fs_cwd()")
    append_line(out, "    let parent = path_dirname(cwd)")
    append_line(out, "    let name = path_basename(cwd)")
    append_line(out, "    if parent.len() == 0 { return 1 }")
    append_line(out, "    if name.len() == 0 { return 2 }")
    append_line(out, "    let start = time_millis()")
    append_line(out, "    let got = capture_exit()")
    append_line(out, "    let stop = time_millis()")
    append_line(out, "    if stop < start { return 3 }")
    append_line(out, "    if got.code != 42 { return 4 }")
    append_line(out, "    if str_contains(got.stdout, \"ok\") != 1 { return 5 }")
    append_line(out, "    let out_path = path_join(fs_temp_dir(), \"vais-direct-e300-cli-report.txt\")")
    append_line(out, "    let mut report = \"VaisDB CLI benchmark report\\n\"")
    append_line(out, "    report = append_metric(report, \"code=\", got.code)")
    append_line(out, "    report = append_metric(report, \"elapsed_ms=\", stop - start)")
    append_line(out, "    if fs_write_text(out_path, report) != 0 { return 6 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"code=42\") != 1 { return 7 }")
    append_line(out, "    if str_contains(saved, \"elapsed_ms=\") != 1 { return 8 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_benchmark_summary_tool(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn append_metric(report: Str, name: Str, value: Int) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(Str(value), str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn append_text(report: Str, name: Str, value: Str) -> Str {")
    append_line(out, "    return str_concat(report, str_concat(name, str_concat(value, str_byte(10))))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn metric_value(report: Str, prefix: Str) -> Int {")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(report, lines)")
    append_line(out, "    if n < 0 { return 0 - 1 }")
    append_line(out, "    for line in lines {")
    append_line(out, "        if str_starts_with(line, prefix) == 1 {")
    append_line(out, "            let raw = str_slice(line, prefix.len(), line.len() - prefix.len())")
    append_line(out, "            return parse_int(raw)")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return 0 - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn summarize_report(report: Str, out_path: Str) -> Int {")
    append_line(out, "    let direct_code = metric_value(report, \"direct_code=\")")
    append_line(out, "    let default_code = metric_value(report, \"default_code=\")")
    append_line(out, "    let direct_ms = metric_value(report, \"direct_ms=\")")
    append_line(out, "    let default_ms = metric_value(report, \"default_ms=\")")
    append_line(out, "    if direct_code != 42 { return 1 }")
    append_line(out, "    if default_code != 42 { return 2 }")
    append_line(out, "    if direct_ms < 0 { return 3 }")
    append_line(out, "    if default_ms < 0 { return 4 }")
    append_line(out, "    let delta = default_ms - direct_ms")
    append_line(out, "    let mut faster = \"tie\"")
    append_line(out, "    if direct_ms < default_ms {")
    append_line(out, "        faster = \"direct\"")
    append_line(out, "    } else if default_ms < direct_ms {")
    append_line(out, "        faster = \"default\"")
    append_line(out, "    }")
    append_line(out, "    let mut summary = str_concat(\"VaisDB benchmark summary\", str_byte(10))")
    append_line(out, "    summary = append_metric(summary, \"direct_ms=\", direct_ms)")
    append_line(out, "    summary = append_metric(summary, \"default_ms=\", default_ms)")
    append_line(out, "    summary = append_metric(summary, \"delta_ms_default_minus_direct=\", delta)")
    append_line(out, "    summary = append_text(summary, \"faster=\", faster)")
    append_line(out, "    if fs_write_text(out_path, summary) != 0 { return 5 }")
    append_line(out, "    let saved = fs_read_text(out_path)")
    append_line(out, "    if str_contains(saved, \"direct_ms=20\") != 1 { return 6 }")
    append_line(out, "    if str_contains(saved, \"default_ms=35\") != 1 { return 7 }")
    append_line(out, "    if str_contains(saved, \"delta_ms_default_minus_direct=15\") != 1 { return 8 }")
    append_line(out, "    if str_contains(saved, \"faster=direct\") != 1 { return 9 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut raw = str_concat(\"VaisDB CLI benchmark report\", str_byte(10))")
    append_line(out, "    raw = append_metric(raw, \"direct_code=\", 42)")
    append_line(out, "    raw = append_metric(raw, \"direct_ms=\", 20)")
    append_line(out, "    raw = append_metric(raw, \"default_code=\", 42)")
    append_line(out, "    raw = append_metric(raw, \"default_ms=\", 35)")
    append_line(out, "    let out_path = path_join(fs_temp_dir(), \"vais-direct-e301-summary-report.txt\")")
    append_line(out, "    return summarize_report(raw, out_path)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_indexer_prototype(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn require_present_len(meta: Map<Str,Str>, key: Str) -> Int {")
    append_line(out, "    return match meta.get_opt(key) { Some(value) => str_trim(value).len(), None => 0 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn ingest_doc(meta: Map<Str,Str>, title_key: Str, body_key: Str, title: Str, body: Str, terms: Map<Str,Int>) -> Int {")
    append_line(out, "    if title.len() == 0 { return 0 }")
    append_line(out, "    if body.len() == 0 { return 0 }")
    append_line(out, "    meta.insert(title_key, title)")
    append_line(out, "    meta.insert(body_key, body)")
    append_line(out, "    return doc_term_counts_into(body, terms)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_indexer() -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let a_total = ingest_doc(meta, \"d1.title\", \"d1.body\", \"VaisDB Guide\", \"AI cache ai CACHE vector ai\", doc_a)")
    append_line(out, "    let b_total = ingest_doc(meta, \"d2.title\", \"d2.body\", \"Cache Notes\", \"cache cache vector vector\", doc_b)")
    append_line(out, "    if a_total != 6 { return 20 }")
    append_line(out, "    if b_total != 4 { return 21 }")
    append_line(out, "    if meta.len() != 4 { return 22 }")
    append_line(out, "    let snapshot = map_str_str_snapshot(meta)")
    append_line(out, "    let loaded: Map<Str,Str> = {}")
    append_line(out, "    if map_str_str_load_snapshot(snapshot, loaded) != 4 { return 23 }")
    append_line(out, "    if loaded.get(\"d1.title\", \"\") != \"VaisDB Guide\" { return 24 }")
    append_line(out, "    if loaded.get(\"d2.title\", \"\") != \"Cache Notes\" { return 25 }")
    append_line(out, "    if require_present_len(loaded, \"d1.title\") == 0 { return 26 }")
    append_line(out, "    if require_present_len(loaded, \"d2.body\") == 0 { return 27 }")
    append_line(out, "    if require_present_len(loaded, \"d3.title\") != 0 { return 28 }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let q_total = doc_term_counts_into(\"ai cache ai\", query)")
    append_line(out, "    if q_total != 3 { return 29 }")
    append_line(out, "    let a_score = doc_term_weighted_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_weighted_score(query, doc_b)")
    append_line(out, "    if a_score != 8 { return 30 }")
    append_line(out, "    if b_score != 2 { return 31 }")
    append_line(out, "    if a_score <= b_score { return 32 }")
    append_line(out, "    return a_score * 5 + b_score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return run_indexer()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_vaisdb_file_ingest_workflow(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn ingest_file(meta: Map<Str,Str>, title_key: Str, body_key: Str, path: Str, terms: Map<Str,Int>) -> Int {")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n < 2 { return 0 }")
    append_line(out, "    let title = str_trim(lines[0])")
    append_line(out, "    let body = str_trim(lines[1])")
    append_line(out, "    if title.len() == 0 { return 0 }")
    append_line(out, "    if body.len() == 0 { return 0 }")
    append_line(out, "    meta.insert(title_key, title)")
    append_line(out, "    meta.insert(body_key, body)")
    append_line(out, "    return doc_term_counts_into(body, terms)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn read_query_file(path: Str, query: Map<Str,Int>) -> Int {")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n == 0 { return 0 }")
    append_line(out, "    let query_text = str_trim(lines[0])")
    append_line(out, "    if query_text.len() == 0 { return 0 }")
    append_line(out, "    return doc_term_counts_into(query_text, query)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_files(doc_a_path: Str, doc_b_path: Str, query_path: Str) -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let a_total = ingest_file(meta, \"d1.title\", \"d1.body\", doc_a_path, doc_a)")
    append_line(out, "    let b_total = ingest_file(meta, \"d2.title\", \"d2.body\", doc_b_path, doc_b)")
    append_line(out, "    if a_total != 6 { return 20 }")
    append_line(out, "    if b_total != 4 { return 21 }")
    append_line(out, "    let snapshot = map_str_str_snapshot(meta)")
    append_line(out, "    let loaded: Map<Str,Str> = {}")
    append_line(out, "    if map_str_str_load_snapshot(snapshot, loaded) != 4 { return 22 }")
    append_line(out, "    if loaded.get(\"d1.title\", \"\") != \"VaisDB Guide\" { return 23 }")
    append_line(out, "    if loaded.get(\"d2.title\", \"\") != \"Cache Notes\" { return 24 }")
    append_line(out, "    if loaded.get(\"d1.body\", \"\").len() == 0 { return 25 }")
    append_line(out, "    if loaded.get(\"d2.body\", \"\").len() == 0 { return 26 }")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let q_total = read_query_file(query_path, query)")
    append_line(out, "    if q_total != 3 { return 27 }")
    append_line(out, "    let a_score = doc_term_weighted_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_weighted_score(query, doc_b)")
    append_line(out, "    if a_score != 8 { return 28 }")
    append_line(out, "    if b_score != 2 { return 29 }")
    append_line(out, "    if a_score <= b_score { return 30 }")
    append_line(out, "    return a_score * 5 + b_score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn run_generated_files() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let doc_a = path_join(root, \"vais-direct-e297-doc-a.txt\")")
    append_line(out, "    let doc_b = path_join(root, \"vais-direct-e297-doc-b.txt\")")
    append_line(out, "    let query = path_join(root, \"vais-direct-e297-query.txt\")")
    append_line(out, "    let lf = str_byte(10)")
    append_line(out, "    let doc_a_text = str_concat(\"VaisDB Guide\", str_concat(lf, str_concat(\"AI cache ai CACHE vector ai\", lf)))")
    append_line(out, "    let doc_b_text = str_concat(\"Cache Notes\", str_concat(lf, str_concat(\"cache cache vector vector\", lf)))")
    append_line(out, "    let query_text = str_concat(\"ai cache ai\", lf)")
    append_line(out, "    if fs_write_text(doc_a, doc_a_text) != 0 { return 2 }")
    append_line(out, "    if fs_write_text(doc_b, doc_b_text) != 0 { return 3 }")
    append_line(out, "    if fs_write_text(query, query_text) != 0 { return 4 }")
    append_line(out, "    return run_files(doc_a, doc_b, query)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    if proc_argc() == 3 {")
    append_line(out, "        return run_files(proc_arg(0), proc_arg(1), proc_arg(2))")
    append_line(out, "    }")
    append_line(out, "    if proc_argc() != 0 { return 1 }")
    append_line(out, "    return run_generated_files()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_doc_term_counts_into(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let counts: Map<Str,Int> = {}")
    append_line(out, "    let total = doc_term_counts_into(\"AI cache ai CACHE vector ai\", counts)")
    append_line(out, "    if total != 6 { return 1 }")
    append_line(out, "    if counts.len() != 3 { return 2 }")
    append_line(out, "    if counts.get(\"ai\", 0) != 3 { return 3 }")
    append_line(out, "    if counts.get(\"cache\", 0) != 2 { return 4 }")
    append_line(out, "    if counts.get(\"vector\", 0) != 1 { return 5 }")
    append_line(out, "    return counts.get(\"ai\", 0) * 10 + counts.get(\"cache\", 0) * 5 + counts.get(\"vector\", 0) * 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_doc_term_overlap_score(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let q_total = doc_term_counts_into(\"ai cache ai\", query)")
    append_line(out, "    let a_total = doc_term_counts_into(\"AI cache ai CACHE vector ai\", doc_a)")
    append_line(out, "    let b_total = doc_term_counts_into(\"cache cache vector vector\", doc_b)")
    append_line(out, "    if q_total != 3 { return 1 }")
    append_line(out, "    if a_total != 6 { return 2 }")
    append_line(out, "    if b_total != 4 { return 3 }")
    append_line(out, "    let a_score = doc_term_overlap_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_overlap_score(query, doc_b)")
    append_line(out, "    if a_score != 3 { return 4 }")
    append_line(out, "    if b_score != 1 { return 5 }")
    append_line(out, "    if a_score <= b_score { return 6 }")
    append_line(out, "    return a_score * 10 + b_score * 9 + q_total")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_doc_term_weighted_score(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let query: Map<Str,Int> = {}")
    append_line(out, "    let doc_a: Map<Str,Int> = {}")
    append_line(out, "    let doc_b: Map<Str,Int> = {}")
    append_line(out, "    let q_total = doc_term_counts_into(\"ai cache ai\", query)")
    append_line(out, "    let a_total = doc_term_counts_into(\"AI cache ai CACHE vector ai\", doc_a)")
    append_line(out, "    let b_total = doc_term_counts_into(\"cache cache vector vector\", doc_b)")
    append_line(out, "    if q_total != 3 { return 1 }")
    append_line(out, "    if a_total != 6 { return 2 }")
    append_line(out, "    if b_total != 4 { return 3 }")
    append_line(out, "    let a_score = doc_term_weighted_score(query, doc_a)")
    append_line(out, "    let b_score = doc_term_weighted_score(query, doc_b)")
    append_line(out, "    if a_score != 8 { return 4 }")
    append_line(out, "    if b_score != 2 { return 5 }")
    append_line(out, "    if a_score <= b_score { return 6 }")
    append_line(out, "    return a_score * 5 + b_score")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_doc_score_for_each(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_space(c: Int) -> Int {")
    append_line(out, "    if c == 32 { return 1 }")
    append_line(out, "    if c == 9 { return 1 }")
    append_line(out, "    if c == 10 { return 1 }")
    append_line(out, "    if c == 13 { return 1 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn split_words(text: Str) -> List<Str> {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    let mut i = 0")
    append_line(out, "    while i < text.len() {")
    append_line(out, "        while i < text.len() and is_space(text[i]) == 1 {")
    append_line(out, "            i = i + 1")
    append_line(out, "        }")
    append_line(out, "        let start = i")
    append_line(out, "        while i < text.len() and is_space(text[i]) == 0 {")
    append_line(out, "            i = i + 1")
    append_line(out, "        }")
    append_line(out, "        if i > start {")
    append_line(out, "            let token = str_lower(str_trim(str_slice(text, start, i - start)))")
    append_line(out, "            words.push(token)")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return words")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_tokens(words: List<Str>) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, "    for word in words {")
    append_line(out, "        if str_contains(word, \"ai\") == 1 {")
    append_line(out, "            score = score + word.len()")
    append_line(out, "        } else if str_contains(word, \"cache\") == 1 {")
    append_line(out, "            score = score + 10")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words = split_words(\"  VaisDB   AI cache Vector  \")")
    append_line(out, "    if words.len() != 4 { return 1 }")
    append_line(out, "    if words[0] != \"vaisdb\" { return 2 }")
    append_line(out, "    if words.last() != \"vector\" { return 3 }")
    append_line(out, "    return score_tokens(words) + words.len() * 6")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_str_chained_len(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn make_words() -> List<Str> {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"alpha\")")
    append_line(out, "    words.push(\"beta\")")
    append_line(out, "    words.push(\"gamma\")")
    append_line(out, "    words.push(\"delta\")")
    append_line(out, "    return words")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words = make_words()")
    append_line(out, "    if words[0] != \"alpha\" { return 0 }")
    append_line(out, "    if words.last() != \"delta\" { return 1 }")
    append_line(out, "    let first_len = words[0].len()")
    append_line(out, "    let last_len = words.last().len()")
    append_line(out, "    if words.pop() != \"delta\" { return 2 }")
    append_line(out, "    let tail_len = words.pop().len()")
    append_line(out, "    if first_len != 5 { return 3 }")
    append_line(out, "    if last_len != 5 { return 4 }")
    append_line(out, "    if tail_len != 5 { return 5 }")
    append_line(out, "    return words.len() * 16 + words.is_empty() + first_len + last_len")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_int_int(path: Str) -> Int {

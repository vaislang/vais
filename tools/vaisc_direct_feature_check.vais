fn write_list_str_pipeline_scalar_bool_negation(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let map_filter_prefix = str_concat(str_concat(str_concat("words.map(", pipe), "word"), str_concat(pipe, " str_lower(str_trim(word))).filter("))
    let map_chain = str_concat(map_filter_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_contains(word, needle) == 1)")))
    let filter_map_prefix = str_concat(str_concat(str_concat("words.filter(", pipe), "word"), str_concat(pipe, " str_contains(str_lower(str_trim(word)), needle) == 1).map("))
    let filter_chain = str_concat(filter_map_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_lower(str_trim(word)))")))
    let not_map_missing = str_concat("not ", str_concat(map_chain, ".contains(\"missing\")"))
    let not_filter_missing = str_concat("not ", str_concat(filter_chain, ".contains(\"missing\")"))
    let if_cond = str_concat(str_concat(not_map_missing, " and "), str_concat(filter_chain, ".contains(\"ai\")"))
    let while_cond = str_concat(str_concat(not_filter_missing, " and "), "guard < 2")
    let not_map_vais = str_concat("not ", str_concat(map_chain, ".contains(\"vais\")"))
    append_line(out, "fn bool_score(flag: Bool, yes: Int, no: Int) -> Int {")
    append_line(out, "    if flag { return yes }")
    append_line(out, "    return no")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    let mut present = ", not_map_missing))
    append_line(out, str_concat("    present = ", not_filter_missing))
    append_line(out, "    let mut total = bool_score(present, 10, 0)")
    append_line(out, str_concat("    if ", str_concat(if_cond, " {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    } else {")
    append_line(out, "        return 1")
    append_line(out, "    }")
    append_line(out, "    let mut guard = 0")
    append_line(out, str_concat("    while ", str_concat(while_cond, " {")))
    append_line(out, "        guard = guard + 1")
    append_line(out, "    }")
    append_line(out, "    if guard != 2 { return 2 }")
    append_line(out, str_concat("    if ", str_concat(not_map_vais, " {")))
    append_line(out, "        return 3")
    append_line(out, "    }")
    append_line(out, "    return total + guard + 20")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"  Vais\")")
    append_line(out, "    words.push(\"AI\")")
    append_line(out, "    words.push(\"db\")")
    append_line(out, "    words.push(\"ai  \")")
    append_line(out, "    return score(words, \"ai\")")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_str_pipeline_scalar_bool_if_expr(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let map_filter_prefix = str_concat(str_concat(str_concat("words.map(", pipe), "word"), str_concat(pipe, " str_lower(str_trim(word))).filter("))
    let map_chain = str_concat(map_filter_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_contains(word, needle) == 1)")))
    let filter_map_prefix = str_concat(str_concat(str_concat("words.filter(", pipe), "word"), str_concat(pipe, " str_contains(str_lower(str_trim(word)), needle) == 1).map("))
    let filter_chain = str_concat(filter_map_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_lower(str_trim(word)))")))
    let if_map_vais = str_concat(str_concat("if ", str_concat(map_chain, ".contains(\"vais\")")), " then true else false")
    let if_filter_missing = str_concat(str_concat("if ", str_concat(filter_chain, ".contains(\"missing\")")), " then true else false")
    let if_map_missing = str_concat(str_concat("if ", str_concat(map_chain, ".contains(\"missing\")")), " then true else false")
    let both_cond = str_concat(str_concat(map_chain, ".contains(\"vais\")"), str_concat(" and ", str_concat(filter_chain, ".contains(\"ai\")")))
    let if_both = str_concat(str_concat("if ", both_cond), " then true else false")
    append_line(out, "fn bool_score(flag: Bool, yes: Int, no: Int) -> Int {")
    append_line(out, "    if flag { return yes }")
    append_line(out, "    return no")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    let mut ok = ", if_map_vais))
    append_line(out, str_concat("    ok = ", str_concat(filter_chain, ".contains(\"ai\")")))
    append_line(out, str_concat("    let mut missing = ", if_filter_missing))
    append_line(out, str_concat("    missing = ", if_map_missing))
    append_line(out, str_concat("    let mut both = ", if_both))
    append_line(out, str_concat("    both = ", str_concat(map_chain, ".contains(\"ai\")")))
    append_line(out, "    let mut total = bool_score(ok, 10, 0)")
    append_line(out, "    total = total + bool_score(missing, 0, 10)")
    append_line(out, "    total = total + bool_score(both, 10, 0)")
    append_line(out, "    return total + 12")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"  Vais\")")
    append_line(out, "    words.push(\"AI\")")
    append_line(out, "    words.push(\"db\")")
    append_line(out, "    words.push(\"ai  \")")
    append_line(out, "    return score(words, \"ai\")")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


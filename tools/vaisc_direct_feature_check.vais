    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn local_flow(docs: List<Doc>) -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, str_concat("    total = ", str_concat(sum_expr, " + 1")))
    append_line(out, "    let mut best: Int = 0")
    append_line(out, str_concat("    best = ", str_concat(max_expr, " - 1")))
    append_line(out, "    let mut low = 100")
    append_line(out, str_concat("    low = ", str_concat(min_expr, " * 2")))
    append_line(out, "    return total + best - low - 11")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn parameter_flow(score: Int, docs: List<Doc>) -> Int {")
    append_line(out, str_concat("    score = ", str_concat(max_expr, " + 22")))
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    if local_flow(docs) != 42 { return 1 }")
    append_line(out, "    return parameter_flow(0, docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_map_projection_aggregate_embedded_expr(path: Str) -> Int {

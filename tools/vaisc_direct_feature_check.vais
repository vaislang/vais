    let out = str_builder_new()
    let pipe = str_byte(124)
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn score_until_stable(docs: List<Doc>, needle: Str, min_score: Int) -> Int {")
    append_line(out, "    let mut rounds = 0")
    let line1 = str_concat(str_concat(str_concat("    while combine_later(docs.filter(", pipe), "doc"), pipe)
    let line2 = str_concat(line1, " str_contains(doc.body, needle) == 1).first().score, docs.filter(")

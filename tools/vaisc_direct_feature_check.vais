    append_line(out, "    if xs[1] != 30 { return 3 }")
    append_line(out, "    if remove_mid(xs, 2) != 40 { return 4 }")
    append_line(out, "    if xs.len() != 2 { return 5 }")
    append_line(out, "    if xs.sum() != 40 { return 6 }")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"ai\")")
    append_line(out, "    words.push(\"cache\")")
    append_line(out, "    words.push(\"vector\")")
    append_line(out, "    words.push(\"cache\")")
    append_line(out, "    let removed: Str = words.remove_at(2)")
    append_line(out, "    if removed.len() != 6 { return 7 }")
    append_line(out, "    if words.len() != 3 { return 8 }")
    append_line(out, "    if words.index_of(\"cache\") != 1 { return 9 }")
    append_line(out, "    let removed2: Str = remove_word(words, 1)")
    append_line(out, "    if removed2.len() != 5 { return 10 }")
    append_line(out, "    if words.count(\"cache\") != 1 { return 11 }")
    append_line(out, "    return xs.sum() + words.len()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


    append_line(out, str_concat("    values.insert_at(0, ", str_concat(mixed_insert, ")")))
    append_line(out, str_concat("    if ", str_concat(mixed_bool, " {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    }")
    append_line(out, "    let mut guard = 0")
    append_line(out, str_concat("    while ", str_concat(mixed_guard, " > guard {")))
    append_line(out, "        guard = guard + 2")
    append_line(out, "    }")
    append_line(out, "    return total + values[0] + values[1] + guard")

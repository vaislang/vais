    let filter_chain = str_concat(filter_map_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_lower(str_trim(word)))")))
    let map_len = str_concat(map_chain, ".len()")
    let map_count = str_concat(map_chain, ".count(\"ai\")")
    let map_index_vais = str_concat(map_chain, ".index_of(\"vais\")")
    let map_index_ai = str_concat(map_chain, ".index_of(\"ai\")")
    let map_contains_vais = str_concat(map_chain, ".contains(\"vais\")")
    let map_contains_ai = str_concat(map_chain, ".contains(\"ai\")")
    let map_pair = str_concat(map_len, str_concat(" + ", map_count))
    let map_pos_pair = str_concat(map_index_vais, str_concat(" + ", map_index_ai))
    let map_bool_pair = str_concat(map_contains_vais, str_concat(" and ", map_contains_ai))
    let map_guard = str_concat(map_count, str_concat(" + ", map_index_ai))
    let filter_len = str_concat(filter_chain, ".len()")
    let filter_count = str_concat(filter_chain, ".count(\"ai\")")
    let filter_index_vais = str_concat(filter_chain, ".index_of(\"vais\")")
    let filter_index_ai = str_concat(filter_chain, ".index_of(\"ai\")")
    let filter_contains_vais = str_concat(filter_chain, ".contains(\"vais\")")
    let filter_contains_ai = str_concat(filter_chain, ".contains(\"ai\")")
    let filter_contains_missing = str_concat(filter_chain, ".contains(\"missing\")")
    let filter_pair = str_concat(filter_len, str_concat(" + ", filter_count))
    let filter_pos_pair = str_concat(filter_index_vais, str_concat(" + ", filter_index_ai))
    let filter_bool_pair = str_concat(filter_contains_vais, str_concat(" and ", filter_contains_ai))
    let filter_missing_pair = str_concat(filter_contains_missing, str_concat(" and ", filter_contains_ai))
    append_line(out, "fn weigh(n: Int) -> Int {")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn map_pair(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    return ", map_pair))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn filter_pair(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    return ", filter_pair))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn map_score(words: List<Str>, needle: Str) -> Int {")
    append_line(out, "    if map_pair(words, needle) != 5 { return 1 }")
    append_line(out, str_concat("    let pair = ", map_pair))
    append_line(out, "    let mut total = pair")
    append_line(out, str_concat("    total = total + weigh(", str_concat(map_pos_pair, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(", str_concat(map_pair, ")")))
    append_line(out, str_concat("    if ", str_concat(map_bool_pair, " {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    }")
    append_line(out, "    let mut guard = 0")
    append_line(out, str_concat("    while ", str_concat(map_guard, " > guard {")))
    append_line(out, "        guard = guard + 2")
    append_line(out, "    }")
    append_line(out, "    return total + values[0] + guard")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn filter_score(words: List<Str>, needle: Str) -> Int {")
    append_line(out, "    if filter_pair(words, needle) != 5 { return 2 }")
    append_line(out, str_concat("    let pair = ", filter_pair))
    append_line(out, "    let mut total = pair")
    append_line(out, str_concat("    total = total + weigh(", str_concat(filter_pos_pair, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.insert_at(0, ", str_concat(filter_pair, ")")))
    append_line(out, str_concat("    if ", str_concat(filter_missing_pair, " {")))
    append_line(out, "        return 3")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(filter_bool_pair, " {")))
    append_line(out, "        total = total + 7")
    append_line(out, "    }")
    append_line(out, "    return total + values[0] - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"  Vais\")")
    append_line(out, "    words.push(\"AI\")")
    append_line(out, "    words.push(\"db\")")
    append_line(out, "    words.push(\"ai  \")")
    append_line(out, "    return map_score(words, \"ai\") + filter_score(words, \"ai\")")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


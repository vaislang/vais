    append_line(out, "    let maybe = match copy.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    if copy.contains(\"blue\") and not scores.contains(\"red\") and scores.get(\"green\", 0) == 1 and scores.len() == 1 {")
    append_line(out, "        return maybe + copy.get(\"blue\", 0) - 18")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


    append_line(out, "    return a + b + xs.len()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_int_while_hoist(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn make(n: Int) -> List<Int> {")
    append_line(out, "    return [n]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(xs: List<Int>) -> Int {")
    append_line(out, "    xs.push(1)")
    append_line(out, "    return xs.sum()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut total = 0")
    append_line(out, "    while score(make(i)) < 4 {")
    append_line(out, "        total = total + score(make(i))")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return total * 6 + i * 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_if_hoist(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_int(n: Int) -> List<Int> {")
    append_line(out, "    return [n, n + 1]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_int(xs: List<Int>) -> Int {")
    append_line(out, "    return xs.sum()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_box(n: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: n }, Box { value: n + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_box(xs: List<Box>) -> Int {")
    append_line(out, "    return xs[0].value + xs[1].value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    if score_int(make_int(20)) == 41 {")
    append_line(out, "        total = total + 20")
    append_line(out, "    }")
    append_line(out, "    if score_box(make_box(10)) == 21 {")
    append_line(out, "        total = total + 22")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_else_if_hoist(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_int(n: Int) -> List<Int> {")
    append_line(out, "    return [n, n + 1]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_int(xs: List<Int>) -> Int {")
    append_line(out, "    return xs.sum()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_box(n: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: n }, Box { value: n + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_box(xs: List<Box>) -> Int {")
    append_line(out, "    return xs[0].value + xs[1].value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    if score_int([1, 1]) == 99 {")
    append_line(out, "        total = total + 1")
    append_line(out, "    } else if score_int(make_int(20)) == 41 {")
    append_line(out, "        total = total + 20")
    append_line(out, "    }")
    append_line(out, "    if score_box([Box { value: 1 }, Box { value: 1 }]) == 99 {")
    append_line(out, "        total = total + 1")
    append_line(out, "    } else if score_box(make_box(10)) == 21 {")
    append_line(out, "        total = total + 22")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_proc_capture_result(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct ProcessResult { code: Int, stdout: Str, stderr: Str }")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let argv: List<Str> = []")
    append_line(out, "    argv.push(\"/bin/sh\")")
    append_line(out, "    argv.push(\"-c\")")
    append_line(out, "    argv.push(\"printf allout; printf allerr >&2; exit 17\")")
    append_line(out, "    let got = proc_capture(argv)")
    append_line(out, "    if got.code != 17 { return 1 }")
    append_line(out, "    if got.stdout.len() != 6 { return 2 }")
    append_line(out, "    if str_starts_with(got.stdout, \"all\") != 1 { return 3 }")
    append_line(out, "    if got.stderr.len() != 6 { return 4 }")
    append_line(out, "    if str_contains(got.stderr, \"err\") != 1 { return 5 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn capture_emit_direct(vaisc: Str, src: Str, ll: Str, out_path: Str, err_path: Str) -> Int {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("emit-ir")
    argv.push(src)
    argv.push("--engine")
    argv.push("direct")
    argv.push("-o")
    argv.push(ll)
    return proc_capture_to(argv, out_path, err_path)
}

fn capture_run_direct(vaisc: Str, src: Str, out_path: Str, err_path: Str) -> Int {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("run")
    argv.push(src)
    argv.push("--engine")
    argv.push("direct")
    return proc_capture_to(argv, out_path, err_path)
}

fn emit_failed(label: Str, err_path: Str) -> Int {
    print(str_concat("  FAIL ", str_concat(label, " emission")))
    if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
    return 1
}

fn run_failed(label: Str, got: Int, err_path: Str) -> Int {
    print(str_concat("  FAIL ", str_concat(label, str_concat(" got=", str_concat(uint_to_str(got), " want=42")))))
    if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
    return 1
}


    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut total = 0")
    append_line(out, "    while score(make(i)) < 4 {")
    append_line(out, "        total = total + score(make(i))")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return total * 6 + i * 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_if_hoist(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_int(n: Int) -> List<Int> {")
    append_line(out, "    return [n, n + 1]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_int(xs: List<Int>) -> Int {")
    append_line(out, "    return xs.sum()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_box(n: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: n }, Box { value: n + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_box(xs: List<Box>) -> Int {")
    append_line(out, "    return xs[0].value + xs[1].value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    if score_int(make_int(20)) == 41 {")
    append_line(out, "        total = total + 20")
    append_line(out, "    }")
    append_line(out, "    if score_box(make_box(10)) == 21 {")
    append_line(out, "        total = total + 22")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_else_if_hoist(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_int(n: Int) -> List<Int> {")
    append_line(out, "    return [n, n + 1]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_int(xs: List<Int>) -> Int {")
    append_line(out, "    return xs.sum()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_box(n: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: n }, Box { value: n + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_box(xs: List<Box>) -> Int {")
    append_line(out, "    return xs[0].value + xs[1].value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut total = 0")
    append_line(out, "    if score_int([1, 1]) == 99 {")
    append_line(out, "        total = total + 1")
    append_line(out, "    } else if score_int(make_int(20)) == 41 {")
    append_line(out, "        total = total + 20")
    append_line(out, "    }")
    append_line(out, "    if score_box([Box { value: 1 }, Box { value: 1 }]) == 99 {")
    append_line(out, "        total = total + 1")
    append_line(out, "    } else if score_box(make_box(10)) == 21 {")
    append_line(out, "        total = total + 22")
    append_line(out, "    }")
    append_line(out, "    return total")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn capture_emit_direct(vaisc: Str, src: Str, ll: Str, out_path: Str, err_path: Str) -> Int {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("emit-ir")
    argv.push(src)
    argv.push("--engine")
    argv.push("direct")
    argv.push("-o")
    argv.push(ll)
    return proc_capture_to(argv, out_path, err_path)
}

fn capture_run_direct(vaisc: Str, src: Str, out_path: Str, err_path: Str) -> Int {
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("run")
    argv.push(src)
    argv.push("--engine")
    argv.push("direct")
    return proc_capture_to(argv, out_path, err_path)
}

fn emit_failed(label: Str, err_path: Str) -> Int {
    print(str_concat("  FAIL ", str_concat(label, " emission")))
    if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
    return 1
}

fn run_failed(label: Str, got: Int, err_path: Str) -> Int {
    print(str_concat("  FAIL ", str_concat(label, str_concat(" got=", str_concat(uint_to_str(got), " want=42")))))
    if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
    return 1
}

fn expect_case(vaisc: Str, tmp: Str, name: Str, pass_label: Str, shape: Int) -> Int {
    let src = path_join(tmp, str_concat(name, ".vais"))
    let ir = path_join(tmp, str_concat(name, ".ll"))
    let out_path = path_join(tmp, str_concat(name, ".out"))
    let err_path = path_join(tmp, str_concat(name, ".err"))
    let run_out = path_join(tmp, str_concat(name, "-run.out"))
    let run_err = path_join(tmp, str_concat(name, "-run.err"))

    let mut wrote = 1
    if str_contains(name, "list_else_if_hoist") == 1 { wrote = write_list_else_if_hoist(src) }
    else if str_contains(name, "list_if_hoist") == 1 { wrote = write_list_if_hoist(src) }
    else if str_contains(name, "list_int_while_hoist") == 1 { wrote = write_list_int_while_hoist(src) }
    else if str_contains(name, "list_int_return_call_args") == 1 { wrote = write_list_int_return_call_args(src) }
    else if str_contains(name, "list_int_inline_values") == 1 { wrote = write_list_int_inline_values(src) }
    else if str_contains(name, "list_int_out_param") == 1 { wrote = write_list_int_out_param(src) }
    else if str_contains(name, "list_int_abi") == 1 { wrote = write_list_int_abi(src) }
    else if str_contains(name, "list_assignment") == 1 { wrote = write_list_assignment(src) }
    else if str_contains(name, "list_element_assignment") == 1 { wrote = write_list_element_assignment(src) }
    else if str_contains(name, "list_struct_field_write") == 1 { wrote = write_list_struct_field_write(src) }
    else if str_contains(name, "list_struct_abi") == 1 { wrote = write_list_struct_abi(src) }
    else if str_contains(name, "parse_helpers") == 1 { wrote = write_parse_helpers(src) }
    else if str_contains(name, "helper") == 1 { wrote = write_helper_control(src) }
    else if str_contains(name, "for") == 1 { wrote = write_for_loop(src) }
    else if str_contains(name, "list_struct_local") == 1 { wrote = write_list_struct_local(src) }
    else if str_contains(name, "struct_local") == 1 { wrote = write_struct_local(src) }
    else if str_contains(name, "struct_abi") == 1 { wrote = write_struct_abi(src) }
    else if str_contains(name, "list_int") == 1 { wrote = write_list_int(src) }
    else if str_contains(name, "str_slice") == 1 { wrote = write_str_slice(src) }
    else if str_contains(name, "char_literal") == 1 { wrote = write_char_literal(src) }
    else if str_contains(name, "map_remove") == 1 { wrote = write_map_remove(src) }
    else if str_contains(name, "map_clear") == 1 { wrote = write_map_clear(src) }
    else if str_contains(name, "map_str_int_return") == 1 { wrote = write_map_str_int_return(src) }
    else if str_contains(name, "map_str_int_param") == 1 { wrote = write_map_str_int_param(src) }
    else if str_contains(name, "map_str_bool_return") == 1 { wrote = write_map_str_bool_return(src) }
    else if str_contains(name, "map_str_bool_param") == 1 { wrote = write_map_str_bool_param(src) }
    else if str_contains(name, "map_str_char_return") == 1 { wrote = write_map_str_char_return(src) }
    else if str_contains(name, "map_str_char_param") == 1 { wrote = write_map_str_char_param(src) }
    else if str_contains(name, "map_str_char") == 1 { wrote = write_map_str_char(src) }
    else if str_contains(name, "map_str_bool") == 1 { wrote = write_map_str_bool(src) }
    else if str_contains(name, "map_str_int") == 1 { wrote = write_map_str_int(src) }
    else if str_contains(name, "map_char_return") == 1 { wrote = write_map_char_return(src) }
    else if str_contains(name, "map_bool_return") == 1 { wrote = write_map_bool_return(src) }
    else if str_contains(name, "map_int_return") == 1 { wrote = write_map_int_return(src) }
    else if str_contains(name, "map_char_param") == 1 { wrote = write_map_char_param(src) }
    else if str_contains(name, "map_bool_param") == 1 { wrote = write_map_bool_param(src) }
    else if str_contains(name, "map_int_param") == 1 { wrote = write_map_int_param(src) }
    else if str_contains(name, "map_int_char") == 1 { wrote = write_map_int_char(src) }
    else if str_contains(name, "map_int_bool") == 1 { wrote = write_map_int_bool(src) }
    else if str_contains(name, "map_get_opt") == 1 { wrote = write_map_get_opt(src) }
    else if str_contains(name, "map_param_assignment") == 1 { wrote = write_map_param_assignment(src) }
    else if str_contains(name, "map_assignment") == 1 { wrote = write_map_assignment(src) }
    else if str_contains(name, "map_int_int") == 1 { wrote = write_map_int_int(src) }
    if wrote != 0 {
        print(str_concat("  FAIL direct ", str_concat(name, " source write")))
        return 1
    }

    if capture_emit_direct(vaisc, src, ir, out_path, err_path) != 0 {
        return emit_failed(str_concat("direct ", name), err_path)
    }
    let text = fs_read_text(ir)
    let mut ok = 0
    if shape == 1 {
        ok = str_contains(text, "define i64 @add") and str_contains(text, "call i64 @add") and str_contains(text, " br ")
    } else if shape == 2 {
        ok = str_contains(text, " br ")
    } else if shape == 3 {
        ok = str_contains(text, "%struct.Box = type") and str_contains(text, "getelementptr") and str_contains(text, "%struct.Box")
    } else if shape == 4 {
        ok = str_contains(text, "%struct.Pair = type") and str_contains(text, "@make") and str_contains(text, "@sum")
    } else if shape == 5 {
        ok = str_contains(text, "__vais_list_int_sum") and str_contains(text, "DirectListInt")
    } else if shape == 6 {
        ok = str_contains(text, "__vais_str_len") and str_contains(text, "__vais_str_byte") and str_contains(text, "__vais_str_eq")
    } else if shape == 7 {
        ok = str_contains(text, "store i64 65") and str_contains(text, "icmp eq i64")
    } else if shape == 8 {
        ok = str_contains(text, "__vais_parse_uint") and str_contains(text, "__vais_parse_int")
    } else if shape == 9 {
        ok = str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "__vais_map_int_int_get") and str_contains(text, "__vais_map_int_int_contains") and str_contains(text, "__vais_map_int_int_len")
    } else if shape == 10 {
        ok = str_contains(text, "DirectList_Box") and str_contains(text, "getelementptr") and str_contains(text, "struct.Box")
    } else if shape == 11 {
        ok = str_contains(text, "%struct.DirectList_Box = type") and str_contains(text, "sret(%struct.DirectList_Box)") and str_contains(text, "define i64 @append(ptr") and str_contains(text, "define i64 @score(ptr")
    } else if shape == 12 {
        ok = str_contains(text, "%struct.DirectList_Box = type") and str_contains(text, "store i64 10") and str_contains(text, "define i64 @bump(ptr")
    } else if shape == 13 {
        ok = str_contains(text, "%struct.DirectList_Box = type") and str_contains(text, "define i64 @set_box(ptr") and str_contains(text, "llvm.memcpy") and str_contains(text, "store i64 5")
    } else if shape == 14 {
        ok = str_contains(text, "%struct.DirectList_Box = type") and str_contains(text, "sret(%struct.DirectList_Box)")
    } else if shape == 15 {
        ok = str_contains(text, "@make") and str_contains(text, "@score") and str_contains(text, "call")
    } else if shape == 16 {
        ok = str_contains(text, "@fill") and str_contains(text, "call")
    } else if shape == 17 {
        ok = str_contains(text, "@make") and str_contains(text, "@score") and str_contains(text, "call")
    } else if shape == 18 {
        ok = str_contains(text, "call void @make") and str_contains(text, "call void @pass") and str_contains(text, "@score")
    } else if shape == 19 {
        ok = str_contains(text, "br label") and str_contains(text, "call void @make") and str_contains(text, "@score")
    } else if shape == 20 {
        ok = str_contains(text, "call void @make_int") and str_contains(text, "@score_int") and str_contains(text, "call void @make_box") and str_contains(text, "@score_box")
    } else if shape == 21 {
        ok = str_contains(text, "call void @make_int") and str_contains(text, "@score_int") and str_contains(text, "call void @make_box") and str_contains(text, "@score_box")
    } else if shape == 22 {
        ok = str_contains(text, "__vais_map_int_int_get_opt") and str_contains(text, "srem i64") and str_contains(text, "sdiv i64")
    } else if shape == 23 {
        ok = str_contains(text, "__vais_map_int_int_copy") and str_contains(text, "__vais_map_int_int_get") and str_contains(text, "__vais_map_int_int_len")
    } else if shape == 24 {
        ok = str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "__vais_map_int_int_get") and str_contains(text, "__vais_map_int_int_contains") and str_contains(text, "__vais_map_int_int_copy")
    } else if shape == 25 {
        ok = str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "__vais_map_int_int_get") and str_contains(text, "__vais_map_int_int_contains") and str_contains(text, "__vais_map_int_int_copy")
    } else if shape == 26 {
        ok = str_contains(text, "define i64 @put(ptr") and str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "call i64 @put(ptr")
    } else if shape == 27 {
        ok = str_contains(text, "define i64 @mark(ptr") and str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "call i64 @mark(ptr")
    } else if shape == 28 {
        ok = str_contains(text, "define i64 @stamp(ptr") and str_contains(text, "__vais_map_int_int_insert") and str_contains(text, "call i64 @stamp(ptr")
    } else if shape == 29 {
        ok = str_contains(text, "sret(%struct.DirectMapIntInt)") and str_contains(text, "define void @make_scores") and str_contains(text, "call void @make_scores")
    } else if shape == 30 {
        ok = str_contains(text, "sret(%struct.DirectMapIntInt)") and str_contains(text, "define void @make_flags") and str_contains(text, "call void @make_flags")
    } else if shape == 31 {
        ok = str_contains(text, "sret(%struct.DirectMapIntInt)") and str_contains(text, "define void @make_letters") and str_contains(text, "call void @make_letters")
    } else if shape == 32 {
        ok = str_contains(text, "__vais_map_int_int_remove") and str_contains(text, "__vais_map_int_int_len") and str_contains(text, "__vais_map_int_int_contains")
    } else if shape == 33 {
        ok = str_contains(text, "__vais_map_int_int_clear") and str_contains(text, "__vais_map_int_int_len") and str_contains(text, "__vais_map_int_int_contains")
    } else if shape == 34 {
        ok = str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_get") and str_contains(text, "__vais_map_str_int_contains") and str_contains(text, "__vais_map_str_int_copy")
    } else if shape == 35 {
        ok = str_contains(text, "define i64 @put(ptr") and str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_remove") and str_contains(text, "call i64 @put(ptr")
    } else if shape == 36 {
        ok = str_contains(text, "sret(%struct.DirectMapStrInt)") and str_contains(text, "define void @make_scores") and str_contains(text, "call void @make_scores")
    } else if shape == 37 {
        ok = str_contains(text, "%struct.DirectMapStrInt") and str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_get") and str_contains(text, "__vais_map_str_int_get_opt")
    } else if shape == 38 {
        ok = str_contains(text, "define i64 @mark(ptr") and str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_remove") and str_contains(text, "call i64 @mark(ptr")
    } else if shape == 39 {
        ok = str_contains(text, "sret(%struct.DirectMapStrInt)") and str_contains(text, "define void @make_flags") and str_contains(text, "call void @make_flags")
    } else if shape == 40 {
        ok = str_contains(text, "%struct.DirectMapStrInt") and str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_get") and str_contains(text, "__vais_map_str_int_get_opt")
    } else if shape == 41 {
        ok = str_contains(text, "define i64 @stamp(ptr") and str_contains(text, "__vais_map_str_int_insert") and str_contains(text, "__vais_map_str_int_remove") and str_contains(text, "call i64 @stamp(ptr")
    } else if shape == 42 {
        ok = str_contains(text, "sret(%struct.DirectMapStrInt)") and str_contains(text, "define void @make_letters") and str_contains(text, "call void @make_letters")
    } else if shape == 43 {
        ok = str_contains(text, "define i64 @copy_in(ptr") and str_contains(text, "__vais_map_str_int_copy") and str_contains(text, "call i64 @copy_in(ptr")
    }
    if ok == 0 {
        return emit_failed(str_concat("direct ", name), err_path)
    }
    let rc = capture_run_direct(vaisc, src, run_out, run_err)
    if rc == 42 {
        print(str_concat("  PASS ", pass_label))
        return 0
    }
    return run_failed(str_concat("direct ", name), rc, run_err)
}

fn usage() -> Int {
    print("usage: vaisc-direct-feature-check <repo-root> <tmp-dir>")
    return 2
}

fn main() -> Int {
    if proc_argc() != 2 { return usage() }
    let root = proc_arg(0)
    let tmp = proc_arg(1)
    if fs_mkdirs(tmp) != 0 {
        print(str_concat("  FAIL direct feature check cannot create ", tmp))
        return 1
    }
    let vaisc = path_join(root, "scripts/vaisc")
    let mut fail = 0
    fail = fail + expect_case(vaisc, tmp, "helper_control", "direct helper calls, locals, if, and while run (=42)", 1)
    fail = fail + expect_case(vaisc, tmp, "for_loop", "direct range for-loops and break/continue run (=42)", 2)
    fail = fail + expect_case(vaisc, tmp, "struct_local", "direct struct local literal, field read, and field write run (=42)", 3)
    fail = fail + expect_case(vaisc, tmp, "struct_abi", "direct struct parameter and return ABI runs (=42)", 4)
    fail = fail + expect_case(vaisc, tmp, "list_int", "direct local List<Int> push, len, is_empty, last, pop, index, literal, and sum run (=42)", 5)
    fail = fail + expect_case(vaisc, tmp, "str_slice", "direct Str len, index, equality, Bool helper, and byte classification run (=42)", 6)
    fail = fail + expect_case(vaisc, tmp, "char_literal", "direct Char literal, type annotation, return, and Bool helper run (=42)", 7)
    fail = fail + expect_case(vaisc, tmp, "parse_helpers", "direct parse_uint/parse_int Str helpers run (=42)", 8)
    fail = fail + expect_case(vaisc, tmp, "map_int_int", "direct local Map<Int,Int> insert/get/contains/len run (=42)", 9)
    fail = fail + expect_case(vaisc, tmp, "map_get_opt", "direct local concrete Map get_opt Option match run (=42)", 22)
    fail = fail + expect_case(vaisc, tmp, "map_assignment", "direct local Map<Int,Int> assignment copy runs (=42)", 23)
    fail = fail + expect_case(vaisc, tmp, "map_param_assignment", "direct Map parameter assignment copy runs (=42)", 43)
    fail = fail + expect_case(vaisc, tmp, "map_int_bool", "direct local Map<Int,Bool> insert/get/contains/len and assignment copy run (=42)", 24)
    fail = fail + expect_case(vaisc, tmp, "map_int_char", "direct local Map<Int,Char> insert/get/contains/len and assignment copy run (=42)", 25)
    fail = fail + expect_case(vaisc, tmp, "map_remove", "direct concrete Map remove deletes keys and updates len (=42)", 32)
    fail = fail + expect_case(vaisc, tmp, "map_clear", "direct concrete Map clear empties maps and allows reuse (=42)", 33)
    fail = fail + expect_case(vaisc, tmp, "map_str_int", "direct local Map<Str,Int> string-key operations run (=42)", 34)
    fail = fail + expect_case(vaisc, tmp, "map_str_bool", "direct local Map<Str,Bool> string-key operations run (=42)", 37)
    fail = fail + expect_case(vaisc, tmp, "map_str_char", "direct local Map<Str,Char> string-key operations run (=42)", 40)
    fail = fail + expect_case(vaisc, tmp, "map_str_char_param", "direct Map<Str,Char> parameter mutation run (=42)", 41)
    fail = fail + expect_case(vaisc, tmp, "map_str_char_return", "direct Map<Str,Char> return value initializes a local and runs (=42)", 42)
    fail = fail + expect_case(vaisc, tmp, "map_str_bool_param", "direct Map<Str,Bool> parameter mutation run (=42)", 38)
    fail = fail + expect_case(vaisc, tmp, "map_str_bool_return", "direct Map<Str,Bool> return value initializes a local and runs (=42)", 39)
    fail = fail + expect_case(vaisc, tmp, "map_str_int_param", "direct Map<Str,Int> parameter mutation run (=42)", 35)
    fail = fail + expect_case(vaisc, tmp, "map_str_int_return", "direct Map<Str,Int> return value initializes a local and runs (=42)", 36)
    fail = fail + expect_case(vaisc, tmp, "map_int_param", "direct Map<Int,Int> parameter mutation run (=42)", 26)
    fail = fail + expect_case(vaisc, tmp, "map_bool_param", "direct Map<Int,Bool> parameter mutation run (=42)", 27)
    fail = fail + expect_case(vaisc, tmp, "map_char_param", "direct Map<Int,Char> parameter mutation run (=42)", 28)
    fail = fail + expect_case(vaisc, tmp, "map_int_return", "direct Map<Int,Int> return value initializes a local and runs (=42)", 29)
    fail = fail + expect_case(vaisc, tmp, "map_bool_return", "direct Map<Int,Bool> return value initializes a local and runs (=42)", 30)
    fail = fail + expect_case(vaisc, tmp, "map_char_return", "direct Map<Int,Char> return value initializes a local and runs (=42)", 31)
    fail = fail + expect_case(vaisc, tmp, "list_struct_local", "direct local List<Struct> push, len, is_empty, last, pop, index, and field read run (=42)", 10)
    fail = fail + expect_case(vaisc, tmp, "list_struct_abi", "direct List<Struct> parameter, return, inline, and hoisted arguments run (=42)", 11)
    fail = fail + expect_case(vaisc, tmp, "list_struct_field_write", "direct List<Struct> indexed field assignment runs (=42)", 12)
    fail = fail + expect_case(vaisc, tmp, "list_element_assignment", "direct List<Int> and List<Struct> element assignments run (=42)", 13)
    fail = fail + expect_case(vaisc, tmp, "list_assignment", "direct List<Int> and List<Struct> assignments run (=42)", 14)
    fail = fail + expect_case(vaisc, tmp, "list_int_abi", "direct List<Int> parameter and return ABI runs (=42)", 15)
    fail = fail + expect_case(vaisc, tmp, "list_int_out_param", "direct List<Int> parameter push mutates caller list (=42)", 16)
    fail = fail + expect_case(vaisc, tmp, "list_int_inline_values", "direct inline List<Int> call and return values run (=42)", 17)
    fail = fail + expect_case(vaisc, tmp, "list_int_return_call_args", "direct List<Int> return-call arguments hoist and run (=42)", 18)
    fail = fail + expect_case(vaisc, tmp, "list_int_while_hoist", "direct List<Int> while-condition returned arguments hoist per iteration (=42)", 19)
    fail = fail + expect_case(vaisc, tmp, "list_if_hoist", "direct List<Int> and List<Struct> if-condition returned arguments hoist (=42)", 20)
    fail = fail + expect_case(vaisc, tmp, "list_else_if_hoist", "direct List<Int> and List<Struct> else-if returned arguments lower (=42)", 21)
    return fail
}

fn write_scalar_value_if_expr_embedded_call_args(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn add(a: Int, b: Int) -> Int {")
    append_line(out, "    return a + b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn choose(flag: Bool, yes: Int, no: Int) -> Int {")
    append_line(out, "    if flag { return yes }")
    append_line(out, "    return no")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(a: Int, b: Int) -> Int {")
    append_line(out, "    let mut total = if a > b then 10 else 0")
    append_line(out, "    total = if a == b then total else total + 10")
    append_line(out, "    total = total + add(if total == 20 then 10 else 0, 0)")
    append_line(out, "    total = total + choose(if total == 30 then true else false, 12, 0)")
    append_line(out, "    return if total == 42 then total else 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    return score(3, 1)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_scalar_bool_value_if_expr(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn bool_score(flag: Bool, yes: Int, no: Int) -> Int {")
    append_line(out, "    if flag { return yes }")
    append_line(out, "    return no")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn decide(a: Int, b: Int) -> Bool {")
    append_line(out, "    let mut high: Bool = if a > b then true else false")
    append_line(out, "    high = if a == b then false else high")
    append_line(out, "    let checked = if bool_score(if high then true else false, 1, 0) == 1 then true else false")
    append_line(out, "    return if checked and high then true else false")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    if decide(5, 2) { return 42 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_scalar_str_value_if_expr(path: Str) -> Int {

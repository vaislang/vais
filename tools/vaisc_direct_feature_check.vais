fn expect_vaisdb_module_boundary(vaisc: Str, tmp: Str) -> Int {
    let root = path_join(tmp, "vaisdb_module_boundary")
    let src = write_vaisdb_module_boundary(root)
    let ir = path_join(root, "module.ll")
    let out_path = path_join(root, "module.out")
    let err_path = path_join(root, "module.err")
    let run_out = path_join(root, "module-run.out")
    let run_err = path_join(root, "module-run.err")
    if src.len() == 0 {
        print("  FAIL direct vaisdb module boundary source write")
        return 1
    }
    if capture_emit_direct(vaisc, src, ir, out_path, err_path) != 0 {
        return emit_failed("direct vaisdb module boundary", err_path)
    }
    let text = fs_read_text(ir)
    let mut ok = 1
    if str_contains(text, "%struct.DocArtifact = type { ptr, ptr, ptr, i64, i64 }") != 1 { print("  MISSING DocArtifact struct layout"); ok = 0 }
    if str_contains(text, "%struct.VaisResultDocArtifactInt = type") != 1 { print("  MISSING Result<DocArtifact,Int> layout"); ok = 0 }
    if str_contains(text, "%struct.DirectList_DocArtifact = type") != 1 { print("  MISSING List<DocArtifact> layout"); ok = 0 }
    if str_contains(text, "define i64 @cleaned_len") != 1 { print("  MISSING cleaned_len function"); ok = 0 }
    if str_contains(text, "define i64 @count_terms") != 1 { print("  MISSING count_terms function"); ok = 0 }
    if str_contains(text, "define i64 @score_body") != 1 { print("  MISSING score_body function"); ok = 0 }
    if str_contains(text, "define void @build_doc_artifact") != 1 { print("  MISSING build_doc_artifact function"); ok = 0 }
    if str_contains(text, "define i64 @seed_artifacts") != 1 { print("  MISSING seed_artifacts function"); ok = 0 }
    if str_contains(text, "define i64 @best_artifact_score") != 1 { print("  MISSING best_artifact_score function"); ok = 0 }
    if str_contains(text, "define i64 @usable_or_missing") != 1 { print("  MISSING usable_or_missing function"); ok = 0 }
    if str_contains(text, "call i64 @score_body") != 1 { print("  MISSING score_body call"); ok = 0 }
    if str_contains(text, "call i64 @seed_artifacts") != 1 { print("  MISSING seed_artifacts call"); ok = 0 }
    if str_contains(text, "__vais_doc_term_counts_into") != 1 { print("  MISSING doc_term_counts_into helper"); ok = 0 }
    if str_contains(text, "__vais_doc_term_weighted_score") != 1 { print("  MISSING doc_term_weighted_score helper"); ok = 0 }
    if str_contains(text, "__vais_map_str_int") != 1 { print("  MISSING Map<Str,Int> helper"); ok = 0 }
    if str_contains(text, "icmp sge i64") != 1 { print("  MISSING signed greater-equal comparison"); ok = 0 }
    if str_contains(text, "icmp eq i64") != 1 { print("  MISSING integer equality comparison"); ok = 0 }
    if ok == 0 {
        return emit_failed("direct vaisdb module boundary", err_path)
    }
    let rc = capture_run_direct(vaisc, src, run_out, run_err)
    if rc == 42 {
        print("  PASS direct imported VaisDB modules share Struct/Result/List/Map helpers (=42)")
        return 0
    }
    return run_failed("direct vaisdb module boundary", rc, run_err)
}

fn expect_cli_package_directory(vaisc: Str, root: Str, tmp: Str) -> Int {
    let examples = path_join(root, "examples")
    let src = path_join(examples, "e323_cli_package")
    let out_dir = path_join(tmp, "cli_package_directory")
    if fs_mkdirs(out_dir) != 0 {
        print("  FAIL direct CLI package directory temp setup")
        return 1
    }
    let ir = path_join(out_dir, "package.ll")
    let out_path = path_join(out_dir, "package.out")
    let err_path = path_join(out_dir, "package.err")
    let run_out = path_join(out_dir, "package-run.out")
    let run_err = path_join(out_dir, "package-run.err")
    if capture_emit_direct(vaisc, src, ir, out_path, err_path) != 0 {
        return emit_failed("direct CLI package directory", err_path)
    }
    let text = fs_read_text(ir)
    let mut ok = 1
    if str_contains(text, "define i64 @package_score") != 1 { print("  MISSING package_score function"); ok = 0 }
    if str_contains(text, "call i64 @package_score") != 1 { print("  MISSING package_score call"); ok = 0 }
    if str_contains(text, "call i64 @proc_argc") != 1 { print("  MISSING proc_argc call"); ok = 0 }
    if str_contains(text, "call ptr @proc_arg") != 1 { print("  MISSING proc_arg call"); ok = 0 }
    if ok == 0 {
        return emit_failed("direct CLI package directory", err_path)
    }
    let rc = capture_run_direct(vaisc, src, run_out, run_err)
    if rc == 42 {
        print("  PASS direct CLI package directory resolves manifest entry and imports (=42)")
        return 0
    }
    return run_failed("direct CLI package directory", rc, run_err)
}

fn expect_cli_package_output(vaisc: Str, root: Str, tmp: Str) -> Int {
    let examples = path_join(root, "examples")
    let src = path_join(examples, "e323_cli_package")
    let out_dir = path_join(tmp, "cli_package_output")
    let out_path = path_join(tmp, "cli-package.out")
    let err_path = path_join(tmp, "cli-package.err")
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("package")
    argv.push(src)
    argv.push("-o")
    argv.push(out_dir)
    argv.push("--engine")
    argv.push("direct")
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc != 0 {
        print("  FAIL direct CLI package output command")
        if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
        return 1
    }
    let bin = path_join(path_join(out_dir, "bin"), "e323_cli_package")
    if fs_exists(bin) != 1 {
        print("  FAIL direct CLI package output binary missing")
        return 1
    }
    if fs_exists(path_join(out_dir, "vais.toml")) != 1 {
        print("  FAIL direct CLI package output manifest missing")
        return 1
    }
    let run_argv: List<Str> = []
    run_argv.push(bin)
    run_argv.push("vaisdb")
    run_argv.push("cache")
    let got = proc_run(run_argv)
    if got == 42 {
        print("  PASS direct CLI package output builds argv-capable installable bin (=42)")
        return 0
    }
    print(str_concat("  FAIL direct CLI package output got=", str_concat(uint_to_str(got), " want=42")))
    return 1
}

fn expect_cli_package_binary_target(vaisc: Str, root: Str, tmp: Str) -> Int {
    let examples = path_join(root, "examples")
    let src = path_join(examples, "e326_cli_binary_target")
    let out_dir = path_join(tmp, "cli_package_binary_target")
    let out_path = path_join(tmp, "cli-package-binary.out")
    let err_path = path_join(tmp, "cli-package-binary.err")
    let argv: List<Str> = []
    argv.push(vaisc)
    argv.push("package")
    argv.push(src)
    argv.push("-o")
    argv.push(out_dir)
    argv.push("--engine")
    argv.push("direct")
    argv.push("--archive")
    let rc = proc_capture_to(argv, out_path, err_path)
    if rc != 0 {
        print("  FAIL direct CLI package binary target command")
        if fs_exists(err_path) == 1 { print(fs_read_text(err_path)) }
        return 1
    }
    let bin = path_join(path_join(out_dir, "bin"), "veriqel-demo")
    if fs_exists(bin) != 1 {
        print("  FAIL direct CLI package binary target missing")
        return 1
    }
    if fs_exists(path_join(path_join(out_dir, "bin"), "e326_cli_binary_target")) == 1 {
        print("  FAIL direct CLI package binary target wrote package-name binary")
        return 1
    }
    if fs_exists(path_join(out_dir, "vais.toml")) != 1 {
        print("  FAIL direct CLI package binary target manifest missing")
        return 1
    }
    let archive = path_join(out_dir, "veriqel-demo-0.1.0.tar.gz")
    if fs_exists(archive) != 1 {
        print("  FAIL direct CLI package binary target archive missing")
        return 1
    }
    let extract = path_join(tmp, "cli_package_binary_target_extract")
    if fs_mkdirs(extract) != 0 {
        print("  FAIL direct CLI package binary target archive extract dir")
        return 1
    }
    let tar_argv: List<Str> = []
    tar_argv.push("tar")
    tar_argv.push("-C")
    tar_argv.push(extract)
    tar_argv.push("-xzf")
    tar_argv.push(archive)
    if proc_run(tar_argv) != 0 {
        print("  FAIL direct CLI package binary target archive extract")
        return 1
    }
    let archived_bin = path_join(path_join(path_join(extract, "veriqel-demo-0.1.0"), "bin"), "veriqel-demo")
    let archived_manifest = path_join(path_join(extract, "veriqel-demo-0.1.0"), "vais.toml")
    if fs_exists(archived_manifest) != 1 {
        print("  FAIL direct CLI package binary target archive manifest missing")
        return 1
    }
    let run_argv: List<Str> = []
    run_argv.push(archived_bin)
    run_argv.push("veriqel")
    run_argv.push("package")
    let got = proc_run(run_argv)
    if got == 42 {
        print("  PASS direct CLI package binary target builds argv-capable archive bin (=42)")
        return 0
    }
    print(str_concat("  FAIL direct CLI package binary target got=", str_concat(uint_to_str(got), " want=42")))
    return 1
}


    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    let empty_boxes: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10 })")

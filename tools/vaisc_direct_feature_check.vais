    append_line(out, "    let red_value = match flags.get_opt(red) { Some(v) => v, None => 0 }")
    append_line(out, "    if flags.contains(\"green\") and not flags.contains(\"blue\") and flags.get(\"green\", false) {")
    append_line(out, "        return n * 20 + red_value + flags.contains(\"green\")")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


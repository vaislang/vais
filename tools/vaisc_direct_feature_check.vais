    let line6 = str_concat(line5, " doc.score > min_score).last().title.len()) > 40 {")
    append_line(out, line6)
    append_line(out, "        rounds = rounds + 1")
    append_line(out, "        docs[2].score = docs[2].score - 5")
    append_line(out, "        if rounds > 3 {")
    append_line(out, "            return 3")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return rounds * 40 + docs[2].score - 13")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn combine_later(first_score: Int, last_doc: Doc, last_title_len: Int) -> Int {")
    append_line(out, "    return first_score + last_doc.score + last_title_len + 8")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 9 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    return score_until_stable(docs, \"tokens\", 10)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


    let src = path_join(tmp, str_concat(name, ".vais"))
    let ir = path_join(tmp, str_concat(name, ".ll"))
    let out_path = path_join(tmp, str_concat(name, ".out"))
    let err_path = path_join(tmp, str_concat(name, ".err"))
    let run_out = path_join(tmp, str_concat(name, "-run.out"))
    let run_err = path_join(tmp, str_concat(name, "-run.err"))

    let mut wrote = 1
    if str_contains(name, "map_str_str_get_opt_condition_chains") == 1 { wrote = write_map_str_str_get_opt_condition_chains(src) }

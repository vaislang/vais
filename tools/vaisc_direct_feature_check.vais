fn write_map_str_str_get_opt_str_transforms(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn score(text: Str) -> Int {")
    append_line(out, "    if text == \"vaisdb-ready\" { return 40 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn normalize(docs: Map<Str, Str>, key: Str) -> Str {")
    append_line(out, "    return match docs.get_opt(key) { Some(v) => str_lower(str_trim(v)), None => str_concat(\"missing\", \"\") }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str, Str> = {}")
    append_line(out, "    docs.insert(\"title\", \" VaisDB \")")
    append_line(out, "    docs.insert(\"suffix\", \"READY\")")
    append_line(out, "    let mut selected: Str = \"bad\"")
    append_line(out, "    selected = match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => str_concat(\"fallback\", \"\") }")
    append_line(out, "    let from_call = score(str_concat(match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => str_concat(\"missing\", \"\") }, str_concat(\"-\", match docs.get_opt(\"suffix\") { Some(v) => str_lower(v), None => str_concat(\"none\", \"\") })))")
    append_line(out, "    let normalized = normalize(docs, \"title\")")
    append_line(out, "    if selected != \"vaisdb\" { return 1 }")
    append_line(out, "    if normalized != \"vaisdb\" { return 2 }")
    append_line(out, "    return from_call + 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


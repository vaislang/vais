    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn copy_edges(src: List<Box>, dst: List<Box>) -> Int {")
    append_line(out, "    dst.push(src.first())")
    append_line(out, "    dst.insert_at(1, src.last())")
    append_line(out, "    dst.insert_at(0, dst.last())")
    append_line(out, "    let head = dst[0]")
    append_line(out, "    let mid = dst[2]")
    append_line(out, "    let tail = dst.last()")
    append_line(out, "    return head.value + mid.tag + tail.tag + src.len() + dst.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10, tag: 1 })")
    append_line(out, "    xs.push(Box { value: 20, tag: 2 })")
    append_line(out, "    xs.push(Box { value: 30, tag: 3 })")
    append_line(out, "")
    append_line(out, "    let ys: List<Box> = []")
    append_line(out, "    ys.push(Box { value: 1, tag: 4 })")
    append_line(out, "    ys.push(xs.first())")
    append_line(out, "    ys.insert_at(1, xs.last())")
    append_line(out, "    ys.insert_at(0, ys.last())")
    append_line(out, "")
    append_line(out, "    let score = copy_edges(xs, ys)")
    append_line(out, "    let head = ys[0]")
    append_line(out, "    let third = ys[2]")
    append_line(out, "    let last = ys.last()")
    append_line(out, "    return head.value + third.value + last.tag + ys.len() + score - 30")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


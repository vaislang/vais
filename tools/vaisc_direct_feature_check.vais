    append_line(out, "    let title = match docs.get_opt(\"title\") { Some(v) => v, None => \"\" }")
    append_line(out, "    let missing = match docs.get_opt(\"missing\") { Some(v) => \"bad\", None => \"fallback\" }")
    append_line(out, "    let title_len = match docs.get_opt(\"title\") { Some(v) => v.len(), None => 0 }")
    append_line(out, "    if title != \"VaisDB\" { return 1 }")
    append_line(out, "    if missing != \"fallback\" { return 2 }")

    append_line(out, "    scores.clear()")
    append_line(out, "    scores.insert(9, 40)")
    append_line(out, "    let flags: Map<Int, Bool> = {}")
    append_line(out, "    flags.insert(4, false)")
    append_line(out, "    flags.clear()")
    append_line(out, "    flags.insert(9, true)")
    append_line(out, "    let letters: Map<Int, Char> = {}")
    append_line(out, "    letters.insert(4, 'Z')")
    append_line(out, "    letters.clear()")
    append_line(out, "    letters.insert(9, 'A')")
    append_line(out, "    if not scores.contains(4) and scores.get(9, 0) == 40 and scores.len() == 1 {")
    append_line(out, "        if not flags.contains(4) and flags.get(9, false) and flags.len() == 1 {")
    append_line(out, "            if not letters.contains(4) and letters.get(9, 'Z') == 'A' and letters.len() == 1 {")
    append_line(out, "                return 42")
    append_line(out, "            }")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_int(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: Map<Str, Int> = {}")
    append_line(out, "    let red: Str = \"red\"")
    append_line(out, "    scores.insert(\"red\", 10)")
    append_line(out, "    scores.insert(\"blue\", 20)")
    append_line(out, "    scores.insert(red, 40)")
    append_line(out, "    let copy: Map<Str, Int> = {}")
    append_line(out, "    copy = scores")
    append_line(out, "    scores.remove(\"blue\")")
    append_line(out, "    scores.clear()")
    append_line(out, "    scores.insert(\"green\", 1)")
    append_line(out, "    let maybe = match copy.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    if copy.contains(\"blue\") and not scores.contains(\"red\") and scores.get(\"green\", 0) == 1 and scores.len() == 1 {")
    append_line(out, "        return maybe + copy.get(\"blue\", 0) - 18")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_bool(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let flags: Map<Str, Bool> = {}")
    append_line(out, "    let red: Str = \"red\"")
    append_line(out, "    flags.insert(\"red\", true)")
    append_line(out, "    flags.insert(\"blue\", false)")
    append_line(out, "    flags.insert(red, true)")
    append_line(out, "    let copy: Map<Str, Bool> = {}")
    append_line(out, "    copy = flags")
    append_line(out, "    flags.remove(\"blue\")")
    append_line(out, "    flags.clear()")
    append_line(out, "    flags.insert(\"green\", true)")
    append_line(out, "    let yes_value = match copy.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    let no_value = match copy.get_opt(\"blue\") { Some(v) => v, None => 1 }")
    append_line(out, "    let missing = match flags.get_opt(\"red\") { Some(v) => 0, None => 5 }")
    append_line(out, "    if copy.contains(\"blue\") and not flags.contains(\"red\") and flags.get(\"green\", false) and flags.len() == 1 {")
    append_line(out, "        return yes_value * 20 + (1 - no_value) * 10 + missing + flags.contains(\"green\") + copy.len() * 3")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_char(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let letters: Map<Str, Char> = {}")
    append_line(out, "    let red: Str = \"red\"")
    append_line(out, "    letters.insert(\"red\", 'A')")
    append_line(out, "    letters.insert(\"blue\", 'B')")
    append_line(out, "    letters.insert(red, 'A')")
    append_line(out, "    let copy: Map<Str, Char> = {}")
    append_line(out, "    copy = letters")
    append_line(out, "    letters.remove(\"blue\")")
    append_line(out, "    letters.clear()")
    append_line(out, "    letters.insert(\"green\", 'C')")
    append_line(out, "    let red_value = match copy.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    let blue_value = match copy.get_opt(\"blue\") { Some(v) => v, None => 0 }")
    append_line(out, "    let missing = match letters.get_opt(\"red\") { Some(v) => 0, None => 5 }")
    append_line(out, "    if copy.contains(\"blue\") and not letters.contains(\"red\") and letters.get(\"green\", 'Z') == 'C' and letters.len() == 1 {")
    append_line(out, "        return red_value - 65 + blue_value - 66 + missing + letters.contains(\"green\") + copy.len() * 18")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_char_param(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn stamp(letters: Map<Str, Char>, key: Str, value: Char) -> Int {")
    append_line(out, "    letters.insert(key, value)")
    append_line(out, "    letters.insert(\"blue\", 'B')")
    append_line(out, "    letters.remove(\"blue\")")
    append_line(out, "    letters.insert(\"green\", 'C')")
    append_line(out, "    return letters.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let letters: Map<Str, Char> = {}")
    append_line(out, "    let red: Str = \"red\"")
    append_line(out, "    let n = stamp(letters, red, 'A')")
    append_line(out, "    let red_value = match letters.get_opt(red) { Some(v) => v, None => 0 }")
    append_line(out, "    if letters.contains(\"green\") and not letters.contains(\"blue\") and letters.get(\"green\", 'Z') == 'C' {")
    append_line(out, "        return n * 20 + red_value - 65 + letters.contains(\"green\") + letters.len() - 1")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_char_return(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn make_letters() -> Map<Str, Char> {")
    append_line(out, "    let letters: Map<Str, Char> = {}")
    append_line(out, "    letters.insert(\"red\", 'A')")
    append_line(out, "    letters.insert(\"blue\", 'B')")
    append_line(out, "    return letters")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let letters: Map<Str, Char> = make_letters()")
    append_line(out, "    let copy: Map<Str, Char> = {}")
    append_line(out, "    copy = letters")
    append_line(out, "    letters.remove(\"blue\")")
    append_line(out, "    let red_value = match letters.get_opt(\"red\") { Some(v) => v, None => 0 }")
    append_line(out, "    let blue_value = match copy.get_opt(\"blue\") { Some(v) => v, None => 0 }")
    append_line(out, "    if copy.contains(\"blue\") and letters.contains(\"red\") and not letters.contains(\"blue\") {")
    append_line(out, "        return red_value - 65 + blue_value - 66 + copy.len() * 20 + letters.len() + copy.contains(\"blue\")")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_str_slice(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_digit(c: Int) -> Bool {")
    append_line(out, "    return c >= 48 and c <= 57")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn same(a: Str, b: Str) -> Bool {")
    append_line(out, "    return a == b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn byte_at(s: Str, i: Int) -> Int {")
    append_line(out, "    return s[i]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn count_digits(s: Str) -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut n = 0")
    append_line(out, "    while i < s.len() {")
    append_line(out, "        if is_digit(s[i]) {")
    append_line(out, "            n = n + 1")
    append_line(out, "        }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let a: Str = \"a1b2\"")
    append_line(out, "    let b = `a1b2`")
    append_line(out, "    if a != b {")
    append_line(out, "        return 0")
    append_line(out, "    }")
    append_line(out, "    return count_digits(a) * 20 + byte_at(b, 0) - 96 + same(\"ok\", `ok`)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_index_of(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn index_of(hay: Str, needle: Str) -> Int {")
    append_line(out, "    let hn = hay.len()")
    append_line(out, "    let nn = needle.len()")
    append_line(out, "    if nn == 0 { return 0 }")
    append_line(out, "    if nn > hn { return 0 - 1 }")
    append_line(out, "    let mut i = 0")
    append_line(out, "    while i <= hn - nn {")
    append_line(out, "        let mut j = 0")
    append_line(out, "        let mut ok = 1")
    append_line(out, "        while j < nn {")
    append_line(out, "            if hay[i + j] != needle[j] {")
    append_line(out, "                ok = 0")
    append_line(out, "            }")
    append_line(out, "            j = j + 1")
    append_line(out, "        }")
    append_line(out, "        if ok == 1 { return i }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return 0 - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let a = index_of(\"selfhost\", \"host\")")
    append_line(out, "    let b = index_of(\"xxxt\", \"t\")")
    append_line(out, "    let miss = index_of(\"abc\", \"z\")")
    append_line(out, "    return a * 10 + b + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_index_of_builtin(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let text = \"selfhost compiler\"")
    append_line(out, "    let a = str_index_of(text, \"host\")")
    append_line(out, "    let b = str_index_of(\"xxxt\", \"t\")")
    append_line(out, "    let empty = str_index_of(\"abc\", \"\")")
    append_line(out, "    let miss = str_index_of(\"abc\", \"z\")")
    append_line(out, "    if a != 4 { return 1 }")
    append_line(out, "    if b != 3 { return 2 }")
    append_line(out, "    if empty != 0 { return 3 }")
    append_line(out, "    if miss != 0 - 1 { return 4 }")
    append_line(out, "    if str_index_of(str_lower(\"VaisDB\"), \"db\") != 4 { return 5 }")
    append_line(out, "    return a * 10 + b + empty + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_starts_with_builtin(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let text = \"selfhost compiler\"")
    append_line(out, "    let a = str_starts_with(text, \"self\")")
    append_line(out, "    let b = str_starts_with(text, \"host\")")
    append_line(out, "    let c = str_starts_with(\"abc\", \"\")")
    append_line(out, "    let d = str_starts_with(str_lower(\"VaisDB\"), \"vais\")")
    append_line(out, "    if a != 1 { return 1 }")
    append_line(out, "    if b != 0 { return 2 }")
    append_line(out, "    if c != 1 { return 3 }")
    append_line(out, "    if d != 1 { return 4 }")
    append_line(out, "    if str_starts_with(\"abc\", \"abcd\") != 0 { return 5 }")
    append_line(out, "    return a * 20 + c * 10 + d * 12")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_ends_with_builtin(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let path = \"compiler/self/fixpoint_full.vais\"")
    append_line(out, "    let a = str_ends_with(path, \".vais\")")
    append_line(out, "    let b = str_ends_with(path, \"fixpoint\")")
    append_line(out, "    let c = str_ends_with(\"abc\", \"\")")
    append_line(out, "    let d = str_ends_with(str_lower(\"VaisDB\"), \"db\")")
    append_line(out, "    if a != 1 { return 1 }")
    append_line(out, "    if b != 0 { return 2 }")
    append_line(out, "    if c != 1 { return 3 }")
    append_line(out, "    if d != 1 { return 4 }")
    append_line(out, "    if str_ends_with(\"abc\", \"zabc\") != 0 { return 5 }")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"file\", \"notes.vais\")")
    append_line(out, "    docs.insert(\"title\", \"VaisDB\")")
    append_line(out, "    if str_ends_with(docs.get(\"file\", \"\"), \".vais\") != 1 { return 6 }")
    append_line(out, "    if str_ends_with(docs.value_at(0), \".md\") != 0 { return 7 }")
    append_line(out, "    let names: List<Str> = [\"README.md\", \"compiler.vais\"]")
    append_line(out, "    if str_ends_with(names[1], \".vais\") != 1 { return 8 }")
    append_line(out, "    if str_ends_with(names.last(), \".md\") != 0 { return 9 }")
    append_line(out, "    let from_match = match docs.get_opt(\"file\") { Some(v) => str_lower(v), None => \"\" }")
    append_line(out, "    if str_ends_with(from_match, \".vais\") != 1 { return 10 }")
    append_line(out, "    if str_ends_with(match docs.get_opt(\"title\") { Some(v) => str_lower(v), None => \"\" }, \"db\") != 1 { return 11 }")
    append_line(out, "    return a * 20 + c * 10 + d * 12")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_replace_builtin(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"title\", \"Vais DB\")")
    append_line(out, "    docs.insert(\"body\", \"AI_AI_cache\")")
    append_line(out, "    let words: List<Str> = [\"notes-v1.md\", \"alpha_beta\"]")
    append_line(out, "    let slug = str_replace(str_lower(docs.get(\"title\", \"\")), \" \", \"-\")")
    append_line(out, "    if slug != \"vais-db\" { return 1 }")
    append_line(out, "    if str_replace(\"vaisdb vector cache\", \" \", \"_\") != \"vaisdb_vector_cache\" { return 2 }")
    append_line(out, "    if str_replace(\"aaaa\", \"aa\", \"b\") != \"bb\" { return 3 }")
    append_line(out, "    if str_replace(\"abc\", \"\", \"x\") != \"abc\" { return 4 }")
    append_line(out, "    if str_replace(docs.value_at(1), \"_\", \" \") != \"AI AI cache\" { return 5 }")
    append_line(out, "    if str_replace(words[1], \"_\", \"-\") != \"alpha-beta\" { return 6 }")
    append_line(out, "    let mut from_match: Str = \"\"")
    append_line(out, "    from_match = match docs.get_opt(\"body\") { Some(v) => str_replace(str_lower(v), \"_\", \" \"), None => \"\" }")
    append_line(out, "    if from_match != \"ai ai cache\" { return 7 }")
    append_line(out, "    if str_replace(match docs.get_opt(\"title\") { Some(v) => str_lower(v), None => \"\" }, \" \", \"\") != \"vaisdb\" { return 8 }")
    append_line(out, "    return slug.len() * 6")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_palindrome(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_palindrome(s: Str) -> Int {")
    append_line(out, "    let mut left = 0")
    append_line(out, "    let mut right = s.len() - 1")
    append_line(out, "    while left < right {")
    append_line(out, "        if s[left] != s[right] { return 0 }")
    append_line(out, "        left = left + 1")
    append_line(out, "        right = right - 1")
    append_line(out, "    }")
    append_line(out, "    return 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let odd = is_palindrome(\"level\")")
    append_line(out, "    let even = is_palindrome(\"abba\")")
    append_line(out, "    let miss = is_palindrome(\"robot\")")
    append_line(out, "    return odd * 40 + even * 2 + miss")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_print_interpolation(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let name: Str = \"vais\"")
    append_line(out, "    let n = 3")
    append_line(out, "    print(\"lang={name} n={n}\")")
    append_line(out, "    print(\"rate={n}%\")")
    append_line(out, "    putchar(33)")
    append_line(out, "    putchar(10)")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_char_literal(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn choose(flag: Bool) -> Char {")
    append_line(out, "    if flag {")
    append_line(out, "        return 'A'")
    append_line(out, "    }")
    append_line(out, "    return 'B'")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn same(c: Char) -> Bool {")
    append_line(out, "    return c == 'A'")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let c: Char = choose(true)")
    append_line(out, "    if same(c) and c != 'B' {")
    append_line(out, "        return 42")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_parse_helpers(path: Str) -> Int {
    let out = str_builder_new()

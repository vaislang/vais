fn write_list_struct_filter_first_last_value(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn first_matching_doc(docs: List<Doc>, needle: Str) -> Doc {")
    append_line(out, str_concat(str_concat(str_concat("    return docs.filter(", pipe), "doc"), str_concat(pipe, " str_contains(doc.body, needle) == 1).first()")))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn last_high_doc(docs: List<Doc>, min_score: Int) -> Doc {")
    append_line(out, str_concat(str_concat(str_concat("    let hit: Doc = docs.filter(", pipe), "doc"), str_concat(pipe, " doc.score > min_score).last()")))
    append_line(out, "    return hit")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn first_high_doc_local(docs: List<Doc>, min_score: Int) -> Doc {")
    append_line(out, str_concat(str_concat(str_concat("    let hit = docs.filter(", pipe), "doc"), str_concat(pipe, " doc.score > min_score).first()")))
    append_line(out, "    return hit")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")

    append_line(out, "    let n = 0 - 7")
    append_line(out, "    let b = Str(n)")
    append_line(out, "    if a != \"42\" {")
    append_line(out, "        return 1")
    append_line(out, "    }")
    append_line(out, "    if b != \"-7\" {")
    append_line(out, "        return 2")
    append_line(out, "    }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_contains_builtin(path: Str) -> Int {

    str_builder_append(min_builder, "docs.map(")
    str_builder_push(min_builder, 124)
    str_builder_append(min_builder, "doc")
    str_builder_push(min_builder, 124)
    str_builder_append(min_builder, " doc.score).min()")
    let min_expr = str_builder_finish(min_builder)
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn weigh(value: Int) -> Int {")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn local_flow(docs: List<Doc>) -> Int {")
    append_line(out, "    let mut total = 3")
    append_line(out, str_concat("    total = total + ", sum_expr))
    append_line(out, str_concat("    let offset = 2 + ", min_expr))
    append_line(out, str_concat("    let via_call = weigh(1 + ", str_concat(max_expr, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(total + ", str_concat(min_expr, ")")))
    append_line(out, str_concat("    values.insert_at(0, 4 + ", str_concat(sum_expr, ")")))
    append_line(out, "    return total + offset + via_call + values[0] + values[1] - 60")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn return_flow(base: Int, docs: List<Doc>) -> Int {")
    append_line(out, str_concat("    return base + ", max_expr))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 8 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 10 })")
    append_line(out, "    if local_flow(docs) != 42 { return 1 }")
    append_line(out, "    return return_flow(32, docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_map_projection_aggregate_embedded_conditions(path: Str) -> Int {
    let out = str_builder_new()

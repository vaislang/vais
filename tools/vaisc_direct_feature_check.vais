}

fn write_list_int(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    let empty: List<Int> = []")
    append_line(out, "    xs.push(10)")
    append_line(out, "    xs.push(20)")
    append_line(out, "    xs.push(30)")
    append_line(out, "    let ys = [1, 2, xs.len()]")
    append_line(out, "    let tail = xs.last()")
    append_line(out, "    let popped = xs.pop()")
    append_line(out, "    return xs.sum() - xs.len() - xs[1] + ys[2] + ys.sum() + 25 + empty.is_empty() - xs.is_empty() - 1 + tail - 30 + popped - 30")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_slice(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_digit(c: Int) -> Bool {")
    append_line(out, "    return c >= 48 and c <= 57")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn same(a: Str, b: Str) -> Bool {")
    append_line(out, "    return a == b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn byte_at(s: Str, i: Int) -> Int {")
    append_line(out, "    return s[i]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn count_digits(s: Str) -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut n = 0")
    append_line(out, "    while i < s.len() {")
    append_line(out, "        if is_digit(s[i]) {")
    append_line(out, "            n = n + 1")
    append_line(out, "        }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let a: Str = \"a1b2\"")
    append_line(out, "    let b = `a1b2`")
    append_line(out, "    if a != b {")
    append_line(out, "        return 0")
    append_line(out, "    }")
    append_line(out, "    return count_digits(a) * 20 + byte_at(b, 0) - 96 + same(\"ok\", `ok`)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_char_literal(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn choose(flag: Bool) -> Char {")
    append_line(out, "    if flag {")
    append_line(out, "        return 'A'")
    append_line(out, "    }")
    append_line(out, "    return 'B'")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn same(c: Char) -> Bool {")
    append_line(out, "    return c == 'A'")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let c: Char = choose(true)")
    append_line(out, "    if same(c) and c != 'B' {")
    append_line(out, "        return 42")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_parse_helpers(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let s: Str = \"16x\"")
    append_line(out, "    let a = parse_uint(\"19\")")
    append_line(out, "    let b = parse_uint(s)")
    append_line(out, "    let c = parse_int(\"-5\")")
    append_line(out, "    let d = parse_int(`12z`)")
    append_line(out, "    return a + b + c + d")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_list_multi_field_nested_struct(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Inner {")
    append_line(out, "    a: Int,")
    append_line(out, "    b: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "struct Outer {")
    append_line(out, "    inner: Inner,")
    append_line(out, "    tag: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make(a: Int, b: Int, tag: Int) -> Outer {")
    append_line(out, "    return Outer {")
    append_line(out, "        inner: Inner {")
    append_line(out, "            a: a,")
    append_line(out, "            b: b,")
    append_line(out, "        },")
    append_line(out, "        tag: tag,")
    append_line(out, "    }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn update(xs: List<Outer>, idx: Int) -> Int {")
    append_line(out, "    xs[idx].inner.a = xs[idx].inner.a + xs[idx].tag")
    append_line(out, "    return xs[idx].inner.a")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Outer> = []")
    append_line(out, "    let one = make(10, 20, 1)")
    append_line(out, "    let two = make(3, 4, 2)")
    append_line(out, "    xs.push(one)")
    append_line(out, "    xs.push(two)")
    append_line(out, "    xs[0].inner.b = 30")
    append_line(out, "    let copied = xs[0]")
    append_line(out, "    xs[1] = copied")
    append_line(out, "    let p = update(xs, 1)")
    append_line(out, "    return xs[0].inner.b + p + xs.last().inner.a - xs[0].inner.a")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_struct_str_fields(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Doc {")
    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make_doc(title: Str, body: Str, score: Int) -> Doc {")
    append_line(out, "    return Doc { title: title, body: body, score: score }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let doc = make_doc(\"Vais\", \"cache learn\", 40)")
    append_line(out, "    if doc.title == \"Vais\" and str_contains(doc.body, \"learn\") {")
    append_line(out, "        return doc.score + doc.title.len() - 2")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_str_fields(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Doc {")
    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn add_doc(docs: List<Doc>, title: Str, body: Str, score: Int) -> Int {")
    append_line(out, "    docs.push(Doc { title: title, body: body, score: score })")
    append_line(out, "    return docs.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    add_doc(docs, \"alpha\", \"Vais cache\", 10)")
    append_line(out, "    add_doc(docs, \"beta\", \"learn tokens\", 20)")
    append_line(out, "    let mut total = 0")
    append_line(out, "    for doc in docs {")
    append_line(out, "        if str_contains(doc.body, \"tokens\") { total = total + doc.score }")
    append_line(out, "    }")
    append_line(out, "    if docs[0].title == \"alpha\" and docs.last().body.len() == 12 {")
    append_line(out, "        return total + docs.first().title.len() + docs[1].score + docs[1].title.len() - 7")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_str_field_write(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Doc {")
    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn retitle(docs: List<Doc>, index: Int, title: Str, body: Str) -> Int {")
    append_line(out, "    docs[index].title = title")
    append_line(out, "    docs[index].body = body")
    append_line(out, "    docs[index].score = docs[index].score + docs[index].title.len()")
    append_line(out, "    return docs[index].body.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"draft\", body: \"old\", score: 10 })")
    append_line(out, "    docs.push(Doc { title: \"tmp\", body: \"cache\", score: 20 })")
    append_line(out, "    docs[0].title = \"alpha\"")
    append_line(out, "    docs[0].body = \"Vais cache\"")
    append_line(out, "    let n = retitle(docs, 1, \"beta\", \"learn tokens\")")
    append_line(out, "    if docs[0].title == \"alpha\" and docs[1].body.len() == 12 {")
    append_line(out, "        return docs[0].body.len() + docs[1].score + docs[1].title.len() + n - 8")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_str_method_fields(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Doc {")
    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"Vais cache\", score: 10 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 20 })")
    append_line(out, "    let removed = docs.remove_at(0)")
    append_line(out, "    let tail = docs.pop()")
    append_line(out, "    if removed.body.len() == 10 and tail.title == \"beta\" and docs.len() == 0 {")
    append_line(out, "        return removed.title.len() + tail.body.len() + tail.score + docs.len() + 5")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_int(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    let empty: List<Int> = []")
    append_line(out, "    xs.push(10)")
    append_line(out, "    xs.push(20)")
    append_line(out, "    xs.push(30)")
    append_line(out, "    let ys = [1, 2, xs.len()]")
    append_line(out, "    let tail = xs.last()")
    append_line(out, "    let popped = xs.pop()")
    append_line(out, "    return xs.sum() - xs.len() - xs[1] + ys[2] + ys.sum() + 25 + empty.is_empty() - xs.is_empty() - 1 + tail - 30 + popped - 30")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


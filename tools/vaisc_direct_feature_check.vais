    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 16 })")
    append_line(out, "    return condition_flow(docs, 1)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_int_closure_capture(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn tail_sum(nums: List<Int>, min: Int) -> Int {")
    append_line(out, str_concat(str_concat("    return nums.filter(", str_byte(124)), str_concat("n", str_concat(str_byte(124), " n > min).sum()"))))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(nums: List<Int>, min: Int) -> Int {")
    append_line(out, str_concat(str_concat("    let selected = nums.filter(", str_byte(124)), str_concat("n", str_concat(str_byte(124), " n > min)"))))
    append_line(out, "    if selected.len() != 3 { return 1 }")
    append_line(out, "    let offset = 1")
    append_line(out, str_concat(str_concat("    let bumped = selected.map(", str_byte(124)), str_concat("n", str_concat(str_byte(124), " n + offset)"))))
    append_line(out, "    if bumped.sum() != 15 { return 2 }")
    append_line(out, "    return bumped.sum() + tail_sum(nums, min) + selected.len() * 5")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let nums: List<Int> = []")
    append_line(out, "    nums.push(1)")
    append_line(out, "    nums.push(2)")
    append_line(out, "    nums.push(3)")
    append_line(out, "    nums.push(4)")
    append_line(out, "    nums.push(5)")
    append_line(out, "    return score(nums, 2)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


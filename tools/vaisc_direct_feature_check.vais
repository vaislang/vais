fn write_list_assignment(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make(v: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: v }, Box { value: v + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn replace(out: List<Box>, v: Int) -> Int {")
    append_line(out, "    out = [Box { value: v }, Box { value: v + 1 }]")
    append_line(out, "    out = make(v + 2)")
    append_line(out, "    return out.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs = []")
    append_line(out, "    xs.push(Box { value: 5 })")
    append_line(out, "    xs = list()")
    append_line(out, "    xs.push(Box { value: 7 })")
    append_line(out, "    xs = make(20)")
    append_line(out, "    let n = replace(xs, 30)")
    append_line(out, "    let ints: List<Int> = []")
    append_line(out, "    ints = [1, 2]")
    append_line(out, "    ints = list()")
    append_line(out, "    ints.push(4)")
    append_line(out, "    ints = [5, 6]")
    append_line(out, "    return xs[0].value + xs[1].value + n + ints.sum() - 36")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


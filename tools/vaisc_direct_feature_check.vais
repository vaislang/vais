    append_line(out, "    let ys: List<Box> = []")
    append_line(out, "    ys.push(Box { value: 1, tag: 4 })")
    append_line(out, "    ys.push(xs.pop())")
    append_line(out, "    ys.insert_at(1, xs.remove_at(0))")
    append_line(out, "")
    append_line(out, "    let score = move_one(xs, ys)")
    append_line(out, "    let first = ys[0]")
    append_line(out, "    let mid = ys[2]")
    append_line(out, "    let last = ys.last()")
    append_line(out, "    return first.tag + mid.value + last.value + ys.len() + score - 33")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


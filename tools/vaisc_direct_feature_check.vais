    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn pick(docs: Map<Str, Str>, key: Str) -> Str {")
    append_line(out, "    return match docs.get_opt(key) { Some(v) => v, None => \"missing\" }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str, Str> = {}")

    append_line(out, "    if fs_exists(path) != 1 { return Err(10) }")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    if text.len() == 0 { return Err(11) }")
    append_line(out, "    return Ok(text)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn read_first_line(path: Str) -> Result<Str, Int> {")
    append_line(out, "    let text = read_text_checked(path)?")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n == 0 { return Err(12) }")
    append_line(out, "    let first = str_trim(lines[0])")
    append_line(out, "    if first.len() == 0 { return Err(13) }")
    append_line(out, "    return Ok(first)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let doc = path_join(root, \"vais-direct-e301-doc.txt\")")
    append_line(out, "    let missing = path_join(root, \"vais-direct-e301-missing/no-doc.txt\")")
    append_line(out, "    let text = str_concat(\"VaisDB Guide\", str_concat(str_byte(10), \"AI cache\"))")
    append_line(out, "    if fs_write_text(doc, text) != 0 { return 4 }")
    append_line(out, "    let title_flow = read_first_line(doc)")
    append_line(out, "    let title_len = match title_flow { Ok(title) => title.len(), Err(code) => code }")
    append_line(out, "    let normalized = match title_flow { Ok(title) => str_lower(title), Err(code) => Str(code) }")
    append_line(out, "    let missing_flow = read_first_line(missing)")
    append_line(out, "    let missing_code = match missing_flow { Ok(title) => title.len(), Err(code) => code }")
    append_line(out, "    if title_len != 12 { return 1 }")
    append_line(out, "    if normalized != \"vaisdb guide\" { return 2 }")
    append_line(out, "    if missing_code != 10 { return 3 }")
    append_line(out, "    return title_len * 2 + missing_code + 8")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_str_int_param_flow(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn read_text_checked(path: Str) -> Result<Str, Int> {")
    append_line(out, "    if fs_exists(path) != 1 { return Err(10) }")
    append_line(out, "    let text = fs_read_text(path)")
    append_line(out, "    if text.len() == 0 { return Err(11) }")
    append_line(out, "    return Ok(text)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn read_first_line(path: Str) -> Result<Str, Int> {")
    append_line(out, "    let text = read_text_checked(path)?")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n == 0 { return Err(12) }")
    append_line(out, "    let first = str_trim(lines[0])")
    append_line(out, "    if first.len() == 0 { return Err(13) }")
    append_line(out, "    return Ok(first)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn title_len(flow: Result<Str, Int>, fallback: Int) -> Int {")
    append_line(out, "    let value = match flow { Ok(title) => title.len(), Err(code) => fallback + code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn normalize_or_code(flow: Result<Str, Int>) -> Str {")
    append_line(out, "    let value = match flow { Ok(title) => str_lower(title), Err(code) => Str(code) }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn choose_longer(left: Result<Str, Int>, right: Result<Str, Int>) -> Int {")
    append_line(out, "    let left_len = title_len(left, 0)")
    append_line(out, "    let right_len = title_len(right, 0)")
    append_line(out, "    if left_len > right_len { return left_len }")
    append_line(out, "    return right_len")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let root = fs_temp_dir()")
    append_line(out, "    let doc = path_join(root, \"vais-direct-e302-doc.txt\")")
    append_line(out, "    let missing = path_join(root, \"vais-direct-e302-missing/no-doc.txt\")")
    append_line(out, "    let text = str_concat(\"VaisDB Guide\", str_concat(str_byte(10), \"AI cache\"))")
    append_line(out, "    if fs_write_text(doc, text) != 0 { return 4 }")
    append_line(out, "    let ok_flow = read_first_line(doc)")
    append_line(out, "    let missing_flow = read_first_line(missing)")
    append_line(out, "    let longest = choose_longer(ok_flow, missing_flow)")
    append_line(out, "    let normalized = normalize_or_code(ok_flow)")
    append_line(out, "    let missing_text = normalize_or_code(missing_flow)")
    append_line(out, "    if longest != 12 { return 1 }")
    append_line(out, "    if normalized != \"vaisdb guide\" { return 2 }")
    append_line(out, "    if missing_text != \"10\" { return 3 }")
    append_line(out, "    return longest * 2 + missing_text.len() + 16")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_str_str_error_message(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn lookup_title(key: Str) -> Result<Str, Str> {")
    append_line(out, "    if key == \"missing\" { return Err(\"not found\") }")
    append_line(out, "    if key == \"empty\" { return Err(\"blank title\") }")
    append_line(out, "    return Ok(\"VaisDB Guide\")")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn normalized_title(key: Str) -> Result<Str, Str> {")
    append_line(out, "    let title = lookup_title(key)?")
    append_line(out, "    if title.len() == 0 { return Err(\"blank title\") }")
    append_line(out, "    return Ok(str_lower(title))")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn describe(key: Str) -> Int {")
    append_line(out, "    let flow = normalized_title(key)")
    append_line(out, "    let title_len = match flow { Ok(title) => title.len(), Err(msg) => msg.len() }")
    append_line(out, "    return title_len")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = describe(\"guide\")")
    append_line(out, "    if good != 12 { return 1 }")
    append_line(out, "    let missing = describe(\"missing\")")
    append_line(out, "    if missing != 9 { return 2 }")
    append_line(out, "    let flow = lookup_title(\"missing\")")
    append_line(out, "    let recovered = match flow { Ok(title) => title, Err(msg) => msg }")
    append_line(out, "    if recovered != \"not found\" { return 3 }")
    append_line(out, "    return good + missing + 21")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_metric_int_struct_payload(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Metric { docs: Int, terms: Int }")
    append_line(out, "")
    append_line(out, "fn parse_metric(docs: Int, terms: Int) -> Result<Metric, Int> {")
    append_line(out, "    if docs < 1 { return Err(10) }")
    append_line(out, "    let metric = Metric { docs: docs, terms: terms }")
    append_line(out, "    return Ok(metric)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn metric_score(flow: Result<Metric, Int>, fallback: Int) -> Int {")
    append_line(out, "    let value = match flow { Ok(metric) => metric.docs + metric.terms, Err(code) => fallback + code }")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn choose_metric(left: Result<Metric, Int>, right: Result<Metric, Int>) -> Int {")
    append_line(out, "    let left_score = metric_score(left, 0)")
    append_line(out, "    let right_score = metric_score(right, 0)")
    append_line(out, "    if left_score > right_score { return left_score }")
    append_line(out, "    return right_score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let ok = parse_metric(14, 18)")
    append_line(out, "    let missing = parse_metric(0, 5)")
    append_line(out, "    let ok_score = metric_score(ok, 0)")
    append_line(out, "    let missing_score = metric_score(missing, 0)")
    append_line(out, "    let chosen = choose_metric(ok, missing)")
    append_line(out, "    if ok_score != 32 { return 1 }")
    append_line(out, "    if missing_score != 10 { return 2 }")
    append_line(out, "    if chosen != 32 { return 3 }")
    append_line(out, "    return ok_score + missing_score")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


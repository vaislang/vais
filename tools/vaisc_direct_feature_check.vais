fn write_list_str_contains(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn score_word(words: List<Str>, value: Str) -> Int {")
    append_line(out, "    if words.contains(value) { return 40 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"vaisdb\")")
    append_line(out, "    words.push(\"cache\")")
    append_line(out, "    words.push(\"vector\")")
    append_line(out, "    let found: Bool = words.contains(\"cache\")")
    append_line(out, "    if not found { return 1 }")
    append_line(out, "    if words.contains(\"missing\") { return 2 }")
    append_line(out, "    if score_word(words, \"vector\") != 40 { return 3 }")
    append_line(out, "    words.clear()")
    append_line(out, "    if words.contains(\"cache\") { return 4 }")
    append_line(out, "    words.push(str_lower(\"AI\"))")
    append_line(out, "    return score_word(words, \"ai\") + words.contains(\"ai\") + words.contains(\"cache\") + 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


    append_line(out, str_concat(str_concat("    let found_beta = has_title(docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.title), \"beta\")"))))
    append_line(out, "    let titles: List<Str> = []")
    append_line(out, str_concat(str_concat("    titles.extend(docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.title))"))))
    append_line(out, "    let scores: List<Int> = []")
    append_line(out, "    scores.push(99)")
    append_line(out, str_concat(str_concat("    scores = docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score)"))))
    append_line(out, "    if returned_scores.len() != 3 { return 1 }")
    append_line(out, "    if returned_titles.contains(\"gamma\") != 1 { return 2 }")
    append_line(out, "    if direct_total != 43 { return 3 }")
    append_line(out, "    if found_beta != 1 { return 4 }")
    append_line(out, "    if titles.len() != 3 { return 5 }")
    append_line(out, "    if scores.sum() != 43 { return 6 }")
    append_line(out, "    return direct_total + scores.sum() + titles.len() + returned_scores.len() + returned_titles.len() + found_beta - 54")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_map_projection_call_arg_conditions(path: Str) -> Int {

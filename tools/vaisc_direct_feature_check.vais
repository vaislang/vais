    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: Map<Int, Int> = {}")
    append_line(out, "    let flags: Map<Int, Bool> = {}")
    append_line(out, "    let letters: Map<Int, Char> = {}")
    append_line(out, "    scores.insert(4, 40)")
    append_line(out, "    scores.insert(9, 2)")
    append_line(out, "    scores.remove(9)")
    append_line(out, "    flags.insert(4, true)")
    append_line(out, "    flags.insert(9, false)")
    append_line(out, "    flags.remove(9)")
    append_line(out, "    letters.insert(4, 'A')")
    append_line(out, "    letters.insert(9, 'B')")
    append_line(out, "    letters.remove(9)")
    append_line(out, "    if scores.get(4, 0) == 40 and not scores.contains(9) and scores.len() == 1 {")
    append_line(out, "        if flags.get(4, false) and not flags.contains(9) and flags.len() == 1 {")
    append_line(out, "            if letters.get(4, 'Z') == 'A' and not letters.contains(9) and letters.len() == 1 {")
    append_line(out, "                return 42")
    append_line(out, "            }")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return 0")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


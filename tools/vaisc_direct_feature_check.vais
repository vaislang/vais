fn write_map_get_opt(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: Map<Int, Int> = {}")
    append_line(out, "    scores.insert(4, 40)")
    append_line(out, "    scores.insert(9, 2)")
    append_line(out, "    let found = match scores.get_opt(4) { Some(v) => v, None => 0 }")
    append_line(out, "    let missing = match scores.get_opt(5) { Some(v) => v, None => 2 }")
    append_line(out, "    let flags: Map<Int, Bool> = {}")
    append_line(out, "    flags.insert(4, true)")
    append_line(out, "    flags.insert(5, false)")
    append_line(out, "    let yes_value = match flags.get_opt(4) { Some(v) => v, None => 0 }")
    append_line(out, "    let no_value = match flags.get_opt(5) { Some(v) => v, None => 1 }")
    append_line(out, "    let absent = match flags.get_opt(9) { Some(v) => 0, None => 5 }")
    append_line(out, "    let letters: Map<Int, Char> = {}")
    append_line(out, "    letters.insert(4, 'A')")
    append_line(out, "    let letter_value = match letters.get_opt(4) { Some(v) => v, None => 58 }")
    append_line(out, "    return found + missing - 42 + yes_value * 20 + (1 - no_value) * 10 + absent + letter_value - 58")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


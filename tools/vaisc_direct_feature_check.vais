    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let b = Box { value: 39, bonus: inc(1) }")
    append_line(out, "    b.value = b.value + b.bonus + 1")
    append_line(out, "    return b.value")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_struct_abi(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Pair {")
    append_line(out, "    a: Int,")
    append_line(out, "    b: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make(x: Int) -> Pair {")
    append_line(out, "    return Pair { a: x, b: x + 1 }")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn id(p: Pair) -> Pair {")
    append_line(out, "    return p")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn sum(p: Pair) -> Int {")
    append_line(out, "    return p.a + p.b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let p = id(make(20))")
    append_line(out, "    return sum(p) + sum(Pair { a: 0, b: 1 })")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


fn write_list_struct_map_projection_aggregates(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    append_line(out, "struct Doc {")
    append_line(out, "    title: Str,")
    append_line(out, "    body: Str,")
    append_line(out, "    score: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn total_score(docs: List<Doc>) -> Int {")
    append_line(out, str_concat(str_concat("    return docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).sum()"))))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn best_score(docs: List<Doc>) -> Int {")
    append_line(out, str_concat(str_concat("    return docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).max()"))))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn lowest_score(docs: List<Doc>) -> Int {")
    append_line(out, str_concat(str_concat("    return docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).min()"))))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_flow(docs: List<Doc>) -> Int {")
    append_line(out, str_concat(str_concat("    let total = docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).sum()"))))
    append_line(out, str_concat(str_concat("    let best: Int = docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).max()"))))
    append_line(out, str_concat(str_concat("    let lowest = docs.map(", pipe), str_concat("doc", str_concat(pipe, " doc.score).min()"))))
    append_line(out, "    if total != 43 { return 1 }")
    append_line(out, "    if best != 20 { return 2 }")
    append_line(out, "    if lowest != 5 { return 3 }")
    append_line(out, "    return total + best - lowest - 16")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")

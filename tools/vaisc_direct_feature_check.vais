    append_line(out, "    value: Int,")
    append_line(out, "    tag: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn move_one(src: List<Box>, dst: List<Box>) -> Int {")
    append_line(out, "    dst.push(src.remove_at(0))")
    append_line(out, "    dst.insert_at(0, src.pop())")
    append_line(out, "    let head = dst[0]")
    append_line(out, "    let tail = dst.last()")
    append_line(out, "    return head.value + tail.tag + src.len() + dst.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    xs.push(Box { value: 10, tag: 1 })")
    append_line(out, "    xs.push(Box { value: 20, tag: 2 })")
    append_line(out, "    xs.push(Box { value: 30, tag: 3 })")
    append_line(out, "    xs.push(Box { value: 40, tag: 4 })")

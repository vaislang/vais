    append_line(out, "fn score_flow(docs: List<Doc>) -> Int {")
    let line1 = str_concat(str_concat(str_concat(str_concat(str_concat(str_concat("    return combine_scores(docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"tokens\") == 1).map("), pipe), str_concat(str_concat("doc", pipe), " doc.score).sum(), docs.filter("))
    let line2 = str_concat(str_concat(str_concat(line1, pipe), "doc"), pipe)
    let line3 = str_concat(str_concat(str_concat(line2, " doc.score > 6).map("), pipe), str_concat(str_concat("doc", pipe), " doc.score + 1).max(), docs.filter("))
    let line4 = str_concat(str_concat(str_concat(line3, pipe), "doc"), pipe)
    let line5 = str_concat(str_concat(str_concat(line4, " doc.score > 6).map("), pipe), str_concat(str_concat("doc", pipe), " doc.score - 1).min())"))
    append_line(out, line5)
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")

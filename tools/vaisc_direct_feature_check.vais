fn write_list_clear(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Pair { a: Int, b: Int }")
    append_line(out, "")
    append_line(out, "fn reset_ints(xs: List<Int>) -> Int {")
    append_line(out, "    xs.clear()")
    append_line(out, "    xs.push(40)")
    append_line(out, "    xs.push(2)")
    append_line(out, "    return xs.len() + xs[0]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn reset_pairs(xs: List<Pair>) -> Int {")
    append_line(out, "    xs.clear()")
    append_line(out, "    xs.push(Pair { a: 20, b: 22 })")
    append_line(out, "    let p = xs[0]")
    append_line(out, "    return xs.len() + p.a + p.b - 1")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    xs.push(1)")
    append_line(out, "    xs.push(2)")
    append_line(out, "    xs.clear()")
    append_line(out, "    if xs.len() != 0 { return 1 }")
    append_line(out, "    xs.push(42)")
    append_line(out, "    if xs.last() != 42 { return 2 }")
    append_line(out, "    let ys: List<Int> = []")
    append_line(out, "    ys.push(9)")
    append_line(out, "    if reset_ints(ys) != 42 { return 3 }")
    append_line(out, "    if ys.len() != 2 { return 4 }")
    append_line(out, "    let pairs: List<Pair> = []")
    append_line(out, "    pairs.push(Pair { a: 1, b: 2 })")
    append_line(out, "    pairs.clear()")
    append_line(out, "    if pairs.len() != 0 { return 5 }")
    append_line(out, "    pairs.push(Pair { a: 40, b: 2 })")
    append_line(out, "    let pair_check = pairs[0]")
    append_line(out, "    if pair_check.a + pair_check.b != 42 { return 6 }")
    append_line(out, "    if reset_pairs(pairs) != 42 { return 7 }")
    append_line(out, "    if pairs.len() != 1 { return 8 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_contains(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn score_has(xs: List<Int>, value: Int) -> Int {")
    append_line(out, "    if xs.contains(value) { return 40 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Int> = []")
    append_line(out, "    xs.push(3)")
    append_line(out, "    xs.push(42)")
    append_line(out, "    xs.push(7)")
    append_line(out, "    let found: Bool = xs.contains(42)")
    append_line(out, "    if not found { return 1 }")
    append_line(out, "    if xs.contains(9) { return 2 }")
    append_line(out, "    if score_has(xs, 42) != 40 { return 3 }")
    append_line(out, "    xs.clear()")
    append_line(out, "    if xs.contains(42) { return 4 }")
    append_line(out, "    xs.push(2)")
    append_line(out, "    return score_has(xs, 2) + xs.contains(2) + xs.contains(9) + 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_int_index_count(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn first_pos(xs: List<Int>, value: Int) -> Int {")
    append_line(out, "    return xs.index_of(value)")
    append_line(out, "}")

}

fn write_list_struct_abi(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "struct Box {")
    append_line(out, "    value: Int,")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn make(v: Int) -> List<Box> {")
    append_line(out, "    return [Box { value: v }, Box { value: v + 1 }]")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn empty_box() -> List<Box> {")
    append_line(out, "    return []")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn append(out: List<Box>, v: Int) -> Int {")
    append_line(out, "    out.push(Box { value: v })")
    append_line(out, "    return out.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score(xs: List<Box>) -> Int {")
    append_line(out, "    return xs[0].value + xs.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let xs: List<Box> = []")
    append_line(out, "    let n = append(xs, 20)")
    append_line(out, "    let ys: List<Box> = make(21)")
    append_line(out, "    let zs: List<Box> = empty_box()")
    append_line(out, "    zs.push(Box { value: 1 })")
    append_line(out, "    let inline_score = score([Box { value: 17 }])")
    append_line(out, "    let returned_score = score(make(2))")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut total = 0")
    append_line(out, "    while score(make(i)) < 5 {")
    append_line(out, "        total = total + score(make(i))")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return xs[0].value + ys[1].value + n + zs[0].value + inline_score + returned_score + total - 33")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


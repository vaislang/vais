    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n == 0 { return Err(11) }")
    append_line(out, "    let title = str_trim(lines[0])")
    append_line(out, "    if title.len() == 0 { return Err(12) }")
    append_line(out, "    return Ok(title.len())")
    append_line(out, "}")

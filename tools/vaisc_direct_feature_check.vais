fn text_at(src: Str, i: Int, word: Str) -> Int {
    if i < 0 { return 0 }
    if i + word.len() > src.len() { return 0 }
    let mut k = 0
    while k < word.len() {
        if src[i + k] != word[k] { return 0 }
        k = k + 1
    }
    return 1
}

fn str_contains(src: Str, word: Str) -> Int {
    if word.len() == 0 { return 1 }
    let mut i = 0
    while i + word.len() <= src.len() {
        if text_at(src, i, word) == 1 { return 1 }
        i = i + 1
    }
    return 0
}

fn append_uint(out: Int, n: Int) -> Int {
    if n >= 10 { append_uint(out, n / 10) }
    str_builder_push(out, 48 + (n % 10))
    return 0
}

fn uint_to_str(n: Int) -> Str {
    if n == 0 { return "0" }
    let out = str_builder_new()
    append_uint(out, n)
    return str_builder_finish(out)
}

fn append_line(out: Int, line: Str) -> Int {
    str_builder_append(out, line)
    str_builder_push(out, 10)
    return 0
}

fn write_helper_control(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn add(a: Int, b: Int) -> Int {")
    append_line(out, "    return a + b")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut i = 0")
    append_line(out, "    let mut acc = 0")
    append_line(out, "    while i < 6 {")
    append_line(out, "        if i > 2 {")
    append_line(out, "            acc = add(acc, i)")
    append_line(out, "        }")
    append_line(out, "        i = i + 1")
    append_line(out, "    }")
    append_line(out, "    return acc + 30")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_for_loop(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let mut s = 0")
    append_line(out, "    for i in 0..6 {")
    append_line(out, "        if i > 2 {")
    append_line(out, "            s = s + i")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    for j in 0..=3 {")
    append_line(out, "        s = s + j")
    append_line(out, "    }")
    append_line(out, "    for k in 0..10 {")
    append_line(out, "        if k == 3 { continue }")
    append_line(out, "        if k == 6 { break }")
    append_line(out, "        s = s + k")
    append_line(out, "    }")
    append_line(out, "    let xs = [1, 2, 3, 4, 5, 6]")
    append_line(out, "    for x in xs {")
    append_line(out, "        if x % 2 == 0 {")
    append_line(out, "            s = s + x")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return s")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


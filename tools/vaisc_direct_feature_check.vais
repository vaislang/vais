    append_line(out, "    let from_call = score(match docs.get_opt(\"title\") { Some(v) => v, None => \"\" })")
    append_line(out, "    let from_return = pick(docs, \"title\")")
    append_line(out, "    if selected != \"fallback\" { return 1 }")
    append_line(out, "    if from_return != \"VaisDB\" { return 2 }")

    let sum_expr = str_builder_finish(sum_builder)
    let max_builder = str_builder_new()
    str_builder_append(max_builder, "docs.map(")
    str_builder_push(max_builder, 124)
    str_builder_append(max_builder, "doc")
    str_builder_push(max_builder, 124)
    str_builder_append(max_builder, " doc.score).max()")
    let max_expr = str_builder_finish(max_builder)
    let min_builder = str_builder_new()
    str_builder_append(min_builder, "docs.map(")
    str_builder_push(min_builder, 124)
    str_builder_append(min_builder, "doc")
    str_builder_push(min_builder, 124)
    str_builder_append(min_builder, " doc.score).min()")
    let min_expr = str_builder_finish(min_builder)
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn condition_flow(docs: List<Doc>, base: Int) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    if base + ", str_concat(sum_expr, " > 27 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut rounds = 0")
    append_line(out, str_concat("    while rounds + ", str_concat(max_expr, " > 12 {")))
    append_line(out, "        score = score + 7")
    append_line(out, "        docs[2].score = docs[2].score - 3")
    append_line(out, "        rounds = rounds + 1")
    append_line(out, "        if rounds > 2 {")
    append_line(out, "            return 1")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    if base < 0 {")
    append_line(out, "        return 2")
    append_line(out, str_concat("    } else if base + ", str_concat(min_expr, " > 5 {")))
    append_line(out, "        score = score + 18")
    append_line(out, "    } else {")
    append_line(out, "        return 3")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")

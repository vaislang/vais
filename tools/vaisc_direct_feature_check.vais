fn write_doc_tokenize(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn is_space(c: Int) -> Int {")
    append_line(out, "    if c == 32 { return 1 }")
    append_line(out, "    if c == 9 { return 1 }")
    append_line(out, "    if c == 10 { return 1 }")
    append_line(out, "    if c == 13 { return 1 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn split_words(text: Str) -> List<Str> {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    let mut i = 0")
    append_line(out, "    while i < text.len() {")
    append_line(out, "        while i < text.len() and is_space(text[i]) == 1 {")
    append_line(out, "            i = i + 1")
    append_line(out, "        }")
    append_line(out, "        let start = i")
    append_line(out, "        while i < text.len() and is_space(text[i]) == 0 {")
    append_line(out, "            i = i + 1")
    append_line(out, "        }")
    append_line(out, "        if i > start {")
    append_line(out, "            let token = str_lower(str_trim(str_slice(text, start, i - start)))")
    append_line(out, "            words.push(token)")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return words")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words = split_words(\"  VaisDB   Vector CACHE  \")")
    append_line(out, "    if words.len() != 3 { return 1 }")
    append_line(out, "    if words[0] != \"vaisdb\" { return 2 }")
    append_line(out, "    if words[1] != \"vector\" { return 3 }")
    append_line(out, "    if words.last() != \"cache\" { return 4 }")
    append_line(out, "    if str_contains(words[1], \"ctor\") != 1 { return 5 }")
    append_line(out, "    return words.len() * 10 + words[0].len() * 2")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_split_ws_into(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn score_tokens(words: List<Str>) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, "    for word in words {")
    append_line(out, "        let token = str_lower(word)")
    append_line(out, "        if str_contains(token, \"ai\") == 1 {")
    append_line(out, "            score = score + token.len()")
    append_line(out, "        } else if str_contains(token, \"cache\") == 1 {")
    append_line(out, "            score = score + 10")
    append_line(out, "        }")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    let n = str_split_ws_into(\"  VaisDB   AI cache Vector  \", words)")
    append_line(out, "    if n != 4 { return 1 }")
    append_line(out, "    if words.len() != 4 { return 2 }")
    append_line(out, "    if str_lower(words[0]) != \"vaisdb\" { return 3 }")
    append_line(out, "    if str_lower(words.last()) != \"vector\" { return 4 }")
    append_line(out, "    return score_tokens(words) + n * 6")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_split_into(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let fields: List<Str> = []")
    append_line(out, "    let n = str_split_into(\"title=VaisDB=cache\", \"=\", fields)")
    append_line(out, "    if n != 3 { return 1 }")
    append_line(out, "    if fields.len() != 3 { return 2 }")
    append_line(out, "    if fields[0] != \"title\" { return 3 }")
    append_line(out, "    if fields[1] != \"VaisDB\" { return 4 }")
    append_line(out, "    if str_lower(fields[2]) != \"cache\" { return 5 }")
    append_line(out, "    let csv: List<Str> = []")
    append_line(out, "    let n2 = str_split_into(\",alpha,,beta,\", \",\", csv)")
    append_line(out, "    if n2 != 5 { return 6 }")
    append_line(out, "    if csv[0] != \"\" { return 7 }")
    append_line(out, "    if csv[2] != \"\" { return 8 }")
    append_line(out, "    if csv[4] != \"\" { return 9 }")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"path\", \"docs/veriqel/vais\")")
    append_line(out, "    let path_parts: List<Str> = []")
    append_line(out, "    if str_split_into(docs.get(\"path\", \"\"), \"/\", path_parts) != 3 { return 10 }")
    append_line(out, "    if path_parts[1] != \"veriqel\" { return 11 }")
    append_line(out, "    let one: List<Str> = []")
    append_line(out, "    if str_split_into(\"abc\", \"\", one) != 1 { return 12 }")
    append_line(out, "    if one[0] != \"abc\" { return 13 }")
    append_line(out, "    return n * n2 + path_parts[1].len() * 4 - 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_split_lines_into(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let lf = str_byte(10)")
    append_line(out, "    let cr = str_byte(13)")
    append_line(out, "    let crlf = str_concat(cr, lf)")
    append_line(out, "    let text = str_concat(str_concat(\"title=VaisDB\", lf), str_concat(\"body=AI cache\", str_concat(lf, \"score=42\")))")
    append_line(out, "    let win_text = str_concat(str_concat(\"alpha\", crlf), str_concat(crlf, str_concat(\"beta\", crlf)))")
    append_line(out, "    let lines: List<Str> = []")
    append_line(out, "    let n = str_split_lines_into(text, lines)")
    append_line(out, "    if n != 3 { return 1 }")
    append_line(out, "    if lines.len() != 3 { return 2 }")
    append_line(out, "    if lines[0] != \"title=VaisDB\" { return 3 }")
    append_line(out, "    if lines[1] != \"body=AI cache\" { return 4 }")
    append_line(out, "    if lines[2] != \"score=42\" { return 5 }")
    append_line(out, "    let win: List<Str> = []")
    append_line(out, "    if str_split_lines_into(win_text, win) != 3 { return 6 }")
    append_line(out, "    if win[0] != \"alpha\" { return 7 }")
    append_line(out, "    if win[1] != \"\" { return 8 }")
    append_line(out, "    if win[2] != \"beta\" { return 9 }")
    append_line(out, "    let empty: List<Str> = []")
    append_line(out, "    if str_split_lines_into(\"\", empty) != 0 { return 10 }")
    append_line(out, "    if empty.len() != 0 { return 11 }")
    append_line(out, "    let joined = str_join(lines, \"|\")")
    append_line(out, "    if joined != \"title=VaisDB|body=AI cache|score=42\" { return 12 }")
    append_line(out, "    return n * 10 + win.len() * 4")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_str_join(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let parts: List<Str> = []")
    append_line(out, "    parts.push(\"vais\")")
    append_line(out, "    parts.push(\"db\")")
    append_line(out, "    parts.push(\"cache\")")
    append_line(out, "    let slug = str_join(parts, \"-\")")
    append_line(out, "    if slug != \"vais-db-cache\" { return 1 }")
    append_line(out, "    let fields: List<Str> = []")
    append_line(out, "    let n = str_split_into(\"title=VaisDB=cache\", \"=\", fields)")
    append_line(out, "    if n != 3 { return 2 }")
    append_line(out, "    if str_join(fields, \"=\") != \"title=VaisDB=cache\" { return 3 }")
    append_line(out, "    let csv: List<Str> = []")
    append_line(out, "    if str_split_into(\",alpha,,beta,\", \",\", csv) != 5 { return 4 }")
    append_line(out, "    if str_join(csv, \",\") != \",alpha,,beta,\" { return 5 }")
    append_line(out, "    let empty: List<Str> = []")
    append_line(out, "    if str_join(empty, \"/\") != \"\" { return 6 }")
    append_line(out, "    let compact = str_join(parts, \"\")")
    append_line(out, "    let empty_joined = str_join(empty, \"/\")")
    append_line(out, "    return slug.len() * 2 + compact.len() + csv.len() + empty_joined.len()")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_map_str_str_snapshot_builtin(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: Map<Str,Str> = {}")
    append_line(out, "    docs.insert(\"title\", \"VaisDB\")")
    append_line(out, "    docs.insert(\"body\", \"AI cache\")")
    append_line(out, "    docs.insert(\"model\", \"local\")")
    append_line(out, "    docs.insert(\"empty\", \"\")")
    append_line(out, "    docs.insert(\"expr\", \"a=b=c\")")
    append_line(out, "    let snapshot = map_str_str_snapshot(docs)")
    append_line(out, "    let loaded: Map<Str,Str> = {}")
    append_line(out, "    loaded.insert(\"stale\", \"drop\")")
    append_line(out, "    let lf = str_byte(10)")
    append_line(out, "    let cr = str_byte(13)")
    append_line(out, "    let crlf = str_concat(cr, lf)")
    append_line(out, "    let extra = str_concat(str_concat(\"ignored\", lf), str_concat(\"win=ok\", crlf))")
    append_line(out, "    let count = map_str_str_load_snapshot(str_concat(snapshot, extra), loaded)")
    append_line(out, "    if count != 6 { return 2 }")
    append_line(out, "    if loaded.len() != 6 { return 3 }")
    append_line(out, "    if loaded.get(\"stale\", \"gone\") != \"gone\" { return 4 }")
    append_line(out, "    if loaded.get(\"title\", \"\") != \"VaisDB\" { return 5 }")
    append_line(out, "    if loaded.get(\"body\", \"\") != \"AI cache\" { return 6 }")
    append_line(out, "    if loaded.get(\"model\", \"\") != \"local\" { return 7 }")
    append_line(out, "    if loaded.get(\"empty\", \"fallback\") != \"\" { return 8 }")
    append_line(out, "    if loaded.get(\"expr\", \"\") != \"a=b=c\" { return 9 }")
    append_line(out, "    if loaded.get(\"win\", \"\") != \"ok\" { return 10 }")
    append_line(out, "    let roundtrip = map_str_str_snapshot(loaded)")
    append_line(out, "    let again: Map<Str,Str> = {}")
    append_line(out, "    if map_str_str_load_snapshot(roundtrip, again) != 6 { return 11 }")
    append_line(out, "    if again.get(\"expr\", \"\") != \"a=b=c\" { return 12 }")
    append_line(out, "    if again.get(\"win\", \"\") != \"ok\" { return 13 }")
    append_line(out, "    return count * 7")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_try_parse_error_flow(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn parse_required_count(raw: Str, label: Str) -> Result<Int, Int> {")
    append_line(out, "    if raw.len() == 0 { return Err(10) }")
    append_line(out, "    if label.len() == 0 { return Err(11) }")
    append_line(out, "    let value = parse_int(raw)")
    append_line(out, "    if value <= 0 { return Err(12) }")
    append_line(out, "    return Ok(value)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_doc(raw_terms: Str, raw_boost: Str) -> Result<Int, Int> {")
    append_line(out, "    let terms = parse_required_count(raw_terms, \"terms\")?")
    append_line(out, "    let boost = parse_required_count(raw_boost, \"boost\")?")
    append_line(out, "    return Ok(terms * boost)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let good = match score_doc(\"6\", \"7\") { Ok(good_value) => good_value, Err(good_error) => good_error }")
    append_line(out, "    let empty = match score_doc(\"\", \"7\") { Ok(empty_value) => empty_value, Err(empty_error) => empty_error }")
    append_line(out, "    let bad_parse = match score_doc(\"6\", \"no\") { Ok(parse_value) => parse_value, Err(parse_error) => parse_error }")
    append_line(out, "    return good - empty - bad_parse + 22")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_result_map_param_flow(path: Str) -> Int {
    let out = str_builder_new()
    append_line(out, "fn require_meta_len(meta: Map<Str,Str>, key: Str) -> Result<Int, Int> {")
    append_line(out, "    let length = match meta.get_opt(key) { Some(value) => str_trim(value).len(), None => 0 }")
    append_line(out, "    if length == 0 { return Err(20) }")
    append_line(out, "    return Ok(length)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_meta(meta: Map<Str,Str>) -> Result<Int, Int> {")
    append_line(out, "    let title_len = require_meta_len(meta, \"title\")?")
    append_line(out, "    let body_len = require_meta_len(meta, \"body\")?")
    append_line(out, "    return Ok(title_len + body_len)")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let meta: Map<Str,Str> = {}")
    append_line(out, "    meta.insert(\"title\", \"VaisDB\")")
    append_line(out, "    meta.insert(\"body\", \"ai cache\")")
    append_line(out, "    let good = match score_meta(meta) { Ok(value) => value, Err(code) => code }")
    append_line(out, "    let missing = match require_meta_len(meta, \"missing\") { Ok(value) => value, Err(code) => code }")
    append_line(out, "    return good + missing + 8")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_file_exists_result_flow(path: Str) -> Int {

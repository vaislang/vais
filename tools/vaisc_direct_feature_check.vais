    let mixed_bool = str_concat(str_concat(map_chain, ".contains(\"vais\")"), str_concat(" and ", str_concat(filter_chain, ".contains(\"ai\")")))
    let mixed_guard = str_concat(str_concat(map_chain, ".count(\"ai\")"), str_concat(" + ", str_concat(filter_chain, ".index_of(\"ai\")")))
    let mixed_insert = str_concat(str_concat(filter_chain, ".index_of(\"vais\")"), str_concat(" + ", str_concat(map_chain, ".index_of(\"ai\")")))

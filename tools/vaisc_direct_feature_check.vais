        return 1
    }
    let archived_bin = path_join(path_join(path_join(extract, "veriqel-assets-0.1.0"), "bin"), "veriqel-assets")
    let archived_asset = path_join(path_join(path_join(path_join(extract, "veriqel-assets-0.1.0"), "assets"), "docs"), "guide.txt")
    let run_argv: List<Str> = []
    run_argv.push(archived_bin)
    run_argv.push("assets")
    run_argv.push("package")
    let got = proc_run(run_argv)
    if got == 42 and fs_exists(archived_asset) == 1 and str_contains(fs_read_text(archived_asset), "veriqel packaged assets") == 1 {
        print("  PASS direct CLI package assets archive includes files and runs (=42)")
        return 0
    }
    print(str_concat("  FAIL direct CLI package assets got=", str_concat(uint_to_str(got), " want=42")))
    return 1
}

fn usage() -> Int {
    print("usage: vaisc-direct-feature-check <repo-root> <tmp-dir>")
    return 2
}

fn main() -> Int {
    if proc_argc() != 2 { return usage() }
    let root = proc_arg(0)
    let tmp = proc_arg(1)
    if fs_mkdirs(tmp) != 0 {
        print(str_concat("  FAIL direct feature check cannot create ", tmp))
        return 1
    }
    let vaisc = path_join(root, "scripts/vaisc")
    let mut fail = 0
    fail = fail + expect_case(vaisc, tmp, "helper_control", "direct helper calls, locals, if, and while run (=42)", 1)

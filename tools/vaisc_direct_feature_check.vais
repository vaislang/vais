    append_line(out, "    let normalized = match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => \"\" }")
    append_line(out, "    if str_contains(match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => \"\" }, \"vector\") != 1 { return 1 }")
    append_line(out, "    if str_starts_with(match docs.get_opt(\"title\") { Some(v) => str_lower(str_trim(v)), None => \"\" }, \"vais\") != 1 { return 2 }")
    append_line(out, "    if normalized.len() != 19 { return 3 }")
    append_line(out, "    return 42")
    append_line(out, "}")

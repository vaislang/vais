    let chain = str_concat(map_filter_prefix, str_concat(str_concat(pipe, "word"), str_concat(pipe, " str_contains(word, needle) == 1)")))
    append_line(out, "fn weigh(n: Int) -> Int {")
    append_line(out, "    return n")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn bool_score(flag: Bool) -> Int {")
    append_line(out, "    if flag { return 3 }")
    append_line(out, "    return 0")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn normalized_count(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    return ", str_concat(chain, ".len()")))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_words(words: List<Str>, needle: Str) -> Int {")
    append_line(out, str_concat("    let hits: Int = ", str_concat(chain, ".len()")))
    append_line(out, "    if hits != 3 { return 1 }")
    append_line(out, str_concat("    let found: Bool = ", str_concat(chain, ".contains(\"vais\")")))
    append_line(out, "    if not found { return 2 }")
    append_line(out, str_concat("    let first_ai = ", str_concat(chain, ".index_of(\"ai\")")))
    append_line(out, str_concat("    let ai_count = ", str_concat(chain, ".count(\"ai\")")))
    append_line(out, "    let mut total = 0")
    append_line(out, str_concat("    total = ", str_concat(chain, ".len() + 1")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(", str_concat(chain, ".count(\"ai\"))")))
    append_line(out, str_concat("    values.insert_at(0, ", str_concat(chain, ".index_of(\"vais\"))")))
    append_line(out, str_concat("    if weigh(", str_concat(chain, ".len() + 2) == 5 {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    }")
    append_line(out, str_concat("    if bool_score(", str_concat(chain, ".contains(\"ai\")) == 3 {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    }")
    append_line(out, "    let mut guard = 0")
    append_line(out, str_concat("    while ", str_concat(chain, ".count(\"ai\") > guard {")))
    append_line(out, "        guard = guard + 2")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(chain, ".contains(\"missing\") {")))
    append_line(out, "        return 3")
    append_line(out, str_concat("    } else if ", str_concat(chain, ".index_of(\"vais\") == 0 {")))
    append_line(out, "        total = total + 10")
    append_line(out, "    }")
    append_line(out, "    return total + values[0] + values[1] + first_ai + ai_count + guard + normalized_count(words, needle) + hits - 5")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"  Vais\")")
    append_line(out, "    words.push(\"AI\")")
    append_line(out, "    words.push(\"db\")")
    append_line(out, "    words.push(\"ai  \")")
    append_line(out, "    return score_words(words, \"ai\")")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


    append_line(out, "    if xs[4] != 10 { return 5 }")
    append_line(out, "    if xs[6] != 30 { return 6 }")
    append_line(out, "    let dup: List<Int> = []")
    append_line(out, "    dup.push(5)")
    append_line(out, "    dup.push(6)")
    append_line(out, "    dup.extend(dup)")
    append_line(out, "    if dup.len() != 4 { return 7 }")
    append_line(out, "    if dup.sum() != 22 { return 8 }")
    append_line(out, "    let words: List<Str> = []")
    append_line(out, "    words.push(\"ai\")")
    append_line(out, "    let tail: List<Str> = []")
    append_line(out, "    tail.push(str_lower(\"CACHE\"))")
    append_line(out, "    tail.push(\"vector\")")
    append_line(out, "    words.extend(tail)")
    append_line(out, "    if words.len() != 3 { return 9 }")
    append_line(out, "    if words[1] != \"cache\" { return 10 }")
    append_line(out, "    if words[2] != \"vector\" { return 11 }")
    append_line(out, "    let extra: List<Str> = []")
    append_line(out, "    extra.push(\"rank\")")
    append_line(out, "    if append_words(words, extra) != 4 { return 12 }")
    append_line(out, "    if words[3] != \"rank\" { return 13 }")
    append_line(out, "    return 42")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


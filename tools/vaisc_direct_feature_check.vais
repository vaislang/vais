    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_filter_map_aggregate_call_arg_conditions(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"tokens\") == 1).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score).sum()")))
    let none_sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"none\") == 1).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score).sum()")))
    let max_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score + 1).max()")))
    let min_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score - 1).min()")))
    let call_expr = str_concat(str_concat(str_concat(str_concat("combine_scores(", sum_expr), ", "), str_concat(max_expr, ", ")), str_concat(min_expr, ")"))
    let none_call_expr = str_concat(str_concat(str_concat(str_concat("combine_scores(", none_sum_expr), ", "), str_concat(max_expr, ", ")), str_concat(min_expr, ")"))
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn combine_scores(total: Int, best: Int, low: Int) -> Int {")
    append_line(out, "    return total + best - low")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_flow(docs: List<Doc>) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    if ", str_concat(call_expr, " == 42 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut limit = 40")
    append_line(out, str_concat("    while ", str_concat(call_expr, " > limit {")))
    append_line(out, "        score = score + 20")
    append_line(out, "        limit = limit + 100")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(none_call_expr, " == 1 {")))
    append_line(out, "        return 1")
    append_line(out, str_concat("    } else if ", str_concat(call_expr, " == 42 {")))
    append_line(out, "        score = score + 12")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    return score_flow(docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_filter_map_aggregate_embedded_expr(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"tokens\") == 1).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score).sum()")))
    let max_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score + 1).max()")))
    let min_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score - 1).min()")))
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn weigh(value: Int) -> Int {")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn local_flow(docs: List<Doc>) -> Int {")
    append_line(out, "    let mut total = 3")
    append_line(out, str_concat("    total = total + ", sum_expr))
    append_line(out, str_concat("    let offset = 2 + ", min_expr))
    append_line(out, str_concat("    let via_call = weigh(1 + ", str_concat(max_expr, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(total + ", str_concat(sum_expr, ")")))
    append_line(out, str_concat("    values.insert_at(0, 4 + ", str_concat(min_expr, ")")))
    append_line(out, "    return total + offset + via_call + values[0] + values[1] - 140")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn return_flow(base: Int, docs: List<Doc>) -> Int {")
    append_line(out, str_concat("    return base + ", max_expr))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    if local_flow(docs) != 42 { return 1 }")
    append_line(out, "    return return_flow(21, docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_filter_map_aggregate_embedded_conditions(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"tokens\") == 1).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score).sum()")))
    let none_sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " str_contains(doc.body, \"none\") == 1).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score).sum()")))
    let max_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score + 1).max()")))
    let min_expr = str_concat(str_concat(str_concat(str_concat(str_concat("docs.filter(", pipe), "doc"), pipe), " doc.score > 6).map("), str_concat(str_concat(pipe, "doc"), str_concat(pipe, " doc.score - 1).min()")))
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn condition_flow(docs: List<Doc>) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    if ", str_concat(sum_expr, " + 4 == 42 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut limit = 20")
    append_line(out, str_concat("    while ", str_concat(max_expr, " + score > limit {")))
    append_line(out, "        score = score + 20")
    append_line(out, "        limit = limit + 100")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(none_sum_expr, " + score == 0 {")))
    append_line(out, "        return 1")
    append_line(out, str_concat("    } else if 25 + ", str_concat(min_expr, " == 42 {")))
    append_line(out, "        score = score + 12")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    return condition_flow(docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


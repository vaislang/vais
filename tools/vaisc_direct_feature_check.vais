fn write_list_filter_map_aggregate_embedded_expr(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "score"), pipe), " score > 10).map("), str_concat(str_concat(pipe, "score"), str_concat(pipe, " score + 1).sum()")))
    let max_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "score"), pipe), " score > 10).map("), str_concat(str_concat(pipe, "score"), str_concat(pipe, " score + 4).max()")))
    let min_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "score"), pipe), " score < 20).map("), str_concat(str_concat(pipe, "score"), str_concat(pipe, " score * 2).min()")))
    append_line(out, "fn weigh(value: Int) -> Int {")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn local_flow(scores: List<Int>) -> Int {")
    append_line(out, "    let mut total = 3")
    append_line(out, str_concat("    total = total + ", sum_expr))
    append_line(out, str_concat("    let offset = 2 + ", min_expr))
    append_line(out, str_concat("    let via_call = weigh(1 + ", str_concat(max_expr, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(total + ", str_concat(sum_expr, ")")))
    append_line(out, str_concat("    values.insert_at(0, 4 + ", str_concat(min_expr, ")")))
    append_line(out, "    return total + offset + via_call + values[0] + values[1] - 143")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn return_flow(base: Int, scores: List<Int>) -> Int {")
    append_line(out, str_concat("    return base + ", max_expr))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: List<Int> = []")
    append_line(out, "    scores.push(7)")
    append_line(out, "    scores.push(18)")
    append_line(out, "    scores.push(20)")
    append_line(out, "    if local_flow(scores) != 42 { return 1 }")
    append_line(out, "    return return_flow(18, scores)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_filter_map_aggregate_embedded_conditions(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "value"), pipe), " value > 10).map("), str_concat(str_concat(pipe, "value"), str_concat(pipe, " value + 1).sum()")))
    let none_sum_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "value"), pipe), " value > 100).map("), str_concat(str_concat(pipe, "value"), str_concat(pipe, " value + 1).sum()")))
    let max_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "value"), pipe), " value > 10).map("), str_concat(str_concat(pipe, "value"), str_concat(pipe, " value + 4).max()")))
    let min_expr = str_concat(str_concat(str_concat(str_concat(str_concat("scores.filter(", pipe), "value"), pipe), " value < 20).map("), str_concat(str_concat(pipe, "value"), str_concat(pipe, " value * 2).min()")))
    append_line(out, "fn condition_flow(scores: List<Int>) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    if ", str_concat(sum_expr, " + 2 == 42 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut limit = 20")
    append_line(out, str_concat("    while ", str_concat(max_expr, " + score > limit {")))
    append_line(out, "        score = score + 20")
    append_line(out, "        limit = limit + 100")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(none_sum_expr, " + score == 0 {")))
    append_line(out, "        return 1")
    append_line(out, str_concat("    } else if 28 + ", str_concat(min_expr, " == 42 {")))
    append_line(out, "        score = score + 12")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: List<Int> = []")
    append_line(out, "    scores.push(7)")
    append_line(out, "    scores.push(18)")
    append_line(out, "    scores.push(20)")
    append_line(out, "    return condition_flow(scores)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_map_aggregate_embedded_expr_conditions(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    let sum_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value + boost).sum()"))
    let sum_minus_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value - 1).sum()"))
    let max_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value + 2).max()"))
    let min_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value * 2).min()"))
    let identity_min_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value).min()"))
    let high_min_expr = str_concat(str_concat(str_concat("scores.map(", pipe), "value"), str_concat(pipe, " value + 100).min()"))
    append_line(out, "fn weigh(value: Int) -> Int {")
    append_line(out, "    return value")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn tail_flow(scores: List<Int>) -> Int {")
    append_line(out, str_concat("    return 1 + ", max_expr))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn score_flow(scores: List<Int>, boost: Int) -> Int {")
    append_line(out, "    let mut score = 0")
    append_line(out, str_concat("    let mut total = 1 + ", sum_expr))
    append_line(out, str_concat("    let via_call = weigh(1 + ", str_concat(max_expr, ")")))
    append_line(out, "    let values: List<Int> = []")
    append_line(out, str_concat("    values.push(", str_concat(sum_minus_expr, " + 3)")))
    append_line(out, str_concat("    values.insert_at(0, ", str_concat(min_expr, " + 1)")))
    append_line(out, str_concat("    total = total + via_call + ", str_concat(identity_min_expr, " - values[0] - 3")))
    append_line(out, str_concat("    if total + ", str_concat(sum_expr, " + 2 == 42 {")))
    append_line(out, "        score = score + 10")
    append_line(out, "    }")
    append_line(out, "    let mut limit = 15")
    append_line(out, str_concat("    while ", str_concat(max_expr, " + score > limit {")))
    append_line(out, "        score = score + 20")
    append_line(out, "        limit = limit + 100")
    append_line(out, "    }")
    append_line(out, str_concat("    if ", str_concat(high_min_expr, " + score == 0 {")))
    append_line(out, "        return 1")
    append_line(out, str_concat("    } else if 6 + ", str_concat(min_expr, " == 12 {")))
    append_line(out, "        score = score + 12")
    append_line(out, "    }")
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let scores: List<Int> = []")
    append_line(out, "    scores.push(3)")
    append_line(out, "    scores.push(5)")
    append_line(out, "    scores.push(7)")
    append_line(out, "    return score_flow(scores, 1) + tail_flow(scores) - 10")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}

fn write_list_struct_filter_first_last_field(path: Str) -> Int {
    let out = str_builder_new()
    let pipe = str_byte(124)
    append_line(out, "struct Doc { title: Str, body: Str, score: Int }")
    append_line(out, "")
    append_line(out, "fn first_matching_score(docs: List<Doc>, needle: Str) -> Int {")
    append_line(out, str_concat(str_concat(str_concat("    return docs.filter(", pipe), "doc"), str_concat(pipe, " str_contains(doc.body, needle) == 1).first().score")))
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn last_high_title_len(docs: List<Doc>, min_score: Int) -> Int {")
    append_line(out, str_concat(str_concat(str_concat("    let title: Str = docs.filter(", pipe), "doc"), str_concat(pipe, " doc.score > min_score).last().title")))
    append_line(out, "    return title.len()")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn first_high_score_local(docs: List<Doc>, min_score: Int) -> Int {")
    append_line(out, str_concat(str_concat(str_concat("    let score: Int = docs.filter(", pipe), "doc"), str_concat(pipe, " doc.score > min_score).first().score")))
    append_line(out, "    return score")
    append_line(out, "}")
    append_line(out, "")
    append_line(out, "fn main() -> Int {")
    append_line(out, "    let docs: List<Doc> = []")
    append_line(out, "    docs.push(Doc { title: \"alpha\", body: \"vais cache\", score: 5 })")
    append_line(out, "    docs.push(Doc { title: \"beta\", body: \"learn tokens\", score: 18 })")
    append_line(out, "    docs.push(Doc { title: \"gamma\", body: \"tokens cache\", score: 20 })")
    append_line(out, "    let first = first_matching_score(docs, \"tokens\")")
    append_line(out, "    let last_title = last_high_title_len(docs, 10)")
    append_line(out, "    let first_local = first_high_score_local(docs, 10)")
    append_line(out, "    return first + last_title + first_local + 1")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


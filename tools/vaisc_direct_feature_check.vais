    append_line(out, "    if best_score(docs) != 20 { return 5 }")
    append_line(out, "    if lowest_score(docs) != 5 { return 6 }")
    append_line(out, "    return score_flow(docs)")
    append_line(out, "}")
    return fs_write_text(path, str_builder_finish(out))
}


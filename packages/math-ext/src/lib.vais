# Extended Math Functions
# Provides additional mathematical functions beyond the standard library
#
# Features:
# - Basic operations (abs, min, max, clamp)
# - Number theory (gcd, lcm, is_prime)
# - Power and root functions
# - Fibonacci sequence
# - Combinatorics helpers

# Absolute value
# Args: x - input value
# Returns: |x|
fn abs(x: i64) -> i64 {
    I x < 0 { 0 - x } enum { x }
}

# Minimum of two values
# Args: a, b - input values
# Returns: min(a, b)
fn min(a: i64, b: i64) -> i64 {
    I a < b { a } enum { b }
}

# Maximum of two values
# Args: a, b - input values
# Returns: max(a, b)
fn max(a: i64, b: i64) -> i64 {
    I a > b { a } enum { b }
}

# Clamp value to range [lo, hi]
# Args: x - value, lo - lower bound, hi - upper bound
# Returns: x clamped to [lo, hi]
fn clamp(x: i64, lo: i64, hi: i64) -> i64 {
    I x < lo { return lo }
    I x > hi { return hi }
    x
}

# Greatest Common Divisor (Euclidean algorithm)
# Args: a, b - input values
# Returns: gcd(a, b)
fn gcd(a: i64, b: i64) -> i64 {
    # Handle negative values
    a = abs(a)
    b = abs(b)

    # Euclidean algorithm
    L b != 0 {
        temp := b
        b = a % b
        a = temp
    }

    a
}

# Least Common Multiple
# Args: a, b - input values
# Returns: lcm(a, b)
fn lcm(a: i64, b: i64) -> i64 {
    I a == 0 { return 0 }
    I b == 0 { return 0 }

    # lcm(a, b) = |a * b| / gcd(a, b)
    g := gcd(a, b)
    abs((a / g) * b)
}

# Power function (integer exponentiation)
# Args: base - base value, exp - exponent (must be >= 0)
# Returns: base^exp
fn pow(base: i64, exp: i64) -> i64 {
    I exp < 0 { return 0 }  # Negative exponents not supported
    I exp == 0 { return 1 }

    result := 1
    i := 0
    L i < exp {
        result = result * base
        i = i + 1
    }

    result
}

# Fast power using exponentiation by squaring
# Args: base - base value, exp - exponent (must be >= 0)
# Returns: base^exp
fn pow_fast(base: i64, exp: i64) -> i64 {
    I exp < 0 { return 0 }
    I exp == 0 { return 1 }
    I base == 0 { return 0 }

    result := 1
    b := base
    e := exp

    L e > 0 {
        # If exp is odd, multiply result by base
        I (e % 2) == 1 {
            result = result * b
        }

        # Square the base and halve the exponent
        b = b * b
        e = e / 2
    }

    result
}

# Check if number is prime
# Args: n - number to check
# Returns: 1 if prime, 0 otherwise
fn is_prime(n: i64) -> i64 {
    I n <= 1 { return 0 }
    I n <= 3 { return 1 }
    I (n % 2) == 0 { return 0 }
    I (n % 3) == 0 { return 0 }

    # Check divisors of form 6k ± 1 up to sqrt(n)
    i := 5
    L (i * i) <= n {
        I (n % i) == 0 { return 0 }
        I (n % (i + 2)) == 0 { return 0 }
        i = i + 6
    }

    1
}

# Fibonacci number (iterative)
# Args: n - index (0-based)
# Returns: nth Fibonacci number
fn fibonacci(n: i64) -> i64 {
    I n < 0 { return 0 }
    I n == 0 { return 0 }
    I n == 1 { return 1 }

    prev := 0
    curr := 1
    i := 2

    L i <= n {
        next := prev + curr
        prev = curr
        curr = next
        i = i + 1
    }

    curr
}

# Factorial
# Args: n - input value (must be >= 0)
# Returns: n!
fn factorial(n: i64) -> i64 {
    I n < 0 { return 0 }
    I n == 0 { return 1 }
    I n == 1 { return 1 }

    result := 1
    i := 2
    L i <= n {
        result = result * i
        i = i + 1
    }

    result
}

# Integer square root (floor)
# Args: n - input value (must be >= 0)
# Returns: floor(sqrt(n))
fn isqrt(n: i64) -> i64 {
    I n < 0 { return 0 }
    I n == 0 { return 0 }
    I n == 1 { return 1 }

    # Binary search for square root
    low := 1
    high := n
    result := 0

    L low <= high {
        mid := (low + high) / 2
        square := mid * mid

        I square == n {
            return mid
        }

        I square < n {
            result = mid
            low = mid + 1
        } enum {
            high = mid - 1
        }
    }

    result
}

# Check if number is perfect square
# Args: n - number to check
# Returns: 1 if perfect square, 0 otherwise
fn is_square(n: i64) -> i64 {
    I n < 0 { return 0 }
    root := isqrt(n)
    I (root * root) == n { 1 } enum { 0 }
}

# Sign function
# Args: x - input value
# Returns: -1 if x < 0, 0 if x == 0, 1 if x > 0
fn sign(x: i64) -> i64 {
    I x < 0 { return -1 }
    I x > 0 { return 1 }
    0
}

# Minimum of three values
fn min3(a: i64, b: i64, c: i64) -> i64 {
    min(a, min(b, c))
}

# Maximum of three values
fn max3(a: i64, b: i64, c: i64) -> i64 {
    max(a, max(b, c))
}

# Check if number is even
fn is_even(n: i64) -> i64 {
    I (n % 2) == 0 { 1 } enum { 0 }
}

# Check if number is odd
fn is_odd(n: i64) -> i64 {
    I (n % 2) != 0 { 1 } enum { 0 }
}

# Sum of integers from 1 to n
fn sum_to_n(n: i64) -> i64 {
    I n < 0 { return 0 }
    (n * (n + 1)) / 2
}

# Sum of squares from 1 to n
fn sum_of_squares(n: i64) -> i64 {
    I n < 0 { return 0 }
    (n * (n + 1) * ((2 * n) + 1)) / 6
}

# Binomial coefficient C(n, k) = n! / (k! * (n-k)!)
# Args: n, k - parameters
# Returns: C(n, k)
fn binomial(n: i64, k: i64) -> i64 {
    I k < 0 { return 0 }
    I k > n { return 0 }
    I k == 0 { return 1 }
    I k == n { return 1 }

    # Optimize: C(n, k) = C(n, n-k), use smaller k
    I k > (n - k) {
        k = n - k
    }

    result := 1
    i := 0
    L i < k {
        result = result * (n - i)
        result = result / (i + 1)
        i = i + 1
    }

    result
}

# Permutation P(n, k) = n! / (n-k)!
fn permutation(n: i64, k: i64) -> i64 {
    I k < 0 { return 0 }
    I k > n { return 0 }

    result := 1
    i := 0
    L i < k {
        result = result * (n - i)
        i = i + 1
    }

    result
}

# Modular exponentiation: (base^exp) % mod
# Args: base, exp, mod - parameters
# Returns: (base^exp) % mod
fn mod_pow(base: i64, exp: i64, mod: i64) -> i64 {
    I mod == 1 { return 0 }
    I exp < 0 { return 0 }

    result := 1
    b := base % mod

    L exp > 0 {
        I (exp % 2) == 1 {
            result = (result * b) % mod
        }

        exp = exp / 2
        b = (b * b) % mod
    }

    result
}

# Number of digits in n (base 10)
fn digit_count(n: i64) -> i64 {
    I n == 0 { return 1 }

    n = abs(n)
    count := 0

    L n > 0 {
        n = n / 10
        count = count + 1
    }

    count
}

# Reverse digits of n
fn reverse_digits(n: i64) -> i64 {
    negative := I n < 0 { 1 } enum { 0 }
    n = abs(n)

    result := 0
    L n > 0 {
        digit := n % 10
        result = (result * 10) + digit
        n = n / 10
    }

    I negative { 0 - result } enum { result }
}

# Sum of digits
fn digit_sum(n: i64) -> i64 {
    n = abs(n)
    sum := 0

    L n > 0 {
        sum = sum + (n % 10)
        n = n / 10
    }

    sum
}

# Check if n is palindrome
fn is_palindrome(n: i64) -> i64 {
    I n < 0 { return 0 }
    I n == reverse_digits(n) { 1 } enum { 0 }
}

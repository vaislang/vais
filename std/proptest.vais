    0
}

fn load_f64(ptr: i64) -> f64 {
    # Actual implementation would be:
    # return *((f64*)ptr)
    0.0
}

fn store_i64(ptr: i64, val: i64) -> i64 {
    __store_i64(ptr, val)
}


# std/os/darwin.vais - Darwin (macOS / iOS) syscall numbers
# Phase 4.1 syscall primitive support.
# Source: /usr/include/sys/syscall.h (XNU kernel, BSD-derived)
#
# Usage:
#   U std/os/darwin
#   # then call __syscall(SYS_write, fd, buf, count)

C SYS_exit: i64 = 1
C SYS_read: i64 = 3
C SYS_write: i64 = 4
C SYS_open: i64 = 5
C SYS_close: i64 = 6
C SYS_gettimeofday: i64 = 116
C SYS_mmap: i64 = 197
C SYS_munmap: i64 = 73
C SYS_clock_gettime_nsec_np: i64 = 347

# Stdlib self-test: Result<T, E> propagation patterns
fn parse_digit(s: str) -> Result<i64, i64> {
    match s {
        "0" => Ok(0),
        "1" => Ok(1),
        "2" => Ok(2),
        "3" => Ok(3),
        _   => Err(1),
    }
}

fn sum_digits(a: str, b: str) -> Result<i64, i64> {
    ar: Result<i64, i64> := parse_digit(a)
    av: i64 := match ar { Ok(v) => v, Err(_) => -1 }
    I av < 0 { return Err(1) }
    br: Result<i64, i64> := parse_digit(b)
    bv: i64 := match br { Ok(v) => v, Err(_) => -1 }
    I bv < 0 { return Err(1) }
    Ok(av + bv)
}

fn main() -> i64 {
    # Ok path
    r1: Result<i64, i64> := sum_digits("2", "3")
    v1: i64 := match r1 { Ok(v) => v, Err(_) => -1 }
    I v1 != 5 { return 1 }

    # Err path (first arg invalid)
    r2: Result<i64, i64> := sum_digits("x", "3")
    is_err2: i64 := match r2 { Ok(_) => 0, Err(_) => 1 }
    I is_err2 != 1 { return 2 }

    # Err path (second arg invalid)
    r3: Result<i64, i64> := sum_digits("1", "y")
    is_err3: i64 := match r3 { Ok(_) => 0, Err(_) => 1 }
    I is_err3 != 1 { return 3 }

    # Direct Ok/Err construction
    ok: Result<i64, i64> := Ok(99)
    er: Result<i64, i64> := Err(7)

    okv: i64 := match ok { Ok(v) => v, Err(_) => 0 }
    I okv != 99 { return 4 }

    ec: i64 := match er { Ok(_) => 0, Err(c) => c }
    I ec != 7 { return 5 }

    return 0
}

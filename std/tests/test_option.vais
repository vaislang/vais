# Stdlib self-test: Option<T> + method dispatch on builtin enum
U std/option

F main() -> i64 {
    a: Option<i64> := Some(42)
    b: Option<i64> := None

    # is_some / is_none
    I a.is_some() != 1 { R 1 }
    I a.is_none() != 0 { R 2 }
    I b.is_some() != 0 { R 3 }
    I b.is_none() != 1 { R 4 }

    # unwrap_or
    I a.unwrap_or(0) != 42 { R 5 }
    I b.unwrap_or(7) != 7 { R 6 }

    # match destructuring
    av: i64 := M a { Some(v) => v, None => -1 }
    I av != 42 { R 7 }
    bv: i64 := M b { Some(v) => v, None => -1 }
    I bv != -1 { R 8 }

    # nested Option chain via match
    c: Option<i64> := Some(10)
    doubled: Option<i64> := M c {
        Some(v) => Some(v * 2),
        None    => None,
    }
    dv: i64 := M doubled { Some(v) => v, None => 0 }
    I dv != 20 { R 9 }

    R 0
}

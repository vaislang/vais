impl fn __tcp_recv(fd: i64, buffer: i64, len: i64) -> i64
impl fn __tcp_close(fd: i64) -> i64

# HTTP client runtime (from http_client_runtime.c)
impl fn __hc_tcp_connect(host: i64, port: i64, timeout_ms: i64) -> i64
impl fn __hc_set_timeout(fd: i64, timeout_ms: i64) -> i64
impl fn __hc_parse_url_host(url: str) -> str
impl fn __hc_parse_url_port(url: str) -> i64
impl fn __hc_parse_url_path(url: str) -> str
impl fn __hc_parse_url_query(url: str) -> str
impl fn __hc_parse_url_scheme(url: str) -> str
impl fn __hc_parse_response(buffer: i64, len: i64) -> HttpResponse
impl fn __hc_get_content_length(buffer: i64, len: i64) -> i64
impl fn __hc_str_from_buffer(ptr: i64, len: i64) -> str

# HTTP parsing (shared with http_runtime.c)
impl fn __find_header_end(buffer: i64, len: i64) -> i64

# String operations
impl fn __strlen(s: str) -> i64
impl fn __str_copy_to(dst: i64, src: str) -> i64
impl fn __str_eq(a: str, b: str) -> i64
impl fn __str_eq_ignore_case(a: str, b: str) -> i64
impl fn __i64_to_str(dst: i64, value: i64) -> i64
impl fn __str_to_i64(s: str) -> i64

# Memory operations
impl fn __malloc(size: i64) -> i64
impl fn __free(ptr: i64) -> i64

# TLS operations (from tls_runtime.c) — used by the HTTPS path
impl fn __tls_ctx_new(mode: i64) -> i64
impl fn __tls_ctx_free(handle: i64) -> i64
impl fn __tls_ctx_set_default_verify(handle: i64) -> i64
impl fn __tls_ctx_set_verify(handle: i64, mode: i64) -> i64
impl fn __tls_new(ctx: i64, fd: i64) -> i64
impl fn __tls_free(handle: i64) -> i64
impl fn __tls_set_hostname(handle: i64, hostname: str) -> i64
impl fn __tls_connect(handle: i64) -> i64
impl fn __tls_read(handle: i64, buf: i64, len: i64) -> i64
impl fn __tls_write(handle: i64, data: i64, len: i64) -> i64
impl fn __tls_shutdown(handle: i64) -> i64
impl fn __memcpy(dst: i64, src: i64, len: i64) -> i64
impl fn __memset(dst: i64, value: i64, len: i64) -> i64
impl fn __store_byte(ptr: i64, value: i64) -> i64
impl fn __store_ptr(ptr: i64, value: i64) -> i64
impl fn __store_i64(ptr: i64, value: i64) -> i64
impl fn __load_ptr(ptr: i64) -> i64
impl fn __load_i64(ptr: i64) -> i64

    putchar(10)
    emit_str("  %last = sub i64 %len, 1")
    putchar(10)
    emit_str("  %same = icmp eq i64 %idx, %last")
    putchar(10)
    emit_str("  br i1 %same, label %shrink, label %move")
    putchar(10)
    emit_str("move:")
    putchar(10)
    emit_str("  %lastkp = getelementptr i64, i64* %m, i64 %last")

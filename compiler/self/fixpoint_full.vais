                                handled = 1
                            } else if aarr == 0 {
                                # Struct local passed by value: pass a pointer to
                                # its first field; callee copies into its local.
                                let mut ast = sty_of(slots, src, argt.nstart, argt.nlen)
                                if want_ty >= 3 { ast = want_ty - 3 }
                                if ast >= 0 and want_ty >= 3 {
                                    let aslot = find_slot(slots, src, argt.nstart, argt.nlen)
                                    let anf = struct_flat_nfields(toks, defs, src, ast)
                                    emit_str("  %t")
                                    pint(cc)
                                    emit_str(" = getelementptr [")
                                    pint(anf)
                                    emit_str(" x i64], [")
                                    pint(anf)
                                    emit_str(" x i64]* %v")
                                    pint(aslot)
                                    emit_str(", i64 0, i64 0")
                                    putchar(10)
                                    ekind = 3
                                    eval2 = cc
                                    cc = cc + 1
                                    handled = 1
                                }
                            }
                        } else if after.kind == 9 {
                            let want_call_ty = call_param_ty(fns, src, t.nstart, t.nlen, nargs)
                            let call_sty = call_retsty(toks, fns, src, q)
                            let call_close = paren_end(toks, q + 2)
                            if call_sty >= 0 and want_call_ty >= 3 and want_call_ty - 3 == call_sty and call_close + 1 == astop {
                                let anf_call = struct_flat_nfields(toks, defs, src, call_sty)
                                let aid_call = cc
                                emit_str("  %sa")
                                pint(aid_call)
                                emit_str(" = alloca [")
                                pint(anf_call)
                                emit_str(" x i64]")
                                putchar(10)
                                cc = cc + 1
                                emit_str("  %t")
                                pint(cc)
                                emit_str(" = getelementptr [")
                                pint(anf_call)
                                emit_str(" x i64], [")
                                pint(anf_call)
                                emit_str(" x i64]* %sa")
                                pint(aid_call)
                                emit_str(", i64 0, i64 0")
                                putchar(10)
                                let outp_call = cc
                                cc = cc + 1
                                cc = emit_struct_out_call(toks, slots, fns, defs, src, q, q + 2, call_close, cc, outp_call)
                                ekind = 3
                                eval2 = outp_call
                                handled = 1
                            }
                        } else if after.kind == 11 {
                            # Struct literal as an argument, e.g. emit_op(Op { ... }).
                            # Materialize a temporary [nf x i64] and pass its base.
                            let ast = struct_index_by_name(defs, src, argt.nstart, argt.nlen)
                            if ast >= 0 {
                                let anf = struct_flat_nfields(toks, defs, src, ast)
                                let aid = cc
                                emit_str("  %sa")
                                pint(aid)
                                emit_str(" = alloca [")
                                pint(anf)
                                emit_str(" x i64]")
                                putchar(10)
                                cc = cc + 1
                                let bopen = q + 1
                                let bclose = match_brace(toks, bopen, close)
                                let mut fq = bopen + 1
                                while fq < bclose {
                                    let fld = toks[fq]
                                    let fi = field_index(defs, ast, src, fld.nstart, fld.nlen)
                                    let mut vstart = fq + 1
                                    let colt = toks[fq + 1]
                                    if colt.kind == 16 { vstart = fq + 2 }
                                    let vstop = arr_elem_end(toks, vstart, bclose)
                                    let fe = gen_expr(toks, slots, fns, defs, src, vstart, vstop, cc)
                                    cc = fe.next
                                    let fe64 = ensure_i64_op(fe, cc)
                                    cc = fe64.next
                                    emit_str("  %t")
                                    pint(cc)
                                    emit_str(" = getelementptr [")
                                    pint(anf)
                                    emit_str(" x i64], [")
                                    pint(anf)
                                    emit_str(" x i64]* %sa")
                                    pint(aid)
                                    emit_str(", i64 0, i64 ")
                                    pint(fi)
                                    putchar(10)
                                    emit_str("  store i64 ")
                                    emit_op(fe64)
                                    emit_str(", i64* %t")
                                    pint(cc)
                                    putchar(10)
                                    cc = cc + 1
                                    fq = vstop + 1
                                }
                                emit_str("  %t")
                                pint(cc)
                                emit_str(" = getelementptr [")
                                pint(anf)
                                emit_str(" x i64], [")
                                pint(anf)
                                emit_str(" x i64]* %sa")
                                pint(aid)
                                emit_str(", i64 0, i64 0")
                                putchar(10)
                                ekind = 3
                                eval2 = cc
                                cc = cc + 1
                                handled = 1
                            }
                        }
                    }
                    if handled == 0 and argt.kind == 23 {
                        let want_ty2 = call_param_ty(fns, src, t.nstart, t.nlen, nargs)
                        let pst2 = param_list_elem_sty(toks, defs, src, toks.len(), t.nstart, t.nlen, nargs)
                        if want_ty2 == 2 {
                            let lop = emit_inline_list_literal_arg(toks, slots, fns, defs, src, q, pst2, cc)
                            ekind = lop.kind
                            eval2 = lop.val
                            cc = lop.next
                            handled = 1
                        }
                    }
                    if handled == 0 {
                        let e = gen_expr(toks, slots, fns, defs, src, q, astop, cc)
                        cc = e.next
                        ekind = e.kind
                        eval2 = e.val
                    }
                    if nargs == 0 { a0k = ekind; a0v = eval2 }
                    else if nargs == 1 { a1k = ekind; a1v = eval2 }
                    else if nargs == 2 { a2k = ekind; a2v = eval2 }
                    else if nargs == 3 { a3k = ekind; a3v = eval2 }
                    else if nargs == 4 { a4k = ekind; a4v = eval2 }
                    else if nargs == 5 { a5k = ekind; a5v = eval2 }
                    else if nargs == 6 { a6k = ekind; a6v = eval2 }
                    else if nargs == 7 { a7k = ekind; a7v = eval2 }
                    else if nargs == 8 { a8k = ekind; a8v = eval2 }
                    else { a9k = ekind; a9v = eval2 }
                    nargs = nargs + 1
                    q = astop + 1
                }
            }
            let dest = cc
            let mut retstr = is_host_str_return(src, t.nstart, t.nlen)
            if call_retstr(toks, fns, src, i) == 1 { retstr = 1 }
            emit_str("  %t")
            pint(dest)
            if retstr == 1 { emit_str(" = call i8* @") }
            else { emit_str(" = call i64 @") }
            emit_name(src, t.nstart, t.nlen)
            emit_str("(")
            let mut ai = 0
            while ai < nargs {
                if ai > 0 { emit_str(", ") }
                let mut ak = a0k
                let mut av = a0v
                if ai == 1 { ak = a1k; av = a1v }
                else if ai == 2 { ak = a2k; av = a2v }
                else if ai == 3 { ak = a3k; av = a3v }
                else if ai == 4 { ak = a4k; av = a4v }
                else if ai == 5 { ak = a5k; av = a5v }
                else if ai == 6 { ak = a6k; av = a6v }
                else if ai == 7 { ak = a7k; av = a7v }
                else if ai == 8 { ak = a8k; av = a8v }
                else if ai == 9 { ak = a9k; av = a9v }
                # kind 2 = i8* (string pointer); else i64.
                if ak == 2 { emit_str("i8* ") } else if ak == 3 { emit_str("i64* ") } else { emit_str("i64 ") }
                emit_op(Op { kind: ak, val: av, next: 0 })
                ai = ai + 1
            }
            emit_str(")")
            putchar(10)
            # sync the length of any List-local args from buf[63] (the callee may
            # have pushed into them via the out-param). %v<slot+1> = load buf[63].
            let mut rc = dest + 1
            rc = sync_list_len(ls0, li0, lb0, rc)
            rc = sync_list_len(ls1, li1, lb1, rc)
            rc = sync_list_len(ls2, li2, lb2, rc)
            rc = sync_list_len(ls3, li3, lb3, rc)
            rc = sync_list_len(ls4, li4, lb4, rc)
            rc = sync_list_len(ls5, li5, lb5, rc)
            rc = sync_list_len(ls6, li6, lb6, rc)
            rc = sync_list_len(ls7, li7, lb7, rc)
            rc = sync_list_len(ls8, li8, lb8, rc)
            rc = sync_list_len(ls9, li9, lb9, rc)
            if retstr == 1 { return Op { kind: 2, val: dest, next: rc } }
            return Op { kind: 1, val: dest, next: rc }
        }
        if nx.kind == 27 {
            # `name . X` — disambiguate by the variable's kind:
            #   string (is_arr=3) -> `.len()` (compile-time length literal)
            #   struct (sty>=0)   -> field read (GEP field-index + load)
            #   List              -> `.len` (load the length counter)
            # NOTE: string check FIRST — a string slot stores the global key in
            # sty, which would otherwise be misread as a struct index.
            let karr = isarr_of(slots, src, t.nstart, t.nlen)
            let meth = toks[i + 2]
            if karr == 2 or karr == 4 {
                let lsty_field = sty_of(slots, src, t.nstart, t.nlen)
                if lsty_field >= 0 {
                    let mopen_field = toks[i + 3]
                    if mopen_field.kind == 9 {
                        let mclose_field = paren_end(toks, i + 4)
                        let mdot_field = toks[mclose_field + 1]
                        if mdot_field.kind == 27 {
                            let mfld = toks[mclose_field + 2]
                            if mfld.kind == 1 {
                                let method_tmp = emit_los_method_to_tmp(toks, slots, fns, defs, src, i, mclose_field + 1, lsty_field, counter)
                                if method_tmp.kind == 1 {
                                    let mnf = struct_flat_nfields(toks, defs, src, lsty_field)
                                    let mfi = field_chain_flat_offset(toks, defs, src, lsty_field, mclose_field + 2)
                                    emit_str("  %t")
                                    pint(method_tmp.next)
                                    emit_str(" = getelementptr [")
                                    pint(mnf)
                                    emit_str(" x i64], [")
                                    pint(mnf)
                                    emit_str(" x i64]* %sa")
                                    pint(method_tmp.val)
                                    emit_str(", i64 0, i64 ")
                                    pint(mfi)
                                    putchar(10)
                                    let mload = method_tmp.next + 1
                                    emit_str("  %t")
                                    pint(mload)
                                    emit_str(" = load i64, i64* %t")
                                    pint(method_tmp.next)
                                    putchar(10)
                                    let mfty = field_chain_type_index(toks, defs, src, lsty_field, mclose_field + 2)
                                    if mfty == 0 - 2 {
                                        let mfend = field_chain_end_pos(toks, defs, src, lsty_field, mclose_field + 2)
                                        return emit_str_from_i64_value(toks, src, mload, mfend, mload + 1)
                                    }
                                    return Op { kind: 1, val: mload, next: mload + 1 }
                                }
                            }
                        }
                    }
                }
            }
            if karr == 5 or karr == 6 {
                let opn = toks[i + 3]
                if opn.kind == 9 {
                    let close = paren_end(toks, i + 4)
                    if kw3(src, meth.nstart, meth.nlen, 108, 101, 110) == 1 {
                        let base = counter
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "len")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(")")
                        putchar(10)
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    if is_contains(src, meth.nstart, meth.nlen) == 1 {
                        let a0stop = arg_comma_end(toks, i + 4, close)
                        let key = gen_map_key_expr(toks, slots, fns, defs, src, t.nstart, t.nlen, i + 4, a0stop, counter)
                        let base = key.next
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "contains")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(", ")
                        emit_map_key_arg(slots, src, t.nstart, t.nlen, key)
                        emit_str(")")
                        putchar(10)
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    if is_get(src, meth.nstart, meth.nlen) == 1 {
                        let a0stop = arg_comma_end(toks, i + 4, close)
                        let key = gen_map_key_expr(toks, slots, fns, defs, src, t.nstart, t.nlen, i + 4, a0stop, counter)
                        let defstop = arg_comma_end(toks, a0stop + 1, close)
                        let fallback = gen_expr(toks, slots, fns, defs, src, a0stop + 1, defstop, key.next)
                        let mut fkind = fallback.kind
                        let mut fval = fallback.val
                        let mut fnext = fallback.next
                        if map_is_str_value(slots, src, t.nstart, t.nlen) == 1 {
                            emit_str("  %t")
                            pint(fnext)
                            emit_str(" = ptrtoint i8* ")
                            emit_op(fallback)
                            emit_str(" to i64")
                            putchar(10)
                            fkind = 1
                            fval = fnext
                            fnext = fnext + 1
                        }
                        let base = fnext
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "get")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(", ")
                        emit_map_key_arg(slots, src, t.nstart, t.nlen, key)
                        emit_str(", i64 ")
                        emit_op(Op { kind: fkind, val: fval, next: 0 })
                        emit_str(")")
                        putchar(10)
                        if map_is_str_value(slots, src, t.nstart, t.nlen) == 1 {
                            let ptrc = dest + 1
                            emit_str("  %t")
                            pint(ptrc)
                            emit_str(" = inttoptr i64 %t")
                            pint(dest)
                            emit_str(" to i8*")
                            putchar(10)
                            let lend = trailing_len_call_end(toks, src, close + 1)
                            if lend != close + 1 {
                                return emit_strlen_from_ptr(ptrc, ptrc + 1)
                            }
                            return Op { kind: 2, val: ptrc, next: ptrc + 1 }
                        }
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    if is_get_opt(src, meth.nstart, meth.nlen) == 1 {
                        let a0stop = arg_comma_end(toks, i + 4, close)
                        let key = gen_map_key_expr(toks, slots, fns, defs, src, t.nstart, t.nlen, i + 4, a0stop, counter)
                        let base = key.next
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "get_opt")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(", ")
                        emit_map_key_arg(slots, src, t.nstart, t.nlen, key)
                        emit_str(")")
                        putchar(10)
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    if is_key_at(src, meth.nstart, meth.nlen) == 1 {
                        let a0stop = arg_comma_end(toks, i + 4, close)
                        let index = gen_expr(toks, slots, fns, defs, src, i + 4, a0stop, counter)
                        let base = index.next
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "key_at")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(", i64 ")
                        emit_op(index)
                        emit_str(")")
                        putchar(10)
                        if map_is_str_key(slots, src, t.nstart, t.nlen) == 1 {
                            let ptrc = dest + 1
                            emit_str("  %t")
                            pint(ptrc)
                            emit_str(" = inttoptr i64 %t")
                            pint(dest)
                            emit_str(" to i8*")
                            putchar(10)
                            let lend = trailing_len_call_end(toks, src, close + 1)
                            if lend != close + 1 {
                                return emit_strlen_from_ptr(ptrc, ptrc + 1)
                            }
                            return Op { kind: 2, val: ptrc, next: ptrc + 1 }
                        }
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    if is_value_at(src, meth.nstart, meth.nlen) == 1 {
                        let a0stop = arg_comma_end(toks, i + 4, close)
                        let index = gen_expr(toks, slots, fns, defs, src, i + 4, a0stop, counter)
                        let base = index.next
                        emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                        let dest = base + 1
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i64 @")
                        emit_map_helper_name(slots, src, t.nstart, t.nlen, "value_at")
                        emit_str("(i64* %t")
                        pint(base)
                        emit_str(", i64 ")
                        emit_op(index)
                        emit_str(")")
                        putchar(10)
                        if map_is_str_value(slots, src, t.nstart, t.nlen) == 1 {
                            let ptrc = dest + 1
                            emit_str("  %t")
                            pint(ptrc)
                            emit_str(" = inttoptr i64 %t")
                            pint(dest)
                            emit_str(" to i8*")
                            putchar(10)
                            let lend = trailing_len_call_end(toks, src, close + 1)
                            if lend != close + 1 {
                                return emit_strlen_from_ptr(ptrc, ptrc + 1)
                            }
                            return Op { kind: 2, val: ptrc, next: ptrc + 1 }
                        }
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                }
                return Op { kind: 0, val: 0, next: counter }
            }
            if is_is_empty(src, meth.nstart, meth.nlen) == 1 {
                if karr == 1 {
                    let sal = arrlen_of(slots, src, t.nstart, t.nlen)
                    if sal == 0 { return Op { kind: 0, val: 1, next: counter } }
                    return Op { kind: 0, val: 0, next: counter }
                }
                if karr == 2 {
                    let sslot = find_slot(slots, src, t.nstart, t.nlen)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = load i64, i64* %v")
                    pint(sslot + 1)
                    putchar(10)
                    let cmpc = counter + 1
                    emit_str("  %t")
                    pint(cmpc)
                    emit_str(" = icmp eq i64 %t")
                    pint(counter)
                    emit_str(", 0")
                    putchar(10)
                    let zc = cmpc + 1
                    emit_str("  %t")
                    pint(zc)
                    emit_str(" = zext i1 %t")
                    pint(cmpc)
                    emit_str(" to i64")
                    putchar(10)
                    return Op { kind: 1, val: zc, next: zc + 1 }
                }
                if karr == 4 {
                    let pslot = find_slot(slots, src, t.nstart, t.nlen)
                    let plsty = sty_of(slots, src, t.nstart, t.nlen)
                    let mut plenidx2 = list_lenidx()
                    if plsty >= 0 { plenidx2 = list_lenidx_for_nfields(struct_flat_nfields(toks, defs, src, plsty)) }
                    let bp = counter
                    emit_str("  %t")
                    pint(bp)
                    emit_str(" = load i64*, i64** %v")
                    pint(pslot)
                    putchar(10)
                    let lp = bp + 1
                    emit_str("  %t")
                    pint(lp)
                    emit_str(" = getelementptr i64, i64* %t")
                    pint(bp)
                    emit_str(", i64 ")
                    pint(plenidx2)
                    putchar(10)
                    let lv = lp + 1
                    emit_str("  %t")
                    pint(lv)
                    emit_str(" = load i64, i64* %t")
                    pint(lp)
                    putchar(10)
                    let cmpc = lv + 1
                    emit_str("  %t")
                    pint(cmpc)
                    emit_str(" = icmp eq i64 %t")
                    pint(lv)
                    emit_str(", 0")
                    putchar(10)
                    let zc = cmpc + 1
                    emit_str("  %t")
                    pint(zc)
                    emit_str(" = zext i1 %t")
                    pint(cmpc)
                    emit_str(" to i64")
                    putchar(10)
                    return Op { kind: 1, val: zc, next: zc + 1 }
                }
            }
            if is_contains(src, meth.nstart, meth.nlen) == 1 {
                let cclose = paren_end(toks, i + 4)
                let carg = gen_expr(toks, slots, fns, defs, src, i + 4, cclose, counter)
                let lsty = sty_of(slots, src, t.nstart, t.nlen)
                if karr == 2 and lsty == 0 - 1 {
                    let cslot = find_slot(slots, src, t.nstart, t.nlen)
                    let ccap = arrlen_of(slots, src, t.nstart, t.nlen)
                    let base = carg.next
                    emit_str("  %ct")
                    pint(base)
                    emit_str(" = alloca i64")
                    putchar(10)
                    emit_str("  %ci")
                    pint(base)
                    emit_str(" = alloca i64")
                    putchar(10)
                    emit_str("  store i64 0, i64* %ct")
                    pint(base)
                    putchar(10)
                    emit_str("  store i64 0, i64* %ci")
                    pint(base)
                    putchar(10)
                    emit_str("  br label %containsL")
                    pint(base)
                    putchar(10)
                    emit_str("containsL")
                    pint(base)
                    emit_str(":")
                    putchar(10)
                    let ic = base + 1
                    emit_str("  %t")
                    pint(ic)
                    emit_str(" = load i64, i64* %ci")
                    pint(base)
                    putchar(10)
                    let lc = ic + 1
                    emit_str("  %t")
                    pint(lc)
                    emit_str(" = load i64, i64* %v")
                    pint(cslot + 1)
                    putchar(10)
                    let cmpc = lc + 1
                    emit_str("  %t")
                    pint(cmpc)
                    emit_str(" = icmp slt i64 %t")
                    pint(ic)
                    emit_str(", %t")
                    pint(lc)
                    putchar(10)
                    emit_str("  br i1 %t")
                    pint(cmpc)
                    emit_str(", label %containsB")
                    pint(base)
                    emit_str(", label %containsD")
                    pint(base)
                    putchar(10)
                    emit_str("containsB")
                    pint(base)
                    emit_str(":")
                    putchar(10)
                    let gepc = cmpc + 1
                    emit_str("  %t")
                    pint(gepc)
                    emit_str(" = getelementptr [")
                    pint(ccap)
                    emit_str(" x i64], [")
                    pint(ccap)
                    emit_str(" x i64]* %v")
                    pint(cslot)
                    emit_str(", i64 0, i64 %t")
                    pint(ic)
                    putchar(10)
                    let evc = gepc + 1
                    emit_str("  %t")

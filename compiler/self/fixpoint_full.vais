    putchar(10)
    emit_str("copy_body:")
    putchar(10)
    emit_str("  %ckp = getelementptr i64, i64* %m, i64 %civ")
    putchar(10)
    emit_str("  %cki = load i64, i64* %ckp")
    putchar(10)
    emit_str("  %ckey = inttoptr i64 %cki to i8*")
    putchar(10)

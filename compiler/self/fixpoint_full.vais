                        emit_str(" = icmp sle i64 %t")
                        pint(lc0)
                        emit_str(", 0")
                        putchar(10)
                        emit_str("  br i1 %t")
                        pint(emptyc)
                        emit_str(", label %maxE")
                        pint(base)
                        emit_str(", label %maxN")
                        pint(base)
                        putchar(10)
                        emit_str("maxE")
                        pint(base)
                        emit_str(":")
                        putchar(10)
                        emit_str("  call void @llvm.trap()")
                        putchar(10)
                        emit_str("  br label %maxN")
                        pint(base)
                        putchar(10)
                        emit_str("maxN")
                        pint(base)
                        emit_str(":")
                        putchar(10)
                        let firstv = emptyc + 1
                        emit_str("  %t")
                        pint(firstv)
                        emit_str(" = load i64, i64* %t")
                        pint(bp)
                        putchar(10)
                        emit_str("  store i64 %t")
                        pint(firstv)
                        emit_str(", i64* %max")
                        pint(base)
                        putchar(10)
                        emit_str("  store i64 1, i64* %mi")
                        pint(base)
                        putchar(10)
                        emit_str("  br label %maxL")
                        pint(base)
                        putchar(10)
                        emit_str("maxL")
                        pint(base)
                        emit_str(":")
                        putchar(10)
                        let ic = firstv + 1
                        emit_str("  %t")
                        pint(ic)
                        emit_str(" = load i64, i64* %mi")
                        pint(base)
                        putchar(10)
                        let lp = ic + 1
                        emit_str("  %t")
                        pint(lp)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(bp)
                        emit_str(", i64 ")
                        pint(list_lenidx())
                        putchar(10)
                        let lc = lp + 1
                        emit_str("  %t")
                        pint(lc)
                        emit_str(" = load i64, i64* %t")
                        pint(lp)
                        putchar(10)
                        let loopc = lc + 1
                        emit_str("  %t")
                        pint(loopc)
                        emit_str(" = icmp slt i64 %t")
                        pint(ic)
                        emit_str(", %t")
                        pint(lc)
                        putchar(10)
                        emit_str("  br i1 %t")
                        pint(loopc)
                        emit_str(", label %maxB")
                        pint(base)
                        emit_str(", label %maxD")
                        pint(base)
                        putchar(10)
                        emit_str("maxB")
                        pint(base)
                        emit_str(":")
                        putchar(10)
                        let gepc = loopc + 1
                        emit_str("  %t")
                        pint(gepc)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(bp)
                        emit_str(", i64 %t")
                        pint(ic)
                        putchar(10)
                        let evc = gepc + 1
                        emit_str("  %t")
                        pint(evc)
                        emit_str(" = load i64, i64* %t")
                        pint(gepc)
                        putchar(10)
                        let svc = evc + 1
                        emit_str("  %t")
                        pint(svc)
                        emit_str(" = load i64, i64* %max")
                        pint(base)
                        putchar(10)
                        let cmpc = svc + 1
                        emit_str("  %t")
                        pint(cmpc)
                        emit_str(" = icmp ")
                        if use_min == 1 { emit_str("slt") } else { emit_str("sgt") }
                        emit_str(" i64 %t")
                        pint(evc)
                        emit_str(", %t")
                        pint(svc)
                        putchar(10)
                        let selc = cmpc + 1
                        emit_str("  %t")
                        pint(selc)
                        emit_str(" = select i1 %t")
                        pint(cmpc)
                        emit_str(", i64 %t")
                        pint(evc)
                        emit_str(", i64 %t")
                        pint(svc)
                        putchar(10)
                        emit_str("  store i64 %t")
                        pint(selc)
                        emit_str(", i64* %max")
                        pint(base)
                        putchar(10)
                        let inc = selc + 1
                        emit_str("  %t")
                        pint(inc)
                        emit_str(" = add i64 %t")
                        pint(ic)
                        emit_str(", 1")
                        putchar(10)
                        emit_str("  store i64 %t")
                        pint(inc)
                        emit_str(", i64* %mi")
                        pint(base)
                        putchar(10)
                        emit_str("  br label %maxL")
                        pint(base)
                        putchar(10)
                        emit_str("maxD")
                        pint(base)
                        emit_str(":")
                        putchar(10)
                        let resc = inc + 1
                        emit_str("  %t")
                        pint(resc)
                        emit_str(" = load i64, i64* %max")
                        pint(base)
                        putchar(10)
                        return Op { kind: 1, val: resc, next: resc + 1 }
                    }
                }
            }
            if karr == 3 {
                # Str locals can be reassigned from helper calls or Map payloads,
                # so `.len()` must inspect the current pointer value at runtime.
                let sslot = find_slot(slots, src, t.nstart, t.nlen)
                let basec = counter
                emit_str("  %t")
                pint(basec)
                emit_str(" = load i8*, i8** %v")
                pint(sslot)
                putchar(10)
                return emit_strlen_from_ptr(basec, basec + 1)
            }
            if karr == 4 {
                # List PARAMETER `.len`: load buffer ptr, GEP to the length slot,
                # load length. Scalar List: length at [63]. List-of-structs (sty>=0):
                # length at [64*nf] (past the strided data region).
                let pslot = find_slot(slots, src, t.nstart, t.nlen)
                let plsty = sty_of(slots, src, t.nstart, t.nlen)
                let mut plenidx2 = list_lenidx()
                if plsty >= 0 { plenidx2 = list_lenidx_for_nfields(struct_flat_nfields(toks, defs, src, plsty)) }
                let bp = counter
                emit_str("  %t")
                pint(bp)
                emit_str(" = load i64*, i64** %v")
                pint(pslot)
                putchar(10)
                let lp = bp + 1
                emit_str("  %t")
                pint(lp)
                emit_str(" = getelementptr i64, i64* %t")
                pint(bp)
                emit_str(", i64 ")
                pint(plenidx2)
                putchar(10)
                let lv = lp + 1
                emit_str("  %t")
                pint(lv)
                emit_str(" = load i64, i64* %t")
                pint(lp)
                putchar(10)
                return Op { kind: 1, val: lv, next: lv + 1 }
            }
            # struct field read requires a SCALAR struct var. A List var (is_arr=2)
            # carries the element struct type in sty too, but `lst.X` is ALWAYS the
            # List `.len` (a List has no addressable struct fields) -- so List vars
            # must skip this branch and fall through to the `.len` length load below.
            let sti = sty_of(slots, src, t.nstart, t.nlen)
            if sti >= 0 and karr != 2 {
                let fld = toks[i + 2]
                let slot = find_slot(slots, src, t.nstart, t.nlen)
                let nf = struct_flat_nfields(toks, defs, src, sti)
                let fi = field_chain_flat_offset(toks, defs, src, sti, i + 2)
                emit_str("  %t")
                pint(counter)
                emit_str(" = getelementptr [")
                pint(nf)
                emit_str(" x i64], [")
                pint(nf)
                emit_str(" x i64]* %v")
                pint(slot)
                emit_str(", i64 0, i64 ")
                pint(fi)
                putchar(10)
                let loadc = counter + 1
                emit_str("  %t")
                pint(loadc)
                emit_str(" = load i64, i64* %t")
                pint(counter)
                putchar(10)
                let fty = field_chain_type_index(toks, defs, src, sti, i + 2)
                if fty == 0 - 2 {
                    let fend = field_chain_end_pos(toks, defs, src, sti, i + 2)
                    return emit_str_from_i64_value(toks, src, loadc, fend, loadc + 1)
                }
                return Op { kind: 1, val: loadc, next: loadc + 1 }
            }
            # list length: lst.len -> load the length counter at %v<slot+1>
            let slot = find_slot(slots, src, t.nstart, t.nlen)
            emit_str("  %t")
            pint(counter)
            emit_str(" = load i64, i64* %v")
            pint(slot + 1)
            putchar(10)
            return Op { kind: 1, val: counter, next: counter + 1 }
        }
        if nx.kind == 23 {
            # string byte index: s[<expr>] -> load i8* base, GEP i8, load i8, zext
            let karr = isarr_of(slots, src, t.nstart, t.nlen)
            if karr == 3 {
                let sslot = find_slot(slots, src, t.nstart, t.nlen)
                let sbend = bracket_end(toks, i + 2)
                let sidx = gen_expr(toks, slots, fns, defs, src, i + 2, sbend, counter)
                let basec = sidx.next
                emit_str("  %t")
                pint(basec)
                emit_str(" = load i8*, i8** %v")
                pint(sslot)
                putchar(10)
                let sgepc = basec + 1
                emit_str("  %t")
                pint(sgepc)
                emit_str(" = getelementptr i8, i8* %t")
                pint(basec)
                emit_str(", i64 ")
                emit_op(sidx)
                putchar(10)
                let sldc = sgepc + 1
                emit_str("  %t")
                pint(sldc)
                emit_str(" = load i8, i8* %t")
                pint(sgepc)
                putchar(10)
                let szc = sldc + 1
                emit_str("  %t")
                pint(szc)
                emit_str(" = zext i8 %t")
                pint(sldc)
                emit_str(" to i64")
                putchar(10)
                return Op { kind: 1, val: szc, next: szc + 1 }
            }
            if karr == 4 {
                let p4sty = sty_of(slots, src, t.nstart, t.nlen)
                if p4sty >= 0 {
                    # List-of-structs PARAMETER element field: out[<expr>].field ->
                    # load bufptr, load buf[idx*nf + field_index] (stride nf).
                    let p4bend = bracket_end(toks, i + 2)
                    let p4dot = toks[p4bend + 1]
                    if p4dot.kind == 27 {
                        let p4fld = toks[p4bend + 2]
                        let p4slot = find_slot(slots, src, t.nstart, t.nlen)
                        let p4nf = struct_flat_nfields(toks, defs, src, p4sty)
                        let p4fi = field_chain_flat_offset(toks, defs, src, p4sty, p4bend + 2)
                        let p4idx = gen_expr(toks, slots, fns, defs, src, i + 2, p4bend, counter)
                        let p4base = p4idx.next
                        emit_str("  %t")
                        pint(p4base)
                        emit_str(" = load i64*, i64** %v")
                        pint(p4slot)
                        putchar(10)
                        let p4lenp = p4base + 1
                        emit_str("  %t")
                        pint(p4lenp)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(p4base)
                        emit_str(", i64 ")
                        pint(list_lenidx_for_nfields(p4nf))
                        putchar(10)
                        let p4len = p4lenp + 1
                        emit_str("  %t")
                        pint(p4len)
                        emit_str(" = load i64, i64* %t")
                        pint(p4lenp)
                        putchar(10)
                        let p4after = emit_list_bounds_trap(p4idx, Op { kind: 1, val: p4len, next: 0 }, p4len + 1)
                        let p4mul = p4after
                        emit_str("  %t")
                        pint(p4mul)
                        emit_str(" = mul i64 ")
                        emit_op(p4idx)
                        emit_str(", ")
                        pint(p4nf)
                        putchar(10)
                        let p4off = p4mul + 1
                        emit_str("  %t")
                        pint(p4off)
                        emit_str(" = add i64 %t")
                        pint(p4mul)
                        emit_str(", ")
                        pint(p4fi)
                        putchar(10)
                        let p4gep = p4off + 1
                        emit_str("  %t")
                        pint(p4gep)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(p4base)
                        emit_str(", i64 %t")
                        pint(p4off)
                        putchar(10)
                        let p4ld = p4gep + 1
                        emit_str("  %t")
                        pint(p4ld)
	                        emit_str(" = load i64, i64* %t")
	                        pint(p4gep)
	                        putchar(10)
	                        let p4fty = field_chain_type_index(toks, defs, src, p4sty, p4bend + 2)
	                        if p4fty == 0 - 2 {
	                            let p4fend = field_chain_end_pos(toks, defs, src, p4sty, p4bend + 2)
	                            return emit_str_from_i64_value(toks, src, p4ld, p4fend, p4ld + 1)
	                        }
	                        return Op { kind: 1, val: p4ld, next: p4ld + 1 }
	                    }
                }
                # List PARAMETER index (scalar): load buffer ptr, GEP i64, load i64.
                let pslot = find_slot(slots, src, t.nstart, t.nlen)
                let pbend = bracket_end(toks, i + 2)
                let pidx = gen_expr(toks, slots, fns, defs, src, i + 2, pbend, counter)
                let pbase = pidx.next
                emit_str("  %t")
                pint(pbase)
                emit_str(" = load i64*, i64** %v")
                pint(pslot)
                putchar(10)
                let plenp = pbase + 1
                emit_str("  %t")
                pint(plenp)
                emit_str(" = getelementptr i64, i64* %t")
                pint(pbase)
                emit_str(", i64 ")
                pint(list_lenidx())
                putchar(10)
                let plen = plenp + 1
                emit_str("  %t")
                pint(plen)
                emit_str(" = load i64, i64* %t")
                pint(plenp)
                putchar(10)
                let pafter = emit_list_bounds_trap(pidx, Op { kind: 1, val: plen, next: 0 }, plen + 1)
                let pgep = pafter
                emit_str("  %t")
                pint(pgep)
                emit_str(" = getelementptr i64, i64* %t")
                pint(pbase)
                emit_str(", i64 ")
                emit_op(pidx)
                putchar(10)
                let pld = pgep + 1
                emit_str("  %t")
                pint(pld)
                emit_str(" = load i64, i64* %t")
                pint(pgep)
                putchar(10)
                if p4sty == 0 - 2 {
                    let pptr = pld + 1
                    emit_str("  %t")
                    pint(pptr)
                    emit_str(" = inttoptr i64 %t")
                    pint(pld)
                    emit_str(" to i8*")
                    putchar(10)
                    let lend = trailing_len_call_end(toks, src, pbend + 1)
                    if lend != pbend + 1 {
                        return emit_strlen_from_ptr(pptr, pptr + 1)
                    }
                    return Op { kind: 2, val: pptr, next: pptr + 1 }
                }
                return Op { kind: 1, val: pld, next: pld + 1 }
            }
            # List-of-structs element field read: toks[<expr>].field
            #   buffer [64*nf x i64], element stride nf -> load buf[idx*nf + fi].
            let lsty2 = sty_of(slots, src, t.nstart, t.nlen)
            if karr == 2 {
              if lsty2 >= 0 {
                let lbend = bracket_end(toks, i + 2)
                let dotk = toks[lbend + 1]
                if dotk.kind == 27 {
                    let fld = toks[lbend + 2]
                    let lslot = find_slot(slots, src, t.nstart, t.nlen)
                    let nf = struct_flat_nfields(toks, defs, src, lsty2)
                    let lbuf = list_bufsz_for_nfields(nf)
                    let fi = field_chain_flat_offset(toks, defs, src, lsty2, lbend + 2)
                    let lidx = gen_expr(toks, slots, fns, defs, src, i + 2, lbend, counter)
                    let llen = lidx.next
                    emit_str("  %t")
                    pint(llen)
                    emit_str(" = load i64, i64* %v")
                    pint(lslot + 1)
                    putchar(10)
                    let lafter = emit_list_bounds_trap(lidx, Op { kind: 1, val: llen, next: 0 }, llen + 1)
                    let mulc = lafter
                    emit_str("  %t")
                    pint(mulc)
                    emit_str(" = mul i64 ")
                    emit_op(lidx)
                    emit_str(", ")
                    pint(nf)
                    putchar(10)
                    let offc = mulc + 1
                    emit_str("  %t")
                    pint(offc)
                    emit_str(" = add i64 %t")
                    pint(mulc)
                    emit_str(", ")
                    pint(fi)
                    putchar(10)
                    let lgepc = offc + 1
                    emit_str("  %t")
                    pint(lgepc)
                    emit_str(" = getelementptr [")
                    pint(lbuf)
                    emit_str(" x i64], [")
                    pint(lbuf)
                    emit_str(" x i64]* %v")
                    pint(lslot)
                    emit_str(", i64 0, i64 %t")
                    pint(offc)
                    putchar(10)
                    let lldc = lgepc + 1
                    emit_str("  %t")
                    pint(lldc)
                    emit_str(" = load i64, i64* %t")
                    pint(lgepc)
                    putchar(10)
                    let lfty = field_chain_type_index(toks, defs, src, lsty2, lbend + 2)
                    if lfty == 0 - 2 {
                        let lfend = field_chain_end_pos(toks, defs, src, lsty2, lbend + 2)
                        return emit_str_from_i64_value(toks, src, lldc, lfend, lldc + 1)
                    }
                    return Op { kind: 1, val: lldc, next: lldc + 1 }
                }
              }
            }
            # array/list index read: name [ <expr> ] -> GEP + load
            let slot = find_slot(slots, src, t.nstart, t.nlen)
            let alen = arrlen_of(slots, src, t.nstart, t.nlen)
            let elem_sty = sty_of(slots, src, t.nstart, t.nlen)
            let bend = bracket_end(toks, i + 2)
            let idx = gen_expr(toks, slots, fns, defs, src, i + 2, bend, counter)
            let mut gepc = idx.next
            if karr == 2 {
                emit_str("  %t")
                pint(gepc)
                emit_str(" = load i64, i64* %v")
                pint(slot + 1)
                putchar(10)
                let dlen = gepc
                gepc = emit_list_bounds_trap(idx, Op { kind: 1, val: dlen, next: 0 }, dlen + 1)
            }
            emit_str("  %t")
            pint(gepc)
            emit_str(" = getelementptr [")
            pint(alen)
            emit_str(" x i64], [")
            pint(alen)
            emit_str(" x i64]* %v")
            pint(slot)
            emit_str(", i64 0, i64 ")
            emit_op(idx)
            putchar(10)
            let loadc = gepc + 1
            emit_str("  %t")
            pint(loadc)
            emit_str(" = load i64, i64* %t")
            pint(gepc)
            putchar(10)
            if karr == 2 and elem_sty == 0 - 2 {
                let ptrc = loadc + 1
                emit_str("  %t")
                pint(ptrc)
                emit_str(" = inttoptr i64 %t")
                pint(loadc)
                emit_str(" to i8*")
                putchar(10)
                let lend = trailing_len_call_end(toks, src, bend + 1)
                if lend != bend + 1 {
                    return emit_strlen_from_ptr(ptrc, ptrc + 1)
                }
                return Op { kind: 2, val: ptrc, next: ptrc + 1 }
            }
            return Op { kind: 1, val: loadc, next: loadc + 1 }
        }
        let slot = find_slot(slots, src, t.nstart, t.nlen)
        if slot < 0 {
            # Unresolved identifier: emit an attributable undefined marker so a
            # half-lowered shape fails at the clang stage naming the identifier
            # (`use of undefined value '@VAIS_UNRESOLVED_IDENT_<name>'`)
            # instead of the cryptic `%v-1`.
            emit_str("  %t")
            pint(counter)
            emit_str(" = load i64, i64* @VAIS_UNRESOLVED_IDENT_")
            emit_name(src, t.nstart, t.nlen)
            putchar(10)
            return Op { kind: 1, val: counter, next: counter + 1 }
        }
        if isarr_of(slots, src, t.nstart, t.nlen) == 3 {
            emit_str("  %t")
            pint(counter)
            emit_str(" = load i8*, i8** %v")
            pint(slot)
            putchar(10)
            return Op { kind: 2, val: counter, next: counter + 1 }
        }
        if isarr_of(slots, src, t.nstart, t.nlen) == 5 or isarr_of(slots, src, t.nstart, t.nlen) == 6 {
            emit_map_base_ptr(slots, src, t.nstart, t.nlen, counter)
            return Op { kind: 3, val: counter, next: counter + 1 }
        }
        # emit `  %t<counter> = load i64, i64* %v<slot>`
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %v")
        pint(slot)
        putchar(10)
        return Op { kind: 1, val: counter, next: counter + 1 }
    }
    return Op { kind: 0, val: 0, next: counter }
}

fn emit_binop(op_s: Str, l: Op, r: Op, counter: Int) -> Int {
    emit_str("  %t")
    pint(counter)
    emit_str(" = ")
    emit_str(op_s)
    emit_str(" i64 ")
    emit_op(l)
    emit_str(", ")
    emit_op(r)
    putchar(10)
    return counter
}

fn gen_term(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, stop: Int, acc: Op) -> Op {
    if i >= stop { return acc }
    let t = toks[i]
    if t.kind == 3 or t.kind == 38 or t.kind == 39 {
        let rf = gen_factor(toks, slots, fns, defs, src, i + 1, acc.next)
        let mut dest = 0
        if t.kind == 38 { dest = emit_binop("sdiv", acc, rf, rf.next) }
        else if t.kind == 39 { dest = emit_binop("srem", acc, rf, rf.next) }
        else { dest = emit_binop("mul", acc, rf, rf.next) }
        let nacc = Op { kind: 1, val: dest, next: dest + 1 }
        let after = skip_factor(toks, src, i + 1)
        return gen_term(toks, slots, fns, defs, src, after, stop, nacc)
    }
    return acc
}
fn skip_term(toks: &List<Token>, src: Str, i: Int, stop: Int) -> Int {
    if i >= stop { return stop }
    let t = toks[i]
    if t.kind == 3 or t.kind == 38 or t.kind == 39 {
        let after = skip_factor(toks, src, i + 1)
        return skip_term(toks, src, after, stop)
    }
    return i
}
fn gen_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, stop: Int, counter: Int) -> Op {
    let f0 = gen_factor(toks, slots, fns, defs, src, i, counter)
    let af = skip_factor(toks, src, i)
    let t0 = gen_term(toks, slots, fns, defs, src, af, stop, f0)
    let after = skip_term(toks, src, af, stop)
    return gen_fold(toks, slots, fns, defs, src, after, stop, t0)
}

fn gen_str_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, stop: Int, counter: Int) -> Op {
    if map_str_str_get_opt_match_result_is_str_at(toks, slots, src, i, stop) == 1 {
        return emit_map_str_str_get_opt_match_str_expr(toks, slots, fns, defs, src, i, stop, counter)
    }
    return gen_expr(toks, slots, fns, defs, src, i, stop, counter)
}
# Index just past the matching ')' for the '(' at index `op2` (args start). `op2`
# is the token after '('. Returns the ')' index.
fn paren_end(toks: &List<Token>, op2: Int) -> Int {
    let mut j = op2
    let mut depth = 0
    let mut go = true
    while go {
        let t = toks[j]
        if t.kind == 9 { depth = depth + 1; j = j + 1 }
        else if t.kind == 10 {
            if depth == 0 { go = false } else { depth = depth - 1; j = j + 1 }
        }
        else { j = j + 1 }
    }
    return j
}
# Find the end of a call argument: next ',' or ')' at delimiter-depth 0 (so
# nested calls, struct literals, and array literals are skipped). `close` bounds
# the scan (the call's ')').
fn arg_comma_end(toks: &List<Token>, i: Int, close: Int) -> Int {
    let mut j = i
    let mut depth = 0
    let mut bdepth = 0
    let mut sdepth = 0
    let mut go = true
    while go {
        if j >= close { go = false }
        else {
            let t = toks[j]
            if t.kind == 9 { depth = depth + 1; j = j + 1 }
            else if t.kind == 10 {
                if depth == 0 { go = false } else { depth = depth - 1; j = j + 1 }
            }
            else if t.kind == 11 { bdepth = bdepth + 1; j = j + 1 }
            else if t.kind == 12 { if bdepth == 0 { j = j + 1 } else { bdepth = bdepth - 1; j = j + 1 } }
            else if t.kind == 23 { sdepth = sdepth + 1; j = j + 1 }
            else if t.kind == 24 { if sdepth == 0 { j = j + 1 } else { sdepth = sdepth - 1; j = j + 1 } }
            else if t.kind == 25 {
                if depth == 0 and bdepth == 0 and sdepth == 0 { go = false } else { j = j + 1 }
            }
            else { j = j + 1 }
        }
    }
    return j
}

fn emit_strlen_from_ptr(ptr: Int, counter: Int) -> Op {
    let lenslot = counter
    emit_str("  %sl")
    pint(lenslot)
    emit_str(" = alloca i64")
    putchar(10)
    emit_str("  store i64 0, i64* %sl")
    pint(lenslot)
    putchar(10)
    emit_str("  br label %slL")
    pint(lenslot)
    putchar(10)
    emit_str("slL")
    pint(lenslot)
    emit_str(":")
    putchar(10)
    let ic = lenslot + 1
    emit_str("  %t")
    pint(ic)
    emit_str(" = load i64, i64* %sl")
    pint(lenslot)
    putchar(10)
    let gepc = ic + 1
    emit_str("  %t")
    pint(gepc)
    emit_str(" = getelementptr i8, i8* %t")
    pint(ptr)
    emit_str(", i64 %t")
    pint(ic)
    putchar(10)
    let bc = gepc + 1
    emit_str("  %t")
    pint(bc)
    emit_str(" = load i8, i8* %t")
    pint(gepc)
    putchar(10)
    let cc = bc + 1
    emit_str("  %t")
    pint(cc)
    emit_str(" = icmp eq i8 %t")
    pint(bc)
    emit_str(", 0")
    putchar(10)
    emit_str("  br i1 %t")
    pint(cc)
    emit_str(", label %slD")
    pint(lenslot)
    emit_str(", label %slB")
    pint(lenslot)
    putchar(10)
    emit_str("slB")
    pint(lenslot)
    emit_str(":")
    putchar(10)
    let nc = cc + 1
    emit_str("  %t")
    pint(nc)
    emit_str(" = add i64 %t")
    pint(ic)
    emit_str(", 1")
    putchar(10)
    emit_str("  store i64 %t")
    pint(nc)
    emit_str(", i64* %sl")
    pint(lenslot)
    putchar(10)
    emit_str("  br label %slL")
    pint(lenslot)
    putchar(10)
    emit_str("slD")
    pint(lenslot)
    emit_str(":")
    putchar(10)
    let resc = nc + 1
    emit_str("  %t")
    pint(resc)
    emit_str(" = load i64, i64* %sl")
    pint(lenslot)
    putchar(10)
    return Op { kind: 1, val: resc, next: resc + 1 }
}

fn emit_map_str_str_match_str_arm(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, binder_i: Int, payload_ptr: Int, counter: Int) -> Op {
    let binder = toks[binder_i]
    if arm_is_payload_bare(toks, src, start, stop, binder.nstart, binder.nlen) == 1 {
        return Op { kind: 2, val: payload_ptr, next: counter }
    }
    let t = toks[start]
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 == stop {
                if is_str_trim(src, t.nstart, t.nlen) == 1 {
                    let arg = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start + 2, close, binder_i, payload_ptr, counter)
                    let dest = arg.next
                    emit_str("  %t")
                    pint(dest)
                    emit_str(" = call i8* @__vais_str_trim(i8* ")
                    emit_op(arg)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest, next: dest + 1 }
                }
                if is_str_lower(src, t.nstart, t.nlen) == 1 {
                    let arg2 = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start + 2, close, binder_i, payload_ptr, counter)
                    let dest2 = arg2.next
                    emit_str("  %t")
                    pint(dest2)
                    emit_str(" = call i8* @__vais_str_lower(i8* ")
                    emit_op(arg2)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest2, next: dest2 + 1 }
                }
                if is_str_upper(src, t.nstart, t.nlen) == 1 {
                    let arg_upper = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start + 2, close, binder_i, payload_ptr, counter)
                    let dest_upper = arg_upper.next
                    emit_str("  %t")
                    pint(dest_upper)
                    emit_str(" = call i8* @__vais_str_upper(i8* ")
                    emit_op(arg_upper)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_upper, next: dest_upper + 1 }
                }
                if is_str_concat(src, t.nstart, t.nlen) == 1 {
                    let comma = arg_comma_end(toks, start + 2, close)
                    let left = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start + 2, comma, binder_i, payload_ptr, counter)
                    let right = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, comma + 1, close, binder_i, payload_ptr, left.next)
                    let dest3 = right.next
                    emit_str("  %t")
                    pint(dest3)
                    emit_str(" = call i8* @__vais_str_concat(i8* ")
                    emit_op(left)
                    emit_str(", i8* ")
                    emit_op(right)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest3, next: dest3 + 1 }
                }
                if is_str_replace(src, t.nstart, t.nlen) == 1 {
                    let comma_r1 = arg_comma_end(toks, start + 2, close)
                    let r_text = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start + 2, comma_r1, binder_i, payload_ptr, counter)
                    let comma_r2 = arg_comma_end(toks, comma_r1 + 1, close)
                    let r_needle = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, comma_r1 + 1, comma_r2, binder_i, payload_ptr, r_text.next)
                    let r_value = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, comma_r2 + 1, close, binder_i, payload_ptr, r_needle.next)
                    let dest4 = r_value.next
                    emit_str("  %t")
                    pint(dest4)
                    emit_str(" = call i8* @__vais_str_replace(i8* ")
                    emit_op(r_text)
                    emit_str(", i8* ")
                    emit_op(r_needle)
                    emit_str(", i8* ")
                    emit_op(r_value)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest4, next: dest4 + 1 }
                }
            }
        }
    }
    return gen_expr(toks, slots, fns, defs, src, start, stop, counter)
}

fn emit_map_str_str_match_int_arm(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, binder_i: Int, payload_ptr: Int, counter: Int) -> Op {
    let binder = toks[binder_i]
    if arm_is_str_expr_len(toks, slots, src, start, stop, binder.nstart, binder.nlen) == 1 {
        let sop = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, start, stop - 4, binder_i, payload_ptr, counter)
        return emit_strlen_from_ptr(sop.val, sop.next)
    }
    if arm_is_payload_len(toks, src, start, stop, binder.nstart, binder.nlen) == 1 {
        return emit_strlen_from_ptr(payload_ptr, counter)
    }
    return gen_expr(toks, slots, fns, defs, src, start, stop, counter)
}

fn emit_map_str_str_get_opt_match_let(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, npos: Int, slot: Int, dest_is_str: Int, counter0: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let basei = map_str_str_get_opt_match_base_index(toks, slots, src, vp)
    if basei < 0 { return counter0 }
    let base = toks[basei]
    let close = paren_end(toks, vp + 5)
    let bo = close + 1
    let binder_i = bo + 3
    let binder = toks[bo + 3]
    let ss = map_get_opt_match_some_expr_start(toks, vp)
    let se = map_get_opt_match_some_expr_end(toks, vp)
    let ns = map_get_opt_match_none_expr_start(toks, vp)
    let ne = map_get_opt_match_none_expr_end(toks, vp)
    let key = gen_map_key_expr(toks, slots, fns, defs, src, base.nstart, base.nlen, vp + 5, close, counter0)
    let basec = key.next
    emit_map_base_ptr(slots, src, base.nstart, base.nlen, basec)
    let hasc = basec + 1
    emit_str("  %t")
    pint(hasc)
    emit_str(" = call i64 @")
    emit_map_helper_name(slots, src, base.nstart, base.nlen, "contains")
    emit_str("(i64* %t")
    pint(basec)
    emit_str(", ")
    emit_map_key_arg(slots, src, base.nstart, base.nlen, key)
    emit_str(")")
    putchar(10)
    let is_some = hasc + 1
    emit_str("  %t")
    pint(is_some)
    emit_str(" = icmp eq i64 %t")
    pint(hasc)
    emit_str(", 1")
    putchar(10)
    let lbl = is_some + 1
    emit_str("  br i1 %t")
    pint(is_some)
    emit_str(", label %mssThen")
    pint(lbl)
    emit_str(", label %mssElse")
    pint(lbl)
    putchar(10)
    emit_str("mssThen")
    pint(lbl)
    emit_str(":")
    putchar(10)
    let got_i = lbl + 1
    emit_str("  %t")
    pint(got_i)
    emit_str(" = call i64 @")
    emit_map_helper_name(slots, src, base.nstart, base.nlen, "get")
    emit_str("(i64* %t")
    pint(basec)
    emit_str(", ")
    emit_map_key_arg(slots, src, base.nstart, base.nlen, key)
    emit_str(", i64 0)")
    putchar(10)
    let payload_ptr = got_i + 1
    emit_str("  %t")
    pint(payload_ptr)
    emit_str(" = inttoptr i64 %t")
    pint(got_i)
    emit_str(" to i8*")
    putchar(10)
    let mut cc = payload_ptr + 1
    if dest_is_str == 1 {
        let sop = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, ss, se, binder_i, payload_ptr, cc)
        cc = sop.next
        emit_str("  store i8* ")
        emit_op(sop)
        emit_str(", i8** %v")
        pint(slot)
        putchar(10)
    } else {
        let iop = emit_map_str_str_match_int_arm(toks, slots, fns, defs, src, ss, se, binder_i, payload_ptr, cc)
        cc = iop.next
        emit_str("  store i64 ")
        emit_op(iop)
        emit_str(", i64* %v")
        pint(slot)
        putchar(10)
    }
    emit_str("  br label %mssMerge")
    pint(lbl)
    putchar(10)
    emit_str("mssElse")
    pint(lbl)
    emit_str(":")
    putchar(10)
    if dest_is_str == 1 {
        let nop = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, ns, ne, binder_i, payload_ptr, cc)
        cc = nop.next
        emit_str("  store i8* ")
        emit_op(nop)
        emit_str(", i8** %v")
        pint(slot)
        putchar(10)
    } else {
        let niop = emit_map_str_str_match_int_arm(toks, slots, fns, defs, src, ns, ne, binder_i, payload_ptr, cc)
        cc = niop.next
        emit_str("  store i64 ")
        emit_op(niop)
        emit_str(", i64* %v")
        pint(slot)
        putchar(10)
    }
    emit_str("  br label %mssMerge")
    pint(lbl)
    putchar(10)
    emit_str("mssMerge")
    pint(lbl)
    emit_str(":")
    putchar(10)
    return cc
}

fn emit_map_str_str_get_opt_match_str_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, stop: Int, counter0: Int) -> Op {
    let basei = map_str_str_get_opt_match_base_index(toks, slots, src, vp)
    let base = toks[basei]
    let close = paren_end(toks, vp + 5)
    let bo = close + 1
    let binder_i = bo + 3
    let ss = map_get_opt_match_some_expr_start(toks, vp)
    let se = map_get_opt_match_some_expr_end(toks, vp)
    let ns = map_get_opt_match_none_expr_start(toks, vp)
    let ne = map_get_opt_match_none_expr_end(toks, vp)
    let nop = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, ns, ne, binder_i, counter0, counter0)
    let none_i = ensure_i64_op(nop, nop.next)
    let key = gen_map_key_expr(toks, slots, fns, defs, src, base.nstart, base.nlen, vp + 5, close, none_i.next)
    let basec = key.next
    emit_map_base_ptr(slots, src, base.nstart, base.nlen, basec)
    let hasc = basec + 1
    emit_str("  %t")
    pint(hasc)
    emit_str(" = call i64 @")
    emit_map_helper_name(slots, src, base.nstart, base.nlen, "contains")
    emit_str("(i64* %t")
    pint(basec)
    emit_str(", ")
    emit_map_key_arg(slots, src, base.nstart, base.nlen, key)
    emit_str(")")
    putchar(10)
    let got_i = hasc + 1
    emit_str("  %t")
    pint(got_i)
    emit_str(" = call i64 @")
    emit_map_helper_name(slots, src, base.nstart, base.nlen, "get")
    emit_str("(i64* %t")
    pint(basec)
    emit_str(", ")
    emit_map_key_arg(slots, src, base.nstart, base.nlen, key)
    emit_str(", i64 ")
    emit_op(none_i)
    emit_str(")")
    putchar(10)
    let payload_ptr = got_i + 1
    emit_str("  %t")
    pint(payload_ptr)
    emit_str(" = inttoptr i64 %t")
    pint(got_i)
    emit_str(" to i8*")
    putchar(10)
    let sop = emit_map_str_str_match_str_arm(toks, slots, fns, defs, src, ss, se, binder_i, payload_ptr, payload_ptr + 1)
    let is_some = sop.next
    emit_str("  %t")
    pint(is_some)
    emit_str(" = icmp eq i64 %t")
    pint(hasc)
    emit_str(", 1")
    putchar(10)
    let resultp = is_some + 1
    emit_str("  %t")
    pint(resultp)
    emit_str(" = select i1 %t")
    pint(is_some)
    emit_str(", i8* ")
    emit_op(sop)
    emit_str(", i8* ")
    emit_op(nop)
    putchar(10)
    return Op { kind: 2, val: resultp, next: resultp + 1 }
}

fn trailing_len_call_end(toks: &List<Token>, src: Str, pos: Int) -> Int {
    let dot = toks[pos]
    if dot.kind != 27 { return pos }
    let meth = toks[pos + 1]
    if meth.kind != 1 { return pos }
    if kw3(src, meth.nstart, meth.nlen, 108, 101, 110) != 1 { return pos }
    let op = toks[pos + 2]
    if op.kind == 9 {
        let close = paren_end(toks, pos + 3)
        if close == pos + 3 { return close + 1 }
        return pos
    }
    return pos + 2
}

# Advance past one factor: number/var = 1 token; call = name '(' ... ')';
# array index = name '[' ... ']'.
fn skip_factor(toks: &List<Token>, src: Str, i: Int) -> Int {
    let t = toks[i]
    if t.kind == 42 { return skip_factor(toks, src, i + 1) }
    if t.kind == 9 {
        # parenthesized group `( ... )` -> skip to just past the matching ')'.
        return paren_end(toks, i + 1) + 1
    }
    if t.kind == 1 {
        let nx = toks[i + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, i + 2)
            let dot = toks[close + 1]
            if dot.kind == 27 {
                let mut j = close + 3
                let mut go = true
                while go {
                    let maybe_dot = toks[j]
                    if maybe_dot.kind == 27 { j = j + 2 } else { go = false }
                }
                let after_chain = toks[j]
                if after_chain.kind == 9 {
                    let mend = paren_end(toks, j + 1) + 1
                    let lend = trailing_len_call_end(toks, src, mend)
                    if lend != mend { return lend }
                    return mend
                }
                return j
            }
            return close + 1
        }
        if nx.kind == 23 {
            # name [ idx ]  -> just past ']'. But a List-of-structs element field
            # read `name [ idx ] . field` extends 2 more tokens (. field), and
            # a List<Str> element can chain `.len()`.
            let be = bracket_end(toks, i + 2)
            let pd = toks[be + 1]
            if pd.kind == 27 {
                let mut j = be + 3
                let mut go = true
                while go {
                    let maybe_dot = toks[j]
                    if maybe_dot.kind == 27 { j = j + 2 } else { go = false }
                }
                let after = toks[j]
                if after.kind == 9 {
                    let mend = paren_end(toks, j + 1) + 1
                    let lend = trailing_len_call_end(toks, src, mend)
                    if lend != mend { return lend }
                    return mend
                }
                return j
            }
            return be + 1
        }
        if nx.kind == 27 {
            # name . field  = 3 tokens; nested scalar struct reads can chain
            # additional `.field` pairs. name . len ( ) still skips the call.
            let mut j = i + 3
            let mut go = true
            while go {
                let maybe_dot = toks[j]
                if maybe_dot.kind == 27 { j = j + 2 } else { go = false }
            }
            let after = toks[j]
            if after.kind == 9 {
                let mend = paren_end(toks, j + 1) + 1
                let lend = trailing_len_call_end(toks, src, mend)
                if lend != mend { return lend }
                let mdot = toks[mend]
                if mdot.kind == 27 {
                    let mut mj = mend + 2
                    let mut mgo = true
                    while mgo {
                        let maybe_mdot = toks[mj]
                        if maybe_mdot.kind == 27 { mj = mj + 2 } else { mgo = false }
                    }
                    let mafter = toks[mj]
                    if mafter.kind == 9 {
                        let mmend = paren_end(toks, mj + 1) + 1
                        let mlend = trailing_len_call_end(toks, src, mmend)
                        if mlend != mmend { return mlend }
                        return mmend
                    }
                    return mj
                }
                return mend
            }
            return j
        }
    }
    return i + 1
}
# Find the next `and`(31)/`or`(32) at paren-depth 0 in [i, stop); returns stop if
# none. Used to bound a comparison's RHS so `and`/`or` stay lower-precedence.
fn next_logical(toks: &List<Token>, i: Int, stop: Int) -> Int {
    let mut j = i
    let mut depth = 0
    let mut go = true
    while go {
        if j >= stop { go = false }
        else {
            let t = toks[j]
            if t.kind == 9 { depth = depth + 1; j = j + 1 }
            else if t.kind == 10 { depth = depth - 1; j = j + 1 }
            else if depth == 0 {
                if t.kind == 31 { go = false } else if t.kind == 32 { go = false } else { j = j + 1 }
            }
            else { j = j + 1 }
        }
    }
    return j
}
fn gen_fold(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, stop: Int, acc: Op) -> Op {
    if i >= stop { return acc }
    let op = toks[i]
    if op.kind == 2 {
        let rf = gen_factor(toks, slots, fns, defs, src, i + 1, acc.next)
        let rt = gen_term(toks, slots, fns, defs, src, skip_factor(toks, src, i + 1), stop, rf)
        let dest = emit_binop("add", acc, rt, rt.next)
        let nacc = Op { kind: 1, val: dest, next: dest + 1 }
        return gen_fold(toks, slots, fns, defs, src, skip_term(toks, src, skip_factor(toks, src, i + 1), stop), stop, nacc)
    }
    if op.kind == 4 {
        let rf = gen_factor(toks, slots, fns, defs, src, i + 1, acc.next)
        let rt = gen_term(toks, slots, fns, defs, src, skip_factor(toks, src, i + 1), stop, rf)
        let dest = emit_binop("sub", acc, rt, rt.next)
        let nacc = Op { kind: 1, val: dest, next: dest + 1 }
        return gen_fold(toks, slots, fns, defs, src, skip_term(toks, src, skip_factor(toks, src, i + 1), stop), stop, nacc)
    }
    # comparison as a value: `<` (18) / `>` (19) / `==` (20) -> icmp + zext i1->i64.
    # Lower precedence than +/-, so the RHS is a full additive expression
    # (gen_expr from the operand). The boolean result is widened to i64 (1/0).
    if op.kind == 18 or op.kind == 19 or op.kind == 20 or op.kind == 29 or op.kind == 30 or op.kind == 33 {
        # RHS is the additive expr up to the next `and`/`or` (so logicals stay
        # lower-precedence): `c >= 48 and c <= 57` parses as `(c>=48) and (c<=57)`.
        # kind 33 = `!=` (not-equal); the others are < > == <= >=.
        if op.kind == 20 or op.kind == 33 {
            let ltok = toks[i - 1]
            let rtok = toks[i + 1]
            if ltok.kind == 1 {
                if rtok.kind == 1 {
                    let seq = string_slot_eq(slots, src, ltok.nstart, ltok.nlen, rtok.nstart, rtok.nlen)
                    if seq >= 0 {
                        let mut sv = seq
                        if op.kind == 33 {
                            if seq == 0 { sv = 1 } else { sv = 0 }
                        }
                        let cacc0 = Op { kind: 0, val: sv, next: acc.next }
                        return gen_fold(toks, slots, fns, defs, src, skip_factor(toks, src, i + 1), stop, cacc0)
                    }
                }
            }
        }
        let rstop = next_logical(toks, i + 1, stop)
        let rhs = gen_expr(toks, slots, fns, defs, src, i + 1, rstop, acc.next)
        let cnum = rhs.next
        if op.kind == 20 or op.kind == 33 {
            if acc.kind == 2 {
                if rhs.kind == 2 {
                    emit_str("  %t")
                    pint(cnum)
                    emit_str(" = call i64 @__vais_str_eq(i8* ")
                    emit_op(acc)
                    emit_str(", i8* ")
                    emit_op(rhs)
                    emit_str(")")
                    putchar(10)
                    if op.kind == 33 {
                        let nnum = cnum + 1
                        emit_str("  %t")
                        pint(nnum)
                        emit_str(" = xor i64 %t")
                        pint(cnum)
                        emit_str(", 1")
                        putchar(10)
                        let nacc = Op { kind: 1, val: nnum, next: nnum + 1 }
                        return gen_fold(toks, slots, fns, defs, src, rstop, stop, nacc)
                    }
                    let sacc = Op { kind: 1, val: cnum, next: cnum + 1 }
                    return gen_fold(toks, slots, fns, defs, src, rstop, stop, sacc)
                }
            }
        }
        emit_str("  %t")
        pint(cnum)
        emit_str(" = icmp ")
        if op.kind == 18 { emit_str("slt") } else if op.kind == 19 { emit_str("sgt") } else if op.kind == 29 { emit_str("sle") } else if op.kind == 30 { emit_str("sge") } else if op.kind == 33 { emit_str("ne") } else { emit_str("eq") }
        emit_str(" i64 ")
        emit_op(acc)
        emit_str(", ")
        emit_op(rhs)
        putchar(10)
        let zc = cnum + 1
        emit_str("  %t")
        pint(zc)
        emit_str(" = zext i1 %t")
        pint(cnum)
        emit_str(" to i64")
        putchar(10)
        let cacc = Op { kind: 1, val: zc, next: zc + 1 }
        # continue folding from rstop so a following `and`/`or` is applied.
        return gen_fold(toks, slots, fns, defs, src, rstop, stop, cacc)
    }
    # logical `and` (31) / `or` (32) as a value. Operands are 0/1 (from
    # comparisons), so bitwise `and i64`/`or i64` yields the correct boolean.
    # Lowest precedence -> RHS is a full expression (gen_expr).
    if op.kind == 31 or op.kind == 32 {
        # RHS is the next comparison/additive expr up to the following `and`/`or`
        # (left-associative): `a and b and c` -> `((a and b) and c)`.
        let rstop = next_logical(toks, i + 1, stop)
        let rhs = gen_expr(toks, slots, fns, defs, src, i + 1, rstop, acc.next)
        let dest = rhs.next
        emit_str("  %t")
        pint(dest)
        emit_str(" = ")
        if op.kind == 31 { emit_str("and") } else { emit_str("or") }
        emit_str(" i64 ")
        emit_op(acc)
        emit_str(", ")
        emit_op(rhs)
        putchar(10)
        let nacc = Op { kind: 1, val: dest, next: dest + 1 }
        return gen_fold(toks, slots, fns, defs, src, rstop, stop, nacc)
    }
    return acc
}

fn find_semi(toks: &List<Token>, i: Int, n: Int) -> Int {
    if i >= n { return n }
    let t = toks[i]
    if t.kind == 6 { return i }
    return find_semi(toks, i + 1, n)
}

fn source_newline_between(src: Str, a: Int, b: Int) -> Int {
    let mut i = a
    let n = src.len()
    while i < b and i < n {
        if src[i] == 10 { return 1 }
        i = i + 1
    }
    return 0
}

fn prev_source_end(toks: &List<Token>, i: Int) -> Int {
    let mut k = i
    while k > 0 {
        k = k - 1
        let t = toks[k]
        if t.nstart > 0 { return t.nstart + t.nlen }
    }
    return 0
}

fn token_can_start_stmt_at(toks: &List<Token>, j: Int, n: Int) -> Int {
    let t = toks[j]
    if t.kind == 7 { return 1 }
    if t.kind == 8 { return 1 }
    if t.kind == 15 { return 1 }
    if t.kind == 22 { return 1 }
    if t.kind == 34 { return 1 }
    if t.kind == 40 { return 1 }
    if t.kind == 41 { return 1 }
    if t.kind == 1 {
        if j + 1 >= n { return 0 }
        let nx = toks[j + 1]
        if nx.kind == 5 { return 1 }
        if nx.kind == 9 { return 1 }
        if nx.kind == 23 { return 1 }
        if nx.kind == 27 { return 1 }
    }
    return 0
}

fn find_stmt_end(toks: &List<Token>, src: Str, i: Int, n: Int) -> Int {
    let mut j = i
    let mut par = 0
    let mut brace = 0
    let mut brack = 0
    let mut seen = 0
    let mut last_end = prev_source_end(toks, i)
    while j < n {
        let t = toks[j]
        if par == 0 and brace == 0 and brack == 0 {
            if t.kind == 6 { return j }
            if t.kind == 12 { return j }
            if seen == 1 and t.nstart > 0 and last_end > 0 {
                if token_can_start_stmt_at(toks, j, n) == 1 {
                    if source_newline_between(src, last_end, t.nstart) == 1 { return j }
                }
            }
        }
        if t.nstart > 0 { last_end = t.nstart + t.nlen }
        if t.kind == 9 { par = par + 1 }
        else if t.kind == 10 { if par > 0 { par = par - 1 } }
        else if t.kind == 11 { brace = brace + 1 }
        else if t.kind == 12 { if brace > 0 { brace = brace - 1 } }
        else if t.kind == 23 { brack = brack + 1 }
        else if t.kind == 24 { if brack > 0 { brack = brack - 1 } }
        seen = 1
        j = j + 1
    }
    return n
}

# First pass: collect all declared variables (assign each an alloca slot) and
# emit their `alloca` at the top of @main. Returns the slot table.
# Collect `let`-declared variable slots in token range [start, end), each given
# an alloca. `slot0` is the first slot number to use (params occupy lower slots).
# Skips nested fn bodies' lets? No — ranges passed in are already a single
# function's body (or the top level minus fn defs), so all `let`s here are local.
fn collect_slots_range(toks: &List<Token>, src: Str, start: Int, end: Int, slot0: Int) -> List<Slot> {
    let mut slots: List<Slot> = []
    let mut next_slot = slot0
    let mut i = start
    while i < end {
        let t = toks[i]
        if t.kind == 7 {
            let nx = toks[i + 1]
            let mut npos = i + 1
            if nx.kind == 21 { npos = i + 2 }
            let name = toks[npos]
            slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: 0 - 1 })
            emit_str("  %v")
            pint(next_slot)
            emit_str(" = alloca i64")
            putchar(10)
            next_slot = next_slot + 1
        }
        i = i + 1
    }
    return slots
}
# Append the variable slots of [start,end) into an existing slot list (so a
# function's slot table can hold both its param and its body locals). Returns the
# combined list. (Re-emits allocas for the body locals.)
# Count elements of an array literal whose '[' contents start at `astart`
# (commas + 1). Assumes non-empty.
fn count_arr_elems(toks: &List<Token>, astart: Int) -> Int {
    let bend = bracket_end(toks, astart)
    let mut commas = 0
    let mut q = astart
    while q < bend {
        let qt = toks[q]
        if qt.kind == 25 { commas = commas + 1 }
        q = q + 1
    }
    return commas + 1
}

# Position of a let's RHS value (the token just after `=`), given `npos` = the
# name token index. Handles an optional type annotation `name : Type = rhs`
# (including `List<...>`, which spans to the closing `>`). Without an annotation
# `name = rhs`, the RHS is at npos+2 (npos+1 is `=`). With `name : Type = rhs`,
# we skip the `:` + Type tokens to land just past `=`.
fn rhs_pos(toks: &List<Token>, npos: Int) -> Int {
    let c1 = toks[npos + 1]
    if c1.kind == 16 {
        # `:` annotation. The type is `List<...>` (spans to '>') or a single ident.
        let ty = toks[npos + 2]
        let mut q = npos + 3
        if ty.kind == 1 {
            let after = toks[npos + 3]
            if after.kind == 18 {
                # `<...>` generic args: advance to the matching '>' (kind 19).
                let mut tq = npos + 4
                let mut tg = true
                while tg {
                    let tt = toks[tq]
                    if tt.kind == 19 { tg = false } else { tq = tq + 1 }
                }
                q = tq + 1
            }
        }
        # q now points at `=`; the RHS is the next token.
        return q + 1
    }
    # no annotation: npos+1 is `=`, RHS at npos+2.
    return npos + 2
}
# Is the RHS a `list()` constructor (ident 'list' then '(') OR an empty list
# literal `[]`? Both create an empty List. Handles typed lets (`name: Type = rhs`).
fn rhs_is_list(toks: &List<Token>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let rhs = toks[vp]
    if rhs.kind == 1 {
        if kw4(src, rhs.nstart, rhs.nlen, 108, 105, 115, 116) == 1 {
            let after = toks[vp + 1]
            if after.kind == 9 { return 1 }
        }
    }
    # empty list literal: `[` immediately followed by `]` (kind 23 then 24).
    if rhs.kind == 23 {
        let after = toks[vp + 1]
        if after.kind == 24 { return 1 }
    }
    return 0
}
fn let_anno_is_scalar_list(toks: &List<Token>, src: Str, npos: Int) -> Int {
    let c1 = toks[npos + 1]
    if c1.kind != 16 { return 0 }
    let ty = toks[npos + 2]
    if kw4(src, ty.nstart, ty.nlen, 76, 105, 115, 116) != 1 { return 0 }
    let lt = toks[npos + 3]
    if lt.kind != 18 { return 0 }
    let et = toks[npos + 4]
    let is_int = kw3(src, et.nstart, et.nlen, 73, 110, 116)
    let is_str = kw3(src, et.nstart, et.nlen, 83, 116, 114)
    if is_int != 1 and is_str != 1 { return 0 }
    let gt = toks[npos + 5]
    if gt.kind != 19 { return 0 }
    return 1
}
fn let_anno_is_list_literal(toks: &List<Token>, defs: &List<StructDef>, src: Str, npos: Int) -> Int {
    if let_anno_is_scalar_list(toks, src, npos) == 1 { return 1 }
    if let_anno_elem_sty(toks, defs, src, npos) >= 0 { return 1 }
    return 0
}
fn rhs_is_host_str_call(toks: &List<Token>, fns: &List<Fn>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let rhs = toks[vp]
    if rhs.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            if is_host_str_return(src, rhs.nstart, rhs.nlen) == 1 { return 1 }
            return call_retstr(toks, fns, src, vp)
        }
    }
    return 0
}
fn map_anno_value_ty(toks: &List<Token>, src: Str, npos: Int) -> Int {
    let c1 = toks[npos + 1]
    if c1.kind != 16 { return 0 - 1 }
    let ty = toks[npos + 2]
    if kw3(src, ty.nstart, ty.nlen, 77, 97, 112) != 1 { return 0 - 1 }
    let lt = toks[npos + 3]
    if lt.kind != 18 { return 0 - 1 }
    let kt = toks[npos + 4]
    let is_int_key = kw3(src, kt.nstart, kt.nlen, 73, 110, 116)
    let is_str_key = kw3(src, kt.nstart, kt.nlen, 83, 116, 114)
    if is_int_key != 1 and is_str_key != 1 { return 0 - 1 }
    let comma = toks[npos + 5]
    if comma.kind != 25 { return 0 - 1 }
    let vt = toks[npos + 6]
    let is_int_value = kw3(src, vt.nstart, vt.nlen, 73, 110, 116)
    let is_bool_value = kw4(src, vt.nstart, vt.nlen, 66, 111, 111, 108)
    let is_char_value = kw4(src, vt.nstart, vt.nlen, 67, 104, 97, 114)
    let is_str_value = kw3(src, vt.nstart, vt.nlen, 83, 116, 114)
    let gt = toks[npos + 7]
    if gt.kind != 19 { return 0 - 1 }
    if is_str_key == 1 {
        if is_int_value == 1 { return map_str_int_ty() }
        if is_bool_value == 1 { return map_str_bool_ty() }
        if is_char_value == 1 { return map_str_char_ty() }
        if is_str_value == 1 { return map_str_str_ty() }
        return 0 - 1
    }
    if is_int_value == 1 { return map_value_int_ty() }
    if is_bool_value == 1 { return map_value_bool_ty() }
    if is_char_value == 1 { return map_value_char_ty() }
    return 0 - 1
}
fn let_anno_is_map_int_scalar(toks: &List<Token>, src: Str, npos: Int) -> Int {
    if map_anno_value_ty(toks, src, npos) >= 0 { return 1 }
    return 0
}
fn rhs_is_empty_map(toks: &List<Token>, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let rhs = toks[vp]
    if rhs.kind == 11 {
        let close = toks[vp + 1]
        if close.kind == 12 { return 1 }
    }
    return 0
}
# If `let name = Name { ... }`, returns the struct-type index of Name, else -1.
fn rhs_struct_type(toks: &List<Token>, defs: &List<StructDef>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let rhs = toks[vp]
    if rhs.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 11 {
            return struct_index_by_name(defs, src, rhs.nstart, rhs.nlen)
        }
    }
    return 0 - 1
}
fn rhs_struct_field_chain_sty(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, npos: Int, end: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let base = toks[vp]
    if base.kind != 1 { return 0 - 1 }
    let dot = toks[vp + 1]
    if dot.kind != 27 { return 0 - 1 }
    if isarr_of(slots, src, base.nstart, base.nlen) != 0 { return 0 - 1 }
    let base_sty = sty_of(slots, src, base.nstart, base.nlen)
    if base_sty < 0 { return 0 - 1 }
    let field_sty = field_chain_type_index(toks, defs, src, base_sty, vp + 2)
    if field_sty < 0 { return 0 - 1 }
    let chain_end = field_chain_end_pos(toks, defs, src, base_sty, vp + 2)
    let stop = find_stmt_end(toks, src, vp, end)
    if chain_end != stop { return 0 - 1 }
    return field_sty
}
fn let_anno_struct_sty(toks: &List<Token>, defs: &List<StructDef>, src: Str, npos: Int) -> Int {
    let colon = toks[npos + 1]
    if colon.kind != 16 { return 0 - 1 }
    let ty = toks[npos + 2]
    if ty.kind != 1 { return 0 - 1 }
    return struct_index_by_name(defs, src, ty.nstart, ty.nlen)
}
# If the RHS is `<listvar>[<expr>]` where <listvar> is a List-of-structs (slot
# is_arr 2 (local) or 4 (param) with sty>=0), returns the element struct-type
# index, else -1. This lets `let t = toks[i]` bind a whole Token struct to a
# local (copying its fields) so `t.kind` / `t.value` work -- the core eval
# pattern `let t = toks[i]; if t.kind == 2 { ... }`.
fn rhs_los_elem_sty(toks: &List<Token>, slots: &List<Slot>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let rhs = toks[vp]
    if rhs.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 23 {
            let bend = bracket_end(toks, vp + 2)
            let dot = toks[bend + 1]
            if dot.kind == 27 { return 0 - 1 }
            let karr = isarr_of(slots, src, rhs.nstart, rhs.nlen)
            if karr == 2 {
                return sty_of(slots, src, rhs.nstart, rhs.nlen)
            }
            if karr == 4 {
                return sty_of(slots, src, rhs.nstart, rhs.nlen)
            }
        }
        if after.kind == 27 {
            let meth = toks[vp + 2]
            if is_first(src, meth.nstart, meth.nlen) == 1 or is_last(src, meth.nstart, meth.nlen) == 1 or is_pop(src, meth.nstart, meth.nlen) == 1 or is_remove_at(src, meth.nstart, meth.nlen) == 1 {
                let op = toks[vp + 3]
                if op.kind == 9 {
                    let close = paren_end(toks, vp + 4)
                    let postdot = toks[close + 1]
                    if postdot.kind == 27 { return 0 - 1 }
                }
                let karr2 = isarr_of(slots, src, rhs.nstart, rhs.nlen)
                if karr2 == 2 {
                    return sty_of(slots, src, rhs.nstart, rhs.nlen)
                }
                if karr2 == 4 {
                    return sty_of(slots, src, rhs.nstart, rhs.nlen)
                }
            }
        }
    }
    return 0 - 1
}
# If the RHS is a local/parameter `List<Str>` element expression, it binds to a
# `Str` local rather than the scalar `i64` default.
fn rhs_list_str_elem(toks: &List<Token>, slots: &List<Slot>, src: Str, npos: Int) -> Int {
    let vp0 = rhs_pos(toks, npos)
    let rhs0 = toks[vp0]
    if rhs0.kind == 1 {
        let after0 = toks[vp0 + 1]
        if after0.kind == 27 {
            let meth0 = toks[vp0 + 2]
            if is_first(src, meth0.nstart, meth0.nlen) == 1 {
                let karr0 = isarr_of(slots, src, rhs0.nstart, rhs0.nlen)
                if karr0 == 2 or karr0 == 4 {
                    if sty_of(slots, src, rhs0.nstart, rhs0.nlen) == 0 - 2 {
                        let op0 = toks[vp0 + 3]
                        if op0.kind == 9 {
                            let close0 = paren_end(toks, vp0 + 4)
                            if trailing_len_call_end(toks, src, close0 + 1) == close0 + 1 { return 1 }
                        }
                    }
                }
            }
        }
    }
    if rhs_los_elem_sty(toks, slots, src, npos) == 0 - 2 {
        let vp = rhs_pos(toks, npos)
        let rhs = toks[vp]
        if rhs.kind == 1 {
            let after = toks[vp + 1]
            if after.kind == 27 {
                let op = toks[vp + 3]
                if op.kind == 9 {
                    let close = paren_end(toks, vp + 4)
                    if trailing_len_call_end(toks, src, close + 1) != close + 1 { return 0 }
                }
            }
        }
        return 1
    }
    return 0
}

fn rhs_map_str_index_result(toks: &List<Token>, slots: &List<Slot>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let base = toks[vp]
    if base.kind != 1 { return 0 }
    let dot = toks[vp + 1]
    if dot.kind != 27 { return 0 }
    let meth = toks[vp + 2]
    if meth.kind != 1 { return 0 }
    let op = toks[vp + 3]
    if op.kind != 9 { return 0 }
    let close = paren_end(toks, vp + 4)
    if trailing_len_call_end(toks, src, close + 1) != close + 1 { return 0 }
    if is_key_at(src, meth.nstart, meth.nlen) == 1 {
        if map_is_str_key(slots, src, base.nstart, base.nlen) == 1 { return 1 }
    }
    if is_value_at(src, meth.nstart, meth.nlen) == 1 {
        if map_is_str_value(slots, src, base.nstart, base.nlen) == 1 { return 1 }
    }
    return 0
}

fn is_match_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw5(src, a, alen, 109, 97, 116, 99, 104)
}
fn is_some_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw4(src, a, alen, 83, 111, 109, 101)
}
fn is_none_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw4(src, a, alen, 78, 111, 110, 101)
}
fn is_ok_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw2(src, a, alen, 79, 107)
}
fn is_err_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw3(src, a, alen, 69, 114, 114)
}
fn is_len_kw(src: Str, a: Int, alen: Int) -> Int {
    return kw3(src, a, alen, 108, 101, 110)
}

fn map_str_str_get_opt_match_base_index(toks: &List<Token>, slots: &List<Slot>, src: Str, vp: Int) -> Int {
    let mt = toks[vp]
    if mt.kind != 1 { return 0 - 1 }
    if is_match_kw(src, mt.nstart, mt.nlen) != 1 { return 0 - 1 }
    let base = toks[vp + 1]
    if base.kind != 1 { return 0 - 1 }
    if map_is_str_value(slots, src, base.nstart, base.nlen) != 1 { return 0 - 1 }
    let dot = toks[vp + 2]
    if dot.kind != 27 { return 0 - 1 }
    let meth = toks[vp + 3]
    if meth.kind != 1 { return 0 - 1 }
    if is_get_opt(src, meth.nstart, meth.nlen) != 1 { return 0 - 1 }
    let op = toks[vp + 4]
    if op.kind != 9 { return 0 - 1 }
    let close = paren_end(toks, vp + 5)
    let brace = toks[close + 1]
    if brace.kind != 11 { return 0 - 1 }
    return vp + 1
}

fn rhs_is_map_str_str_get_opt_match(toks: &List<Token>, slots: &List<Slot>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    if map_str_str_get_opt_match_base_index(toks, slots, src, vp) >= 0 { return 1 }
    return 0
}

fn map_get_opt_match_brace_open(toks: &List<Token>, vp: Int) -> Int {
    let close = paren_end(toks, vp + 5)
    return close + 1
}
fn map_get_opt_match_some_expr_start(toks: &List<Token>, vp: Int) -> Int {
    return map_get_opt_match_brace_open(toks, vp) + 7
}
fn map_get_opt_match_some_expr_end(toks: &List<Token>, vp: Int) -> Int {
    let bo = map_get_opt_match_brace_open(toks, vp)
    let bc = match_brace(toks, bo, toks.len())
    return arg_comma_end(toks, map_get_opt_match_some_expr_start(toks, vp), bc)
}
fn map_get_opt_match_none_expr_start(toks: &List<Token>, vp: Int) -> Int {
    return map_get_opt_match_some_expr_end(toks, vp) + 4
}
fn map_get_opt_match_none_expr_end(toks: &List<Token>, vp: Int) -> Int {
    let bo = map_get_opt_match_brace_open(toks, vp)
    return match_brace(toks, bo, toks.len())
}

fn map_get_opt_match_has_expected_arms(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = map_get_opt_match_brace_open(toks, vp)
    let st = toks[bo + 1]
    if st.kind != 1 { return 0 }
    if is_some_kw(src, st.nstart, st.nlen) != 1 { return 0 }
    if toks[bo + 2].kind != 9 { return 0 }
    let binder = toks[bo + 3]
    if binder.kind != 1 { return 0 }
    if toks[bo + 4].kind != 10 { return 0 }
    if toks[bo + 5].kind != 5 { return 0 }
    if toks[bo + 6].kind != 19 { return 0 }
    let comma = map_get_opt_match_some_expr_end(toks, vp)
    if toks[comma].kind != 25 { return 0 }
    let nt = toks[comma + 1]
    if nt.kind != 1 { return 0 }
    if is_none_kw(src, nt.nstart, nt.nlen) != 1 { return 0 }
    if toks[comma + 2].kind != 5 { return 0 }
    if toks[comma + 3].kind != 19 { return 0 }
    return 1
}

fn result_match_brace_open(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let mt = toks[vp]
    if mt.kind != 1 { return 0 - 1 }
    if is_match_kw(src, mt.nstart, mt.nlen) != 1 { return 0 - 1 }
    let first = toks[vp + 1]
    if first.kind != 1 { return 0 - 1 }
    let after = toks[vp + 2]
    if after.kind == 9 {
        let close = paren_end(toks, vp + 3)
        let brace = toks[close + 1]
        if brace.kind == 11 { return close + 1 }
        return 0 - 1
    }
    if after.kind == 11 { return vp + 2 }
    return 0 - 1
}

fn result_match_expr_start(toks: &List<Token>, vp: Int) -> Int {
    return vp + 1
}

fn result_match_expr_end(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return vp + 1 }
    return bo
}

fn result_match_ok_expr_start(toks: &List<Token>, src: Str, vp: Int) -> Int {
    return result_match_brace_open(toks, src, vp) + 7
}

fn result_match_ok_expr_end(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    let bc = match_brace(toks, bo, toks.len())
    return arg_comma_end(toks, result_match_ok_expr_start(toks, src, vp), bc)
}

fn result_match_err_expr_start(toks: &List<Token>, src: Str, vp: Int) -> Int {
    return result_match_ok_expr_end(toks, src, vp) + 7
}

fn result_match_err_expr_end(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    return match_brace(toks, bo, toks.len())
}

fn result_match_has_payload_arms(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let ok = toks[bo + 1]
    if ok.kind != 1 { return 0 }
    if is_ok_kw(src, ok.nstart, ok.nlen) != 1 { return 0 }
    if toks[bo + 2].kind != 9 { return 0 }
    let ok_bind = toks[bo + 3]
    if ok_bind.kind != 1 { return 0 }
    if toks[bo + 4].kind != 10 { return 0 }
    if toks[bo + 5].kind != 5 { return 0 }
    if toks[bo + 6].kind != 19 { return 0 }
    let comma = result_match_ok_expr_end(toks, src, vp)
    if toks[comma].kind != 25 { return 0 }
    let err = toks[comma + 1]
    if err.kind != 1 { return 0 }
    if is_err_kw(src, err.nstart, err.nlen) != 1 { return 0 }
    if toks[comma + 2].kind != 9 { return 0 }
    let err_bind = toks[comma + 3]
    if err_bind.kind != 1 { return 0 }
    if toks[comma + 4].kind != 10 { return 0 }
    if toks[comma + 5].kind != 5 { return 0 }
    if toks[comma + 6].kind != 19 { return 0 }
    let ok_start = result_match_ok_expr_start(toks, src, vp)
    let ok_end = result_match_ok_expr_end(toks, src, vp)
    let err_start = result_match_err_expr_start(toks, src, vp)
    let err_end = result_match_err_expr_end(toks, src, vp)
    if arm_is_payload_bare(toks, src, ok_start, ok_end, ok_bind.nstart, ok_bind.nlen) != 1 { return 0 }
    if arm_is_payload_bare(toks, src, err_start, err_end, err_bind.nstart, err_bind.nlen) != 1 { return 0 }
    return 1
}

fn result_match_payload_result_is_int_at(toks: &List<Token>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    return result_match_has_payload_arms(toks, src, vp)
}

fn rhs_result_match_payload_result_is_int(toks: &List<Token>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, toks.len())
    return result_match_payload_result_is_int_at(toks, src, vp, stop)
}

fn rhs_result_question_call_end(toks: &List<Token>, src: Str, npos: Int, stop: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let callee = toks[vp]
    if callee.kind != 1 { return 0 - 1 }
    let op = toks[vp + 1]
    if op.kind != 9 { return 0 - 1 }
    let close = paren_end(toks, vp + 2)
    let qmark = toks[close + 1]
    if qmark.kind != 44 { return 0 - 1 }
    if close + 2 != stop { return 0 - 1 }
    return close
}

fn arm_is_payload_bare(toks: &List<Token>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if stop != start + 1 { return 0 }
    let t = toks[start]
    if t.kind != 1 { return 0 }
    return name_eq(src, t.nstart, t.nlen, bs, bl)
}
fn arm_is_payload_len(toks: &List<Token>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if stop != start + 5 { return 0 }
    let t = toks[start]
    if t.kind != 1 { return 0 }
    if name_eq(src, t.nstart, t.nlen, bs, bl) != 1 { return 0 }
    if toks[start + 1].kind != 27 { return 0 }
    let meth = toks[start + 2]
    if meth.kind != 1 { return 0 }
    if is_len_kw(src, meth.nstart, meth.nlen) != 1 { return 0 }
    if toks[start + 3].kind != 9 { return 0 }
    if toks[start + 4].kind != 10 { return 0 }
    return 1
}
fn arm_is_str_expr_inner(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, depth: Int) -> Int {
    if depth > 6 { return 0 }
    if arm_is_payload_bare(toks, src, start, stop, bs, bl) == 1 { return 1 }
    if stop == start + 1 {
        let one = toks[start]
        if one.kind == 28 { return 1 }
        if one.kind == 1 {
            if isarr_of(slots, src, one.nstart, one.nlen) == 3 { return 1 }
        }
        return 0
    }
    let t = toks[start]
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 != stop { return 0 }
            if is_str_trim(src, t.nstart, t.nlen) == 1 {
                return arm_is_str_expr_inner(toks, slots, src, start + 2, close, bs, bl, depth + 1)
            }
            if is_str_lower(src, t.nstart, t.nlen) == 1 {
                return arm_is_str_expr_inner(toks, slots, src, start + 2, close, bs, bl, depth + 1)
            }
            if is_str_upper(src, t.nstart, t.nlen) == 1 {
                return arm_is_str_expr_inner(toks, slots, src, start + 2, close, bs, bl, depth + 1)
            }
            if is_str_concat(src, t.nstart, t.nlen) == 1 {
                let comma = arg_comma_end(toks, start + 2, close)
                if comma >= close { return 0 }
                if arm_is_str_expr_inner(toks, slots, src, start + 2, comma, bs, bl, depth + 1) != 1 { return 0 }
                return arm_is_str_expr_inner(toks, slots, src, comma + 1, close, bs, bl, depth + 1)
            }
            if is_str_replace(src, t.nstart, t.nlen) == 1 {
                let comma_r1 = arg_comma_end(toks, start + 2, close)
                if comma_r1 >= close { return 0 }
                if arm_is_str_expr_inner(toks, slots, src, start + 2, comma_r1, bs, bl, depth + 1) != 1 { return 0 }
                let comma_r2 = arg_comma_end(toks, comma_r1 + 1, close)
                if comma_r2 >= close { return 0 }
                if arm_is_str_expr_inner(toks, slots, src, comma_r1 + 1, comma_r2, bs, bl, depth + 1) != 1 { return 0 }
                return arm_is_str_expr_inner(toks, slots, src, comma_r2 + 1, close, bs, bl, depth + 1)
            }
        }
    }
    return 0
}

fn arm_is_str_expr(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    return arm_is_str_expr_inner(toks, slots, src, start, stop, bs, bl, 0)
}

fn map_str_str_get_opt_match_result_is_str_at(toks: &List<Token>, slots: &List<Slot>, src: Str, vp: Int, stop: Int) -> Int {
    if map_str_str_get_opt_match_base_index(toks, slots, src, vp) < 0 { return 0 }
    if map_get_opt_match_has_expected_arms(toks, src, vp) != 1 { return 0 }
    if map_get_opt_match_none_expr_end(toks, vp) + 1 != stop { return 0 }
    let bo = map_get_opt_match_brace_open(toks, vp)
    let binder = toks[bo + 3]
    let ss = map_get_opt_match_some_expr_start(toks, vp)
    let se = map_get_opt_match_some_expr_end(toks, vp)
    let ns = map_get_opt_match_none_expr_start(toks, vp)
    let ne = map_get_opt_match_none_expr_end(toks, vp)
    if arm_is_str_expr(toks, slots, src, ss, se, binder.nstart, binder.nlen) == 1 {
        if arm_is_str_expr(toks, slots, src, ns, ne, binder.nstart, binder.nlen) == 1 { return 1 }
    }
    return 0
}

fn arm_is_str_expr_len(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if stop < start + 5 { return 0 }
    if toks[stop - 4].kind != 27 { return 0 }
    let meth = toks[stop - 3]
    if meth.kind != 1 { return 0 }
    if is_len_kw(src, meth.nstart, meth.nlen) != 1 { return 0 }
    if toks[stop - 2].kind != 9 { return 0 }
    if toks[stop - 1].kind != 10 { return 0 }
    return arm_is_str_expr(toks, slots, src, start, stop - 4, bs, bl)
}

fn rhs_map_str_str_get_opt_match_result_is_str(toks: &List<Token>, slots: &List<Slot>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    if map_str_str_get_opt_match_base_index(toks, slots, src, vp) < 0 { return 0 }
    if map_get_opt_match_has_expected_arms(toks, src, vp) != 1 { return 0 }
    let bo = map_get_opt_match_brace_open(toks, vp)
    let binder = toks[bo + 3]
    let ss = map_get_opt_match_some_expr_start(toks, vp)
    let se = map_get_opt_match_some_expr_end(toks, vp)
    let ns = map_get_opt_match_none_expr_start(toks, vp)
    let ne = map_get_opt_match_none_expr_end(toks, vp)
    if arm_is_str_expr(toks, slots, src, ss, se, binder.nstart, binder.nlen) == 1 {
        if arm_is_str_expr(toks, slots, src, ns, ne, binder.nstart, binder.nlen) == 1 { return 1 }
    }
    return 0
}

fn result_match_has_result_arms(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let ok = toks[bo + 1]
    if ok.kind != 1 { return 0 }
    if is_ok_kw(src, ok.nstart, ok.nlen) != 1 { return 0 }
    if toks[bo + 2].kind != 9 { return 0 }
    let ok_bind = toks[bo + 3]
    if ok_bind.kind != 1 { return 0 }
    if toks[bo + 4].kind != 10 { return 0 }
    if toks[bo + 5].kind != 5 { return 0 }
    if toks[bo + 6].kind != 19 { return 0 }
    let comma = result_match_ok_expr_end(toks, src, vp)
    if toks[comma].kind != 25 { return 0 }
    let err = toks[comma + 1]
    if err.kind != 1 { return 0 }
    if is_err_kw(src, err.nstart, err.nlen) != 1 { return 0 }
    if toks[comma + 2].kind != 9 { return 0 }
    let err_bind = toks[comma + 3]
    if err_bind.kind != 1 { return 0 }
    if toks[comma + 4].kind != 10 { return 0 }
    if toks[comma + 5].kind != 5 { return 0 }
    if toks[comma + 6].kind != 19 { return 0 }
    return 1
}

fn result_match_ok_binder_i(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    return bo + 3
}

fn result_match_err_binder_i(toks: &List<Token>, src: Str, vp: Int) -> Int {
    let comma = result_match_ok_expr_end(toks, src, vp)
    return comma + 3
}

fn result_match_expr_is_result_str_int(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let start = result_match_expr_start(toks, vp)
    let stop = result_match_expr_end(toks, src, vp)
    let t = toks[start]
    if stop == start + 1 and t.kind == 1 {
        if sty_of(slots, src, t.nstart, t.nlen) == result_str_int_ty() { return 1 }
    }
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 == stop and call_ret_result_str_int(toks, fns, src, start) == 1 { return 1 }
        }
    }
    return 0
}

fn arm_is_int_binder_to_str(toks: &List<Token>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if stop != start + 4 { return 0 }
    let t = toks[start]
    if t.kind != 1 { return 0 }
    if is_str_conversion(src, t.nstart, t.nlen) != 1 { return 0 }
    if toks[start + 1].kind != 9 { return 0 }
    let arg = toks[start + 2]
    if arg.kind != 1 { return 0 }
    if name_eq(src, arg.nstart, arg.nlen, bs, bl) != 1 { return 0 }
    if toks[start + 3].kind != 10 { return 0 }
    return 1
}

fn err_arm_term_is_int_value(toks: &List<Token>, slots: &List<Slot>, src: Str, pos: Int, bs: Int, bl: Int) -> Int {
    let t = toks[pos]
    if t.kind == 0 { return 1 }
    if t.kind != 1 { return 0 }
    if name_eq(src, t.nstart, t.nlen, bs, bl) == 1 { return 1 }
    if find_slot(slots, src, t.nstart, t.nlen) >= 0 { return 1 }
    return 0
}

fn arm_is_err_binder_plus_int_value(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if stop != start + 3 { return 0 }
    if toks[start + 1].kind != 2 { return 0 }
    if err_arm_term_is_int_value(toks, slots, src, start, bs, bl) != 1 { return 0 }
    if err_arm_term_is_int_value(toks, slots, src, start + 2, bs, bl) != 1 { return 0 }
    let left = toks[start]
    let right = toks[start + 2]
    if left.kind == 1 and name_eq(src, left.nstart, left.nlen, bs, bl) == 1 { return 1 }
    if right.kind == 1 and name_eq(src, right.nstart, right.nlen, bs, bl) == 1 { return 1 }
    return 0
}

fn result_match_str_int_result_is_str_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    if result_match_expr_is_result_str_int(toks, slots, fns, src, vp) != 1 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_str_expr(toks, slots, src, os, oe, ok_bind.nstart, ok_bind.nlen) != 1 { return 0 }
    if arm_is_int_binder_to_str(toks, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    if arm_is_str_expr(toks, slots, src, es, ee, ok_bind.nstart, ok_bind.nlen) == 1 { return 1 }
    return 0
}

fn rhs_result_match_str_int_result_is_str(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, toks.len())
    return result_match_str_int_result_is_str_at(toks, slots, fns, src, vp, stop)
}

fn rhs_result_match_struct_int_result_is_str(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, npos: Int, end: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, end)
    return result_match_struct_int_result_is_str_at(toks, slots, fns, defs, src, vp, stop)
}

fn result_match_str_int_result_is_int_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    if result_match_expr_is_result_str_int(toks, slots, fns, src, vp) != 1 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_str_expr_len(toks, slots, src, os, oe, ok_bind.nstart, ok_bind.nlen) != 1 { return 0 }
    if arm_is_payload_bare(toks, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    if arm_is_err_binder_plus_int_value(toks, slots, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    return 0
}

# ---- Result<Str,Str> (non-Int error payload) match dispatch ----
# The scrutinee is result_str_str_ty(); both Ok and Err payloads are Str
# pointers packed into the i64 via the shared `value*2 (+1 for Err)` scheme, so
# both arms unpack with `inttoptr (val sdiv 2) to i8*`. This is simpler than the
# str_int case, where the Err arm carried an Int code.

fn result_match_expr_is_result_str_str(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let start = result_match_expr_start(toks, vp)
    let stop = result_match_expr_end(toks, src, vp)
    let t = toks[start]
    if stop == start + 1 and t.kind == 1 {
        if sty_of(slots, src, t.nstart, t.nlen) == result_str_str_ty() { return 1 }
    }
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 == stop and call_ret_result_str_str(toks, fns, src, start) == 1 { return 1 }
        }
    }
    return 0
}

fn result_match_str_str_result_is_str_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    if result_match_expr_is_result_str_str(toks, slots, fns, src, vp) != 1 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_str_expr(toks, slots, src, os, oe, ok_bind.nstart, ok_bind.nlen) != 1 { return 0 }
    if arm_is_str_expr(toks, slots, src, es, ee, err_bind.nstart, err_bind.nlen) != 1 { return 0 }
    return 1
}

fn rhs_result_match_str_str_result_is_str(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, npos: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, toks.len())
    return result_match_str_str_result_is_str_at(toks, slots, fns, src, vp, stop)
}

fn result_match_str_str_result_is_int_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    if result_match_expr_is_result_str_str(toks, slots, fns, src, vp) != 1 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_str_expr_len(toks, slots, src, os, oe, ok_bind.nstart, ok_bind.nlen) != 1 { return 0 }
    if arm_is_str_expr_len(toks, slots, src, es, ee, err_bind.nstart, err_bind.nlen) != 1 { return 0 }
    return 1
}

fn rhs_result_question_result_is_str(toks: &List<Token>, fns: &List<Fn>, src: Str, npos: Int) -> Int {
    # Result<Str,Int> and Result<Str,Str> both carry a Str Ok payload, so the
    # `?`-bound local is a Str pointer either way; the Err early-return simply
    # re-returns the packed i64, which is error-payload-agnostic.
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, toks.len())
    let close = rhs_result_question_call_end(toks, src, npos, stop)
    if close < 0 { return 0 }
    if call_ret_result_str_int(toks, fns, src, vp) == 1 { return 1 }
    return call_ret_result_str_str(toks, fns, src, vp)
}

fn rhs_result_question_result_ty(toks: &List<Token>, fns: &List<Fn>, src: Str, npos: Int, end: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, end)
    let close = rhs_result_question_call_end(toks, src, npos, stop)
    if close < 0 { return 0 }
    return call_ret_result_ty(toks, fns, src, vp)
}

fn rhs_call_result_str_int(toks: &List<Token>, fns: &List<Fn>, src: Str, npos: Int, end: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, end)
    let t = toks[vp]
    if t.kind != 1 { return 0 }
    let nx = toks[vp + 1]
    if nx.kind != 9 { return 0 }
    let close = paren_end(toks, vp + 2)
    if close + 1 != stop { return 0 }
    return call_ret_result_str_int(toks, fns, src, vp)
}

fn rhs_call_result_ty(toks: &List<Token>, fns: &List<Fn>, src: Str, npos: Int, end: Int) -> Int {
    let vp = rhs_pos(toks, npos)
    let stop = find_stmt_end(toks, src, vp, end)
    let t = toks[vp]
    if t.kind != 1 { return 0 }
    let nx = toks[vp + 1]
    if nx.kind != 9 { return 0 }
    let close = paren_end(toks, vp + 2)
    if close + 1 != stop { return 0 }
    return call_ret_result_ty(toks, fns, src, vp)
}

fn result_match_expr_result_ty(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let start = result_match_expr_start(toks, vp)
    let stop = result_match_expr_end(toks, src, vp)
    let t = toks[start]
    if stop == start + 1 and t.kind == 1 {
        let sty = sty_of(slots, src, t.nstart, t.nlen)
        if is_result_ty(sty) { return sty }
    }
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 == stop { return call_ret_result_ty(toks, fns, src, start) }
        }
    }
    return 0
}

fn emit_result_int_binder_to_str(toks: &List<Token>, src: Str, err_binder_i: Int, err_payload: Int, counter: Int) -> Op {
    let err_binder = toks[err_binder_i]
    emit_str("  %t")
    pint(counter)
    emit_str(" = call i8* @__vais_int_to_str(i64 %t")
    pint(err_payload)
    emit_str(")")
    putchar(10)
    return Op { kind: 2, val: counter, next: counter + 1 }
}

fn emit_result_str_int_err_term(toks: &List<Token>, slots: &List<Slot>, src: Str, pos: Int, bs: Int, bl: Int, err_payload: Int, counter: Int) -> Op {
    let t = toks[pos]
    if t.kind == 0 { return Op { kind: 0, val: t.value, next: counter } }
    if t.kind == 1 and name_eq(src, t.nstart, t.nlen, bs, bl) == 1 { return Op { kind: 1, val: err_payload, next: counter } }
    if t.kind == 1 {
        let slot = find_slot(slots, src, t.nstart, t.nlen)
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %v")
        pint(slot)
        putchar(10)
        return Op { kind: 1, val: counter, next: counter + 1 }
    }
    return Op { kind: 0, val: 0, next: counter }
}

fn emit_result_str_int_err_int_arm(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, err_binder_i: Int, err_payload: Int, counter: Int) -> Op {
    let err_binder = toks[err_binder_i]
    if arm_is_payload_bare(toks, src, start, stop, err_binder.nstart, err_binder.nlen) == 1 {
        return Op { kind: 1, val: err_payload, next: counter }
    }
    if arm_is_err_binder_plus_int_value(toks, slots, src, start, stop, err_binder.nstart, err_binder.nlen) == 1 {
        let left = emit_result_str_int_err_term(toks, slots, src, start, err_binder.nstart, err_binder.nlen, err_payload, counter)
        let right = emit_result_str_int_err_term(toks, slots, src, start + 2, err_binder.nstart, err_binder.nlen, err_payload, left.next)
        let dest = right.next
        emit_str("  %t")
        pint(dest)
        emit_str(" = add i64 ")
        emit_op(left)
        emit_str(", ")
        emit_op(right)
        putchar(10)
        return Op { kind: 1, val: dest, next: dest + 1 }
    }
    return Op { kind: 0, val: 0, next: counter }
}

fn arm_is_struct_str_expr_len(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    if stop < start + 5 { return 0 }
    if toks[stop - 4].kind != 27 { return 0 }
    let meth = toks[stop - 3]
    if meth.kind != 1 { return 0 }
    if is_len_kw(src, meth.nstart, meth.nlen) != 1 { return 0 }
    if toks[stop - 2].kind != 9 { return 0 }
    if toks[stop - 1].kind != 10 { return 0 }
    return arm_is_struct_str_expr(toks, slots, defs, src, start, stop - 4, bs, bl, sty)
}

fn result_struct_int_helper_call_syntax_end(toks: &List<Token>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if start + 4 > stop { return start }
    let callee = toks[start]
    if callee.kind != 1 { return start }
    if toks[start + 1].kind != 9 { return start }
    let close = paren_end(toks, start + 2)
    if close + 1 > stop { return start }
    if close != start + 3 { return start }
    let arg = toks[start + 2]
    if arg.kind != 1 { return start }
    if name_eq(src, arg.nstart, arg.nlen, bs, bl) != 1 { return start }
    return close + 1
}

fn result_struct_int_field_helper_call_syntax_end(toks: &List<Token>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    if start + 6 > stop { return start }
    let callee = toks[start]
    if callee.kind != 1 { return start }
    if toks[start + 1].kind != 9 { return start }
    let close = paren_end(toks, start + 2)
    if close + 1 > stop { return start }
    if close != start + 5 { return start }
    let arg = toks[start + 2]
    if arg.kind != 1 { return start }
    if name_eq(src, arg.nstart, arg.nlen, bs, bl) != 1 { return start }
    if toks[start + 3].kind != 27 { return start }
    let fld = toks[start + 4]
    if fld.kind != 1 { return start }
    return close + 1
}

fn result_struct_int_helper_call_end(toks: &List<Token>, fns: &List<Fn>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let call_end = result_struct_int_helper_call_syntax_end(toks, src, start, stop, bs, bl)
    if call_end == start { return start }
    let callee = toks[start]
    let fi = find_fn(fns, src, callee.nstart, callee.nlen)
    if fi < 0 { return start }
    let f = fns[fi]
    if f.retlist != 0 { return start }
    if is_result_ty(f.retty) { return start }
    if f.npar != 1 { return start }
    if f.p0ty != sty + 3 { return start }
    return call_end
}

fn result_struct_int_field_helper_call_end(toks: &List<Token>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let call_end = result_struct_int_field_helper_call_syntax_end(toks, src, start, stop, bs, bl)
    if call_end == start { return start }
    let fld = toks[start + 4]
    if field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen) < 0 { return start }
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty >= 0 { return start }
    let callee = toks[start]
    let fi = find_fn(fns, src, callee.nstart, callee.nlen)
    if fi < 0 { return start }
    let f = fns[fi]
    if f.retlist != 0 { return start }
    if f.retty != 0 { return start }
    if f.npar != 1 { return start }
    if fty == 0 - 2 {
        if f.p0ty != 1 { return start }
    } else {
        if f.p0ty != 0 { return start }
    }
    return call_end
}

fn result_struct_int_field_helper_call_shape_end(toks: &List<Token>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let call_end = result_struct_int_field_helper_call_syntax_end(toks, src, start, stop, bs, bl)
    if call_end == start { return start }
    let fld = toks[start + 4]
    if field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen) < 0 { return start }
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty >= 0 { return start }
    return call_end
}

fn result_struct_int_term_end(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let expr_end = skip_factor(toks, src, start)
    if expr_end > start and expr_end <= stop {
        if arm_is_struct_str_expr_len(toks, slots, defs, src, start, expr_end, bs, bl, sty) == 1 { return expr_end }
    }
    let call_end = result_struct_int_helper_call_end(toks, fns, src, start, stop, bs, bl, sty)
    if call_end > start { return call_end }
    let field_call_end = result_struct_int_field_helper_call_end(toks, fns, defs, src, start, stop, bs, bl, sty)
    if field_call_end > start { return field_call_end }
    let field_shape_end = result_struct_int_field_helper_call_shape_end(toks, defs, src, start, stop, bs, bl, sty)
    if field_shape_end > start { return field_shape_end }
    if start + 3 > stop { return start }
    let bind = toks[start]
    if bind.kind != 1 { return start }
    if name_eq(src, bind.nstart, bind.nlen, bs, bl) != 1 { return start }
    if toks[start + 1].kind != 27 { return start }
    let fld = toks[start + 2]
    if fld.kind != 1 { return start }
    if field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen) < 0 { return start }
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty == 0 - 2 {
        let lend = trailing_len_call_end(toks, src, start + 3)
        if lend != start + 3 and lend <= stop { return lend }
        return start
    }
    if fty < 0 { return start + 3 }
    return start
}

fn result_struct_int_emit_term_end(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let expr_end = skip_factor(toks, src, start)
    if expr_end > start and expr_end <= stop {
        if arm_is_struct_str_expr_len(toks, slots, defs, src, start, expr_end, bs, bl, sty) == 1 { return expr_end }
    }
    let call_end = result_struct_int_helper_call_syntax_end(toks, src, start, stop, bs, bl)
    if call_end > start { return call_end }
    let field_call_end = result_struct_int_field_helper_call_syntax_end(toks, src, start, stop, bs, bl)
    if field_call_end > start { return field_call_end }
    if start + 3 > stop { return start }
    let bind = toks[start]
    if bind.kind != 1 { return start }
    if name_eq(src, bind.nstart, bind.nlen, bs, bl) != 1 { return start }
    if toks[start + 1].kind != 27 { return start }
    let fld = toks[start + 2]
    if fld.kind != 1 { return start }
    if field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen) < 0 { return start }
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty == 0 - 2 {
        let lend = trailing_len_call_end(toks, src, start + 3)
        if lend != start + 3 and lend <= stop { return lend }
        return start
    }
    if fty < 0 { return start + 3 }
    return start
}

fn arm_is_struct_int_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let call_end = result_struct_int_helper_call_end(toks, fns, src, start, stop, bs, bl, sty)
    if call_end == stop { return 1 }
    let field_call_end = result_struct_int_field_helper_call_end(toks, fns, defs, src, start, stop, bs, bl, sty)
    if field_call_end == stop { return 1 }
    let mut pos = start
    while pos < stop {
        let next = result_struct_int_term_end(toks, slots, fns, defs, src, pos, stop, bs, bl, sty)
        if next <= pos or next > stop { return 0 }
        pos = next
        if pos == stop { return 1 }
        if pos >= stop { return 0 }
        if toks[pos].kind != 2 { return 0 }
        pos = pos + 1
    }
    return 0
}

fn emit_result_struct_int_helper_call_term(toks: &List<Token>, src: Str, start: Int, payload_ptr: Int, counter: Int) -> Op {
    let callee = toks[start]
    emit_str("  %t")
    pint(counter)
    emit_str(" = call i64 @")
    emit_name(src, callee.nstart, callee.nlen)
    emit_str("(i64* %t")
    pint(payload_ptr)
    emit_str(")")
    putchar(10)
    return Op { kind: 1, val: counter, next: counter + 1 }
}

fn emit_result_struct_int_field_helper_call_term(toks: &List<Token>, defs: &List<StructDef>, src: Str, start: Int, payload_ptr: Int, sty: Int, counter: Int) -> Op {
    let callee = toks[start]
    let fld = toks[start + 4]
    let fi = field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen)
    emit_str("  %t")
    pint(counter)
    emit_str(" = getelementptr i64, i64* %t")
    pint(payload_ptr)
    emit_str(", i64 ")
    pint(fi)
    putchar(10)
    let loadc = counter + 1
    emit_str("  %t")
    pint(loadc)
    emit_str(" = load i64, i64* %t")
    pint(counter)
    putchar(10)
    let ptrc = loadc + 1
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty != 0 - 2 {
        emit_str("  %t")
        pint(ptrc)
        emit_str(" = call i64 @")
        emit_name(src, callee.nstart, callee.nlen)
        emit_str("(i64 %t")
        pint(loadc)
        emit_str(")")
        putchar(10)
        return Op { kind: 1, val: ptrc, next: ptrc + 1 }
    }
    emit_str("  %t")
    pint(ptrc)
    emit_str(" = inttoptr i64 %t")
    pint(loadc)
    emit_str(" to i8*")
    putchar(10)
    let dest = ptrc + 1
    emit_str("  %t")
    pint(dest)
    emit_str(" = call i64 @")
    emit_name(src, callee.nstart, callee.nlen)
    emit_str("(i8* %t")
    pint(ptrc)
    emit_str(")")
    putchar(10)
    return Op { kind: 1, val: dest, next: dest + 1 }
}

fn emit_result_struct_int_term(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, ok_binder_i: Int, sty: Int, payload_ptr: Int, counter: Int) -> Op {
    let ok_binder = toks[ok_binder_i]
    if arm_is_struct_str_expr_len(toks, slots, defs, src, start, stop, ok_binder.nstart, ok_binder.nlen, sty) == 1 {
        let sop = emit_result_struct_int_str_arm(toks, slots, defs, src, start, stop - 4, ok_binder_i, sty, payload_ptr, counter)
        return emit_strlen_from_ptr(sop.val, sop.next)
    }
    if result_struct_int_helper_call_syntax_end(toks, src, start, stop, ok_binder.nstart, ok_binder.nlen) == stop {
        return emit_result_struct_int_helper_call_term(toks, src, start, payload_ptr, counter)
    }
    if result_struct_int_field_helper_call_syntax_end(toks, src, start, stop, ok_binder.nstart, ok_binder.nlen) == stop {
        return emit_result_struct_int_field_helper_call_term(toks, defs, src, start, payload_ptr, sty, counter)
    }
    let fld = toks[start + 2]
    let fi = field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen)
    emit_str("  %t")
    pint(counter)
    emit_str(" = getelementptr i64, i64* %t")
    pint(payload_ptr)
    emit_str(", i64 ")
    pint(fi)
    putchar(10)
    let loadc = counter + 1
    emit_str("  %t")
    pint(loadc)
    emit_str(" = load i64, i64* %t")
    pint(counter)
    putchar(10)
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty == 0 - 2 {
        let lend = trailing_len_call_end(toks, src, start + 3)
        if lend == stop {
            let ptrc = loadc + 1
            emit_str("  %t")
            pint(ptrc)
            emit_str(" = inttoptr i64 %t")
            pint(loadc)
            emit_str(" to i8*")
            putchar(10)
            return emit_strlen_from_ptr(ptrc, ptrc + 1)
        }
    }
    return Op { kind: 1, val: loadc, next: loadc + 1 }
}

fn emit_result_struct_int_ok_arm(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, ok_binder_i: Int, sty: Int, payload_ptr: Int, counter: Int) -> Op {
    let ok_binder = toks[ok_binder_i]
    let first_end = result_struct_int_emit_term_end(toks, slots, defs, src, start, stop, ok_binder.nstart, ok_binder.nlen, sty)
    let mut acc = emit_result_struct_int_term(toks, slots, defs, src, start, first_end, ok_binder_i, sty, payload_ptr, counter)
    let mut pos = first_end
    while pos < stop {
        let rhs_start = pos + 1
        let rhs_end = result_struct_int_emit_term_end(toks, slots, defs, src, rhs_start, stop, ok_binder.nstart, ok_binder.nlen, sty)
        let rhs = emit_result_struct_int_term(toks, slots, defs, src, rhs_start, rhs_end, ok_binder_i, sty, payload_ptr, acc.next)
        let dest = rhs.next
        emit_str("  %t")
        pint(dest)
        emit_str(" = add i64 ")
        emit_op(acc)
        emit_str(", ")
        emit_op(rhs)
        putchar(10)
        acc = Op { kind: 1, val: dest, next: dest + 1 }
        pos = rhs_end
    }
    return acc
}

fn result_bool_cmp_pos(toks: &List<Token>, start: Int, stop: Int) -> Int {
    let mut j = start
    let mut depth = 0
    while j < stop {
        let t = toks[j]
        if t.kind == 9 { depth = depth + 1 }
        else if t.kind == 10 { depth = depth - 1 }
        else if depth == 0 {
            if t.kind == 18 or t.kind == 19 or t.kind == 20 or t.kind == 29 or t.kind == 30 or t.kind == 33 { return j }
        }
        j = j + 1
    }
    return start - 1
}

fn emit_i64_compare_bool(left: Op, right: Op, cmp_kind: Int, counter: Int) -> Op {
    emit_str("  %t")
    pint(counter)
    emit_str(" = icmp ")
    if cmp_kind == 18 { emit_str("slt") } else if cmp_kind == 19 { emit_str("sgt") } else if cmp_kind == 29 { emit_str("sle") } else if cmp_kind == 30 { emit_str("sge") } else if cmp_kind == 33 { emit_str("ne") } else { emit_str("eq") }
    emit_str(" i64 ")
    emit_op(left)
    emit_str(", ")
    emit_op(right)
    putchar(10)
    let zc = counter + 1
    emit_str("  %t")
    pint(zc)
    emit_str(" = zext i1 %t")
    pint(counter)
    emit_str(" to i64")
    putchar(10)
    return Op { kind: 1, val: zc, next: zc + 1 }
}

fn arm_is_struct_int_bool_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    let cmp = result_bool_cmp_pos(toks, start, stop)
    if cmp < start { return 0 }
    if arm_is_struct_int_expr(toks, slots, fns, defs, src, start, cmp, bs, bl, sty) != 1 { return 0 }
    return 1
}

fn arm_is_err_binder_bool_expr(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, bs: Int, bl: Int) -> Int {
    let cmp = result_bool_cmp_pos(toks, start, stop)
    if cmp < start { return 0 }
    if arm_is_payload_bare(toks, src, start, cmp, bs, bl) == 1 { return 1 }
    if arm_is_err_binder_plus_int_value(toks, slots, src, start, cmp, bs, bl) == 1 { return 1 }
    return 0
}

fn emit_result_bool_rhs(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, counter: Int) -> Op {
    if start + 1 == stop {
        let t = toks[start]
        if t.kind == 0 { return Op { kind: 0, val: t.value, next: counter } }
        if t.kind == 42 { return Op { kind: 0, val: t.value, next: counter } }
        if t.kind == 1 {
            let slot = find_slot(slots, src, t.nstart, t.nlen)
            if slot >= 0 {
                emit_str("  %t")
                pint(counter)
                emit_str(" = load i64, i64* %v")
                pint(slot)
                putchar(10)
                return Op { kind: 1, val: counter, next: counter + 1 }
            }
        }
    }
    return Op { kind: 0, val: 0, next: counter }
}

fn emit_result_struct_int_ok_bool_arm(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, ok_binder_i: Int, sty: Int, payload_ptr: Int, counter: Int) -> Op {
    let ok_binder = toks[ok_binder_i]
    let cmp = result_bool_cmp_pos(toks, start, stop)
    let left = emit_result_struct_int_ok_arm(toks, slots, defs, src, start, cmp, ok_binder_i, sty, payload_ptr, counter)
    let right = emit_result_bool_rhs(toks, slots, src, cmp + 1, stop, left.next)
    let op = toks[cmp]
    return emit_i64_compare_bool(left, right, op.kind, right.next)
}

fn emit_result_struct_int_err_bool_arm(toks: &List<Token>, slots: &List<Slot>, src: Str, start: Int, stop: Int, err_binder_i: Int, err_payload: Int, counter: Int) -> Op {
    let err_binder = toks[err_binder_i]
    let cmp = result_bool_cmp_pos(toks, start, stop)
    let mut left = Op { kind: 1, val: err_payload, next: counter }
    if arm_is_payload_bare(toks, src, start, cmp, err_binder.nstart, err_binder.nlen) != 1 {
        left = emit_result_str_int_err_int_arm(toks, slots, src, start, cmp, err_binder_i, err_payload, counter)
    }
    let right = emit_result_bool_rhs(toks, slots, src, cmp + 1, stop, left.next)
    let op = toks[cmp]
    return emit_i64_compare_bool(left, right, op.kind, right.next)
}

fn result_match_struct_int_result_is_bool_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    let rty = result_match_expr_result_ty(toks, slots, fns, src, vp)
    let sty = result_struct_int_payload_ty(rty)
    if sty < 0 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_struct_int_bool_expr(toks, slots, fns, defs, src, os, oe, ok_bind.nstart, ok_bind.nlen, sty) != 1 { return 0 }
    if arm_is_err_binder_bool_expr(toks, slots, src, es, ee, err_bind.nstart, err_bind.nlen) != 1 { return 0 }
    return 1
}

fn emit_result_struct_int_match_bool_return(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, counter0: Int) -> Int {
    let result_expr = gen_expr(toks, slots, fns, defs, src, result_match_expr_start(toks, vp), result_match_expr_end(toks, src, vp), counter0)
    let tag = result_expr.next
    emit_str("  %t")
    pint(tag)
    emit_str(" = srem i64 ")
    emit_op(result_expr)
    emit_str(", 2")
    putchar(10)
    let is_err = tag + 1
    emit_str("  %t")
    pint(is_err)
    emit_str(" = icmp eq i64 %t")
    pint(tag)
    emit_str(", 1")
    putchar(10)
    let payload = is_err + 1
    emit_str("  %t")
    pint(payload)
    emit_str(" = sdiv i64 ")
    emit_op(result_expr)
    emit_str(", 2")
    putchar(10)
    let ok_ptr = payload + 1
    emit_str("  %t")
    pint(ok_ptr)
    emit_str(" = inttoptr i64 %t")
    pint(payload)
    emit_str(" to i64*")
    putchar(10)
    let lbl = ok_ptr + 1
    emit_str("  br i1 %t")
    pint(is_err)
    emit_str(", label %resStructBoolErr")
    pint(lbl)
    emit_str(", label %resStructBoolOk")
    pint(lbl)
    putchar(10)
    let ok_binder_i = result_match_ok_binder_i(toks, src, vp)
    let err_binder_i = result_match_err_binder_i(toks, src, vp)
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    let rty = result_match_expr_result_ty(toks, slots, fns, src, vp)
    let sty = result_struct_int_payload_ty(rty)
    let mut cc = lbl + 1
    emit_str("resStructBoolOk")
    pint(lbl)
    emit_str(":")
    putchar(10)
    let okop = emit_result_struct_int_ok_bool_arm(toks, slots, defs, src, os, oe, ok_binder_i, sty, ok_ptr, cc)
    cc = okop.next
    emit_str("  ret i64 ")
    emit_op(okop)
    putchar(10)
    emit_str("resStructBoolErr")
    pint(lbl)
    emit_str(":")
    putchar(10)
    let errop = emit_result_struct_int_err_bool_arm(toks, slots, src, es, ee, err_binder_i, payload, cc)
    cc = errop.next
    emit_str("  ret i64 ")
    emit_op(errop)
    putchar(10)
    return cc
}

fn result_match_struct_int_result_is_int_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    let rty = result_match_expr_result_ty(toks, slots, fns, src, vp)
    let sty = result_struct_int_payload_ty(rty)
    if sty < 0 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_struct_int_expr(toks, slots, fns, defs, src, os, oe, ok_bind.nstart, ok_bind.nlen, sty) != 1 { return 0 }
    if arm_is_payload_bare(toks, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    if arm_is_err_binder_plus_int_value(toks, slots, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    return 0
}

fn result_struct_str_field_end(toks: &List<Token>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    if start + 3 > stop { return start }
    let bind = toks[start]
    if bind.kind != 1 { return start }
    if name_eq(src, bind.nstart, bind.nlen, bs, bl) != 1 { return start }
    if toks[start + 1].kind != 27 { return start }
    let fld = toks[start + 2]
    if fld.kind != 1 { return start }
    if field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen) < 0 { return start }
    let fty = struct_field_type_index(toks, defs, src, sty, fld.nstart, fld.nlen)
    if fty == 0 - 2 { return start + 3 }
    return start
}

fn arm_is_struct_str_expr_inner(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int, depth: Int) -> Int {
    if depth > 6 { return 0 }
    let next = result_struct_str_field_end(toks, defs, src, start, stop, bs, bl, sty)
    if next == stop { return 1 }
    if stop == start + 1 {
        let one = toks[start]
        if one.kind == 28 { return 1 }
        if one.kind == 1 {
            if isarr_of(slots, src, one.nstart, one.nlen) == 3 { return 1 }
        }
        return 0
    }
    let t = toks[start]
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 != stop { return 0 }
            if is_str_trim(src, t.nstart, t.nlen) == 1 {
                return arm_is_struct_str_expr_inner(toks, slots, defs, src, start + 2, close, bs, bl, sty, depth + 1)
            }
            if is_str_lower(src, t.nstart, t.nlen) == 1 {
                return arm_is_struct_str_expr_inner(toks, slots, defs, src, start + 2, close, bs, bl, sty, depth + 1)
            }
            if is_str_upper(src, t.nstart, t.nlen) == 1 {
                return arm_is_struct_str_expr_inner(toks, slots, defs, src, start + 2, close, bs, bl, sty, depth + 1)
            }
            if is_str_concat(src, t.nstart, t.nlen) == 1 {
                let comma = arg_comma_end(toks, start + 2, close)
                if comma >= close { return 0 }
                if arm_is_struct_str_expr_inner(toks, slots, defs, src, start + 2, comma, bs, bl, sty, depth + 1) != 1 { return 0 }
                return arm_is_struct_str_expr_inner(toks, slots, defs, src, comma + 1, close, bs, bl, sty, depth + 1)
            }
            if is_str_replace(src, t.nstart, t.nlen) == 1 {
                let comma_r1 = arg_comma_end(toks, start + 2, close)
                if comma_r1 >= close { return 0 }
                if arm_is_struct_str_expr_inner(toks, slots, defs, src, start + 2, comma_r1, bs, bl, sty, depth + 1) != 1 { return 0 }
                let comma_r2 = arg_comma_end(toks, comma_r1 + 1, close)
                if comma_r2 >= close { return 0 }
                if arm_is_struct_str_expr_inner(toks, slots, defs, src, comma_r1 + 1, comma_r2, bs, bl, sty, depth + 1) != 1 { return 0 }
                return arm_is_struct_str_expr_inner(toks, slots, defs, src, comma_r2 + 1, close, bs, bl, sty, depth + 1)
            }
        }
    }
    return 0
}

fn arm_is_struct_str_expr(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, bs: Int, bl: Int, sty: Int) -> Int {
    return arm_is_struct_str_expr_inner(toks, slots, defs, src, start, stop, bs, bl, sty, 0)
}

fn result_match_struct_int_result_is_str_at(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, stop: Int) -> Int {
    let bo = result_match_brace_open(toks, src, vp)
    if bo < 0 { return 0 }
    let bc = match_brace(toks, bo, toks.len())
    if bc + 1 != stop { return 0 }
    if result_match_has_result_arms(toks, src, vp) != 1 { return 0 }
    let rty = result_match_expr_result_ty(toks, slots, fns, src, vp)
    let sty = result_struct_int_payload_ty(rty)
    if sty < 0 { return 0 }
    let ok_bind = toks[result_match_ok_binder_i(toks, src, vp)]
    let err_bind = toks[result_match_err_binder_i(toks, src, vp)]
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    if arm_is_struct_str_expr(toks, slots, defs, src, os, oe, ok_bind.nstart, ok_bind.nlen, sty) != 1 { return 0 }
    if arm_is_int_binder_to_str(toks, src, es, ee, err_bind.nstart, err_bind.nlen) == 1 { return 1 }
    return 0
}

fn emit_empty_str_ptr(counter: Int) -> Op {
    emit_str("  %t")
    pint(counter)
    emit_str(" = getelementptr [1 x i8], [1 x i8]* @.vais_empty, i64 0, i64 0")
    putchar(10)
    return Op { kind: 2, val: counter, next: counter + 1 }
}

fn emit_result_struct_int_str_arm(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, start: Int, stop: Int, ok_binder_i: Int, sty: Int, payload_ptr: Int, counter: Int) -> Op {
    let ok_binder = toks[ok_binder_i]
    let next = result_struct_str_field_end(toks, defs, src, start, stop, ok_binder.nstart, ok_binder.nlen, sty)
    if next == stop {
        let fld = toks[start + 2]
        let fi = field_flat_offset(toks, defs, src, sty, fld.nstart, fld.nlen)
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr i64, i64* %t")
        pint(payload_ptr)
        emit_str(", i64 ")
        pint(fi)
        putchar(10)
        let loadc = counter + 1
        emit_str("  %t")
        pint(loadc)
        emit_str(" = load i64, i64* %t")
        pint(counter)
        putchar(10)
        let ptrc = loadc + 1
        emit_str("  %t")
        pint(ptrc)
        emit_str(" = inttoptr i64 %t")
        pint(loadc)
        emit_str(" to i8*")
        putchar(10)
        return Op { kind: 2, val: ptrc, next: ptrc + 1 }
    }
    if stop == start + 1 {
        let one = toks[start]
        if one.kind == 28 {
            emit_str("  %t")
            pint(counter)
            emit_str(" = getelementptr [")
            pint(one.value + 1)
            emit_str(" x i8], [")
            pint(one.value + 1)
            emit_str(" x i8]* @.s")
            pint(one.nstart)
            emit_str(", i64 0, i64 0")
            putchar(10)
            return Op { kind: 2, val: counter, next: counter + 1 }
        }
        if one.kind == 1 {
            let oneslot = find_slot(slots, src, one.nstart, one.nlen)
            if oneslot >= 0 and isarr_of(slots, src, one.nstart, one.nlen) == 3 {
                emit_str("  %t")
                pint(counter)
                emit_str(" = load i8*, i8** %v")
                pint(oneslot)
                putchar(10)
                return Op { kind: 2, val: counter, next: counter + 1 }
            }
        }
        return emit_empty_str_ptr(counter)
    }
    let t = toks[start]
    if t.kind == 1 {
        let nx = toks[start + 1]
        if nx.kind == 9 {
            let close = paren_end(toks, start + 2)
            if close + 1 == stop {
                if is_str_trim(src, t.nstart, t.nlen) == 1 {
                    let arg = emit_result_struct_int_str_arm(toks, slots, defs, src, start + 2, close, ok_binder_i, sty, payload_ptr, counter)
                    let dest = arg.next
                    emit_str("  %t")
                    pint(dest)
                    emit_str(" = call i8* @__vais_str_trim(i8* ")
                    emit_op(arg)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest, next: dest + 1 }
                }
                if is_str_lower(src, t.nstart, t.nlen) == 1 {
                    let arg2 = emit_result_struct_int_str_arm(toks, slots, defs, src, start + 2, close, ok_binder_i, sty, payload_ptr, counter)
                    let dest2 = arg2.next
                    emit_str("  %t")
                    pint(dest2)
                    emit_str(" = call i8* @__vais_str_lower(i8* ")
                    emit_op(arg2)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest2, next: dest2 + 1 }
                }
                if is_str_upper(src, t.nstart, t.nlen) == 1 {
                    let arg_upper = emit_result_struct_int_str_arm(toks, slots, defs, src, start + 2, close, ok_binder_i, sty, payload_ptr, counter)
                    let dest_upper = arg_upper.next
                    emit_str("  %t")
                    pint(dest_upper)
                    emit_str(" = call i8* @__vais_str_upper(i8* ")
                    emit_op(arg_upper)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_upper, next: dest_upper + 1 }
                }
                if is_str_concat(src, t.nstart, t.nlen) == 1 {
                    let comma = arg_comma_end(toks, start + 2, close)
                    let left = emit_result_struct_int_str_arm(toks, slots, defs, src, start + 2, comma, ok_binder_i, sty, payload_ptr, counter)
                    let right = emit_result_struct_int_str_arm(toks, slots, defs, src, comma + 1, close, ok_binder_i, sty, payload_ptr, left.next)
                    let dest3 = right.next
                    emit_str("  %t")
                    pint(dest3)
                    emit_str(" = call i8* @__vais_str_concat(i8* ")
                    emit_op(left)
                    emit_str(", i8* ")
                    emit_op(right)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest3, next: dest3 + 1 }
                }
                if is_str_replace(src, t.nstart, t.nlen) == 1 {
                    let comma_r1 = arg_comma_end(toks, start + 2, close)
                    let r_text = emit_result_struct_int_str_arm(toks, slots, defs, src, start + 2, comma_r1, ok_binder_i, sty, payload_ptr, counter)
                    let comma_r2 = arg_comma_end(toks, comma_r1 + 1, close)
                    let r_needle = emit_result_struct_int_str_arm(toks, slots, defs, src, comma_r1 + 1, comma_r2, ok_binder_i, sty, payload_ptr, r_text.next)
                    let r_value = emit_result_struct_int_str_arm(toks, slots, defs, src, comma_r2 + 1, close, ok_binder_i, sty, payload_ptr, r_needle.next)
                    let dest4 = r_value.next
                    emit_str("  %t")
                    pint(dest4)
                    emit_str(" = call i8* @__vais_str_replace(i8* ")
                    emit_op(r_text)
                    emit_str(", i8* ")
                    emit_op(r_needle)
                    emit_str(", i8* ")
                    emit_op(r_value)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest4, next: dest4 + 1 }
                }
            }
        }
    }
    return emit_empty_str_ptr(counter)
}

fn emit_result_struct_int_match_int_let(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, slot: Int, counter0: Int) -> Int {
    let result_expr = gen_expr(toks, slots, fns, defs, src, result_match_expr_start(toks, vp), result_match_expr_end(toks, src, vp), counter0)
    let tag = result_expr.next
    emit_str("  %t")
    pint(tag)
    emit_str(" = srem i64 ")
    emit_op(result_expr)
    emit_str(", 2")
    putchar(10)
    let is_err = tag + 1
    emit_str("  %t")
    pint(is_err)
    emit_str(" = icmp eq i64 %t")
    pint(tag)
    emit_str(", 1")
    putchar(10)
    let payload = is_err + 1
    emit_str("  %t")
    pint(payload)
    emit_str(" = sdiv i64 ")
    emit_op(result_expr)
    emit_str(", 2")
    putchar(10)
    let ok_ptr = payload + 1
    emit_str("  %t")
    pint(ok_ptr)
    emit_str(" = inttoptr i64 %t")
    pint(payload)
    emit_str(" to i64*")
    putchar(10)
    let lbl = ok_ptr + 1
    emit_str("  br i1 %t")
    pint(is_err)
    emit_str(", label %resStructErr")
    pint(lbl)
    emit_str(", label %resStructOk")
    pint(lbl)
    putchar(10)
    let ok_binder_i = result_match_ok_binder_i(toks, src, vp)
    let err_binder_i = result_match_err_binder_i(toks, src, vp)
    let os = result_match_ok_expr_start(toks, src, vp)
    let oe = result_match_ok_expr_end(toks, src, vp)
    let es = result_match_err_expr_start(toks, src, vp)
    let ee = result_match_err_expr_end(toks, src, vp)
    let rty = result_match_expr_result_ty(toks, slots, fns, src, vp)
    let sty = result_struct_int_payload_ty(rty)
    let mut cc = lbl + 1
    emit_str("resStructOk")
    pint(lbl)
    emit_str(":")
    putchar(10)
    let ok_binder = toks[ok_binder_i]
    let mut okop = Op { kind: 0, val: 0, next: cc }
    if result_struct_int_helper_call_end(toks, fns, src, os, oe, ok_binder.nstart, ok_binder.nlen, sty) == oe {
        okop = emit_result_struct_int_helper_call_term(toks, src, os, ok_ptr, cc)
    } else {
        okop = emit_result_struct_int_ok_arm(toks, slots, defs, src, os, oe, ok_binder_i, sty, ok_ptr, cc)
    }
    cc = okop.next
    emit_str("  store i64 ")
    emit_op(okop)
    emit_str(", i64* %v")
    pint(slot)
    putchar(10)
    emit_str("  br label %resStructMerge")
    pint(lbl)
    putchar(10)
    emit_str("resStructErr")
    pint(lbl)
    emit_str(":")
    putchar(10)
    let errop = emit_result_str_int_err_int_arm(toks, slots, src, es, ee, err_binder_i, payload, cc)
    cc = errop.next
    emit_str("  store i64 ")
    emit_op(errop)
    emit_str(", i64* %v")
    pint(slot)
    putchar(10)
    emit_str("  br label %resStructMerge")
    pint(lbl)
    putchar(10)
    emit_str("resStructMerge")
    pint(lbl)
    emit_str(":")
    putchar(10)
    return cc
}


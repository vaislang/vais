	                    let slen = counter
	                    counter = counter + 1
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = add i64 %t")
	                    pint(dlen)
	                    emit_str(", %t")
	                    pint(slen)
	                    putchar(10)
	                    let newlen = counter
	                    counter = counter + 1
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = icmp sgt i64 %t")
	                    pint(newlen)
	                    emit_str(", ")
	                    pint(ecap)
	                    putchar(10)
	                    let full = counter
	                    counter = counter + 1
	                    let caplab = counter
	                    emit_str("  br i1 %t")
	                    pint(full)
	                    emit_str(", label %listextend_capacity_trap")
	                    pint(caplab)
	                    emit_str(", label %listextend_capacity_ok")
	                    pint(caplab)
	                    putchar(10)
	                    emit_str("listextend_capacity_trap")
	                    pint(caplab)
	                    emit_str(":")
	                    putchar(10)
	                    emit_str("  call void @llvm.trap()")
	                    putchar(10)
	                    emit_str("  unreachable")

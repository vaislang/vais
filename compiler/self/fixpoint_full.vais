# Element type from a let's type annotation `name : List<Type> = ...`, given
# `npos` = the name token. Returns a struct-type index, -2 for List<Str>, or -1
# for no annotation / scalar List<Int>. This is the authoritative element type
# for `let toks: List<Token> = []` where no push reveals it.
fn let_anno_elem_sty(toks: &List<Token>, defs: &List<StructDef>, src: Str, npos: Int) -> Int {
    let c1 = toks[npos + 1]
    if c1.kind == 16 {
        let ty = toks[npos + 2]
        let islist = kw4(src, ty.nstart, ty.nlen, 76, 105, 115, 116)
        if islist == 1 {
            let lt = toks[npos + 3]
            if lt.kind == 18 {
                let et = toks[npos + 4]
                if et.kind == 1 {
                    if kw3(src, et.nstart, et.nlen, 83, 116, 114) == 1 { return 0 - 2 }
                    return struct_index_by_name(defs, src, et.nstart, et.nlen)
                }
            }
        }
    }
    return 0 - 1
}
# Element type of `let name = list()` by scanning [start,end) for the first push.
# Returns a struct-type index, -2 for a string-literal push, or -1 for scalars /
# no useful push found. This lets a List<Token> allocate a contiguous
# [64*nfields x i64] buffer with element stride = nfields.
fn list_elem_sty(toks: &List<Token>, defs: &List<StructDef>, src: Str, start: Int, end: Int, nstart: Int, nlen: Int) -> Int {
    let mut i = start
    while i < end {
        let t = toks[i]
        # match the token run:  name . push ( Type  followed by an open-brace.
        if t.kind == 1 {
            if name_eq(src, t.nstart, t.nlen, nstart, nlen) == 1 {
                let d = toks[i + 1]
                if d.kind == 27 {
                    let m = toks[i + 2]
                    if m.kind == 1 {
                        if kw4(src, m.nstart, m.nlen, 112, 117, 115, 104) == 1 {
                            let op = toks[i + 3]
                            if op.kind == 9 {
                                let ty = toks[i + 4]
                                if ty.kind == 28 { return 0 - 2 }
                                if ty.kind == 1 {
                                    let br = toks[i + 5]
                                    if br.kind == 11 {
                                        return struct_index_by_name(defs, src, ty.nstart, ty.nlen)
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
        i = i + 1
    }
    return 0 - 1
}
# Element type of the param at position `argpos` of `fn <callee>`, if that param
# is annotated `List<Struct>` or `List<Str>`. Scans the callee's signature in the
# token stream (params separated by commas at paren depth 1). Returns -1
# otherwise. This lets a caller infer a local List's element type from the callee
# it is passed to (the push happens in the callee body, not the caller's).
fn param_list_elem_sty(toks: &List<Token>, defs: &List<StructDef>, src: Str, n: Int, cns: Int, cnl: Int, argpos: Int) -> Int {
    let mut i = 0
    while i < n {
        let t = toks[i]
        # find `fn <callee> (`
        if t.kind == 13 {
            let nm = toks[i + 1]
            if nm.kind == 1 {
                if name_eq(src, nm.nstart, nm.nlen, cns, cnl) == 1 {
                    # Params start after the function header's '('. Split the signature by
                    # top-level commas so generic commas in Map<K,V> or Result<T,E> do not
                    # count as params.
                    let popen = fn_params_open(toks, i)
                    let mut close = popen + 1
                    let mut find_close = true
                    while find_close {
                        let ct = toks[close]
                        if ct.kind == 10 { find_close = false } else { close = close + 1 }
                    }
                    let mut q = popen + 1
                    let mut pos = 0
                    while q < close {
                        let mut seg_end = q
                        let mut gdepth = 0
                        let mut seg_go = true
                        while seg_go {
                            if seg_end >= close {
                                seg_go = false
                            } else {
                                let st = toks[seg_end]
                                if st.kind == 18 {
                                    gdepth = gdepth + 1
                                } else if st.kind == 19 {
                                    if gdepth > 0 { gdepth = gdepth - 1 }
                                } else if gdepth == 0 and st.kind == 25 {
                                    seg_go = false
                                }
                                if seg_go { seg_end = seg_end + 1 }
                            }
                        }

                        let mut pname = q
                        let mut have_name = false
                        let mut ps = q
                        while ps < seg_end {
                            let pt = toks[ps]
                            if have_name == false and pt.kind == 1 {
                                pname = ps
                                have_name = true
                            }
                            ps = ps + 1
                        }

                        if have_name {
                            if pos == argpos {
                                let mut colon = pname + 1
                                let mut found_colon = false
                                while colon < seg_end {
                                    let c1 = toks[colon]
                                    if found_colon == false and c1.kind == 16 {
                                        found_colon = true
                                    }
                                    colon = colon + 1
                                }
                                if found_colon {
                                    let mut typos = pname + 1
                                    let mut after_colon = false
                                    while typos < seg_end {
                                        let ty = toks[typos]
                                        if ty.kind == 16 {
                                            after_colon = true
                                        } else if after_colon and ty.kind == 1 {
                                            let islist = kw4(src, ty.nstart, ty.nlen, 76, 105, 115, 116)
                                            if islist == 1 {
                                                let mut lp = typos + 1
                                                while lp < seg_end {
                                                    let lt = toks[lp]
                                                    if lt.kind == 18 {
                                                        let mut ep = lp + 1
                                                        while ep < seg_end {
                                                            let et = toks[ep]
                                                            if et.kind == 1 {
                                                                if kw3(src, et.nstart, et.nlen, 83, 116, 114) == 1 { return 0 - 2 }
                                                                return struct_index_by_name(defs, src, et.nstart, et.nlen)
                                                            }
                                                            ep = ep + 1
                                                        }
                                                    }
                                                    lp = lp + 1
                                                }
                                            }
                                        }
                                        typos = typos + 1
                                    }
                                }
                                return 0 - 1
                            }
                            pos = pos + 1
                        }
                        q = seg_end + 1
                    }
                    return 0 - 1
                }
            }
        }
        i = i + 1
    }
    return 0 - 1
}
# Element struct-type of `let name = list()` inferred from a call site: scan
# [start,end) for a call `f( ... name ... )` where `name` is a direct single-ident
# argument, then read f's matching param's `List<Struct>` annotation. Returns -1
# if no such call. `n` bounds the whole token stream (for the callee lookup).
fn call_arg_elem_sty(toks: &List<Token>, defs: &List<StructDef>, src: Str, start: Int, end: Int, nstart: Int, nlen: Int, n: Int) -> Int {
    let mut i = start
    while i < end {
        let t = toks[i]
        # a call: ident '(' ...
        if t.kind == 1 {
            let nx = toks[i + 1]
            if nx.kind == 9 {
                # walk args, tracking position; match `name` as a single-ident arg.
                let mut q = i + 2
                let mut pos = 0
                let mut go = true
                while go {
                    let qt = toks[q]
                    if qt.kind == 10 { go = false }
                    else if qt.kind == 25 { pos = pos + 1; q = q + 1 }
                    else {
                        # is this arg exactly `name` (single ident followed by , or ))?
                        if qt.kind == 1 {
                            let after = toks[q + 1]
                            if after.kind == 10 {
                                if name_eq(src, qt.nstart, qt.nlen, nstart, nlen) == 1 {
                                    let r = param_list_elem_sty(toks, defs, src, n, t.nstart, t.nlen, pos)
                                    if r != 0 - 1 { return r }
                                }
                            }
                            if after.kind == 25 {
                                if name_eq(src, qt.nstart, qt.nlen, nstart, nlen) == 1 {
                                    let r = param_list_elem_sty(toks, defs, src, n, t.nstart, t.nlen, pos)
                                    if r != 0 - 1 { return r }
                                }
                            }
                        }
                        q = q + 1
                    }
                }
            }
        }
        i = i + 1
    }
    return 0 - 1
}

fn add_local_slots(base: List<Slot>, toks: &List<Token>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, end: Int, slot0: Int, n: Int) -> List<Slot> {
    let mut slots = base
    let mut next_slot = slot0
    let mut i = start
    while i < end {
        let t = toks[i]
        if t.kind == 7 {
            let nx = toks[i + 1]
            let mut npos = i + 1
            if nx.kind == 21 { npos = i + 2 }
            let name = toks[npos]
            # RHS value position handles typed lets `name : Type = rhs`.
            let vp = rhs_pos(toks, npos)
            let rhs = toks[vp]
            let mut sti = let_anno_struct_sty(toks, defs, src, npos)
            if sti < 0 { sti = rhs_struct_type(toks, defs, src, npos) }
            if sti < 0 { sti = rhs_struct_field_chain_sty(toks, &slots, defs, src, npos, end) }
            let mut map_vty = map_anno_value_ty(toks, src, npos)
            if map_vty < 0 { map_vty = call_retmapty(toks, fns, src, vp) }
            if map_vty >= 0 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 5, alen: map_bufsz() , sty: map_vty })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(map_bufsz())
                emit_str(" x i64]")
                putchar(10)
                emit_str("  %mp")
                pint(next_slot)
                emit_str(" = getelementptr [")
                pint(map_bufsz())
                emit_str(" x i64], [")
                pint(map_bufsz())
                emit_str(" x i64]* %v")
                pint(next_slot)
                emit_str(", i64 0, i64 ")
                pint(map_lenidx())
                putchar(10)
                emit_str("  store i64 0, i64* %mp")
                pint(next_slot)
                putchar(10)
                next_slot = next_slot + 1
            } else if sti >= 0 {
                # struct var: alloca [nfields x i64], sty = type index
                let nf = struct_flat_nfields(toks, defs, src, sti)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: sti })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(nf)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_list_str_elem(toks, &slots, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_map_str_index_result(toks, &slots, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_map_str_str_get_opt_match_result_is_str(toks, &slots, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if is_result_struct_int_ty(rhs_result_question_result_ty(toks, fns, src, npos, end)) {
                let rstq = result_struct_int_payload_ty(rhs_result_question_result_ty(toks, fns, src, npos, end))
                let nf = struct_flat_nfields(toks, defs, src, rstq)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: rstq })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(nf)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_result_question_result_is_str(toks, fns, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_result_match_str_int_result_is_str(toks, &slots, fns, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_result_match_str_str_result_is_str(toks, &slots, fns, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_result_match_struct_int_result_is_str(toks, &slots, fns, defs, src, npos, end) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_los_elem_sty(toks, &slots, src, npos) >= 0 {
                # `let t = toks[i]` binding a List-of-structs element: t is a struct
                # local (alloca [nf x i64], sty=elem type). The field copy is emitted
                # in gen_stmts; here we just reserve the slot.
                let est = rhs_los_elem_sty(toks, &slots, src, npos)
                let nf = struct_flat_nfields(toks, defs, src, est)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: est })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(nf)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else if call_retsty(toks, fns, src, vp) != 0 - 2 {
                # `let op = gen_expr(...)` where gen_expr returns a struct: allocate
                # a local [nf x i64] result buffer and pass it as a hidden out-param.
                let rst = call_retsty(toks, fns, src, vp)
                let nf = struct_flat_nfields(toks, defs, src, rst)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: rst })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(nf)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else if call_retty(toks, fns, src, vp) != 0 - 3 {
                # `let ys = build()` where build returns a List: ys is a List local
                # ([64*nf+1 x i64] for struct elems, sty = retty) that the callee
                # fills via the hidden out-param. Allocate buffer + length slot here;
                # the call + length-sync are emitted in gen_stmts.
                let rty = call_retty(toks, fns, src, vp)
                let mut ccap = list_cap()
                let mut cbuf = list_cap()
                if rty >= 0 {
                    let rnf = struct_flat_nfields(toks, defs, src, rty)
                    ccap = list_struct_cap(rnf)
                    cbuf = list_bufsz_for_nfields(rnf)
                }
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 2, alen: ccap , sty: rty })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(cbuf)
                emit_str(" x i64]")
                putchar(10)
                emit_str("  %v")
                pint(next_slot + 1)
                emit_str(" = alloca i64")
                putchar(10)
                emit_str("  store i64 0, i64* %v")
                pint(next_slot + 1)
                putchar(10)
                next_slot = next_slot + 2
            } else if rhs_call_result_ty(toks, fns, src, npos, end) != 0 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: rhs_call_result_ty(toks, fns, src, npos, end) })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i64")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_is_host_str_call(toks, fns, src, npos) == 1 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs.kind == 1 and find_semi(toks, vp, end) == vp + 1 and isarr_of(&slots, src, rhs.nstart, rhs.nlen) == 3 {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs.kind == 1 and find_semi(toks, vp, end) == vp + 1 and isarr_of(&slots, src, rhs.nstart, rhs.nlen) == 4 {
                # `let mut xs = list_param` aliases an incoming List buffer pointer.
                # This keeps self-host helper patterns like `let mut slots = base`
                # from being mistaken for scalar integers.
                let asty = sty_of(&slots, src, rhs.nstart, rhs.nlen)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 4, alen: 0 , sty: asty })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i64*")
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs_is_list(toks, src, npos) == 1 or (let_anno_is_list_literal(toks, defs, src, npos) == 1 and rhs.kind == 23) {
                # List: buffer at %v<slot>, length at %v<slot+1>=0.
                # Element type: a `: List<Type>` annotation is authoritative (covers
                # `let toks: List<Token> = []` where no push reveals it); else scan
                # the body for the first push; else infer from a callee (out-param).
                let mut lest = let_anno_elem_sty(toks, defs, src, npos)
                if lest == 0 - 1 { lest = list_elem_sty(toks, defs, src, vp, end, name.nstart, name.nlen) }
                if lest == 0 - 1 { lest = call_arg_elem_sty(toks, defs, src, vp, end, name.nstart, name.nlen, n) }
                let mut lcap = list_cap()
                let mut lbuf = list_cap()
                # struct-element Lists: [64*nf + 1 x i64] -- the +1 reserves a length
                # header at index 64*nf so the buffer can be passed by-pointer as a
                # List-of-structs param (length stored there, past the data region;
                # avoids the buf[63] collision that stride>1 would otherwise hit).
                if lest >= 0 {
                    let lnf = struct_flat_nfields(toks, defs, src, lest)
                    lcap = list_struct_cap(lnf)
                    lbuf = list_bufsz_for_nfields(lnf)
                }
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 2, alen: lcap , sty: lest })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(lbuf)
                emit_str(" x i64]")
                putchar(10)
                emit_str("  %v")
                pint(next_slot + 1)
                emit_str(" = alloca i64")
                putchar(10)
                emit_str("  store i64 0, i64* %v")
                pint(next_slot + 1)
                putchar(10)
                next_slot = next_slot + 2
            } else if rhs.kind == 28 {
                # string var: is_arr=3, alen=length, sty=global key (literal nstart).
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 3, alen: rhs.value , sty: rhs.nstart })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                emit_str("  %g")
                pint(next_slot)
                emit_str(" = getelementptr [")
                pint(rhs.value + 1)
                emit_str(" x i8], [")
                pint(rhs.value + 1)
                emit_str(" x i8]* @.s")
                pint(rhs.nstart)
                emit_str(", i64 0, i64 0")
                putchar(10)
                emit_str("  store i8* %g")
                pint(next_slot)
                emit_str(", i8** %v")
                pint(next_slot)
                putchar(10)
                next_slot = next_slot + 1
            } else if rhs.kind == 23 {
                let alen = count_arr_elems(toks, vp + 1)
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 1, alen: alen , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(alen)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else {
                slots.push(Slot { nstart: name.nstart, nlen: name.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i64")
                putchar(10)
                next_slot = next_slot + 1
            }
        } else if t.kind == 34 {
            # `for <var> in ... { body }` -- range/List<Int> variables are i64,
            # List<Str> variables are i8*, and List<Struct> variables are
            # field buffers copied from the current element.
            let fv = toks[i + 1]
            let fst = for_each_iter_los_elem_sty(toks, &slots, src, i, end)
            if fst >= 0 {
                let nf = struct_flat_nfields(toks, defs, src, fst)
                slots.push(Slot { nstart: fv.nstart, nlen: fv.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: fst })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca [")
                pint(nf)
                emit_str(" x i64]")
                putchar(10)
                next_slot = next_slot + 1
            } else if for_each_iter_is_list_str(toks, &slots, src, i, end) == 1 {
                slots.push(Slot { nstart: fv.nstart, nlen: fv.nlen, slot: next_slot, is_arr: 3, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i8*")
                putchar(10)
                next_slot = next_slot + 1
            } else {
                slots.push(Slot { nstart: fv.nstart, nlen: fv.nlen, slot: next_slot, is_arr: 0, alen: 0 , sty: 0 - 1 })
                emit_str("  %v")
                pint(next_slot)
                emit_str(" = alloca i64")
                putchar(10)
                next_slot = next_slot + 1
            }
        }
        i = i + 1
    }
    return slots
}

# Find the matching '}' for the '{' at index `op` (handles nesting). Returns its
# index. `op` must be the open-brace token index.
fn match_brace(toks: &List<Token>, op: Int, n: Int) -> Int {
    let mut j = op + 1
    let mut depth = 1
    let mut go = true
    while go {
        if j >= n { go = false }
        else {
            let t = toks[j]
            if t.kind == 11 { depth = depth + 1; j = j + 1 }
            else if t.kind == 12 {
                depth = depth - 1
                if depth == 0 { go = false } else { j = j + 1 }
            }
            else { j = j + 1 }
        }
    }
    return j
}
# Index just past a complete `if [cond] { } [else if [cond] { }]* [else { }]`
# statement, given `ifpos` = the `if` token. Walks the whole else-if chain so the
# else-region of an outer `if` covers a nested `else if ... else ...` entirely
# (not just the first inner then-block). Returns the index after the last `}`.
fn if_stmt_end(toks: &List<Token>, ifpos: Int, n: Int) -> Int {
    let mut cur_if = ifpos
    let mut cur = ifpos
    let mut go = true
    while go {
        # skip the condition to the then-block's `{`
        let bo = stmt_body_brace_open(toks, cur_if + 1, n)
        cur = match_brace(toks, bo, n) + 1
        if cur >= n {
            go = false
        } else {
            let et = toks[cur]
            if et.kind == 17 {
                let nxt = toks[cur + 1]
                if nxt.kind == 15 {
                    # Continue with the nested `if` in an `else if` chain.
                    cur_if = cur + 1
                } else {
                    # plain `else { }` -> skip to its `{`, match, and stop.
                    let eo = stmt_body_brace_open(toks, cur + 1, n)
                    cur = match_brace(toks, eo, n) + 1
                    go = false
                }
            } else { go = false }
        }
    }
    return cur
}
# Does the statement range [start, end) end such that control cannot fall through.
# A `return`, `break`, or `continue` terminates the current block; an if /
# else-if / else chain is conclusive when both sides terminate recursively.
# Used so block emitters avoid adding an extra branch after a terminator.
fn block_returns(toks: &List<Token>, src: Str, start: Int, end: Int) -> Int {
    if start >= end { return 0 }
    let mut s = start
    let mut last = start
    let mut found = 0
    while s < end {
        let st = toks[s]
        if st.kind == 6 {
            s = s + 1
        } else if st.kind == 12 {
            s = s + 1
        } else if st.kind == 17 {
            s = s + 1
        } else {
            last = s
            found = 1
            if st.kind == 15 {
                s = if_stmt_end(toks, s, end)
            } else if st.kind == 22 or st.kind == 34 {
                let mut bo = s + 1
                let mut g = true
                while g {
                    if bo >= end {
                        g = false
                    } else {
                        let bt = toks[bo]
                        if bt.kind == 11 { g = false } else { bo = bo + 1 }
                    }
                }
                if bo < end { s = match_brace(toks, bo, end) + 1 } else { s = end }
            } else {
                let stop = find_stmt_end(toks, src, s, end)
                if stop <= s { s = s + 1 } else { s = stop }
                if s < end {
                    let semi = toks[s]
                    if semi.kind == 6 { s = s + 1 }
                }
            }
        }
    }
    if found == 0 { return 0 }
    s = last
    let t = toks[s]
    if t.kind == 8 {
        # a `return` statement is conclusive when it is the last reachable
        # top-level statement in the block.
        return 1
    }
    if t.kind == 40 { return 1 }
    if t.kind == 41 { return 1 }
    if t.kind == 15 {
        # an `if` chain. Conclusive only if it spans to `end` and all branches return.
        let chainend = if_stmt_end(toks, s, end)
        if chainend < end { return 0 }
        # then-block open-brace
        let mut bo = s + 1
        let mut g = true
        while g {
            if bo >= end {
                g = false
            } else {
                let bt = toks[bo]
                if bt.kind == 11 {
                    g = false
                } else {
                    bo = bo + 1
                }
            }
        }
        let bclose = match_brace(toks, bo, end)
        if block_returns(toks, src, bo + 1, bclose) == 0 { return 0 }
        # must have an else (otherwise control can fall through when cond false)
        let at = bclose + 1
        if at >= end { return 0 }
        let et = toks[at]
        if et.kind != 17 { return 0 }
        let nxt = toks[at + 1]
        if nxt.kind == 15 {
            # else-if: recurse over the nested chain
            return block_returns(toks, src, at + 1, chainend)
        }
        # plain else: its brace interior must return
        let mut eo = at + 1
        let mut g2 = true
        while g2 {
            if eo >= end {
                g2 = false
            } else {
                let ot = toks[eo]
                if ot.kind == 11 {
                    g2 = false
                } else {
                    eo = eo + 1
                }
            }
        }
        let eclose = match_brace(toks, eo, end)
        return block_returns(toks, src, eo + 1, eclose)
    }
    return 0
}

# Emit a call to a struct-returning function. Regular args are evaluated first;
# a hidden trailing `i64*` out-param is then passed as `%t<out_val>`. `vp` is the
# call-name token index. Keep this helper at <=10 params: the self compiler's
# function metadata only tracks ten parameter names safely.
fn emit_struct_out_call(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, q0: Int, close: Int, counter: Int, out_val: Int) -> Int {
    let mut nargs = 0
    let mut a0k = 0
    let mut a0v = 0
    let mut a1k = 0
    let mut a1v = 0
    let mut a2k = 0
    let mut a2v = 0
    let mut a3k = 0
    let mut a3v = 0
    let mut a4k = 0
    let mut a4v = 0
    let mut a5k = 0
    let mut a5v = 0
    let mut a6k = 0
    let mut a6v = 0
    let mut a7k = 0
    let mut a7v = 0
    let mut a8k = 0
    let mut a8v = 0
    let mut a9k = 0
    let mut a9v = 0
    let mut ls0 = 0 - 1
    let mut ls1 = 0 - 1
    let mut ls2 = 0 - 1
    let mut ls3 = 0 - 1
    let mut ls4 = 0 - 1
    let mut ls5 = 0 - 1
    let mut ls6 = 0 - 1
    let mut ls7 = 0 - 1
    let mut ls8 = 0 - 1
    let mut ls9 = 0 - 1
    let mut li0 = list_lenidx()
    let mut li1 = list_lenidx()
    let mut li2 = list_lenidx()
    let mut li3 = list_lenidx()
    let mut li4 = list_lenidx()
    let mut li5 = list_lenidx()
    let mut li6 = list_lenidx()
    let mut li7 = list_lenidx()
    let mut li8 = list_lenidx()
    let mut li9 = list_lenidx()
    let mut lb0 = list_cap()
    let mut lb1 = list_cap()
    let mut lb2 = list_cap()
    let mut lb3 = list_cap()
    let mut lb4 = list_cap()
    let mut lb5 = list_cap()
    let mut lb6 = list_cap()
    let mut lb7 = list_cap()
    let mut lb8 = list_cap()
    let mut lb9 = list_cap()
    let mut cc = counter
    let mut q = q0
    let mut ga = true
    while ga {
        if q >= close { ga = false }
        else {
            let astop = arg_comma_end(toks, q, close)
            let argt = toks[q]
            let mut ekind = 0
            let mut eval2 = 0
            let mut handled = 0
            if argt.kind == 1 {
                let after = toks[q + 1]
                if astop == q + 1 {
                    let cname_arg = toks[vp]
                    let want_ty = call_param_ty(fns, src, cname_arg.nstart, cname_arg.nlen, nargs)
                    let aarr = isarr_of(slots, src, argt.nstart, argt.nlen)
                    if is_map_param_ty(want_ty) and map_arg_matches_param(slots, src, argt.nstart, argt.nlen, want_ty) == 1 {
                        emit_map_base_ptr(slots, src, argt.nstart, argt.nlen, cc)
                        ekind = 3
                        eval2 = cc
                        cc = cc + 1
                        handled = 1
                    } else if aarr == 2 {
                        let lslot = find_slot(slots, src, argt.nstart, argt.nlen)
                        let mut alsty = sty_of(slots, src, argt.nstart, argt.nlen)
                        let pst = param_list_elem_sty(toks, defs, src, toks.len(), cname_arg.nstart, cname_arg.nlen, nargs)
                        if pst >= 0 { alsty = pst }
                        let mut alenidx = list_lenidx()
                        let mut albufsz = list_cap()
                        if alsty >= 0 {
                            let anf = struct_flat_nfields(toks, defs, src, alsty)
                            alenidx = list_lenidx_for_nfields(anf)
                            albufsz = list_bufsz_for_nfields(anf)
                        }
                        let lc = cc
                        emit_str("  %t")
                        pint(lc)
                        emit_str(" = load i64, i64* %v")
                        pint(lslot + 1)
                        putchar(10)
                        let l63 = lc + 1
                        emit_str("  %t")
                        pint(l63)
                        emit_str(" = getelementptr [")
                        pint(albufsz)
                        emit_str(" x i64], [")
                        pint(albufsz)
                        emit_str(" x i64]* %v")
                        pint(lslot)
                        emit_str(", i64 0, i64 ")
                        pint(alenidx)
                        putchar(10)
                        emit_str("  store i64 %t")
                        pint(lc)
                        emit_str(", i64* %t")
                        pint(l63)
                        putchar(10)
                        let bc = l63 + 1
                        emit_str("  %t")
                        pint(bc)
                        emit_str(" = getelementptr [")
                        pint(albufsz)
                        emit_str(" x i64], [")
                        pint(albufsz)
                        emit_str(" x i64]* %v")
                        pint(lslot)
                        emit_str(", i64 0, i64 0")
                        putchar(10)
                        ekind = 3
                        eval2 = bc
                        cc = bc + 1
                        if nargs == 0 { ls0 = lslot; li0 = alenidx; lb0 = albufsz }
                        else if nargs == 1 { ls1 = lslot; li1 = alenidx; lb1 = albufsz }
                        else if nargs == 2 { ls2 = lslot; li2 = alenidx; lb2 = albufsz }
                        else if nargs == 3 { ls3 = lslot; li3 = alenidx; lb3 = albufsz }
                        else if nargs == 4 { ls4 = lslot; li4 = alenidx; lb4 = albufsz }
                        else if nargs == 5 { ls5 = lslot; li5 = alenidx; lb5 = albufsz }
                        else if nargs == 6 { ls6 = lslot; li6 = alenidx; lb6 = albufsz }
                        else if nargs == 7 { ls7 = lslot; li7 = alenidx; lb7 = albufsz }
                        else if nargs == 8 { ls8 = lslot; li8 = alenidx; lb8 = albufsz }
                        else { ls9 = lslot; li9 = alenidx; lb9 = albufsz }
                        handled = 1
                    } else if aarr == 4 {
                        let lslot = find_slot(slots, src, argt.nstart, argt.nlen)
                        emit_str("  %t")
                        pint(cc)
                        emit_str(" = load i64*, i64** %v")
                        pint(lslot)
                        putchar(10)
                        ekind = 3
                        eval2 = cc
                        cc = cc + 1
                        handled = 1
                    } else if aarr == 0 {
                        let mut ast = sty_of(slots, src, argt.nstart, argt.nlen)
                        if want_ty >= 3 { ast = want_ty - 3 }
                        if ast >= 0 and want_ty >= 3 {
                            let aslot = find_slot(slots, src, argt.nstart, argt.nlen)
                            let anf = struct_flat_nfields(toks, defs, src, ast)
                            emit_str("  %t")
                            pint(cc)
                            emit_str(" = getelementptr [")
                            pint(anf)
                            emit_str(" x i64], [")
                            pint(anf)
                            emit_str(" x i64]* %v")
                            pint(aslot)
                            emit_str(", i64 0, i64 0")
                            putchar(10)
                            ekind = 3
                            eval2 = cc
                            cc = cc + 1
                            handled = 1
                        }
                    }
                } else if after.kind == 9 {
                    let cname_call_arg = toks[vp]
                    let want_call_ty = call_param_ty(fns, src, cname_call_arg.nstart, cname_call_arg.nlen, nargs)
                    let call_sty = call_retsty(toks, fns, src, q)
                    let call_close = paren_end(toks, q + 2)
                    if call_sty >= 0 and want_call_ty >= 3 and want_call_ty - 3 == call_sty and call_close + 1 == astop {
                        let anf_call = struct_flat_nfields(toks, defs, src, call_sty)
                        let aid_call = cc
                        emit_str("  %sa")
                        pint(aid_call)
                        emit_str(" = alloca [")
                        pint(anf_call)
                        emit_str(" x i64]")
                        putchar(10)
                        cc = cc + 1
                        emit_str("  %t")
                        pint(cc)
                        emit_str(" = getelementptr [")
                        pint(anf_call)
                        emit_str(" x i64], [")
                        pint(anf_call)
                        emit_str(" x i64]* %sa")
                        pint(aid_call)
                        emit_str(", i64 0, i64 0")
                        putchar(10)
                        let outp_call = cc
                        cc = cc + 1
                        cc = emit_struct_out_call(toks, slots, fns, defs, src, q, q + 2, call_close, cc, outp_call)
                        ekind = 3
                        eval2 = outp_call
                        handled = 1
                    }
                } else if after.kind == 11 {
                    let ast = struct_index_by_name(defs, src, argt.nstart, argt.nlen)
                    if ast >= 0 {
                        let anf = struct_flat_nfields(toks, defs, src, ast)
                        let aid = cc
                        emit_str("  %sa")
                        pint(aid)
                        emit_str(" = alloca [")
                        pint(anf)
                        emit_str(" x i64]")
                        putchar(10)
                        cc = cc + 1
                        let bopen = q + 1
                        let bclose = match_brace(toks, bopen, close)
                        let mut fq = bopen + 1
                        while fq < bclose {
                            let fld = toks[fq]
                            let fi = field_index(defs, ast, src, fld.nstart, fld.nlen)
                            let mut vstart = fq + 1
                            let colt = toks[fq + 1]
                            if colt.kind == 16 { vstart = fq + 2 }
                            let vstop = arr_elem_end(toks, vstart, bclose)
                            let fe = gen_expr(toks, slots, fns, defs, src, vstart, vstop, cc)
                            cc = fe.next
                            let fe64 = ensure_i64_op(fe, cc)
                            cc = fe64.next
                            emit_str("  %t")
                            pint(cc)
                            emit_str(" = getelementptr [")
                            pint(anf)
                            emit_str(" x i64], [")
                            pint(anf)
                            emit_str(" x i64]* %sa")
                            pint(aid)
                            emit_str(", i64 0, i64 ")
                            pint(fi)
                            putchar(10)
                            emit_str("  store i64 ")
                            emit_op(fe64)
                            emit_str(", i64* %t")
                            pint(cc)
                            putchar(10)
                            cc = cc + 1
                            fq = vstop + 1
                        }
                        emit_str("  %t")
                        pint(cc)
                        emit_str(" = getelementptr [")
                        pint(anf)
                        emit_str(" x i64], [")
                        pint(anf)
                        emit_str(" x i64]* %sa")
                        pint(aid)
                        emit_str(", i64 0, i64 0")
                        putchar(10)
                        ekind = 3
                        eval2 = cc
                        cc = cc + 1
                        handled = 1
                    }
                }
            }
            if handled == 0 and argt.kind == 23 {
                let cname_arg2 = toks[vp]
                let want_ty2 = call_param_ty(fns, src, cname_arg2.nstart, cname_arg2.nlen, nargs)
                let pst2 = param_list_elem_sty(toks, defs, src, toks.len(), cname_arg2.nstart, cname_arg2.nlen, nargs)
                if want_ty2 == 2 {
                    let lop = emit_inline_list_literal_arg(toks, slots, fns, defs, src, q, pst2, cc)
                    ekind = lop.kind
                    eval2 = lop.val
                    cc = lop.next
                    handled = 1
                }
            }
            if handled == 0 {
                let e = gen_expr(toks, slots, fns, defs, src, q, astop, cc)
                cc = e.next
                ekind = e.kind
                eval2 = e.val
            }
            if nargs == 0 { a0k = ekind; a0v = eval2 }
            else if nargs == 1 { a1k = ekind; a1v = eval2 }
            else if nargs == 2 { a2k = ekind; a2v = eval2 }
            else if nargs == 3 { a3k = ekind; a3v = eval2 }
            else if nargs == 4 { a4k = ekind; a4v = eval2 }
            else if nargs == 5 { a5k = ekind; a5v = eval2 }
            else if nargs == 6 { a6k = ekind; a6v = eval2 }
            else if nargs == 7 { a7k = ekind; a7v = eval2 }
            else if nargs == 8 { a8k = ekind; a8v = eval2 }
            else { a9k = ekind; a9v = eval2 }
            nargs = nargs + 1
            q = astop + 1
        }
    }
    emit_str("  call void @")
    let cname2 = toks[vp]
    emit_name(src, cname2.nstart, cname2.nlen)
    emit_str("(")
    let mut ai = 0
    while ai < nargs {
        if ai > 0 { emit_str(", ") }
        let mut ak = a0k
        let mut av = a0v
        if ai == 1 { ak = a1k; av = a1v }
        else if ai == 2 { ak = a2k; av = a2v }
        else if ai == 3 { ak = a3k; av = a3v }
        else if ai == 4 { ak = a4k; av = a4v }
        else if ai == 5 { ak = a5k; av = a5v }
        else if ai == 6 { ak = a6k; av = a6v }
        else if ai == 7 { ak = a7k; av = a7v }
        else if ai == 8 { ak = a8k; av = a8v }
        else if ai == 9 { ak = a9k; av = a9v }
        if ak == 2 { emit_str("i8* ") } else if ak == 3 { emit_str("i64* ") } else { emit_str("i64 ") }
        emit_op(Op { kind: ak, val: av, next: 0 })
        ai = ai + 1
    }
    if nargs > 0 { emit_str(", ") }
    emit_str("i64* %t")
    pint(out_val)
    emit_str(")")
    putchar(10)
    let mut rc = cc
    rc = sync_list_len(ls0, li0, lb0, rc)
    rc = sync_list_len(ls1, li1, lb1, rc)
    rc = sync_list_len(ls2, li2, lb2, rc)
    rc = sync_list_len(ls3, li3, lb3, rc)
    rc = sync_list_len(ls4, li4, lb4, rc)
    rc = sync_list_len(ls5, li5, lb5, rc)
    rc = sync_list_len(ls6, li6, lb6, rc)
    rc = sync_list_len(ls7, li7, lb7, rc)
    rc = sync_list_len(ls8, li8, lb8, rc)
    rc = sync_list_len(ls9, li9, lb9, rc)
    return rc
}

fn emit_los_method_to_tmp(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, vp: Int, vstop: Int, expected_sty: Int, counter0: Int) -> Op {
    let valtok = toks[vp]
    let dot = toks[vp + 1]
    if valtok.kind != 1 or dot.kind != 27 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    if sty_of(slots, src, valtok.nstart, valtok.nlen) != expected_sty { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    let srckind = isarr_of(slots, src, valtok.nstart, valtok.nlen)
    if srckind != 2 and srckind != 4 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    let meth = toks[vp + 2]
    let mut mfirst = 0
    let mut mlast = 0
    let mut mpop = 0
    let mut mremove = 0
    if is_first(src, meth.nstart, meth.nlen) == 1 { mfirst = 1 }
    if is_last(src, meth.nstart, meth.nlen) == 1 { mlast = 1 }
    if is_pop(src, meth.nstart, meth.nlen) == 1 { mpop = 1 }
    if is_remove_at(src, meth.nstart, meth.nlen) == 1 { mremove = 1 }
    if mfirst == 0 and mlast == 0 and mpop == 0 and mremove == 0 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    let close = paren_end(toks, vp + 4)
    if vstop != close + 1 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    if mremove == 0 and close != vp + 4 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    if mremove == 1 and close == vp + 4 { return Op { kind: 0 - 1, val: 0, next: counter0 } }
    let nf = struct_flat_nfields(toks, defs, src, expected_sty)
    let srcslot = find_slot(slots, src, valtok.nstart, valtok.nlen)
    let mut counter = counter0
    let mut idxkind = 0
    let mut idxval = 0
    if mremove == 1 {
        let ridx = gen_expr(toks, slots, fns, defs, src, vp + 4, close, counter)
        idxkind = ridx.kind
        idxval = ridx.val
        counter = ridx.next
    }
    let mut srcbp = 0
    let mut lenp = 0
    if srckind == 4 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64*, i64** %v")
        pint(srcslot)
        putchar(10)
        srcbp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr i64, i64* %t")
        pint(srcbp)
        emit_str(", i64 ")
        pint(list_lenidx_for_nfields(nf))
        putchar(10)
        lenp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %t")
        pint(lenp)
        putchar(10)
    } else {
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %v")
        pint(srcslot + 1)
        putchar(10)
    }
    let lenc = counter
    counter = counter + 1
    if mremove == 1 {
        counter = emit_list_bounds_trap(Op { kind: idxkind, val: idxval, next: 0 }, Op { kind: 1, val: lenc, next: 0 }, counter)
    } else {
        counter = emit_list_nonempty_trap(Op { kind: 1, val: lenc, next: 0 }, counter)
    }
    let tmpstruct = counter
    emit_str("  %sa")
    pint(tmpstruct)
    emit_str(" = alloca [")
    pint(nf)
    emit_str(" x i64]")
    putchar(10)
    counter = counter + 1
    let method_lastidx = tmpstruct + 1
    if mremove == 0 and mfirst == 0 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = sub i64 %t")
        pint(lenc)
        emit_str(", 1")
        putchar(10)
        counter = counter + 1
    }
    emit_str("  %t")
    pint(counter)
    emit_str(" = mul i64 ")
    if mremove == 0 and mfirst == 1 {
        pint(0)
    } else if mremove == 0 {
        putchar(37)
        putchar(116)
        pint(method_lastidx)
    } else {
        emit_op(Op { kind: idxkind, val: idxval, next: 0 })
    }
    emit_str(", ")
    pint(nf)
    putchar(10)
    let base = counter
    counter = counter + 1
    let bufsz = list_bufsz_for_nfields(nf)
    let mut k = 0
    while k < nf {
        emit_str("  %t")
        pint(counter)
        emit_str(" = add i64 %t")
        pint(base)
        emit_str(", ")
        pint(k)
        putchar(10)
        let off = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        if srckind == 4 {
            emit_str(" = getelementptr i64, i64* %t")
            pint(srcbp)
            emit_str(", i64 %t")
            pint(off)
        } else {
            emit_str(" = getelementptr [")
            pint(bufsz)
            emit_str(" x i64], [")
            pint(bufsz)
            emit_str(" x i64]* %v")
            pint(srcslot)
            emit_str(", i64 0, i64 %t")
            pint(off)
        }
        putchar(10)
        let srcp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %t")
        pint(srcp)
        putchar(10)
        let srcv = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(nf)
        emit_str(" x i64], [")
        pint(nf)
        emit_str(" x i64]* %sa")
        pint(tmpstruct)
        emit_str(", i64 0, i64 ")
        pint(k)
        putchar(10)
        let dstp = counter
        counter = counter + 1
        emit_str("  store i64 %t")
        pint(srcv)
        emit_str(", i64* %t")
        pint(dstp)
        putchar(10)
        k = k + 1
    }
    if mpop == 1 {
        if srckind == 4 {
            emit_str("  store i64 %t")
            pint(method_lastidx)
            emit_str(", i64* %t")
            pint(lenp)
            putchar(10)
        } else {
            emit_str("  store i64 %t")
            pint(method_lastidx)
            emit_str(", i64* %v")
            pint(srcslot + 1)
            putchar(10)
        }
    }
    if mremove == 1 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = sub i64 %t")
        pint(lenc)
        emit_str(", 1")
        putchar(10)
        let last = counter
        counter = counter + 1
        let rip = counter
        emit_str("  %mri")
        pint(rip)
        emit_str(" = alloca i64")
        putchar(10)
        counter = counter + 1
        emit_str("  store i64 ")
        emit_op(Op { kind: idxkind, val: idxval, next: 0 })
        emit_str(", i64* %mri")
        pint(rip)
        putchar(10)
        emit_str("  br label %losMethRemoveL")
        pint(rip)
        putchar(10)
        emit_str("losMethRemoveL")
        pint(rip)
        emit_str(":")
        putchar(10)
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %mri")
        pint(rip)
        putchar(10)
        let j = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = icmp slt i64 %t")
        pint(j)
        emit_str(", %t")
        pint(last)
        putchar(10)
        let cmp = counter
        counter = counter + 1
        emit_str("  br i1 %t")
        pint(cmp)
        emit_str(", label %losMethRemoveB")
        pint(rip)
        emit_str(", label %losMethRemoveD")
        pint(rip)
        putchar(10)
        emit_str("losMethRemoveB")
        pint(rip)
        emit_str(":")
        putchar(10)
        emit_str("  %t")
        pint(counter)
        emit_str(" = add i64 %t")
        pint(j)
        emit_str(", 1")
        putchar(10)
        let nexti = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = mul i64 %t")
        pint(nexti)
        emit_str(", ")
        pint(nf)
        putchar(10)
        let srcbase = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = mul i64 %t")
        pint(j)
        emit_str(", ")
        pint(nf)
        putchar(10)
        let dstbase = counter
        counter = counter + 1
        let mut mk = 0
        while mk < nf {
            emit_str("  %t")
            pint(counter)
            emit_str(" = add i64 %t")
            pint(srcbase)
            emit_str(", ")
            pint(mk)
            putchar(10)
            let so = counter
            counter = counter + 1
            emit_str("  %t")
            pint(counter)
            if srckind == 4 {
                emit_str(" = getelementptr i64, i64* %t")
                pint(srcbp)
                emit_str(", i64 %t")
                pint(so)
            } else {
                emit_str(" = getelementptr [")
                pint(bufsz)
                emit_str(" x i64], [")
                pint(bufsz)
                emit_str(" x i64]* %v")
                pint(srcslot)
                emit_str(", i64 0, i64 %t")
                pint(so)
            }
            putchar(10)
            let sp = counter
            counter = counter + 1
            emit_str("  %t")
            pint(counter)
            emit_str(" = load i64, i64* %t")
            pint(sp)
            putchar(10)
            let sv = counter
            counter = counter + 1
            emit_str("  %t")
            pint(counter)
            emit_str(" = add i64 %t")
            pint(dstbase)
            emit_str(", ")
            pint(mk)
            putchar(10)
            let doff = counter
            counter = counter + 1
            emit_str("  %t")
            pint(counter)
            if srckind == 4 {
                emit_str(" = getelementptr i64, i64* %t")
                pint(srcbp)
                emit_str(", i64 %t")
                pint(doff)
            } else {
                emit_str(" = getelementptr [")
                pint(bufsz)
                emit_str(" x i64], [")
                pint(bufsz)
                emit_str(" x i64]* %v")
                pint(srcslot)
                emit_str(", i64 0, i64 %t")
                pint(doff)
            }
            putchar(10)
            let dp = counter
            counter = counter + 1
            emit_str("  store i64 %t")
            pint(sv)
            emit_str(", i64* %t")
            pint(dp)
            putchar(10)
            mk = mk + 1
        }
        emit_str("  %t")
        pint(counter)
        emit_str(" = add i64 %t")
        pint(j)
        emit_str(", 1")
        putchar(10)
        let inc = counter
        counter = counter + 1
        emit_str("  store i64 %t")
        pint(inc)
        emit_str(", i64* %mri")
        pint(rip)
        putchar(10)
        emit_str("  br label %losMethRemoveL")
        pint(rip)
        putchar(10)
        emit_str("losMethRemoveD")
        pint(rip)
        emit_str(":")
        putchar(10)
        if srckind == 4 {
            emit_str("  store i64 %t")
            pint(last)
            emit_str(", i64* %t")
            pint(lenp)
            putchar(10)
        } else {
            emit_str("  store i64 %t")
            pint(last)
            emit_str(", i64* %v")
            pint(srcslot + 1)
            putchar(10)
        }
    }
    return Op { kind: 1, val: tmpstruct, next: counter }
}

fn token_continues_expr_after_brace(t: Token) -> Int {
    if t.kind == 10 { return 1 }
    if t.kind == 25 { return 1 }
    if t.kind == 2 or t.kind == 3 or t.kind == 4 or t.kind == 38 or t.kind == 39 { return 1 }
    if t.kind == 5 or t.kind == 18 or t.kind == 19 or t.kind == 20 { return 1 }
    if t.kind == 29 or t.kind == 30 or t.kind == 31 or t.kind == 32 or t.kind == 33 { return 1 }
    return 0
}

fn stmt_body_brace_open(toks: &List<Token>, start: Int, end: Int) -> Int {
    let mut j = start
    while j < end {
        let t = toks[j]
        if t.kind == 9 {
            j = paren_end(toks, j + 1) + 1
        } else if t.kind == 23 {
            j = bracket_end(toks, j + 1) + 1
        } else if t.kind == 11 {
            let close = match_brace(toks, j, end)
            if close + 1 >= end { return j }
            let after = toks[close + 1]
            if token_continues_expr_after_brace(after) == 1 { j = close + 1 }
            else { return j }
        } else {
            j = j + 1
        }
    }
    return end
}

# Generate code for the statements in token range [i, end). Returns the next free
# SSA temp. `retcfg` packs (retout + 1) * 10 + retkind. `loopcfg` packs
# (loop_label + 1) * 10 + continue_kind, where continue_kind 0 targets the
# loop condition and 1 targets a for-loop increment block.
fn gen_stmts(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i0: Int, end: Int, counter0: Int, retcfg: Int, loopcfg: Int) -> Int {
    let mut i = i0
    let mut counter = counter0
    let retout = retcfg_retout(retcfg)
    let retkind = retcfg_retkind(retcfg)
    let loopbase = loopcfg / 10
    let looplbl = loopbase - 1
    let loopkind = loopcfg - (loopbase * 10)
    while i < end {
        let t = toks[i]
        if t.kind == 40 {
            if looplbl >= 0 {
                emit_str("  br label %done")
                pint(looplbl)
                putchar(10)
            } else {
                emit_str("  unreachable")
                putchar(10)
            }
            i = end
        } else if t.kind == 41 {
            if looplbl >= 0 {
                if loopkind == 1 {
                    emit_str("  br label %cont")
                } else {
                    emit_str("  br label %loop")
                }
                pint(looplbl)
                putchar(10)
            } else {
                emit_str("  unreachable")
                putchar(10)
            }
            i = end
        } else if t.kind == 7 {
            let nx = toks[i + 1]
            let mut npos = i + 1
            if nx.kind == 21 { npos = i + 2 }
            let name = toks[npos]
            let slot = find_slot(slots, src, name.nstart, name.nlen)
            # RHS value position handles typed lets `name : Type = rhs`.
            let vp = rhs_pos(toks, npos)
            let rhs = toks[vp]
            let los_est = rhs_los_elem_sty(toks, slots, src, npos)
            let lsti = rhs_struct_type(toks, defs, src, npos)
            let rhs_field_sty = rhs_struct_field_chain_sty(toks, slots, defs, src, npos, end)
            let result_stop = find_stmt_end(toks, src, vp, end)
            let result_try_close = rhs_result_question_call_end(toks, src, npos, result_stop)
            if result_try_close >= 0 {
                let result_raw = gen_expr(toks, slots, fns, defs, src, vp, result_try_close + 1, counter)
                counter = result_raw.next
                emit_str("  %t")
                pint(counter)
                emit_str(" = srem i64 ")
                emit_op(result_raw)
                emit_str(", 2")
                putchar(10)
                let result_tag = counter
                counter = counter + 1
                emit_str("  %t")
                pint(counter)
                emit_str(" = icmp eq i64 %t")
                pint(result_tag)
                emit_str(", 1")
                putchar(10)
                let result_is_err = counter
                let result_lbl = counter
                counter = counter + 1
                emit_str("  br i1 %t")
                pint(result_is_err)
                emit_str(", label %res_try_err")
                pint(result_lbl)
                emit_str(", label %res_try_ok")
                pint(result_lbl)
                putchar(10)
                emit_str("res_try_err")
                pint(result_lbl)
                emit_str(":")
                putchar(10)
                if retout >= 0 and retcfg_returns_vais_result_str_int(defs, src, retcfg) == 1 {
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr i64, i64* %a")
                    pint(retout)
                    emit_str(", i64 0")
                    putchar(10)
                    let result_str_tagp = counter
                    counter = counter + 1
                    emit_str("  store i64 1, i64* %t")
                    pint(result_str_tagp)
                    putchar(10)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [1 x i8], [1 x i8]* @.vais_empty, i64 0, i64 0")
                    putchar(10)
                    let result_str_emptyp = counter
                    counter = counter + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = ptrtoint i8* %t")
                    pint(result_str_emptyp)
                    emit_str(" to i64")
                    putchar(10)
                    let result_str_emptyi = counter
                    counter = counter + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr i64, i64* %a")
                    pint(retout)
                    emit_str(", i64 1")
                    putchar(10)
                    let result_str_valuep = counter
                    counter = counter + 1
                    emit_str("  store i64 %t")
                    pint(result_str_emptyi)
                    emit_str(", i64* %t")
                    pint(result_str_valuep)
                    putchar(10)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = sdiv i64 ")
                    emit_op(result_raw)
                    emit_str(", 2")
                    putchar(10)
                    let result_str_errdiv = counter
                    counter = counter + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = srem i64 %t")
                    pint(result_str_errdiv)
                    emit_str(", 1000000")
                    putchar(10)
                    let result_str_errcode = counter
                    counter = counter + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr i64, i64* %a")
                    pint(retout)
                    emit_str(", i64 2")
                    putchar(10)
                    let result_str_errorp = counter
                    counter = counter + 1
                    emit_str("  store i64 %t")
                    pint(result_str_errcode)
                    emit_str(", i64* %t")
                    pint(result_str_errorp)
                    putchar(10)
                    emit_str("  ret void")
                    putchar(10)
                } else {
                    emit_str("  ret i64 ")
                    emit_op(result_raw)
                    putchar(10)
                }
                emit_str("res_try_ok")
                pint(result_lbl)
                emit_str(":")
                putchar(10)
                emit_str("  %t")
                pint(counter)
                emit_str(" = sdiv i64 ")
                emit_op(result_raw)
                emit_str(", 2")
                putchar(10)
                let result_div = counter
                counter = counter + 1
                if isarr_of(slots, src, name.nstart, name.nlen) == 0 and sty_of(slots, src, name.nstart, name.nlen) >= 0 {
                    let payload_sty = sty_of(slots, src, name.nstart, name.nlen)
                    let payload_nf = struct_flat_nfields(toks, defs, src, payload_sty)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = inttoptr i64 %t")
                    pint(result_div)
                    emit_str(" to i64*")
                    putchar(10)
                    let payload_ptr = counter
                    counter = counter + 1
                    let mut copy_i = 0
                    while copy_i < payload_nf {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(payload_ptr)
                        emit_str(", i64 ")
                        pint(copy_i)
                        putchar(10)
                        let srcp = counter
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64, i64* %t")
                        pint(srcp)
                        putchar(10)
                        let srcv = counter
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr [")
                        pint(payload_nf)
                        emit_str(" x i64], [")
                        pint(payload_nf)
                        emit_str(" x i64]* %v")
                        pint(slot)
                        emit_str(", i64 0, i64 ")
                        pint(copy_i)
                        putchar(10)
                        let dstp = counter
                        counter = counter + 1
                        emit_str("  store i64 %t")
                        pint(srcv)
                        emit_str(", i64* %t")
                        pint(dstp)
                        putchar(10)
                        copy_i = copy_i + 1
                    }
                } else if isarr_of(slots, src, name.nstart, name.nlen) == 3 {
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = inttoptr i64 %t")
                    pint(result_div)
                    emit_str(" to i8*")
                    putchar(10)
                    let result_payload_ptr = counter
                    counter = counter + 1
                    emit_str("  store i8* %t")
                    pint(result_payload_ptr)
                    emit_str(", i8** %v")
                    pint(slot)
                    putchar(10)
                } else {
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = srem i64 %t")
                    pint(result_div)
                    emit_str(", 1000000")
                    putchar(10)
                    let result_payload = counter
                    counter = counter + 1
                    emit_str("  store i64 %t")
                    pint(result_payload)
                    emit_str(", i64* %v")
                    pint(slot)
                    putchar(10)
                }
                if result_stop < end {
                    let rst = toks[result_stop]
                    if rst.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_str_str_result_is_str_at(toks, slots, fns, src, vp, result_stop) == 1 {
                counter = emit_result_str_str_match_str_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_ss_str = toks[result_stop]
                    if rst_ss_str.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_str_str_result_is_int_at(toks, slots, fns, src, vp, result_stop) == 1 {
                counter = emit_result_str_str_match_int_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_ss_int = toks[result_stop]
                    if rst_ss_int.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_str_int_result_is_str_at(toks, slots, fns, src, vp, result_stop) == 1 {
                counter = emit_result_str_int_match_str_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_str = toks[result_stop]
                    if rst_str.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_struct_int_result_is_str_at(toks, slots, fns, defs, src, vp, result_stop) == 1 {
                counter = emit_result_struct_int_match_str_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_struct_str = toks[result_stop]
                    if rst_struct_str.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_struct_int_result_is_int_at(toks, slots, fns, defs, src, vp, result_stop) == 1 {
                counter = emit_result_struct_int_match_int_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_struct = toks[result_stop]
                    if rst_struct.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_str_int_result_is_int_at(toks, slots, fns, src, vp, result_stop) == 1 {
                counter = emit_result_str_int_match_int_let(toks, slots, fns, defs, src, vp, slot, counter)
                if result_stop < end {
                    let rst_int = toks[result_stop]
                    if rst_int.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if result_match_payload_result_is_int_at(toks, src, vp, result_stop) == 1 {
                let result_expr = gen_expr(toks, slots, fns, defs, src, result_match_expr_start(toks, vp), result_match_expr_end(toks, src, vp), counter)
                counter = result_expr.next
                emit_str("  %t")
                pint(counter)
                emit_str(" = sdiv i64 ")
                emit_op(result_expr)
                emit_str(", 2")
                putchar(10)
                let result_match_div = counter
                counter = counter + 1
                emit_str("  %t")
                pint(counter)
                emit_str(" = srem i64 %t")
                pint(result_match_div)
                emit_str(", 1000000")
                putchar(10)
                let result_match_payload = counter
                counter = counter + 1
                emit_str("  store i64 %t")
                pint(result_match_payload)
                emit_str(", i64* %v")
                pint(slot)
                putchar(10)
                if result_stop < end {
                    let rst2 = toks[result_stop]
                    if rst2.kind == 6 { i = result_stop + 1 } else { i = result_stop }
                } else { i = result_stop }
            } else if isarr_of(slots, src, name.nstart, name.nlen) == 5 {
                let stop = find_semi(toks, vp, end)
                if rhs_is_empty_map(toks, npos) == 1 {
                    i = stop + 1
                } else if rhs.kind == 1 and stop == vp + 1 and (isarr_of(slots, src, rhs.nstart, rhs.nlen) == 5 or isarr_of(slots, src, rhs.nstart, rhs.nlen) == 6) {
                    if sty_of(slots, src, rhs.nstart, rhs.nlen) == sty_of(slots, src, name.nstart, name.nlen) {
                        emit_map_base_ptr(slots, src, name.nstart, name.nlen, counter)
                        let dstp = counter
                        counter = counter + 1
                        emit_map_base_ptr(slots, src, rhs.nstart, rhs.nlen, counter)
                        let srcp = counter
                        counter = counter + 1
                        emit_str("  call void @")
                        emit_map_helper_name(slots, src, name.nstart, name.nlen, "copy")
                        emit_str("(i64* %t")
                        pint(dstp)
                        emit_str(", i64* %t")
                        pint(srcp)
                        emit_str(")")
                        putchar(10)
                    }
                    i = stop + 1
                } else if call_retmapty(toks, fns, src, vp) == sty_of(slots, src, name.nstart, name.nlen) {
                    let cclose = paren_end(toks, vp + 2)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(map_bufsz())
                    emit_str(" x i64], [")
                    pint(map_bufsz())
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 0")
                    putchar(10)
                    let outp = counter
                    counter = counter + 1
                    counter = emit_struct_out_call(toks, slots, fns, defs, src, vp, vp + 2, cclose, counter, outp)
                    let cstop = find_stmt_end(toks, src, cclose, end)
                    if cstop < end {
                        let cst = toks[cstop]
                        if cst.kind == 6 { i = cstop + 1 } else { i = cstop }
                    } else { i = cstop }
                } else {
                    i = stop + 1
                }
            } else if rhs_field_sty >= 0 {
                counter = emit_struct_field_chain_to_local(toks, slots, defs, src, vp, slot, rhs_field_sty, counter)
                let stop_field = find_stmt_end(toks, src, vp, end)
                if stop_field < end {
                    let st_field = toks[stop_field]
                    if st_field.kind == 6 { i = stop_field + 1 } else { i = stop_field }
                } else { i = stop_field }
            } else if los_est >= 0 {
                # `let t = toks[idx]`, `let t = toks.first()`, `let t = toks.last()`,
                # `let t = toks.pop()`, or `let t = toks.remove_at(idx)` -> copy
                # the struct element into t's [nf x i64] local. Mutating methods
                # also update the source list length/storage after the copy.
                let lvar = toks[vp]
                let lnf = struct_flat_nfields(toks, defs, src, los_est)
                let lkarr = isarr_of(slots, src, lvar.nstart, lvar.nlen)
                let lsrcslot = find_slot(slots, src, lvar.nstart, lvar.nlen)
                let lnext = toks[vp + 1]
                let mut lafter = vp + 1
                let mut lidxkind = 0
                let mut lidxval = 0
                let mut lbufptr = 0
                let mut lhavebuf = 0
                let mut lpop = 0
                let mut lremove = 0
                let mut lpop_lenp = 0
                let mut lremove_len = 0
                if lnext.kind == 23 {
                    let libend = bracket_end(toks, vp + 2)
                    let lidx0 = gen_expr(toks, slots, fns, defs, src, vp + 2, libend, counter)
                    lidxkind = lidx0.kind
                    lidxval = lidx0.val
                    counter = lidx0.next
                    lafter = libend + 1
                    if lkarr == 4 {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64*, i64** %v")
                        pint(lsrcslot)
                        putchar(10)
                        lbufptr = counter
                        lhavebuf = 1
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(lbufptr)
                        emit_str(", i64 ")
                        pint(list_lenidx_for_nfields(lnf))
                        putchar(10)
                        let llenp0 = counter
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64, i64* %t")
                        pint(llenp0)
                        putchar(10)
                        let llen0 = counter
                        counter = emit_list_bounds_trap(Op { kind: lidxkind, val: lidxval, next: 0 }, Op { kind: 1, val: llen0, next: 0 }, llen0 + 1)
                    } else {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64, i64* %v")
                        pint(lsrcslot + 1)
                        putchar(10)
                        let llen0 = counter
                        counter = emit_list_bounds_trap(Op { kind: lidxkind, val: lidxval, next: 0 }, Op { kind: 1, val: llen0, next: 0 }, llen0 + 1)
                    }
                } else {
                    let lmeth = toks[vp + 2]
                    let mut lfirst = 0
                    if is_first(src, lmeth.nstart, lmeth.nlen) == 1 { lfirst = 1 }
                    if is_pop(src, lmeth.nstart, lmeth.nlen) == 1 { lpop = 1 }
                    if is_remove_at(src, lmeth.nstart, lmeth.nlen) == 1 { lremove = 1 }
                    let lclose = paren_end(toks, vp + 4)
                    if lremove == 1 {
                        let lidx0 = gen_expr(toks, slots, fns, defs, src, vp + 4, lclose, counter)
                        lidxkind = lidx0.kind
                        lidxval = lidx0.val
                        counter = lidx0.next
                    }
                    lafter = lclose + 1
                    if lkarr == 4 {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64*, i64** %v")
                        pint(lsrcslot)
                        putchar(10)
                        lbufptr = counter
                        lhavebuf = 1
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(lbufptr)
                        emit_str(", i64 ")
                        pint(list_lenidx_for_nfields(lnf))
                        putchar(10)
                        let llenp = counter
                        lpop_lenp = llenp
                        counter = counter + 1
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64, i64* %t")
                        pint(llenp)
                        putchar(10)
                    } else {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = load i64, i64* %v")
                        pint(lsrcslot + 1)
                        putchar(10)
                    }
                    let llenc = counter
                    lremove_len = llenc
                    if lremove == 1 {
                        counter = emit_list_bounds_trap(Op { kind: lidxkind, val: lidxval, next: 0 }, Op { kind: 1, val: llenc, next: 0 }, llenc + 1)
                    } else {
                        counter = emit_list_nonempty_trap(Op { kind: 1, val: llenc, next: 0 }, llenc + 1)
                        if lfirst == 1 {
                            lidxkind = 0
                            lidxval = 0
                        } else {
                            emit_str("  %t")
                            pint(counter)
                            emit_str(" = sub i64 %t")
                            pint(llenc)
                            emit_str(", 1")
                            putchar(10)
                            lidxkind = 1
                            lidxval = counter
                            counter = counter + 1
                        }
                    }
                }
                # base = idx * nf  (element offset into the i64 buffer)
                emit_str("  %t")
                pint(counter)
                emit_str(" = mul i64 ")
                emit_op(Op { kind: lidxkind, val: lidxval, next: 0 })
                emit_str(", ")
                pint(lnf)
                putchar(10)
                let lbase = counter
                counter = counter + 1
                # for a param list (is_arr=4) load the buffer pointer once
                if lkarr == 4 and lhavebuf == 0 {
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = load i64*, i64** %v")
                    pint(lsrcslot)
                    putchar(10)
                    lbufptr = counter
                    counter = counter + 1
                }
                let lbufsz = list_bufsz_for_nfields(lnf)
                let mut fk = 0
                while fk < lnf {
                    # source elem ptr = buf + (base + fk)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = add i64 %t")
                    pint(lbase)
                    emit_str(", ")
                    pint(fk)
                    putchar(10)
                    let foff = counter
                    counter = counter + 1
                    if lkarr == 4 {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(lbufptr)
                        emit_str(", i64 %t")
                        pint(foff)
                        putchar(10)
                    } else {
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr [")
                        pint(lbufsz)
                        emit_str(" x i64], [")
                        pint(lbufsz)
                        emit_str(" x i64]* %v")
                        pint(lsrcslot)
                        emit_str(", i64 0, i64 %t")
                        pint(foff)
                        putchar(10)
                    }
                    let fsrc = counter
                    counter = counter + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = load i64, i64* %t")
                    pint(fsrc)
                    putchar(10)
                    let fval = counter
                    counter = counter + 1
                    # dest = t[fk]  (t is a [nf x i64] struct local at %v<slot>)
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(lnf)
                    emit_str(" x i64], [")
                    pint(lnf)
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 ")
                    pint(fk)
                    putchar(10)
                    let fdst = counter
                    counter = counter + 1
                    emit_str("  store i64 %t")
                    pint(fval)
                    emit_str(", i64* %t")
                    pint(fdst)
	                    putchar(10)
	                    fk = fk + 1
	                }
	                if lremove == 1 {
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = sub i64 %t")
	                    pint(lremove_len)
	                    emit_str(", 1")
	                    putchar(10)
	                    let llast = counter
	                    counter = counter + 1
	                    let lri = counter
	                    emit_str("  %lri")
	                    pint(lri)
	                    emit_str(" = alloca i64")
	                    putchar(10)
	                    counter = counter + 1
	                    emit_str("  store i64 ")
	                    emit_op(Op { kind: lidxkind, val: lidxval, next: 0 })
	                    emit_str(", i64* %lri")
	                    pint(lri)
	                    putchar(10)
	                    emit_str("  br label %losRemoveL")
	                    pint(lri)
	                    putchar(10)
	                    emit_str("losRemoveL")
	                    pint(lri)
	                    emit_str(":")
	                    putchar(10)
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = load i64, i64* %lri")
	                    pint(lri)
	                    putchar(10)
	                    let lj = counter
	                    counter = counter + 1
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = icmp slt i64 %t")
	                    pint(lj)
	                    emit_str(", %t")
	                    pint(llast)
	                    putchar(10)
	                    let lcmp = counter
	                    counter = counter + 1
	                    emit_str("  br i1 %t")
	                    pint(lcmp)
	                    emit_str(", label %losRemoveB")
	                    pint(lri)
	                    emit_str(", label %losRemoveD")
	                    pint(lri)
	                    putchar(10)
	                    emit_str("losRemoveB")
	                    pint(lri)
	                    emit_str(":")
	                    putchar(10)
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = add i64 %t")
	                    pint(lj)
	                    emit_str(", 1")
	                    putchar(10)
	                    let lnexti = counter
	                    counter = counter + 1
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = mul i64 %t")
	                    pint(lnexti)
	                    emit_str(", ")
	                    pint(lnf)
	                    putchar(10)
	                    let lsrcbase = counter
	                    counter = counter + 1
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = mul i64 %t")
	                    pint(lj)
	                    emit_str(", ")
	                    pint(lnf)
	                    putchar(10)
	                    let ldstbase = counter
	                    counter = counter + 1
	                    let mut mfk = 0
	                    while mfk < lnf {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = add i64 %t")
	                        pint(lsrcbase)
	                        emit_str(", ")
	                        pint(mfk)
	                        putchar(10)
	                        let lsoff = counter
	                        counter = counter + 1
	                        if lkarr == 4 {
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr i64, i64* %t")
	                            pint(lbufptr)
	                            emit_str(", i64 %t")
	                            pint(lsoff)
	                            putchar(10)
	                        } else {
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr [")
	                            pint(lbufsz)
	                            emit_str(" x i64], [")
	                            pint(lbufsz)
	                            emit_str(" x i64]* %v")
	                            pint(lsrcslot)
	                            emit_str(", i64 0, i64 %t")
	                            pint(lsoff)
	                            putchar(10)
	                        }
	                        let lsp = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = load i64, i64* %t")
	                        pint(lsp)
	                        putchar(10)
	                        let lmv = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = add i64 %t")
	                        pint(ldstbase)
	                        emit_str(", ")
	                        pint(mfk)
	                        putchar(10)
	                        let ldoff = counter
	                        counter = counter + 1
	                        if lkarr == 4 {
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr i64, i64* %t")
	                            pint(lbufptr)
	                            emit_str(", i64 %t")
	                            pint(ldoff)
	                            putchar(10)
	                        } else {
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr [")
	                            pint(lbufsz)
	                            emit_str(" x i64], [")
	                            pint(lbufsz)
	                            emit_str(" x i64]* %v")
	                            pint(lsrcslot)
	                            emit_str(", i64 0, i64 %t")
	                            pint(ldoff)
	                            putchar(10)
	                        }
	                        let ldp = counter
	                        counter = counter + 1
	                        emit_str("  store i64 %t")
	                        pint(lmv)
	                        emit_str(", i64* %t")
	                        pint(ldp)
	                        putchar(10)
	                        mfk = mfk + 1
	                    }
	                    emit_str("  store i64 %t")
	                    pint(lnexti)
	                    emit_str(", i64* %lri")
	                    pint(lri)
	                    putchar(10)
	                    emit_str("  br label %losRemoveL")
	                    pint(lri)
	                    putchar(10)
	                    emit_str("losRemoveD")
	                    pint(lri)
	                    emit_str(":")
	                    putchar(10)
	                    emit_str("  store i64 %t")
	                    pint(llast)
	                    if lkarr == 4 {
	                        emit_str(", i64* %t")
	                        pint(lpop_lenp)
	                    } else {
	                        emit_str(", i64* %v")
	                        pint(lsrcslot + 1)
	                    }
	                    putchar(10)
	                }
	                if lpop == 1 {
	                    emit_str("  store i64 %t")
	                    pint(lidxval)
                    if lkarr == 4 {
                        emit_str(", i64* %t")
                        pint(lpop_lenp)
                    } else {
                        emit_str(", i64* %v")
                        pint(lsrcslot + 1)
                    }
                    putchar(10)
                }
                let stop = find_semi(toks, lafter, end)
                i = stop + 1
            } else if lsti >= 0 {
                # struct literal: Name { f: v, ... } -> store each field via GEP.
                # `vp` is the struct-name token; the open-brace is at vp+1. Field is
                # `name : value` (the `:` is tokenized as kind 16).
                let nf = struct_flat_nfields(toks, defs, src, lsti)
                let bopen = vp + 1
                let bclose = match_brace(toks, bopen, end)
                let mut q = bopen + 1
                while q < bclose {
                    let fld = toks[q]
                    let fi = field_flat_offset(toks, defs, src, lsti, fld.nstart, fld.nlen)
                    let mut vstart = q + 1
                    let colt = toks[q + 1]
                    if colt.kind == 16 { vstart = q + 2 }
                    let vstop = arg_comma_end(toks, vstart, bclose)
                    let mut used_nested = 0
                    let nt = toks[vstart]
                    let nb = toks[vstart + 1]
                    let fty_local = struct_field_type_index(toks, defs, src, lsti, fld.nstart, fld.nlen)
                    if nt.kind == 1 and vstop == vstart + 1 and fty_local >= 0 {
                        if isarr_of(slots, src, nt.nstart, nt.nlen) == 0 and sty_of(slots, src, nt.nstart, nt.nlen) == fty_local {
                            counter = emit_struct_local_to_local_field(toks, slots, defs, src, lsti, slot, q, vstart, counter)
                            used_nested = 1
                        }
                    }
                    if nt.kind == 1 and nb.kind == 11 {
                        let nty = struct_index_by_name(defs, src, nt.nstart, nt.nlen)
                        if nty >= 0 {
                            let fty = fty_local
                            if fty == nty {
                                counter = emit_nested_struct_literal_to_local(toks, slots, fns, defs, src, lsti, slot, q, vstart, counter)
                                used_nested = 1
                            }
                        }
                    }
                    if used_nested == 0 {
                    let e = gen_expr(toks, slots, fns, defs, src, vstart, vstop, counter)
                    counter = e.next
                    let e64 = ensure_i64_op(e, counter)
                    counter = e64.next
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(nf)
                    emit_str(" x i64], [")
                    pint(nf)
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 ")
                    pint(fi)
                    putchar(10)
                    emit_str("  store i64 ")
                    emit_op(e64)
                    emit_str(", i64* %t")
                    pint(counter)
                    putchar(10)
                    counter = counter + 1
                    }
                    q = vstop + 1
                }
                let stop = find_stmt_end(toks, src, bclose, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if call_retsty(toks, fns, src, vp) != 0 - 2 {
                # `let op = gen_expr(...)` where gen_expr returns a struct. The
                # local struct buffer was allocated in add_local_slots; pass its
                # first field pointer as the callee's hidden out-param.
                let rst = call_retsty(toks, fns, src, vp)
                let nf = struct_flat_nfields(toks, defs, src, rst)
                let cclose = paren_end(toks, vp + 2)
                emit_str("  %t")
                pint(counter)
                emit_str(" = getelementptr [")
                pint(nf)
                emit_str(" x i64], [")
                pint(nf)
                emit_str(" x i64]* %v")
                pint(slot)
                emit_str(", i64 0, i64 0")
                putchar(10)
                let outp = counter
                counter = counter + 1
                counter = emit_struct_out_call(toks, slots, fns, defs, src, vp, vp + 2, cclose, counter, outp)
                let stop = find_stmt_end(toks, src, cclose, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if call_retty(toks, fns, src, vp) != 0 - 3 {
                # `let ys = build(args)` -- build returns a List. Emit the call with
                # build's regular args plus a hidden trailing `i64*` = ys's buffer
                # base; build copies its result into it. Then sync ys.len from the
                # out-param's length slot (buf[63] scalar / buf[64*nf] struct).
                let cname = toks[vp]
                let rty = call_retty(toks, fns, src, vp)
                let mut stride = 1
                let mut lenidx = list_lenidx()
                let mut cbuf = list_cap()
                if rty >= 0 {
                    stride = struct_flat_nfields(toks, defs, src, rty)
                    lenidx = list_lenidx_for_nfields(stride)
                    cbuf = list_bufsz_for_nfields(stride)
                }
                let cclose = paren_end(toks, vp + 2)
                # evaluate each comma-separated arg (scalar/string/List) into Ops.
                let mut a0k = 0
                let mut a0v = 0
                let mut a1k = 0
                let mut a1v = 0
                let mut a2k = 0
                let mut a2v = 0
                let mut a3k = 0
                let mut a3v = 0
                let mut a4k = 0
                let mut a4v = 0
                let mut a5k = 0
                let mut a5v = 0
                let mut a6k = 0
                let mut a6v = 0
                let mut a7k = 0
                let mut a7v = 0
                let mut a8k = 0
                let mut a8v = 0
                let mut a9k = 0
                let mut a9v = 0
                let mut nca = 0
                let mut cc = counter
                let mut q = vp + 2
                let mut ga = true
                while ga {
                    if q >= cclose { ga = false }
                    else {
                        let astop = arg_comma_end(toks, q, cclose)
                        let argt = toks[q]
                        let mut ek = 0
                        let mut ev = 0
                        let mut handled = 0
                        if argt.kind == 1 {
                            let after = toks[q + 1]
                            if astop == q + 1 {
                                let want_ty = call_param_ty(fns, src, cname.nstart, cname.nlen, nca)
                                let aarr = isarr_of(slots, src, argt.nstart, argt.nlen)
                                if is_map_param_ty(want_ty) and map_arg_matches_param(slots, src, argt.nstart, argt.nlen, want_ty) == 1 {
                                    emit_map_base_ptr(slots, src, argt.nstart, argt.nlen, cc)
                                    ek = 3
                                    ev = cc
                                    cc = cc + 1
                                    handled = 1
                                } else if aarr == 2 {
                                    # local List arg passed by pointer (write len->buf[63] then base)
                                    let lslot = find_slot(slots, src, argt.nstart, argt.nlen)
                                    let mut alsty = sty_of(slots, src, argt.nstart, argt.nlen)
                                    let pst = param_list_elem_sty(toks, defs, src, toks.len(), cname.nstart, cname.nlen, nca)
                                    if pst >= 0 { alsty = pst }
                                    let mut albuf = list_cap()
                                    let mut alidx = list_lenidx()
                                    if alsty >= 0 {
                                        let anf2 = struct_flat_nfields(toks, defs, src, alsty)
                                        albuf = list_bufsz_for_nfields(anf2)
                                        alidx = list_lenidx_for_nfields(anf2)
                                    }
                                    emit_str("  %t")
                                    pint(cc)
                                    emit_str(" = load i64, i64* %v")
                                    pint(lslot + 1)
                                    putchar(10)
                                    let lc = cc
                                    emit_str("  %t")
                                    pint(lc + 1)
                                    emit_str(" = getelementptr [")
                                    pint(albuf)
                                    emit_str(" x i64], [")
                                    pint(albuf)
                                    emit_str(" x i64]* %v")
                                    pint(lslot)
                                    emit_str(", i64 0, i64 ")
                                    pint(alidx)
                                    putchar(10)
                                    emit_str("  store i64 %t")
                                    pint(lc)
                                    emit_str(", i64* %t")
                                    pint(lc + 1)
                                    putchar(10)
                                    emit_str("  %t")
                                    pint(lc + 2)
                                    emit_str(" = getelementptr [")
                                    pint(albuf)
                                    emit_str(" x i64], [")
                                    pint(albuf)
                                    emit_str(" x i64]* %v")
                                    pint(lslot)
                                    emit_str(", i64 0, i64 0")
                                    putchar(10)
                                    ek = 3
                                    ev = lc + 2
                                    cc = lc + 3
                                    handled = 1
                                } else if aarr == 4 {
                                    # List parameter forwarded to a List-returning call.
                                    let lslot = find_slot(slots, src, argt.nstart, argt.nlen)
                                    emit_str("  %t")
                                    pint(cc)
                                    emit_str(" = load i64*, i64** %v")
                                    pint(lslot)
                                    putchar(10)
                                    ek = 3
                                    ev = cc
                                    cc = cc + 1
                                    handled = 1
                                } else if aarr == 0 {
                                    # Struct local passed by value: pass its base pointer.
                                    let mut ast = sty_of(slots, src, argt.nstart, argt.nlen)
                                    if want_ty >= 3 { ast = want_ty - 3 }
                                    if ast >= 0 and want_ty >= 3 {
                                        let aslot = find_slot(slots, src, argt.nstart, argt.nlen)
                                        let anf = struct_flat_nfields(toks, defs, src, ast)
                                        emit_str("  %t")
                                        pint(cc)
                                        emit_str(" = getelementptr [")
                                        pint(anf)
                                        emit_str(" x i64], [")
                                        pint(anf)
                                        emit_str(" x i64]* %v")
                                        pint(aslot)
                                        emit_str(", i64 0, i64 0")
                                        putchar(10)
                                        ek = 3
                                        ev = cc
                                        cc = cc + 1
                                        handled = 1
                                    }
                                }
                            } else if after.kind == 11 {
                                # Struct literal as an argument to a List-returning call.
                                let ast = struct_index_by_name(defs, src, argt.nstart, argt.nlen)
                                if ast >= 0 {
                                    let anf = struct_flat_nfields(toks, defs, src, ast)
                                    let aid = cc
                                    emit_str("  %sa")
                                    pint(aid)
                                    emit_str(" = alloca [")
                                    pint(anf)
                                    emit_str(" x i64]")
                                    putchar(10)
                                    cc = cc + 1
                                    let bopen = q + 1
                                    let bclose = match_brace(toks, bopen, cclose)
                                    let mut fq = bopen + 1
                                    while fq < bclose {
                                        let fld = toks[fq]
                                        let fi = field_index(defs, ast, src, fld.nstart, fld.nlen)
                                        let mut vstart = fq + 1
                                        let colt = toks[fq + 1]
                                        if colt.kind == 16 { vstart = fq + 2 }
                                        let vstop = arr_elem_end(toks, vstart, bclose)
                                        let fe = gen_expr(toks, slots, fns, defs, src, vstart, vstop, cc)
                                        cc = fe.next
                                        let fe64 = ensure_i64_op(fe, cc)
                                        cc = fe64.next
                                        emit_str("  %t")
                                        pint(cc)
                                        emit_str(" = getelementptr [")
                                        pint(anf)
                                        emit_str(" x i64], [")
                                        pint(anf)
                                        emit_str(" x i64]* %sa")
                                        pint(aid)
                                        emit_str(", i64 0, i64 ")
                                        pint(fi)
                                        putchar(10)
                                        emit_str("  store i64 ")
                                        emit_op(fe64)
                                        emit_str(", i64* %t")
                                        pint(cc)
                                        putchar(10)
                                        cc = cc + 1
                                        fq = vstop + 1
                                    }
                                    emit_str("  %t")
                                    pint(cc)
                                    emit_str(" = getelementptr [")
                                    pint(anf)
                                    emit_str(" x i64], [")
                                    pint(anf)
                                    emit_str(" x i64]* %sa")
                                    pint(aid)
                                    emit_str(", i64 0, i64 0")
                                    putchar(10)
                                    ek = 3
                                    ev = cc
                                    cc = cc + 1
                                    handled = 1
                                }
                            }
                        }
                        if handled == 0 and argt.kind == 23 {
                            let want_ty2 = call_param_ty(fns, src, cname.nstart, cname.nlen, nca)
                            let pst2 = param_list_elem_sty(toks, defs, src, toks.len(), cname.nstart, cname.nlen, nca)
                            if want_ty2 == 2 {
                                let lop = emit_inline_list_literal_arg(toks, slots, fns, defs, src, q, pst2, cc)
                                ek = lop.kind
                                ev = lop.val
                                cc = lop.next
                                handled = 1
                            }
                        }
                        if handled == 0 {
                            let e = gen_expr(toks, slots, fns, defs, src, q, astop, cc)
                            cc = e.next
                            ek = e.kind
                            ev = e.val
                        }
                        if nca == 0 { a0k = ek; a0v = ev }
                        else if nca == 1 { a1k = ek; a1v = ev }
                        else if nca == 2 { a2k = ek; a2v = ev }
                        else if nca == 3 { a3k = ek; a3v = ev }
                        else if nca == 4 { a4k = ek; a4v = ev }
                        else if nca == 5 { a5k = ek; a5v = ev }
                        else if nca == 6 { a6k = ek; a6v = ev }
                        else if nca == 7 { a7k = ek; a7v = ev }
                        else if nca == 8 { a8k = ek; a8v = ev }
                        else { a9k = ek; a9v = ev }
                        nca = nca + 1
                        q = astop + 1
                    }
                }
                # ys buffer base pointer
                let ybase = cc
                emit_str("  %t")
                pint(ybase)
                emit_str(" = getelementptr [")
                pint(cbuf)
                emit_str(" x i64], [")
                pint(cbuf)
                emit_str(" x i64]* %v")
                pint(slot)
                emit_str(", i64 0, i64 0")
                putchar(10)
                counter = ybase + 1
                # emit the void call: build(args..., i64* ybase)
                emit_str("  call void @")
                emit_name(src, cname.nstart, cname.nlen)
                emit_str("(")
                let mut ai = 0
                while ai < nca {
                    if ai > 0 { emit_str(", ") }
                    let mut ak = a0k
                    let mut av = a0v
                    if ai == 1 { ak = a1k; av = a1v }
                    else if ai == 2 { ak = a2k; av = a2v }
                    else if ai == 3 { ak = a3k; av = a3v }
                    else if ai == 4 { ak = a4k; av = a4v }
                    else if ai == 5 { ak = a5k; av = a5v }
                    else if ai == 6 { ak = a6k; av = a6v }
                    else if ai == 7 { ak = a7k; av = a7v }
                    else if ai == 8 { ak = a8k; av = a8v }
                    else if ai == 9 { ak = a9k; av = a9v }
                    if ak == 2 { emit_str("i8* ") } else if ak == 3 { emit_str("i64* ") } else { emit_str("i64 ") }
                    emit_op(Op { kind: ak, val: av, next: 0 })
                    ai = ai + 1
                }
                if nca > 0 { emit_str(", ") }
                emit_str("i64* %t")
                pint(ybase)
                emit_str(")")
                putchar(10)
                # sync ys.len (%v<slot+1>) from the out-param's length slot
                emit_str("  %t")
                pint(counter)
                emit_str(" = getelementptr [")
                pint(cbuf)
                emit_str(" x i64], [")
                pint(cbuf)
                emit_str(" x i64]* %v")
                pint(slot)
                emit_str(", i64 0, i64 ")
                pint(lenidx)
                putchar(10)
                let lgp = counter
                counter = counter + 1
                emit_str("  %t")
                pint(counter)
                emit_str(" = load i64, i64* %t")
                pint(lgp)
                putchar(10)
                emit_str("  store i64 %t")
                pint(counter)
                emit_str(", i64* %v")
                pint(slot + 1)
                putchar(10)
                counter = counter + 1
                let stop = find_stmt_end(toks, src, cclose, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if rhs_is_map_str_str_get_opt_match(toks, slots, src, npos) == 1 {
                let stop = find_semi(toks, vp, end)
                let mut dest_is_str = 0
                if isarr_of(slots, src, name.nstart, name.nlen) == 3 { dest_is_str = 1 }
                counter = emit_map_str_str_get_opt_match_let(toks, slots, fns, defs, src, npos, slot, dest_is_str, counter)
                i = stop + 1
            } else if isarr_of(slots, src, name.nstart, name.nlen) == 3 {
                let stop = find_semi(toks, vp, end)
                if rhs.kind != 28 {
                    let e = gen_expr(toks, slots, fns, defs, src, vp, stop, counter)
                    emit_str("  store i8* ")
                    emit_op(e)
                    emit_str(", i8** %v")
                    pint(slot)
                    putchar(10)
                    counter = e.next
                }
                i = stop + 1
            } else if isarr_of(slots, src, name.nstart, name.nlen) == 2 and rhs.kind == 23 {
                # List literal: materialize elements into the List buffer and
                # store the logical length in the side slot.
                let lty = sty_of(slots, src, name.nstart, name.nlen)
                let bend = bracket_end(toks, vp + 1)
                let lit_len = list_literal_elem_count(toks, vp + 1, bend)
                counter = emit_list_literal_data(toks, slots, fns, defs, src, vp + 1, bend, lty, slot, counter)
                emit_str("  store i64 ")
                pint(lit_len)
                emit_str(", i64* %v")
                pint(slot + 1)
                putchar(10)
                let stop = find_stmt_end(toks, src, bend, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if rhs_is_list(toks, src, npos) == 1 {
                # let lst = list() / [];  — alloca/len already emitted in collect; skip
                let stop = find_stmt_end(toks, src, vp, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if rhs.kind == 1 and find_stmt_end(toks, src, vp, end) == vp + 1 and isarr_of(slots, src, rhs.nstart, rhs.nlen) == 4 and isarr_of(slots, src, name.nstart, name.nlen) == 4 {
                # `let alias = list_param`: copy the incoming buffer pointer into the
                # alias slot. Mutating either name updates the same List buffer.
                let rslot = find_slot(slots, src, rhs.nstart, rhs.nlen)
                emit_str("  %t")
                pint(counter)
                emit_str(" = load i64*, i64** %v")
                pint(rslot)
                putchar(10)
                emit_str("  store i64* %t")
                pint(counter)
                emit_str(", i64** %v")
                pint(slot)
                putchar(10)
                counter = counter + 1
                let stop = find_stmt_end(toks, src, vp, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if rhs.kind == 23 {
                # array literal: store each element via GEP. `vp` is the `[`.
                let alen = arrlen_of(slots, src, name.nstart, name.nlen)
                let bend = bracket_end(toks, vp + 1)
                let mut q = vp + 1
                let mut idx = 0
                while q < bend {
                    let estop = arr_elem_end(toks, q, bend)
                    let e = gen_expr(toks, slots, fns, defs, src, q, estop, counter)
                    counter = e.next
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(alen)
                    emit_str(" x i64], [")
                    pint(alen)
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 ")
                    pint(idx)
                    putchar(10)
                    emit_str("  store i64 ")
                    emit_op(e)
                    emit_str(", i64* %t")
                    pint(counter)
                    putchar(10)
                    counter = counter + 1
                    idx = idx + 1
                    q = estop + 1
                }
                let stop = find_stmt_end(toks, src, bend, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if rhs.kind == 28 {
                # let s = `lit`;  — string global + i8* alloca + ptr-store already
                # emitted in the slot collector; nothing to do here.
                let stop = find_stmt_end(toks, src, vp, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else {
                let stop = find_stmt_end(toks, src, vp, end)
                let e = gen_expr(toks, slots, fns, defs, src, vp, stop, counter)
                emit_str("  store i64 ")
                emit_op(e)
                emit_str(", i64* %v")
                pint(slot)
                putchar(10)
                counter = e.next
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            }
        } else if t.kind == 1 {
            let nx = toks[i + 1]
            let asti = sty_of(slots, src, t.nstart, t.nlen)
            if is_putchar(src, t.nstart, t.nlen) == 1 {
                # putchar(<expr>) ; -> trunc to i32 + call @putchar
                let argstop = paren_end(toks, i + 2)
                let e = gen_expr(toks, slots, fns, defs, src, i + 2, argstop, counter)
                counter = e.next
                emit_str("  %t")
                pint(counter)
                emit_str(" = trunc i64 ")
                emit_op(e)
                emit_str(" to i32")
                putchar(10)
                let tc = counter
                counter = counter + 1
                emit_str("  %t")
                pint(counter)
                emit_str(" = call i32 @putchar(i32 %t")
                pint(tc)
                emit_str(")")
                putchar(10)
                counter = counter + 1
                let stop = find_stmt_end(toks, src, argstop, end)
                if stop < end {
                    let st = toks[stop]
                    if st.kind == 6 { i = stop + 1 } else { i = stop }
                } else { i = stop }
            } else if nx.kind == 9 {
                # bare call statement: name(args) ; -> emit the call, discard result.
                # (gen_expr/gen_factor generate the call IR.) Needed for out-param
                # patterns like `tokenize(src, out);`.
                let callclose = paren_end(toks, i + 2)
                let cstop = find_stmt_end(toks, src, callclose, end)
                let e = gen_expr(toks, slots, fns, defs, src, i, callclose + 1, counter)
                counter = e.next
                if cstop < end {
                    let st = toks[cstop]
                    if st.kind == 6 { i = cstop + 1 } else { i = cstop }
                } else { i = cstop }
            } else if nx.kind == 27 {
              let astiarr = isarr_of(slots, src, t.nstart, t.nlen)
              # struct field write requires a SCALAR struct var (is_arr=0). A
              # List-of-structs (sty>=0, is_arr=2) must skip this and reach the
              # push handler in the final else.
              if astiarr == 5 or astiarr == 6 {
                let meth = toks[i + 2]
                if is_insert(src, meth.nstart, meth.nlen) == 1 {
                    let close = paren_end(toks, i + 4)
                    let a0stop = arg_comma_end(toks, i + 4, close)
                    let key = gen_map_key_expr(toks, slots, fns, defs, src, t.nstart, t.nlen, i + 4, a0stop, counter)
                    counter = key.next
                    let vstop = arg_comma_end(toks, a0stop + 1, close)
                    let value = gen_expr(toks, slots, fns, defs, src, a0stop + 1, vstop, counter)
                    let mut vkind = value.kind
                    let mut vval = value.val
                    let mut vnext = value.next
                    if map_is_str_value(slots, src, t.nstart, t.nlen) == 1 {
                        emit_str("  %t")
                        pint(vnext)
                        emit_str(" = ptrtoint i8* ")
                        emit_op(value)
                        emit_str(" to i64")
                        putchar(10)
                        vkind = 1
                        vval = vnext
                        vnext = vnext + 1
                    }
                    counter = vnext
                    let base = counter
                    emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                    counter = counter + 1
                    emit_str("  call void @")
                    emit_map_helper_name(slots, src, t.nstart, t.nlen, "insert")
                    emit_str("(i64* %t")
                    pint(base)
                    emit_str(", ")
                    emit_map_key_arg(slots, src, t.nstart, t.nlen, key)
                    emit_str(", i64 ")
                    emit_op(Op { kind: vkind, val: vval, next: 0 })
                    emit_str(")")
                    putchar(10)
                    let stop = find_stmt_end(toks, src, close, end)
                    if stop < end {
                        let st = toks[stop]
                        if st.kind == 6 { i = stop + 1 } else { i = stop }
                    } else { i = stop }
                } else if is_remove(src, meth.nstart, meth.nlen) == 1 {
                    let close = paren_end(toks, i + 4)
                    let key = gen_map_key_expr(toks, slots, fns, defs, src, t.nstart, t.nlen, i + 4, close, counter)
                    counter = key.next
                    let base = counter
                    emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                    counter = counter + 1
                    emit_str("  call void @")
                    emit_map_helper_name(slots, src, t.nstart, t.nlen, "remove")
                    emit_str("(i64* %t")
                    pint(base)
                    emit_str(", ")
                    emit_map_key_arg(slots, src, t.nstart, t.nlen, key)
                    emit_str(")")
                    putchar(10)
                    let stop = find_stmt_end(toks, src, close, end)
                    if stop < end {
                        let st = toks[stop]
                        if st.kind == 6 { i = stop + 1 } else { i = stop }
                    } else { i = stop }
                } else if is_clear(src, meth.nstart, meth.nlen) == 1 {
                    let close = paren_end(toks, i + 4)
                    let base = counter
                    emit_map_base_ptr(slots, src, t.nstart, t.nlen, base)
                    counter = counter + 1
                    emit_str("  call void @")
                    emit_map_helper_name(slots, src, t.nstart, t.nlen, "clear")
                    emit_str("(i64* %t")
                    pint(base)
                    emit_str(")")
                    putchar(10)
                    let stop = find_stmt_end(toks, src, close, end)
                    if stop < end {
                        let st = toks[stop]
                        if st.kind == 6 { i = stop + 1 } else { i = stop }
                    } else { i = stop }
                } else {
                    let stop = find_semi(toks, i, end)
                    let e = gen_expr(toks, slots, fns, defs, src, i, stop, counter)
                    counter = e.next
                    i = stop + 1
                }
              } else if asti >= 0 and astiarr == 0 {
                # struct field write: p . field = expr ;
                let fld = toks[i + 2]
                let slot = find_slot(slots, src, t.nstart, t.nlen)
                let nf = struct_flat_nfields(toks, defs, src, asti)
                let fi = field_chain_flat_offset(toks, defs, src, asti, i + 2)
                let maybe_dot = toks[i + 3]
                if maybe_dot.kind == 27 {
                    # Single-field nested struct write: p.inner.v = expr.
                    let stop = find_semi(toks, i + 6, end)
                    let e = gen_expr(toks, slots, fns, defs, src, i + 6, stop, counter)
                    counter = e.next
                    let e64 = ensure_i64_op(e, counter)
                    counter = e64.next
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(nf)
                    emit_str(" x i64], [")
                    pint(nf)
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 ")
                    pint(fi)
                    putchar(10)
                    emit_str("  store i64 ")
                    emit_op(e64)
                    emit_str(", i64* %t")
                    pint(counter)
                    putchar(10)
                    counter = counter + 1
                    i = stop + 1
                } else {
                    # '=' at i+3; value from i+4
                    let stop = find_semi(toks, i + 4, end)
                    let e = gen_expr(toks, slots, fns, defs, src, i + 4, stop, counter)
                    counter = e.next
                    let e64 = ensure_i64_op(e, counter)
                    counter = e64.next
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = getelementptr [")
                    pint(nf)
                    emit_str(" x i64], [")
                    pint(nf)
                    emit_str(" x i64]* %v")
                    pint(slot)
                    emit_str(", i64 0, i64 ")
                    pint(fi)
                    putchar(10)
                    emit_str("  store i64 ")
                    emit_op(e64)
                    emit_str(", i64* %t")
                    pint(counter)
                    putchar(10)
                    counter = counter + 1
                    i = stop + 1
                }
	              } else if is_extend(src, toks[i + 2].nstart, toks[i + 2].nlen) == 1 {
	                let dslot = find_slot(slots, src, t.nstart, t.nlen)
	                let dkind = isarr_of(slots, src, t.nstart, t.nlen)
	                let dsty = sty_of(slots, src, t.nstart, t.nlen)
	                let eclose = paren_end(toks, i + 4)
	                let et = toks[i + 4]
	                let mut sslot = find_slot(slots, src, et.nstart, et.nlen)
	                let mut skind = isarr_of(slots, src, et.nstart, et.nlen)
	                let mut ssty = sty_of(slots, src, et.nstart, et.nlen)
	                let mut source_call = 0
	                let mut source_call_close = 0
	                let mut source_literal = 0
	                let mut source_literal_close = 0
	                let source_fn_idx = find_fn(fns, src, et.nstart, et.nlen)
	                if et.kind == 1 and toks[i + 5].kind == 9 and source_fn_idx >= 0 {
	                    source_call_close = paren_end(toks, i + 6)
	                    let source_fn = fns[source_fn_idx]
	                    if source_call_close + 1 == eclose and source_fn.retlist == 1 and source_fn.retty == dsty {
	                        source_call = 1
	                        skind = 4
	                        ssty = source_fn.retty
	                    }
	                }
	                if et.kind == 23 {
	                    source_literal_close = bracket_end(toks, i + 5)
	                    if source_literal_close + 1 == eclose {
	                        source_literal = 1
	                        skind = 2
	                        ssty = dsty
	                    }
	                }
	                let mut bad_extend = 0
	                if ssty != dsty { bad_extend = 1 }
	                if dkind != 2 and dkind != 4 { bad_extend = 1 }
	                if source_call == 1 {
	                    if skind != 4 { bad_extend = 1 }
	                } else if source_literal == 1 {
	                } else {
	                    if et.kind != 1 { bad_extend = 1 }
	                    if sslot < 0 or (skind != 2 and skind != 4) { bad_extend = 1 }
	                }
	                if bad_extend == 1 {
	                    emit_str("  call void @llvm.trap()")
	                    putchar(10)
	                } else {
	                    let mut dbase = 0
	                    let mut dlenp = 0
	                    let mut sbase = 0
	                    let mut slenp = 0
	                    let mut ecap = list_cap()
	                    let mut ebufsz = list_cap()
	                    let mut estride = 1
	                    let mut elenidx = list_lenidx()
	                    if dsty >= 0 {
	                        estride = struct_flat_nfields(toks, defs, src, dsty)
	                        ecap = list_struct_cap(estride)
	                        ebufsz = list_bufsz_for_nfields(estride)
	                        elenidx = list_lenidx_for_nfields(estride)
	                    }
	                    if dkind == 4 {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = load i64*, i64** %v")
	                        pint(dslot)
	                        putchar(10)
	                        dbase = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr i64, i64* %t")
	                        pint(dbase)
	                        emit_str(", i64 ")
	                        pint(elenidx)
	                        putchar(10)
	                        dlenp = counter
	                        counter = counter + 1
	                    } else {
	                        dbase = dslot
	                        dlenp = dslot + 1
	                    }
	                    if source_call == 1 {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = alloca [")
	                        pint(ebufsz)
	                        emit_str(" x i64]")
	                        putchar(10)
	                        let srcbuf = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr [")
	                        pint(ebufsz)
	                        emit_str(" x i64], [")
	                        pint(ebufsz)
	                        emit_str(" x i64]* %t")
	                        pint(srcbuf)
	                        emit_str(", i64 0, i64 0")
	                        putchar(10)
	                        sbase = counter
	                        counter = counter + 1
	                        counter = emit_struct_out_call(toks, slots, fns, defs, src, i + 4, i + 6, source_call_close, counter, sbase)
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr i64, i64* %t")
	                        pint(sbase)
	                        emit_str(", i64 ")
	                        pint(elenidx)
	                        putchar(10)
	                        slenp = counter
	                        counter = counter + 1
	                    } else if source_literal == 1 {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = alloca [")
	                        pint(ebufsz)
	                        emit_str(" x i64]")
	                        putchar(10)
	                        let srcbuf2 = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr [")
	                        pint(ebufsz)
	                        emit_str(" x i64], [")
	                        pint(ebufsz)
	                        emit_str(" x i64]* %t")
	                        pint(srcbuf2)
	                        emit_str(", i64 0, i64 0")
	                        putchar(10)
	                        sbase = counter
	                        counter = counter + 1
	                        let mut lq = i + 5
	                        let mut lidx = 0
	                        while lq < source_literal_close {
	                            let lend = arg_comma_end(toks, lq, source_literal_close)
	                            if dsty >= 0 {

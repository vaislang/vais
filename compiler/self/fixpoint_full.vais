                                        pint(sbase)
                                        emit_str(", i64 ")
                                        pint(lit_off)
                                        putchar(10)
                                        emit_str("  store i64 ")
                                        emit_op(fe64_lit)
                                        emit_str(", i64* %t")
                                        pint(counter)
                                        putchar(10)
                                        counter = counter + 1
                                        fq_lit = vstop_lit + 1
                                    }
	                                } else {
	                                    emit_str("  call void @llvm.trap()")
	                                    putchar(10)
	                                }
	                            } else {
	                                let le = gen_expr(toks, slots, fns, defs, src, lq, lend, counter)
	                                counter = le.next
	                                let mut lek = le.kind
	                                let mut lev = le.val
	                                if dsty == 0 - 2 {
	                                    emit_str("  %t")
	                                    pint(counter)
	                                    emit_str(" = ptrtoint i8* ")
	                                    emit_op(le)
	                                    emit_str(" to i64")
	                                    putchar(10)
	                                    lek = 1
	                                    lev = counter
	                                    counter = counter + 1
	                                }
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = getelementptr i64, i64* %t")
	                                pint(sbase)
	                                emit_str(", i64 ")
	                                pint(lidx)
	                                putchar(10)
	                                emit_str("  store i64 ")
	                                emit_op(Op { kind: lek, val: lev, next: 0 })
	                                emit_str(", i64* %t")
	                                pint(counter)
	                                putchar(10)
	                                counter = counter + 1
	                            }
	                            lidx = lidx + 1
	                            lq = lend + 1
	                        }
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr i64, i64* %t")
	                        pint(sbase)
	                        emit_str(", i64 ")
	                        pint(elenidx)
	                        putchar(10)
	                        slenp = counter
	                        counter = counter + 1
	                        emit_str("  store i64 ")
	                        pint(lidx)
	                        emit_str(", i64* %t")
	                        pint(slenp)
	                        putchar(10)
	                    } else if skind == 4 {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = load i64*, i64** %v")
	                        pint(sslot)
	                        putchar(10)
	                        sbase = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr i64, i64* %t")
	                        pint(sbase)
	                        emit_str(", i64 ")
	                        pint(elenidx)
	                        putchar(10)
	                        slenp = counter
	                        counter = counter + 1
	                    } else {
	                        sbase = sslot
	                        slenp = sslot + 1
	                    }
	                    emit_str("  %t")
	                    pint(counter)
	                    emit_str(" = load i64, i64* ")

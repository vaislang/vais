# Builtin call ids used by the native parity surface:
#   1=Int(x) identity/truncation, 2=bitnot(x), 3=bitand, 4=bitor,
#   5=bitxor, 6=shl, 7=shr, 8=parse_uint(Str), 9=parse_int(Str),
#   10=Str(Int), 11=str_contains(Str, Str), 12=str_trim(Str),
#   13=str_lower(Str), 14=str_slice(Str, Int, Int),
#   15=str_split_ws_into(Str, List<Str>),
#   16=doc_term_counts_into(Str, Map<Str,Int>),
#   17=doc_term_overlap_score(Map<Str,Int>, Map<Str,Int>),
#   18=doc_term_weighted_score(Map<Str,Int>, Map<Str,Int>),
#   19=str_index_of(Str, Str), 20=str_starts_with(Str, Str),
#   21=str_upper(Str), 22=str_ends_with(Str, Str),
#   23=str_replace(Str, Str, Str), 24=str_split_into(Str, Str, List<Str>),
#   25=str_join(List<Str>, Str), 26=str_split_lines_into(Str, List<Str>),
#   27=str_byte(Int), 28=str_concat(Str, Str),
#   29=map_str_str_snapshot(Map<Str,Str>),
#   30=map_str_str_load_snapshot(Str, Map<Str,Str>).
fn builtin_call_id(src: Str, a: Int, alen: Int) -> Int {
    if alen == 3 {
        if src[a] == 73 and src[a + 1] == 110 and src[a + 2] == 116 { return 1 }
        if src[a] == 83 and src[a + 1] == 116 and src[a + 2] == 114 { return 10 }
        if src[a] == 115 and src[a + 1] == 104 and src[a + 2] == 108 { return 6 }
        if src[a] == 115 and src[a + 1] == 104 and src[a + 2] == 114 { return 7 }
    }
    if alen == 5 {
        if src[a] == 98 and src[a + 1] == 105 and src[a + 2] == 116 and src[a + 3] == 111 and src[a + 4] == 114 { return 4 }
    }
    if alen == 6 {
        if src[a] == 98 and src[a + 1] == 105 and src[a + 2] == 116 and src[a + 3] == 110 and src[a + 4] == 111 and src[a + 5] == 116 { return 2 }
        if src[a] == 98 and src[a + 1] == 105 and src[a + 2] == 116 and src[a + 3] == 97 and src[a + 4] == 110 and src[a + 5] == 100 { return 3 }
        if src[a] == 98 and src[a + 1] == 105 and src[a + 2] == 116 and src[a + 3] == 120 and src[a + 4] == 111 and src[a + 5] == 114 { return 5 }
    }
    if alen == 9 {
        if src[a] == 112 and src[a + 1] == 97 and src[a + 2] == 114 and src[a + 3] == 115 and src[a + 4] == 101 and src[a + 5] == 95 and src[a + 6] == 105 and src[a + 7] == 110 and src[a + 8] == 116 { return 9 }
        if is_str_lower(src, a, alen) == 1 { return 13 }
        if is_str_upper(src, a, alen) == 1 { return 21 }
        if is_str_slice(src, a, alen) == 1 { return 14 }
    }
    if alen == 10 {
        if src[a] == 112 and src[a + 1] == 97 and src[a + 2] == 114 and src[a + 3] == 115 and src[a + 4] == 101 and src[a + 5] == 95 and src[a + 6] == 117 and src[a + 7] == 105 and src[a + 8] == 110 and src[a + 9] == 116 { return 8 }
        if is_str_concat(src, a, alen) == 1 { return 28 }
    }
    if alen == 11 {
        if is_str_replace(src, a, alen) == 1 { return 23 }
    }
    if alen == 14 {
        if is_str_split_into(src, a, alen) == 1 { return 24 }
    }
    if alen == 8 {
        if is_str_join(src, a, alen) == 1 { return 25 }
        if is_str_trim(src, a, alen) == 1 { return 12 }
        if is_str_byte(src, a, alen) == 1 { return 27 }
    }
    if alen == 12 {
        if is_str_contains(src, a, alen) == 1 { return 11 }
        if is_str_index_of(src, a, alen) == 1 { return 19 }
    }
    if alen == 13 {
        if is_str_ends_with(src, a, alen) == 1 { return 22 }
    }
    if alen == 15 {
        if is_str_starts_with(src, a, alen) == 1 { return 20 }
    }
    if alen == 17 {
        if is_str_split_ws_into(src, a, alen) == 1 { return 15 }
    }
    if alen == 20 {
        if is_str_split_lines_into(src, a, alen) == 1 { return 26 }
        if is_map_str_str_snapshot(src, a, alen) == 1 { return 29 }
        if is_doc_term_counts_into(src, a, alen) == 1 { return 16 }
    }
    if alen == 22 {
        if is_doc_term_overlap_score(src, a, alen) == 1 { return 17 }
    }
    if alen == 23 {
        if is_doc_term_weighted_score(src, a, alen) == 1 { return 18 }
    }
    if alen == 25 {
        if is_map_str_str_load_snapshot(src, a, alen) == 1 { return 30 }
    }
    return 0
}
# Does the string-literal source range [start, start+len) contain a `{` (123)?
# Marks a print/puts argument that needs printf interpolation rather than a plain
# puts.
#
# Disambiguating literal braces from interpolation: `{` begins an interpolation ONLY
# when immediately followed by an identifier (letter/`_`, then letters/digits/`_`)
# and a closing `}`. A lone `{`
# (e.g. the trailing `{` of `define i64 @main() {`) is a literal brace.
#
# interp_end: if src[start+k] == '{' starts a valid `{ident}`, returns the offset
# (relative to start) of the closing `}`; else returns -1. `len` bounds the scan.
fn interp_end(src: Str, start: Int, len: Int, k: Int) -> Int {
    if k >= len { return 0 - 1 }
    if src[start + k] != 123 { return 0 - 1 }
    let mut j = k + 1
    # first char after `{` must be an identifier start (A-Z a-z _)
    if j >= len { return 0 - 1 }
    let c0 = src[start + j]
    let lo = c0 >= 97 and c0 <= 122
    let up = c0 >= 65 and c0 <= 90
    let us = c0 == 95
    if lo == false and up == false and us == false { return 0 - 1 }
    j = j + 1
    let mut go = true
    while go {
        if j >= len { return 0 - 1 }
        let c = src[start + j]
        if c == 125 { return j }
        let dl = c >= 97 and c <= 122
        let du = c >= 65 and c <= 90
        let dd = c >= 48 and c <= 57
        let ds = c == 95
        if dl == false and du == false and dd == false and ds == false { return 0 - 1 }
        j = j + 1
    }
    return 0 - 1
}
fn lit_has_brace(src: Str, start: Int, len: Int) -> Int {
    let mut k = 0
    while k < len {
        let e = interp_end(src, start, len, k)
        if e >= 0 { return 1 }
        k = k + 1
    }
    return 0
}
# Is a named function parameter annotated as Str?
fn fn_param_is_str(f: Fn, src: Str, qs: Int, ql: Int) -> Int {
    if f.npar >= 1 { if f.p0ty == 1 { if name_eq(src, f.p0s, f.p0l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 2 { if f.p1ty == 1 { if name_eq(src, f.p1s, f.p1l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 3 { if f.p2ty == 1 { if name_eq(src, f.p2s, f.p2l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 4 { if f.p3ty == 1 { if name_eq(src, f.p3s, f.p3l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 5 { if f.p4ty == 1 { if name_eq(src, f.p4s, f.p4l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 6 { if f.p5ty == 1 { if name_eq(src, f.p5s, f.p5l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 7 { if f.p6ty == 1 { if name_eq(src, f.p6s, f.p6l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 8 { if f.p7ty == 1 { if name_eq(src, f.p7s, f.p7l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 9 { if f.p8ty == 1 { if name_eq(src, f.p8s, f.p8l, qs, ql) == 1 { return 1 } } }
    if f.npar >= 10 { if f.p9ty == 1 { if name_eq(src, f.p9s, f.p9l, qs, ql) == 1 { return 1 } } }
    return 0
}

# Scan earlier lets in [start,end) and report whether name was bound from a string
# literal. This is used only by the module pre-pass to choose %s vs %d for a
# printf format global, so it intentionally stays narrower than full typechecking.
fn range_let_is_str(toks: &List<Token>, src: Str, start: Int, end: Int, qs: Int, ql: Int) -> Int {
    let mut i = start
    while i < end {
        let t = toks[i]
        if t.kind == 13 {
            i = skip_fn_def(toks, i, end)
        } else if t.kind == 26 {
            i = skip_struct_def(toks, i, end)
        } else if t.kind == 7 {
            let nx = toks[i + 1]
            let mut npos = i + 1
            if nx.kind == 21 { npos = i + 2 }
            let name = toks[npos]
            if name_eq(src, name.nstart, name.nlen, qs, ql) == 1 {
                let vp = rhs_pos(toks, npos)
                let rhs = toks[vp]
                if rhs.kind == 28 { return 1 }
            }
            i = i + 1
        } else {
            i = i + 1
        }
    }
    return 0
}

# For the string-literal token at `lit_i`, decide whether `{ident}` should be a
# string interpolation (%s) by checking the surrounding function's Str params and
# earlier string-literal lets. Everything else remains integer interpolation (%d).
fn interp_name_is_str(toks: &List<Token>, fns: &List<Fn>, src: Str, n: Int, lit_i: Int, qs: Int, ql: Int) -> Int {
    let m = fns.len()
    let mut fi = 0
    while fi < m {
        let f = fns[fi]
        if lit_i >= f.bstart and lit_i < f.bend {
            if fn_param_is_str(f, src, qs, ql) == 1 { return 1 }
            return range_let_is_str(toks, src, f.bstart, lit_i, qs, ql)
        }
        fi = fi + 1
    }
    return range_let_is_str(toks, src, 0, lit_i, qs, ql)
}
fn kw3(src: Str, a: Int, alen: Int, w0: Int, w1: Int, w2: Int) -> Int {
    if alen != 3 { return 0 }
    if src[a] != w0 { return 0 }
    if src[a + 1] != w1 { return 0 }
    if src[a + 2] != w2 { return 0 }
    return 1
}
fn kw4(src: Str, a: Int, alen: Int, w0: Int, w1: Int, w2: Int, w3: Int) -> Int {
    if alen != 4 { return 0 }
    if src[a] != w0 { return 0 }
    if src[a + 1] != w1 { return 0 }
    if src[a + 2] != w2 { return 0 }
    if src[a + 3] != w3 { return 0 }
    return 1
}
fn kw5(src: Str, a: Int, alen: Int, w0: Int, w1: Int, w2: Int, w3: Int, w4: Int) -> Int {
    if alen != 5 { return 0 }
    if src[a] != w0 { return 0 }
    if src[a + 1] != w1 { return 0 }
    if src[a + 2] != w2 { return 0 }
    if src[a + 3] != w3 { return 0 }
    if src[a + 4] != w4 { return 0 }
    return 1
}
fn kw6(src: Str, a: Int, alen: Int, w0: Int, w1: Int, w2: Int, w3: Int, w4: Int, w5: Int) -> Int {
    if alen != 6 { return 0 }
    if src[a] != w0 { return 0 }
    if src[a + 1] != w1 { return 0 }
    if src[a + 2] != w2 { return 0 }
    if src[a + 3] != w3 { return 0 }
    if src[a + 4] != w4 { return 0 }
    if src[a + 5] != w5 { return 0 }
    return 1
}
fn is_vais_result_str_int_name(src: Str, a: Int, alen: Int) -> Int {
    if alen != 16 { return 0 }
    if src[a] != 86 { return 0 }
    if src[a + 1] != 97 { return 0 }
    if src[a + 2] != 105 { return 0 }
    if src[a + 3] != 115 { return 0 }
    if src[a + 4] != 82 { return 0 }
    if src[a + 5] != 101 { return 0 }
    if src[a + 6] != 115 { return 0 }
    if src[a + 7] != 117 { return 0 }
    if src[a + 8] != 108 { return 0 }
    if src[a + 9] != 116 { return 0 }
    if src[a + 10] != 83 { return 0 }
    if src[a + 11] != 116 { return 0 }
    if src[a + 12] != 114 { return 0 }
    if src[a + 13] != 73 { return 0 }
    if src[a + 14] != 110 { return 0 }
    if src[a + 15] != 116 { return 0 }
    return 1
}
fn is_continue_kw(src: Str, a: Int, alen: Int) -> Int {
    if alen != 8 { return 0 }
    if src[a] != 99 { return 0 }
    if src[a + 1] != 111 { return 0 }
    if src[a + 2] != 110 { return 0 }
    if src[a + 3] != 116 { return 0 }
    if src[a + 4] != 105 { return 0 }
    if src[a + 5] != 110 { return 0 }
    if src[a + 6] != 117 { return 0 }
    if src[a + 7] != 101 { return 0 }
    return 1
}

fn string_lit_value_len(src: Str, start: Int, raw_len: Int, delim: Int) -> Int {
    if delim != 34 { return raw_len }
    let mut k = 0
    let mut out = 0
    while k < raw_len {
        if src[start + k] == 92 {
            if k + 1 < raw_len {
                out = out + 1
                k = k + 2
            } else {
                out = out + 1
                k = k + 1
            }
        } else {
            out = out + 1
            k = k + 1
        }
    }
    return out
}

fn tokenize(src: Str) -> List<Token> {
    let mut toks: List<Token> = []
    let n = src.len()
    let mut i = 0
    while i < n {
        let c = src[i]
        if is_space(c) {
            i = i + 1
        } else if c == 35 {
            while i < n and src[i] != 10 { i = i + 1 }
        } else if c == 96 or c == 34 {
            # string literal delimited by backtick (96) or double quote (34);
            # kind 28 carries the content source range (nstart/nlen) and length.
            let delim = c
            let sstart = i + 1
            let mut j = sstart
            let mut sgo = true
            while sgo {
                if j >= n { sgo = false }
                else if delim == 34 and src[j] == 92 { j = j + 2 }
                else if src[j] == delim { sgo = false }
                else { j = j + 1 }
            }
            toks.push(Token { kind: 28, value: string_lit_value_len(src, sstart, j - sstart, delim), nstart: sstart, nlen: j - sstart })
            i = j + 1
        } else if c == 39 {
            # single-byte char literal, e.g. 'A', lowers to its ASCII Int value.
            let mut v = 0
            if i + 1 < n { v = src[i + 1] }
            toks.push(Token { kind: 0, value: v, nstart: i + 1, nlen: 1 })
            i = i + 3
        } else if is_digit(c) {
            let mut v = 0
            let mut go = true
            while go {
                if i >= n { go = false }
                else if is_digit(src[i]) { v = v * 10 + (src[i] - 48); i = i + 1 }
                else { go = false }
            }
            toks.push(Token { kind: 0, value: v, nstart: 0, nlen: 0 })
        } else if is_alpha(c) {
            let start = i
            let mut go = true
            while go {
                if i >= n { go = false }
                else if is_alnum(src[i]) { i = i + 1 }
                else { go = false }
            }
            let len = i - start
            if kw3(src, start, len, 108, 101, 116) == 1 {
                toks.push(Token { kind: 7, value: 0, nstart: start, nlen: len })
            } else if kw6(src, start, len, 114, 101, 116, 117, 114, 110) == 1 {
                toks.push(Token { kind: 8, value: 0, nstart: start, nlen: len })
            } else if kw3(src, start, len, 109, 117, 116) == 1 {
                toks.push(Token { kind: 21, value: 0, nstart: start, nlen: len })
            } else if kw5(src, start, len, 119, 104, 105, 108, 101) == 1 {
                toks.push(Token { kind: 22, value: 0, nstart: start, nlen: len })   # while
            } else if kw3(src, start, len, 97, 110, 100) == 1 {
                toks.push(Token { kind: 31, value: 0, nstart: start, nlen: len })   # and
            } else if kw2(src, start, len, 111, 114) == 1 {
                toks.push(Token { kind: 32, value: 0, nstart: start, nlen: len })   # or
            } else if kw3(src, start, len, 110, 111, 116) == 1 {
                toks.push(Token { kind: 42, value: 0, nstart: start, nlen: len })   # not
            } else if kw2(src, start, len, 105, 102) == 1 {
                toks.push(Token { kind: 15, value: 0, nstart: start, nlen: len })   # if
            } else if kw4(src, start, len, 101, 108, 115, 101) == 1 {
                toks.push(Token { kind: 17, value: 0, nstart: start, nlen: len })   # else
            } else if kw2(src, start, len, 102, 110) == 1 {
                toks.push(Token { kind: 13, value: 0, nstart: start, nlen: len })   # fn
            } else if kw6(src, start, len, 115, 116, 114, 117, 99, 116) == 1 {
                toks.push(Token { kind: 26, value: 0, nstart: start, nlen: len })   # struct
            } else if kw3(src, start, len, 102, 111, 114) == 1 {
                toks.push(Token { kind: 34, value: 0, nstart: start, nlen: len })   # for
            } else if kw2(src, start, len, 105, 110) == 1 {
                toks.push(Token { kind: 35, value: 0, nstart: start, nlen: len })   # in
            } else if kw5(src, start, len, 98, 114, 101, 97, 107) == 1 {
                toks.push(Token { kind: 40, value: 0, nstart: start, nlen: len })   # break
            } else if is_continue_kw(src, start, len) == 1 {
                toks.push(Token { kind: 41, value: 0, nstart: start, nlen: len })   # continue
            } else if kw3(src, start, len, 112, 117, 98) == 1 {
                toks.push(Token { kind: 43, value: 0, nstart: start, nlen: len })   # pub
            } else {
                toks.push(Token { kind: 1, value: 0, nstart: start, nlen: len })
            }
        } else if c == 43 { toks.push(Token { kind: 2, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 42 { toks.push(Token { kind: 3, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 45 { toks.push(Token { kind: 4, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 47 { toks.push(Token { kind: 38, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 37 { toks.push(Token { kind: 39, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 40 { toks.push(Token { kind: 9, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 41 { toks.push(Token { kind: 10, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 60 {
            # `<` (18) or `<=` (29)
            if i + 1 < n {
                if src[i + 1] == 61 { toks.push(Token { kind: 29, value: 0, nstart: 0, nlen: 0 }); i = i + 2 }
                else { toks.push(Token { kind: 18, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
            } else { toks.push(Token { kind: 18, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        }
        else if c == 62 {
            # `>` (19) or `>=` (30)
            if i + 1 < n {
                if src[i + 1] == 61 { toks.push(Token { kind: 30, value: 0, nstart: 0, nlen: 0 }); i = i + 2 }
                else { toks.push(Token { kind: 19, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
            } else { toks.push(Token { kind: 19, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        }
        else if c == 61 {
            if i + 1 < n {
                if src[i + 1] == 61 {
                    toks.push(Token { kind: 20, value: 0, nstart: 0, nlen: 0 }); i = i + 2
                } else {
                    toks.push(Token { kind: 5, value: 0, nstart: 0, nlen: 0 }); i = i + 1
                }
            } else {
                toks.push(Token { kind: 5, value: 0, nstart: 0, nlen: 0 }); i = i + 1
            }
        }
        else if c == 123 { toks.push(Token { kind: 11, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 125 { toks.push(Token { kind: 12, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 91 { toks.push(Token { kind: 23, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 93 { toks.push(Token { kind: 24, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 44 { toks.push(Token { kind: 25, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 46 {
            # `.` field access (27), `..` exclusive range (36), `..=` inclusive (37)
            if i + 1 < n {
                if src[i + 1] == 46 {
                    if i + 2 < n {
                        if src[i + 2] == 61 { toks.push(Token { kind: 37, value: 0, nstart: 0, nlen: 0 }); i = i + 3 }
                        else { toks.push(Token { kind: 36, value: 0, nstart: 0, nlen: 0 }); i = i + 2 }
                    } else { toks.push(Token { kind: 36, value: 0, nstart: 0, nlen: 0 }); i = i + 2 }
                } else { toks.push(Token { kind: 27, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
            } else { toks.push(Token { kind: 27, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        }
        else if c == 59 { toks.push(Token { kind: 6, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 58 { toks.push(Token { kind: 16, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else if c == 33 {
            # `!` — only `!=` (not-equal, kind 33) is supported; bare `!` is skipped.
            if i + 1 < n {
                if src[i + 1] == 61 { toks.push(Token { kind: 33, value: 0, nstart: 0, nlen: 0 }); i = i + 2 }
                else { i = i + 1 }
            } else { i = i + 1 }
        }
        else if c == 63 { toks.push(Token { kind: 44, value: 0, nstart: 0, nlen: 0 }); i = i + 1 }
        else { i = i + 1 }
    }
    return toks
}

fn name_eq(src: Str, a: Int, alen: Int, b: Int, blen: Int) -> Int {
    if alen != blen { return 0 }
    let mut k = 0
    while k < alen {
        if src[a + k] == src[b + k] { k = k + 1 } else { return 0 }
    }
    return 1
}
fn emit_str(s: Str) -> Int {
    let n = s.len()
    let mut k = 0
    while k < n {
        putchar(s[k])
        k = k + 1
    }
    return 0
}
fn pint(x: Int) -> Int {
    if x < 0 { putchar(45); return pint(0 - x) }
    if x >= 10 { pint(x / 10) }
    putchar(48 + (x - (x / 10) * 10))
    return 0
}
# Emit one byte into an LLVM c"..." initializer. Backslash and quote must be
# escaped as hex escapes, or the LLVM string literal changes length / terminates.
fn emit_llvm_c_byte(c: Int) -> Int {
    if c == 92 { emit_str("\\5C"); return 0 }
    if c == 34 { emit_str("\\22"); return 0 }
    putchar(c)
    return 0
}
# Copy a source substring into a global initializer, escaping LLVM c-string
# metacharacters while preserving the source byte length.
fn emit_bytes(src: Str, start: Int, len: Int) -> Int {
    let mut k = 0
    while k < len {
        emit_llvm_c_byte(src[start + k])
        k = k + 1
    }
    return 0
}
fn emit_literal_bytes(src: Str, start: Int, raw_len: Int) -> Int {
    if start > 0 {
        if src[start - 1] == 34 {
            let mut k = 0
            while k < raw_len {
                if src[start + k] == 92 {
                    if k + 1 < raw_len {
                        emit_llvm_c_byte(src[start + k + 1])
                        k = k + 2
                    } else {
                        emit_llvm_c_byte(src[start + k])
                        k = k + 1
                    }
                } else {
                    emit_llvm_c_byte(src[start + k])
                    k = k + 1
                }
            }
            return 0
        }
    }
    return emit_bytes(src, start, raw_len)
}
# printf format length: bytes the @.fmt<nstart> global occupies for the literal
# [start,start+len), where each `%` doubles to `%%`, each VALID `{ident}` becomes
# a 2-byte printf directive (`%d` or `%s`), a lone `{` (literal brace) passes
# through 1:1, other bytes 1:1, plus a trailing newline (puts adds one, so printf
# must too). The \00 is added by the caller.
fn fmt_len(src: Str, start: Int, len: Int) -> Int {
    let mut k = 0
    let mut out = 0
    while k < len {
        let c = src[start + k]
        let e = interp_end(src, start, len, k)
        if e >= 0 {
            # valid `{ident}` -> printf directive (2 bytes); advance past `}`
            out = out + 2
            k = e + 1
        } else if c == 37 {
            out = out + 2
            k = k + 1
        } else {
            out = out + 1
            k = k + 1
        }
    }
    # trailing newline to match puts() line semantics
    return out + 1
}
# Emit the printf format bytes for the literal [start,start+len): `%` -> `%%`,
# valid `{ident}` -> `%d` or `%s`, lone `{`/other bytes verbatim, then a trailing
# `\0A` newline (to match puts). (Caller wraps in c"..\00".)
fn emit_fmt_bytes(toks: &List<Token>, fns: &List<Fn>, src: Str, n: Int, lit_i: Int, start: Int, len: Int) -> Int {
    let mut k = 0
    while k < len {
        let c = src[start + k]
        let e = interp_end(src, start, len, k)
        if e >= 0 {
            let astart = start + k + 1
            let alen = e - (k + 1)
            putchar(37)
            if interp_name_is_str(toks, fns, src, n, lit_i, astart, alen) == 1 { putchar(115) }
            else { putchar(100) }
            k = e + 1
        } else if c == 37 {
            putchar(37)
            putchar(37)
            k = k + 1
        } else {
            emit_llvm_c_byte(c)
            k = k + 1
        }
    }
    # trailing newline, written as the LLVM escape \0A
    emit_str("\\0A")
    return 0
}

# Module pre-pass: emit a `@.s<nstart> = [len+1 x i8] c"..\00"` global for every
# string-literal token, keyed by the literal's source nstart (unique per literal).
fn emit_str_globals(toks: &List<Token>, fns: &List<Fn>, src: Str, n: Int) -> Int {
    emit_str("@.vais_empty = private constant [1 x i8] c\"\\00\"")
    putchar(10)
    let mut i = 0
    while i < n {
        let t = toks[i]
        if t.kind == 28 {
            emit_str("@.s")
            pint(t.nstart)
            emit_str(" = private constant [")
            pint(t.value + 1)
            emit_str(" x i8] c\"")
            emit_literal_bytes(src, t.nstart, t.nlen)
            emit_str("\\00\"")
            putchar(10)
            # a brace-bearing literal also gets a printf format global @.fmt<nstart>
            # ({ident} -> %d/%s, % -> %%) for the print(...) interpolation path.
            if lit_has_brace(src, t.nstart, t.nlen) == 1 {
                emit_str("@.fmt")
                pint(t.nstart)
                emit_str(" = private constant [")
                pint(fmt_len(src, t.nstart, t.nlen) + 1)
                emit_str(" x i8] c\"")
                emit_fmt_bytes(toks, fns, src, n, i, t.nstart, t.nlen)
                emit_str("\\00\"")
                putchar(10)
            }
        }
        i = i + 1
    }
    return 0
}

# Look up a variable's alloca slot number by name; -1 if absent.
fn find_slot(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let m = slots.len()
    let mut i = 0
    while i < m {
        let s = slots[i]
        if name_eq(src, s.nstart, s.nlen, qs, ql) == 1 { return s.slot }
        i = i + 1
    }
    return 0 - 1
}
fn arrlen_of(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let m = slots.len()
    let mut i = 0
    while i < m {
        let s = slots[i]
        if name_eq(src, s.nstart, s.nlen, qs, ql) == 1 { return s.alen }
        i = i + 1
    }
    return 0
}
# is_arr discriminator: 0=scalar, 1=array, 2=List, 3=string. -1 if absent.
fn isarr_of(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let m = slots.len()
    let mut i = 0
    while i < m {
        let s = slots[i]
        if name_eq(src, s.nstart, s.nlen, qs, ql) == 1 { return s.is_arr }
        i = i + 1
    }
    return 0 - 1
}
# For a string var (is_arr=3): the global key (the literal's source nstart),
# stored in the slot's sty field. The string global is named @.s<key>.
fn strkey_of(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let m = slots.len()
    let mut i = 0
    while i < m {
        let s = slots[i]
        if name_eq(src, s.nstart, s.nlen, qs, ql) == 1 { return s.sty }
        i = i + 1
    }
    return 0
}
# Find the end of an array-literal element: next ',' or the closing ']' (bend).
fn arr_elem_end(toks: &List<Token>, i: Int, bend: Int) -> Int {
    let mut j = i
    let mut go = true
    while go {
        if j >= bend { go = false }
        else {
            let t = toks[j]
            if t.kind == 25 { go = false } else { j = j + 1 }
        }
    }
    return j
}
# Index just past the matching ']' for the '[' whose contents start at op2.
fn bracket_end(toks: &List<Token>, op2: Int) -> Int {
    let mut j = op2
    let mut depth = 0
    let mut go = true
    while go {
        let t = toks[j]
        if t.kind == 23 { depth = depth + 1; j = j + 1 }
        else if t.kind == 24 {
            if depth == 0 { go = false } else { depth = depth - 1; j = j + 1 }
        }
        else { j = j + 1 }
    }
    return j
}

# Emit a source name verbatim (for @name LLVM identifiers).
fn emit_name(src: Str, start: Int, len: Int) -> Int {
    let mut k = 0
    while k < len {
        putchar(src[start + k])
        k = k + 1
    }
    return 0
}

# Find a function index by name; -1 if absent.
fn find_fn(fns: &List<Fn>, src: Str, qs: Int, ql: Int) -> Int {
    let m = fns.len()
    let mut i = 0
    while i < m {
        let f = fns[i]
        if name_eq(src, f.nstart, f.nlen, qs, ql) == 1 { return i }
        i = i + 1
    }
    return 0 - 1
}
fn token_struct_index_process_result(toks: &List<Token>, src: Str) -> Int {
    let mut idx = 0
    let mut i = 0
    let n = toks.len()
    while i < n {
        let t = toks[i]
        if t.kind == 26 {
            let nt = toks[i + 1]
            if is_process_result_name(src, nt.nstart, nt.nlen) == 1 { return idx }
            idx = idx + 1
        }
        i = i + 1
    }
    return 0 - 2
}
# Index of the params '(' in `fn name(...)` or `fn name<T>(...)`.
fn fn_params_open(toks: &List<Token>, fnpos: Int) -> Int {
    let mut op = fnpos + 2
    let lt = toks[op]
    if lt.kind == 18 {
        let mut depth = 1
        op = op + 1
        let mut go = true
        while go {
            let t = toks[op]
            if t.kind == 18 { depth = depth + 1; op = op + 1 }
            else if t.kind == 19 {
                depth = depth - 1
                if depth == 0 { go = false } else { op = op + 1 }
            } else { op = op + 1 }
        }
        op = op + 1
    }
    return op
}
# Return callee param type encoding for argument position `argpos`:
#   0 Int, 1 Str, 2 List, 3+struct_index plain struct.
fn call_param_ty(fns: &List<Fn>, src: Str, qs: Int, ql: Int, argpos: Int) -> Int {
    let idx = find_fn(fns, src, qs, ql)
    if idx < 0 { return 0 }
    let f = fns[idx]
    if argpos == 0 { return f.p0ty }
    if argpos == 1 { return f.p1ty }
    if argpos == 2 { return f.p2ty }
    if argpos == 3 { return f.p3ty }
    if argpos == 4 { return f.p4ty }
    if argpos == 5 { return f.p5ty }
    if argpos == 6 { return f.p6ty }
    if argpos == 7 { return f.p7ty }
    if argpos == 8 { return f.p8ty }
    return f.p9ty
}
# If the token at `vp` is a call `<ident> (` to a List-returning function, returns
# that function's retty (List<Str> is -2, List<Int> is -1, struct lists are >=0).
# Returns -3 if the RHS is not a call to a list-returning function. Lets
# `let ys = build()` size ys's buffer and pass it as the callee's hidden out-param.
fn call_retty(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let r = toks[vp]
    if r.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            let idx = find_fn(fns, src, r.nstart, r.nlen)
            if idx >= 0 {
                let f = fns[idx]
                if f.retlist == 1 { return f.retty }
            }
        }
    }
    return 0 - 3
}
# If the token at `vp` is a call `<ident> (` to a struct-returning function,
# returns that function's struct type index. Returns -2 otherwise.
fn call_retsty(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let r = toks[vp]
    if r.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            let idx = find_fn(fns, src, r.nstart, r.nlen)
            if idx >= 0 {
                let f = fns[idx]
                if f.retlist == 2 { return f.retty }
            }
            if is_proc_capture(src, r.nstart, r.nlen) == 1 {
                return token_struct_index_process_result(toks, src)
            }
        }
    }
    return 0 - 2
}
fn call_retmapty(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let r = toks[vp]
    if r.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            let idx = find_fn(fns, src, r.nstart, r.nlen)
            if idx >= 0 {
                let f = fns[idx]
                if f.retlist == 4 { return f.retty }
            }
        }
    }
    return 0 - 2
}
fn call_retstr(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let r = toks[vp]
    if r.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            let idx = find_fn(fns, src, r.nstart, r.nlen)
            if idx >= 0 {
                let f = fns[idx]
                if f.retlist == 3 { return 1 }
            }
        }
    }
    return 0
}

fn call_ret_result_ty(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    let r = toks[vp]
    if r.kind == 1 {
        let after = toks[vp + 1]
        if after.kind == 9 {
            let idx = find_fn(fns, src, r.nstart, r.nlen)
            if idx >= 0 {
                let f = fns[idx]
                if f.retlist == 0 and is_result_ty(f.retty) { return f.retty }
            }
        }
    }
    return 0
}

fn call_ret_result_str_int(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    if call_ret_result_ty(toks, fns, src, vp) == result_str_int_ty() { return 1 }
    return 0
}

fn call_ret_result_str_str(toks: &List<Token>, fns: &List<Fn>, src: Str, vp: Int) -> Int {
    if call_ret_result_ty(toks, fns, src, vp) == result_str_str_ty() { return 1 }
    return 0
}

# Build the function table by scanning for `fn name ( param ) { ... }`.
fn build_fns(toks: &List<Token>, defs: &List<StructDef>, src: Str, n: Int) -> List<Fn> {
    let mut fns: List<Fn> = []
    let mut i = 0
    while i < n {
        let t = toks[i]
        if t.kind == 13 {
            let nt = toks[i + 1]
            # params (idents, comma-separated) until close-paren; then body.
            # Generic markers like `fn id<T>(x: T)` are skipped here.
            let popen = fn_params_open(toks, i)
            let mut p0s = 0
            let mut p0l = 0
            let mut p1s = 0
            let mut p1l = 0
            let mut p2s = 0
            let mut p2l = 0
            let mut p3s = 0
            let mut p3l = 0
            let mut p4s = 0
            let mut p4l = 0
            let mut p5s = 0
            let mut p5l = 0
            let mut p6s = 0
            let mut p6l = 0
            let mut p7s = 0
            let mut p7l = 0
            let mut p8s = 0
            let mut p8l = 0
            let mut p9s = 0
            let mut p9l = 0
            let mut p0ty = 0
            let mut p1ty = 0
            let mut p2ty = 0
            let mut p3ty = 0
            let mut p4ty = 0
            let mut p5ty = 0
            let mut p6ty = 0
            let mut p7ty = 0
            let mut p8ty = 0
            let mut p9ty = 0
            let mut npar = 0
            let mut q = popen + 1
            let mut gp = true
            while gp {
                let qt = toks[q]
                if qt.kind == 10 { gp = false }
                else if qt.kind == 16 {
                    # `:` -> the type of the most recent param follows. Types:
                    #   Str         -> 1  (string param, i8*)
                    #   List<...>   -> 2  (List param, buffer pointer; `&` already
                    #                      dropped by the tokenizer)
                    #   Map<Int,Int> -> map_int_param_ty()  (Map buffer pointer)
                    #   Map<Int,Bool> -> map_bool_param_ty() (Map buffer pointer)
                    #   Map<Int,Char> -> map_char_param_ty() (Map buffer pointer)
                    #   Map<Str,Int>  -> map_str_int_param_ty() (Map buffer pointer)
                    #   Map<Str,Bool> -> map_str_bool_param_ty() (Map buffer pointer)
                    #   Map<Str,Char> -> map_str_char_param_ty() (Map buffer pointer)
                    #   Map<Str,Str>  -> map_str_str_param_ty() (Map buffer pointer)
                    #   Result<Str,Int> -> result_str_int_ty() (packed scalar i64)
                    #   Result<Struct,Int> -> result_struct_int_ty(struct_index)
                    #   StructName  -> 3+struct_index  (struct by hidden pointer)
                    #   else        -> 0  (int)
                    let tyt = toks[q + 1]
                    let isstr = kw3(src, tyt.nstart, tyt.nlen, 83, 116, 114)
                    let islist = kw4(src, tyt.nstart, tyt.nlen, 76, 105, 115, 116)
                    let mut mpty = 0
                    if kw3(src, tyt.nstart, tyt.nlen, 77, 97, 112) == 1 {
                        let mlt = toks[q + 2]
                        let mkey = toks[q + 3]
                        let mcomma = toks[q + 4]
                        let mval = toks[q + 5]
                        let mgt = toks[q + 6]
                        if mlt.kind == 18 and mcomma.kind == 25 and mgt.kind == 19 {
                            if kw3(src, mkey.nstart, mkey.nlen, 73, 110, 116) == 1 {
                                if kw3(src, mval.nstart, mval.nlen, 73, 110, 116) == 1 { mpty = map_int_param_ty() }
                                else if kw4(src, mval.nstart, mval.nlen, 66, 111, 111, 108) == 1 { mpty = map_bool_param_ty() }
                                else if kw4(src, mval.nstart, mval.nlen, 67, 104, 97, 114) == 1 { mpty = map_char_param_ty() }
                            } else if kw3(src, mkey.nstart, mkey.nlen, 83, 116, 114) == 1 {
                                if kw3(src, mval.nstart, mval.nlen, 73, 110, 116) == 1 { mpty = map_str_int_param_ty() }
                                else if kw4(src, mval.nstart, mval.nlen, 66, 111, 111, 108) == 1 { mpty = map_str_bool_param_ty() }
                                else if kw4(src, mval.nstart, mval.nlen, 67, 104, 97, 114) == 1 { mpty = map_str_char_param_ty() }
                                else if kw3(src, mval.nstart, mval.nlen, 83, 116, 114) == 1 { mpty = map_str_str_param_ty() }
                            }
                        }
                    }
                    let mut rpty = 0
                    if kw6(src, tyt.nstart, tyt.nlen, 82, 101, 115, 117, 108, 116) == 1 {
                        let rlt = toks[q + 2]
                        let rok = toks[q + 3]
                        let rcomma = toks[q + 4]
                        let rerr = toks[q + 5]
                        let rgt = toks[q + 6]
                        if rlt.kind == 18 and rcomma.kind == 25 and rgt.kind == 19 {
                            if kw3(src, rok.nstart, rok.nlen, 83, 116, 114) == 1 and kw3(src, rerr.nstart, rerr.nlen, 83, 116, 114) == 1 {
                                rpty = result_str_str_ty()
                            } else if kw3(src, rok.nstart, rok.nlen, 83, 116, 114) == 1 and kw3(src, rerr.nstart, rerr.nlen, 73, 110, 116) == 1 {
                                rpty = result_str_int_ty()
                            } else if kw3(src, rerr.nstart, rerr.nlen, 73, 110, 116) == 1 {
                                let rsti = struct_index_by_name(defs, src, rok.nstart, rok.nlen)
                                if rsti >= 0 { rpty = result_struct_int_ty(rsti) }
                            }
                        }
                    }
                    let mut pty = isstr
                    if is_result_ty(rpty) { pty = rpty }
                    else if is_map_param_ty(mpty) { pty = mpty }
                    else if islist == 1 { pty = 2 }
                    else if isstr == 0 {
                        let pst = struct_index_by_name(defs, src, tyt.nstart, tyt.nlen)
                        if pst >= 0 { pty = 3 + pst }
                    }
                    # the type applies to the most recent param (index npar-1).
                    if npar == 1 { p0ty = pty }
                    else if npar == 2 { p1ty = pty }
                    else if npar == 3 { p2ty = pty }
                    else if npar == 4 { p3ty = pty }
                    else if npar == 5 { p4ty = pty }
                    else if npar == 6 { p5ty = pty }
                    else if npar == 7 { p6ty = pty }
                    else if npar == 8 { p7ty = pty }
                    else if npar == 9 { p8ty = pty }
                    else { p9ty = pty }
                    # advance past the type. List<...> and Map<...> span to the closing `>`
                    # (kind 19); a plain type is a single ident.
                    if islist == 1 or is_map_param_ty(mpty) or is_result_ty(rpty) {
                        let mut tq = q + 2
                        let mut tg = true
                        while tg {
                            let tt = toks[tq]
                            if tt.kind == 19 { tg = false } else { tq = tq + 1 }
                        }
                        q = tq + 1
                    } else {
                        q = q + 2
                    }
                }
                else if qt.kind == 1 {
                    if npar == 0 { p0s = qt.nstart; p0l = qt.nlen }
                    else if npar == 1 { p1s = qt.nstart; p1l = qt.nlen }
                    else if npar == 2 { p2s = qt.nstart; p2l = qt.nlen }
                    else if npar == 3 { p3s = qt.nstart; p3l = qt.nlen }
                    else if npar == 4 { p4s = qt.nstart; p4l = qt.nlen }
                    else if npar == 5 { p5s = qt.nstart; p5l = qt.nlen }
                    else if npar == 6 { p6s = qt.nstart; p6l = qt.nlen }
                    else if npar == 7 { p7s = qt.nstart; p7l = qt.nlen }
                    else if npar == 8 { p8s = qt.nstart; p8l = qt.nlen }
                    else { p9s = qt.nstart; p9l = qt.nlen }
                    npar = npar + 1
                    q = q + 1
                }
                else { q = q + 1 }
            }
            # q is close-paren; find the open-brace after it
            let mut bo = q + 1
            let mut gb = true
            while gb {
                let bt = toks[bo]
                if bt.kind == 11 { gb = false } else { bo = bo + 1 }
            }
            # Return type between ')' and '{':
            #   retlist=1 for List, retlist=2 for struct (hidden out-param),
            #   retlist=3 for Str (direct i8* return),
            #   retlist=4 for supported Map returns (hidden out-param).
            # retty is the element/struct type index, or a concrete Result marker.
            let mut retlist = 0
            let mut retty = 0 - 1
            let mut rq = q + 1
            while rq < bo {
                let rt = toks[rq]
                if rt.kind == 1 {
                    if kw4(src, rt.nstart, rt.nlen, 76, 105, 115, 116) == 1 {
                        let lt = toks[rq + 1]
                        if lt.kind == 18 {
                            retlist = 1
                            let et = toks[rq + 2]
                            if et.kind == 1 {
                                if kw3(src, et.nstart, et.nlen, 83, 116, 114) == 1 {
                                    retty = 0 - 2
                                } else {
                                    retty = struct_index_by_name(defs, src, et.nstart, et.nlen)
                                }
                            }
                        }
                    } else if kw3(src, rt.nstart, rt.nlen, 77, 97, 112) == 1 {
                        let mlt = toks[rq + 1]
                        let mkey = toks[rq + 2]
                        let mcomma = toks[rq + 3]
                        let mval = toks[rq + 4]
                        let mgt = toks[rq + 5]
                        if mlt.kind == 18 and mcomma.kind == 25 and mgt.kind == 19 {
                            if kw3(src, mkey.nstart, mkey.nlen, 73, 110, 116) == 1 {
                                if kw3(src, mval.nstart, mval.nlen, 73, 110, 116) == 1 {
                                    retlist = 4
                                    retty = map_value_int_ty()
                                } else if kw4(src, mval.nstart, mval.nlen, 66, 111, 111, 108) == 1 {
                                    retlist = 4
                                    retty = map_value_bool_ty()
                                } else if kw4(src, mval.nstart, mval.nlen, 67, 104, 97, 114) == 1 {
                                    retlist = 4
                                    retty = map_value_char_ty()
                                }
                            } else if kw3(src, mkey.nstart, mkey.nlen, 83, 116, 114) == 1 {
                                if kw3(src, mval.nstart, mval.nlen, 73, 110, 116) == 1 {
                                    retlist = 4
                                    retty = map_str_int_ty()
                                } else if kw4(src, mval.nstart, mval.nlen, 66, 111, 111, 108) == 1 {
                                    retlist = 4
                                    retty = map_str_bool_ty()
                                } else if kw4(src, mval.nstart, mval.nlen, 67, 104, 97, 114) == 1 {
                                    retlist = 4
                                    retty = map_str_char_ty()
                                } else if kw3(src, mval.nstart, mval.nlen, 83, 116, 114) == 1 {
                                    retlist = 4
                                    retty = map_str_str_ty()
                                }
                            }
                        }
                    } else if retlist == 0 and kw6(src, rt.nstart, rt.nlen, 82, 101, 115, 117, 108, 116) == 1 {
                        let rlt = toks[rq + 1]
                        let rok = toks[rq + 2]
                        let rcomma = toks[rq + 3]
                        let rerr = toks[rq + 4]
                        let rgt = toks[rq + 5]
                        if rlt.kind == 18 and rcomma.kind == 25 and rgt.kind == 19 {
                            if kw3(src, rok.nstart, rok.nlen, 83, 116, 114) == 1 and kw3(src, rerr.nstart, rerr.nlen, 83, 116, 114) == 1 {
                                retty = result_str_str_ty()
                            } else if kw3(src, rok.nstart, rok.nlen, 83, 116, 114) == 1 and kw3(src, rerr.nstart, rerr.nlen, 73, 110, 116) == 1 {
                                retty = result_str_int_ty()
                            } else if kw3(src, rerr.nstart, rerr.nlen, 73, 110, 116) == 1 {
                                let rsti = struct_index_by_name(defs, src, rok.nstart, rok.nlen)
                                if rsti >= 0 { retty = result_struct_int_ty(rsti) }
                            }
                        }
                    } else if retlist == 0 and is_result_ty(retty) == false and kw3(src, rt.nstart, rt.nlen, 83, 116, 114) == 1 {
                        retlist = 3
                    } else if retlist == 0 and is_result_ty(retty) == false {
                        let rst = struct_index_by_name(defs, src, rt.nstart, rt.nlen)
                        if rst >= 0 {
                            retlist = 2
                            retty = rst
                        }
                    }
                }
                rq = rq + 1
            }
            let bstart = bo + 1
            let mut be = bstart
            let mut depth = 1
            let mut go = true
            while go {
                if be >= n {
                    go = false
                } else {
                    let bt = toks[be]
                    if bt.kind == 11 { depth = depth + 1; be = be + 1 }
                    else if bt.kind == 12 {
                        depth = depth - 1
                        if depth == 0 { go = false } else { be = be + 1 }
                    }
                    else { be = be + 1 }
                }
            }
            i = be + 1
            fns.push(Fn {
                nstart: nt.nstart, nlen: nt.nlen,
                p0s: p0s, p0l: p0l, p1s: p1s, p1l: p1l, p2s: p2s, p2l: p2l, p3s: p3s, p3l: p3l,
                p4s: p4s, p4l: p4l, p5s: p5s, p5l: p5l, p6s: p6s, p6l: p6l, p7s: p7s, p7l: p7l,
                p8s: p8s, p8l: p8l, p9s: p9s, p9l: p9l,
                p0ty: p0ty, p1ty: p1ty, p2ty: p2ty, p3ty: p3ty,
                p4ty: p4ty, p5ty: p5ty, p6ty: p6ty, p7ty: p7ty, p8ty: p8ty, p9ty: p9ty,
                npar: npar,
                bstart: bstart, bend: be,
                retlist: retlist, retty: retty
            })
        } else {
            i = i + 1
        }
    }
    return fns
}

# Skip a `struct Name { ... }` declaration at `i` (the `struct` token); returns
# index past the closing brace.
fn skip_struct_def(toks: &List<Token>, i: Int, n: Int) -> Int {
    let mut b = i + 1
    let mut g1 = true
    while g1 {
        if b >= n { g1 = false }
        else {
            let bt = toks[b]
            if bt.kind == 11 { g1 = false } else { b = b + 1 }
        }
    }
    return match_brace(toks, b, n) + 1
}

# Build the struct-type table from `struct Name { f0, f1, ... }` declarations.
fn build_defs(toks: &List<Token>, n: Int) -> List<StructDef> {
    let mut defs: List<StructDef> = []
    let mut i = 0
    while i < n {
        let t = toks[i]
        if t.kind == 26 {
            let nt = toks[i + 1]
            let bopen = i + 2
            let bclose = match_brace(toks, bopen, n)
            let mut f0s = 0
            let mut f0l = 0
            let mut f1s = 0
            let mut f1l = 0
            let mut f2s = 0
            let mut f2l = 0
            let mut f3s = 0
            let mut f3l = 0
            let mut f4s = 0
            let mut f4l = 0
            let mut f5s = 0
            let mut f5l = 0
            let mut f6s = 0
            let mut f6l = 0
            let mut f7s = 0
            let mut f7l = 0
            let mut f8s = 0
            let mut f8l = 0
            let mut f9s = 0
            let mut f9l = 0
            let mut f10s = 0
            let mut f10l = 0
            let mut f11s = 0
            let mut f11l = 0
            let mut f12s = 0
            let mut f12l = 0
            let mut f13s = 0
            let mut f13l = 0
            let mut f14s = 0
            let mut f14l = 0
            let mut f15s = 0
            let mut f15l = 0
            let mut f16s = 0
            let mut f16l = 0
            let mut f17s = 0
            let mut f17l = 0
            let mut f18s = 0
            let mut f18l = 0
            let mut f19s = 0
            let mut f19l = 0
            let mut cnt = 0
            let mut skip_type = 0
            let mut q = bopen + 1
            while q < bclose {
                let qt = toks[q]
                if qt.kind == 16 {
                    skip_type = 1
                } else if qt.kind == 25 {
                    skip_type = 0
                } else if qt.kind == 43 {
                    skip_type = 0
                } else if qt.kind == 1 and skip_type == 0 {
                    if cnt == 0 { f0s = qt.nstart; f0l = qt.nlen }
                    else if cnt == 1 { f1s = qt.nstart; f1l = qt.nlen }
                    else if cnt == 2 { f2s = qt.nstart; f2l = qt.nlen }
                    else if cnt == 3 { f3s = qt.nstart; f3l = qt.nlen }
                    else if cnt == 4 { f4s = qt.nstart; f4l = qt.nlen }
                    else if cnt == 5 { f5s = qt.nstart; f5l = qt.nlen }
                    else if cnt == 6 { f6s = qt.nstart; f6l = qt.nlen }
                    else if cnt == 7 { f7s = qt.nstart; f7l = qt.nlen }
                    else if cnt == 8 { f8s = qt.nstart; f8l = qt.nlen }
                    else if cnt == 9 { f9s = qt.nstart; f9l = qt.nlen }
                    else if cnt == 10 { f10s = qt.nstart; f10l = qt.nlen }
                    else if cnt == 11 { f11s = qt.nstart; f11l = qt.nlen }
                    else if cnt == 12 { f12s = qt.nstart; f12l = qt.nlen }
                    else if cnt == 13 { f13s = qt.nstart; f13l = qt.nlen }
                    else if cnt == 14 { f14s = qt.nstart; f14l = qt.nlen }
                    else if cnt == 15 { f15s = qt.nstart; f15l = qt.nlen }
                    else if cnt == 16 { f16s = qt.nstart; f16l = qt.nlen }
                    else if cnt == 17 { f17s = qt.nstart; f17l = qt.nlen }
                    else if cnt == 18 { f18s = qt.nstart; f18l = qt.nlen }
                    else if cnt == 19 { f19s = qt.nstart; f19l = qt.nlen }
                    cnt = cnt + 1
                }
                q = q + 1
            }
            i = bclose + 1
            defs.push(StructDef {
                nstart: nt.nstart, nlen: nt.nlen,
                f0s: f0s, f0l: f0l, f1s: f1s, f1l: f1l, f2s: f2s, f2l: f2l,
                f3s: f3s, f3l: f3l, f4s: f4s, f4l: f4l, f5s: f5s, f5l: f5l,
                f6s: f6s, f6l: f6l, f7s: f7s, f7l: f7l,
                f8s: f8s, f8l: f8l, f9s: f9s, f9l: f9l, f10s: f10s, f10l: f10l,
                f11s: f11s, f11l: f11l, f12s: f12s, f12l: f12l, f13s: f13s, f13l: f13l,
                f14s: f14s, f14l: f14l, f15s: f15s, f15l: f15l, f16s: f16s, f16l: f16l,
                f17s: f17s, f17l: f17l, f18s: f18s, f18l: f18l, f19s: f19s, f19l: f19l,
                nfields: cnt
            })
        } else {
            i = i + 1
        }
    }
    return defs
}
fn struct_index_by_name(defs: &List<StructDef>, src: Str, qs: Int, ql: Int) -> Int {
    let m = defs.len()
    let mut i = 0
    while i < m {
        let d = defs[i]
        if name_eq(src, d.nstart, d.nlen, qs, ql) == 1 { return i }
        i = i + 1
    }
    return 0 - 1
}

fn for_each_iter_pos(toks: &List<Token>, i: Int, end: Int) -> Int {
    let mut bopen = i + 1
    let mut g1 = true
    while g1 {
        if bopen >= end { g1 = false }
        else {
            let bt = toks[bopen]
            if bt.kind == 11 { g1 = false } else { bopen = bopen + 1 }
        }
    }
    let mut rop = i + 3
    let mut g2 = true
    while g2 {
        if rop >= bopen { g2 = false }
        else {
            let rt = toks[rop]
            if rt.kind == 36 { g2 = false } else { if rt.kind == 37 { g2 = false } else { rop = rop + 1 } }
        }
    }
    if rop < bopen {
        let rt2 = toks[rop]
        if rt2.kind == 36 { return 0 - 1 }
        if rt2.kind == 37 { return 0 - 1 }
    }
    return i + 3
}

fn for_each_iter_is_list_str(toks: &List<Token>, slots: &List<Slot>, src: Str, i: Int, end: Int) -> Int {
    let ipos = for_each_iter_pos(toks, i, end)
    if ipos < 0 { return 0 }
    let iter = toks[ipos]
    let ikind = isarr_of(slots, src, iter.nstart, iter.nlen)
    let isty = sty_of(slots, src, iter.nstart, iter.nlen)
    if ikind == 2 and isty == 0 - 2 { return 1 }
    if ikind == 4 and isty == 0 - 2 { return 1 }
    return 0
}
fn for_each_iter_los_elem_sty(toks: &List<Token>, slots: &List<Slot>, src: Str, i: Int, end: Int) -> Int {
    let ipos = for_each_iter_pos(toks, i, end)
    if ipos < 0 { return 0 - 1 }
    let iter = toks[ipos]
    let ikind = isarr_of(slots, src, iter.nstart, iter.nlen)
    let isty = sty_of(slots, src, iter.nstart, iter.nlen)
    if ikind == 2 and isty >= 0 { return isty }
    if ikind == 4 and isty >= 0 { return isty }
    return 0 - 1
}
fn struct_nfields(defs: &List<StructDef>, ti: Int) -> Int {
    let d = defs[ti]
    return d.nfields
}
fn known_field_index(src: Str, ts: Int, tl: Int, qs: Int, ql: Int) -> Int {
    if kw2(src, ts, tl, 70, 110) == 1 {
        if kw6(src, qs, ql, 110, 115, 116, 97, 114, 116) == 1 { return 0 }
        if kw4(src, qs, ql, 110, 108, 101, 110) == 1 { return 1 }
        if ql == 3 {
            if src[qs] == 112 {
                let pd = src[qs + 1] - 48
                if pd >= 0 and pd <= 9 {
                    if src[qs + 2] == 115 { return 2 + pd * 2 }
                    if src[qs + 2] == 108 { return 3 + pd * 2 }
                }
            }
        }
        if ql == 4 {
            if src[qs] == 112 {
                let pd2 = src[qs + 1] - 48
                if pd2 >= 0 and pd2 <= 9 {
                    if src[qs + 2] == 116 and src[qs + 3] == 121 { return 22 + pd2 }
                }
            }
            if kw4(src, qs, ql, 110, 112, 97, 114) == 1 { return 32 }
            if kw4(src, qs, ql, 98, 101, 110, 100) == 1 { return 34 }
        }
        if kw6(src, qs, ql, 98, 115, 116, 97, 114, 116) == 1 { return 33 }
        if ql == 7 {
            if src[qs] == 114 and src[qs + 1] == 101 and src[qs + 2] == 116 and src[qs + 3] == 108 and src[qs + 4] == 105 and src[qs + 5] == 115 and src[qs + 6] == 116 { return 35 }
        }
        if kw5(src, qs, ql, 114, 101, 116, 116, 121) == 1 { return 36 }
    }
    if tl == 9 {
        if src[ts] == 83 and src[ts + 1] == 116 and src[ts + 2] == 114 and src[ts + 3] == 117 and src[ts + 4] == 99 and src[ts + 5] == 116 and src[ts + 6] == 68 and src[ts + 7] == 101 and src[ts + 8] == 102 {
            if kw6(src, qs, ql, 110, 115, 116, 97, 114, 116) == 1 { return 0 }
            if kw4(src, qs, ql, 110, 108, 101, 110) == 1 { return 1 }
            if ql == 3 {
                if src[qs] == 102 {
                    let fd = src[qs + 1] - 48
                    if fd >= 0 and fd <= 9 {
                        if src[qs + 2] == 115 { return 2 + fd * 2 }
                        if src[qs + 2] == 108 { return 3 + fd * 2 }
                    }
                }
            }
            if ql == 4 {
                if src[qs] == 102 {
                    let fd1 = src[qs + 1] - 48
                    let fd2 = src[qs + 2] - 48
                    let fd3 = fd1 * 10 + fd2
                    if fd3 >= 10 and fd3 <= 19 {
                        if src[qs + 3] == 115 { return 2 + fd3 * 2 }
                        if src[qs + 3] == 108 { return 3 + fd3 * 2 }
                    }
                }
            }
            if ql == 7 {
                if src[qs] == 110 and src[qs + 1] == 102 and src[qs + 2] == 105 and src[qs + 3] == 101 and src[qs + 4] == 108 and src[qs + 5] == 100 and src[qs + 6] == 115 { return 42 }
            }
        }
    }
    return 0 - 1
}
fn field_index(defs: &List<StructDef>, ti: Int, src: Str, qs: Int, ql: Int) -> Int {
    let d = defs[ti]
    let mut known = 0 - 1
    if d.nfields >= 19 { known = known_field_index(src, d.nstart, d.nlen, qs, ql) }
    if known >= 0 { return known }
    if d.nfields >= 1 { if name_eq(src, d.f0s, d.f0l, qs, ql) == 1 { return 0 } }
    if d.nfields >= 2 { if name_eq(src, d.f1s, d.f1l, qs, ql) == 1 { return 1 } }
    if d.nfields >= 3 { if name_eq(src, d.f2s, d.f2l, qs, ql) == 1 { return 2 } }
    if d.nfields >= 4 { if name_eq(src, d.f3s, d.f3l, qs, ql) == 1 { return 3 } }
    if d.nfields >= 5 { if name_eq(src, d.f4s, d.f4l, qs, ql) == 1 { return 4 } }
    if d.nfields >= 6 { if name_eq(src, d.f5s, d.f5l, qs, ql) == 1 { return 5 } }
    if d.nfields >= 7 { if name_eq(src, d.f6s, d.f6l, qs, ql) == 1 { return 6 } }
    if d.nfields >= 8 { if name_eq(src, d.f7s, d.f7l, qs, ql) == 1 { return 7 } }
    if d.nfields >= 9 { if name_eq(src, d.f8s, d.f8l, qs, ql) == 1 { return 8 } }
    if d.nfields >= 10 { if name_eq(src, d.f9s, d.f9l, qs, ql) == 1 { return 9 } }
    if d.nfields >= 11 { if name_eq(src, d.f10s, d.f10l, qs, ql) == 1 { return 10 } }
    if d.nfields >= 12 { if name_eq(src, d.f11s, d.f11l, qs, ql) == 1 { return 11 } }
    if d.nfields >= 13 { if name_eq(src, d.f12s, d.f12l, qs, ql) == 1 { return 12 } }
    if d.nfields >= 14 { if name_eq(src, d.f13s, d.f13l, qs, ql) == 1 { return 13 } }
    if d.nfields >= 15 { if name_eq(src, d.f14s, d.f14l, qs, ql) == 1 { return 14 } }
    if d.nfields >= 16 { if name_eq(src, d.f15s, d.f15l, qs, ql) == 1 { return 15 } }
    if d.nfields >= 17 { if name_eq(src, d.f16s, d.f16l, qs, ql) == 1 { return 16 } }
    if d.nfields >= 18 { if name_eq(src, d.f17s, d.f17l, qs, ql) == 1 { return 17 } }
    if d.nfields >= 19 { if name_eq(src, d.f18s, d.f18l, qs, ql) == 1 { return 18 } }
    if d.nfields >= 20 { if name_eq(src, d.f19s, d.f19l, qs, ql) == 1 { return 19 } }
    return 0 - 1
}

fn struct_decl_open(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int) -> Int {
    let d = defs[ti]
    let n = toks.len()
    let mut i = 0
    while i < n {
        let t = toks[i]
        if t.kind == 26 {
            let nt = toks[i + 1]
            if name_eq(src, d.nstart, d.nlen, nt.nstart, nt.nlen) == 1 { return i + 2 }
            i = match_brace(toks, i + 2, n) + 1
        } else { i = i + 1 }
    }
    return 0 - 1
}

fn struct_field_type_index(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, qs: Int, ql: Int) -> Int {
    let bopen = struct_decl_open(toks, defs, src, ti)
    if bopen < 0 { return 0 - 1 }
    let bclose = match_brace(toks, bopen, toks.len())
    let mut q = bopen + 1
    while q < bclose {
        let fld = toks[q]
        if fld.kind == 1 {
            let mut next = q + 1
            let mut fty = 0 - 1
            let colon = toks[q + 1]
            if colon.kind == 16 {
                let ty = toks[q + 2]
                if ty.kind == 1 {
                    if kw3(src, ty.nstart, ty.nlen, 83, 116, 114) == 1 {
                        fty = 0 - 2
                    } else {
                        fty = struct_index_by_name(defs, src, ty.nstart, ty.nlen)
                    }
                }
            }
            let mut scan = true
            while scan {
                if next >= bclose { scan = false }
                else {
                    let nt = toks[next]
                    if nt.kind == 25 { scan = false } else { next = next + 1 }
                }
            }
            if name_eq(src, fld.nstart, fld.nlen, qs, ql) == 1 {
                return fty
            }
            q = next + 1
        } else { q = q + 1 }
    }
    return 0 - 1
}

fn struct_flat_nfields_depth(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, depth: Int) -> Int {
    if depth >= 4 { return struct_nfields(defs, ti) }
    let bopen = struct_decl_open(toks, defs, src, ti)
    if bopen < 0 { return struct_nfields(defs, ti) }
    let bclose = match_brace(toks, bopen, toks.len())
    let mut q = bopen + 1
    let mut total = 0
    while q < bclose {
        let fld = toks[q]
        if fld.kind == 1 {
            let mut width = 1
            let fty = struct_field_type_index(toks, defs, src, ti, fld.nstart, fld.nlen)
            if fty >= 0 { width = struct_flat_nfields_depth(toks, defs, src, fty, depth + 1) }
            total = total + width
            let mut next = q + 1
            let mut scan = true
            while scan {
                if next >= bclose { scan = false }
                else {
                    let nt = toks[next]
                    if nt.kind == 25 { scan = false } else { next = next + 1 }
                }
            }
            q = next + 1
        } else { q = q + 1 }
    }
    return total
}

fn struct_flat_nfields(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int) -> Int {
    return struct_flat_nfields_depth(toks, defs, src, ti, 0)
}

fn field_flat_offset_depth(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, qs: Int, ql: Int, depth: Int) -> Int {
    if depth >= 4 { return field_index(defs, ti, src, qs, ql) }
    let bopen = struct_decl_open(toks, defs, src, ti)
    if bopen < 0 { return field_index(defs, ti, src, qs, ql) }
    let bclose = match_brace(toks, bopen, toks.len())
    let mut q = bopen + 1
    let mut off = 0
    while q < bclose {
        let fld = toks[q]
        if fld.kind == 1 {
            let mut width = 1
            let fty = struct_field_type_index(toks, defs, src, ti, fld.nstart, fld.nlen)
            if fty >= 0 { width = struct_flat_nfields_depth(toks, defs, src, fty, depth + 1) }
            let mut next = q + 1
            let mut scan = true
            while scan {
                if next >= bclose { scan = false }
                else {
                    let nt = toks[next]
                    if nt.kind == 25 { scan = false } else { next = next + 1 }
                }
            }
            if name_eq(src, fld.nstart, fld.nlen, qs, ql) == 1 { return off }
            off = off + width
            q = next + 1
        } else { q = q + 1 }
    }
    return 0 - 1
}

fn field_flat_offset(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, qs: Int, ql: Int) -> Int {
    return field_flat_offset_depth(toks, defs, src, ti, qs, ql, 0)
}

fn field_chain_flat_offset(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, fpos: Int) -> Int {
    let fld = toks[fpos]
    let mut off = field_flat_offset(toks, defs, src, ti, fld.nstart, fld.nlen)
    let mut cty = struct_field_type_index(toks, defs, src, ti, fld.nstart, fld.nlen)
    let mut j = fpos + 1
    let mut go = true
    while go {
        let dot = toks[j]
        if dot.kind == 27 and cty >= 0 {
            let nfld = toks[j + 1]
            let noff = field_flat_offset(toks, defs, src, cty, nfld.nstart, nfld.nlen)
            if noff < 0 { return 0 - 1 }
            off = off + noff
            cty = struct_field_type_index(toks, defs, src, cty, nfld.nstart, nfld.nlen)
            j = j + 2
        } else { go = false }
    }
    return off
}

fn field_chain_type_index(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, fpos: Int) -> Int {
    let fld = toks[fpos]
    let mut cty = struct_field_type_index(toks, defs, src, ti, fld.nstart, fld.nlen)
    let mut j = fpos + 1
    let mut go = true
    while go {
        let dot = toks[j]
        if dot.kind == 27 and cty >= 0 {
            let nfld = toks[j + 1]
            cty = struct_field_type_index(toks, defs, src, cty, nfld.nstart, nfld.nlen)
            j = j + 2
        } else { go = false }
    }
    return cty
}

fn field_chain_end_pos(toks: &List<Token>, defs: &List<StructDef>, src: Str, ti: Int, fpos: Int) -> Int {
    let fld = toks[fpos]
    let mut cty = struct_field_type_index(toks, defs, src, ti, fld.nstart, fld.nlen)
    let mut j = fpos + 1
    let mut go = true
    while go {
        let dot = toks[j]
        if dot.kind == 27 and cty >= 0 {
            let nfld = toks[j + 1]
            cty = struct_field_type_index(toks, defs, src, cty, nfld.nstart, nfld.nlen)
            j = j + 2
        } else { go = false }
    }
    return j
}

fn emit_str_from_i64_value(toks: &List<Token>, src: Str, loadc: Int, after_pos: Int, counter: Int) -> Op {
    emit_str("  %t")
    pint(counter)
    emit_str(" = inttoptr i64 %t")
    pint(loadc)
    emit_str(" to i8*")
    putchar(10)
    let lend = trailing_len_call_end(toks, src, after_pos)
    if lend != after_pos {
        return emit_strlen_from_ptr(counter, counter + 1)
    }
    return Op { kind: 2, val: counter, next: counter + 1 }
}

# Slot's struct-type index for a variable (-1 if not a struct).
fn sty_of(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let m = slots.len()
    let mut i = 0
    while i < m {
        let s = slots[i]
        if name_eq(src, s.nstart, s.nlen, qs, ql) == 1 { return s.sty }
        i = i + 1
    }
    return 0 - 1
}

# Compare two local string-literal slots by their literal bytes. Returns 0/1 for
# known string locals, or -1 if either operand is not a local string literal.
fn string_slot_eq(slots: &List<Slot>, src: Str, ans: Int, anl: Int, bns: Int, bnl: Int) -> Int {
    if isarr_of(slots, src, ans, anl) != 3 { return 0 - 1 }
    if isarr_of(slots, src, bns, bnl) != 3 { return 0 - 1 }
    let al = arrlen_of(slots, src, ans, anl)
    let bl = arrlen_of(slots, src, bns, bnl)
    if al != bl { return 0 }
    let ak = strkey_of(slots, src, ans, anl)
    let bk = strkey_of(slots, src, bns, bnl)
    let mut k = 0
    while k < al {
        if src[ak + k] != src[bk + k] { return 0 }
        k = k + 1
    }
    return 1
}

# Print an operand inline. kind 0 = literal int; kind 1 = i64 temp; kind 2 = i8*
# temp (string pointer) -- both temps print as %t<val>.
fn emit_op(o: Op) -> Int {
    if o.kind == 0 { pint(o.val) }
    else { putchar(37); putchar(116); pint(o.val) }
    return 0
}

fn ensure_i64_op(o: Op, counter: Int) -> Op {
    if o.kind == 2 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = ptrtoint i8* ")
        emit_op(o)
        emit_str(" to i64")
        putchar(10)
        return Op { kind: 1, val: counter, next: counter + 1 }
    }
    if o.kind == 3 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = ptrtoint i64* ")
        emit_op(o)
        emit_str(" to i64")
        putchar(10)
        return Op { kind: 1, val: counter, next: counter + 1 }
    }
    return o
}

fn emit_nested_struct_literal_to_local(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, outer_sty: Int, slot: Int, fpos: Int, vstart: Int, counter0: Int) -> Int {
    let fld = toks[fpos]
    let outer_nf = struct_flat_nfields(toks, defs, src, outer_sty)
    let base_off = field_flat_offset(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let nested_sty = struct_field_type_index(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let nbclose = match_brace(toks, vstart + 1, toks.len())
    let mut q = vstart + 2
    let mut counter = counter0
    while q < nbclose {
        let nfld = toks[q]
        let noff = field_flat_offset(toks, defs, src, nested_sty, nfld.nstart, nfld.nlen)
        let mut nvstart = q + 1
        let ncolon = toks[q + 1]
        if ncolon.kind == 16 { nvstart = q + 2 }
        let nvstop = arg_comma_end(toks, nvstart, nbclose)
        let ne = gen_expr(toks, slots, fns, defs, src, nvstart, nvstop, counter)
        counter = ne.next
        let ne64 = ensure_i64_op(ne, counter)
        counter = ne64.next
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(outer_nf)
        emit_str(" x i64], [")
        pint(outer_nf)
        emit_str(" x i64]* %v")
        pint(slot)
        emit_str(", i64 0, i64 ")
        pint(base_off + noff)
        putchar(10)
        emit_str("  store i64 ")
        emit_op(ne64)
        emit_str(", i64* %t")
        pint(counter)
        putchar(10)
        counter = counter + 1
        q = nvstop + 1
    }
    return counter
}

fn emit_nested_struct_literal_to_out(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, retout: Int, outer_sty: Int, fpos: Int, vstart: Int, counter0: Int) -> Int {
    let fld = toks[fpos]
    let base_off = field_flat_offset(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let nested_sty = struct_field_type_index(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let nbclose = match_brace(toks, vstart + 1, toks.len())
    let mut q = vstart + 2
    let mut counter = counter0
    while q < nbclose {
        let nfld = toks[q]
        let noff = field_flat_offset(toks, defs, src, nested_sty, nfld.nstart, nfld.nlen)
        let mut nvstart = q + 1
        let ncolon = toks[q + 1]
        if ncolon.kind == 16 { nvstart = q + 2 }
        let nvstop = arg_comma_end(toks, nvstart, nbclose)
        let ne = gen_expr(toks, slots, fns, defs, src, nvstart, nvstop, counter)
        counter = ne.next
        let ne64 = ensure_i64_op(ne, counter)
        counter = ne64.next
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr i64, i64* %a")
        pint(retout)
        emit_str(", i64 ")
        pint(base_off + noff)
        putchar(10)
        emit_str("  store i64 ")
        emit_op(ne64)
        emit_str(", i64* %t")
        pint(counter)
        putchar(10)
        counter = counter + 1
        q = nvstop + 1
    }
    return counter
}

fn emit_struct_field_chain_to_local(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, vp: Int, dst_slot: Int, dst_sty: Int, counter0: Int) -> Int {
    let base = toks[vp]
    let base_slot = find_slot(slots, src, base.nstart, base.nlen)
    let base_sty = sty_of(slots, src, base.nstart, base.nlen)
    let base_nf = struct_flat_nfields(toks, defs, src, base_sty)
    let base_off = field_chain_flat_offset(toks, defs, src, base_sty, vp + 2)
    let dst_nf = struct_flat_nfields(toks, defs, src, dst_sty)
    let mut counter = counter0
    let mut fk = 0
    while fk < dst_nf {
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(base_nf)
        emit_str(" x i64], [")
        pint(base_nf)
        emit_str(" x i64]* %v")
        pint(base_slot)
        emit_str(", i64 0, i64 ")
        pint(base_off + fk)
        putchar(10)
        let sp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %t")
        pint(sp)
        putchar(10)
        let sv = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(dst_nf)
        emit_str(" x i64], [")
        pint(dst_nf)
        emit_str(" x i64]* %v")
        pint(dst_slot)
        emit_str(", i64 0, i64 ")
        pint(fk)
        putchar(10)
        let dp = counter
        counter = counter + 1
        emit_str("  store i64 %t")
        pint(sv)
        emit_str(", i64* %t")
        pint(dp)
        putchar(10)
        fk = fk + 1
    }
    return counter
}

fn emit_struct_local_to_local_field(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, outer_sty: Int, dst_slot: Int, fpos: Int, vstart: Int, counter0: Int) -> Int {
    let fld = toks[fpos]
    let value = toks[vstart]
    let src_slot = find_slot(slots, src, value.nstart, value.nlen)
    let src_sty = sty_of(slots, src, value.nstart, value.nlen)
    let nested_nf = struct_flat_nfields(toks, defs, src, src_sty)
    let outer_nf = struct_flat_nfields(toks, defs, src, outer_sty)
    let base_off = field_flat_offset(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let mut counter = counter0
    let mut fk = 0
    while fk < nested_nf {
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(nested_nf)
        emit_str(" x i64], [")
        pint(nested_nf)
        emit_str(" x i64]* %v")
        pint(src_slot)
        emit_str(", i64 0, i64 ")
        pint(fk)
        putchar(10)
        let sp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %t")
        pint(sp)
        putchar(10)
        let sv = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(outer_nf)
        emit_str(" x i64], [")
        pint(outer_nf)
        emit_str(" x i64]* %v")
        pint(dst_slot)
        emit_str(", i64 0, i64 ")
        pint(base_off + fk)
        putchar(10)
        let dp = counter
        counter = counter + 1
        emit_str("  store i64 %t")
        pint(sv)
        emit_str(", i64* %t")
        pint(dp)
        putchar(10)
        fk = fk + 1
    }
    return counter
}

fn emit_struct_local_to_out_field(toks: &List<Token>, slots: &List<Slot>, defs: &List<StructDef>, src: Str, retout: Int, outer_sty: Int, fpos: Int, vstart: Int, counter0: Int) -> Int {
    let fld = toks[fpos]
    let value = toks[vstart]
    let src_slot = find_slot(slots, src, value.nstart, value.nlen)
    let src_sty = sty_of(slots, src, value.nstart, value.nlen)
    let nested_nf = struct_flat_nfields(toks, defs, src, src_sty)
    let base_off = field_flat_offset(toks, defs, src, outer_sty, fld.nstart, fld.nlen)
    let mut counter = counter0
    let mut fk = 0
    while fk < nested_nf {
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(nested_nf)
        emit_str(" x i64], [")
        pint(nested_nf)
        emit_str(" x i64]* %v")
        pint(src_slot)
        emit_str(", i64 0, i64 ")
        pint(fk)
        putchar(10)
        let sp = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64, i64* %t")
        pint(sp)
        putchar(10)
        let sv = counter
        counter = counter + 1
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr i64, i64* %a")
        pint(retout)
        emit_str(", i64 ")
        pint(base_off + fk)
        putchar(10)
        let dp = counter
        counter = counter + 1
        emit_str("  store i64 %t")
        pint(sv)
        emit_str(", i64* %t")
        pint(dp)
        putchar(10)
        fk = fk + 1
    }
    return counter
}

fn list_literal_elem_count(toks: &List<Token>, start: Int, bend: Int) -> Int {
    let mut q = start
    let mut idx = 0
    while q < bend {
        let estop = arg_comma_end(toks, q, bend)
        idx = idx + 1
        q = estop + 1
    }
    return idx
}

fn emit_list_literal_data(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, start: Int, bend: Int, elem_sty: Int, dst_ref: Int, counter: Int) -> Int {
    let mut q = start
    let mut idx = 0
    let mut bufsz = list_cap()
    let mut stride = 1
    let mut dst_is_ptr = 0
    let mut dst_base = dst_ref
    if dst_ref < 0 {
        dst_is_ptr = 1
        dst_base = (0 - dst_ref) - 1
    }
    if elem_sty >= 0 {
        stride = struct_flat_nfields(toks, defs, src, elem_sty)
        bufsz = list_bufsz_for_nfields(stride)
    }
    while q < bend {
        let estop = arg_comma_end(toks, q, bend)
        if elem_sty >= 0 {
            let lit_ty = toks[q]
            let lit_open = toks[q + 1]
            let mut lit_sty = 0 - 1
            if lit_ty.kind == 1 and lit_open.kind == 11 {
                lit_sty = struct_index_by_name(defs, src, lit_ty.nstart, lit_ty.nlen)
            }
            if lit_sty == elem_sty {
                let bclose = match_brace(toks, q + 1, bend)
                let mut fq = q + 2
                while fq < bclose {
                    let fld = toks[fq]
                    let fi = field_index(defs, elem_sty, src, fld.nstart, fld.nlen)
                    let mut vstart = fq + 1
                    let colon = toks[fq + 1]
                    if colon.kind == 16 { vstart = fq + 2 }
                    let vstop = arg_comma_end(toks, vstart, bclose)
                    let mut fe64 = Op { kind: 0, val: 0, next: counter }
                    let mut used_nested = 0
                    let nt = toks[vstart]
                    let nb = toks[vstart + 1]
                    if nt.kind == 1 and nb.kind == 11 {
                        let nty = struct_index_by_name(defs, src, nt.nstart, nt.nlen)
                        if nty >= 0 {
                            if struct_nfields(defs, nty) == 1 {
                                let nbclose = match_brace(toks, vstart + 1, vstop)
                                let nfld = toks[vstart + 2]
                                if field_index(defs, nty, src, nfld.nstart, nfld.nlen) == 0 {
                                    let mut nvstart = vstart + 3
                                    let ncolon = toks[vstart + 3]
                                    if ncolon.kind == 16 { nvstart = vstart + 4 }
                                    let nvstop = arg_comma_end(toks, nvstart, nbclose)
                                    let ne = gen_expr(toks, slots, fns, defs, src, nvstart, nvstop, counter)
                                    counter = ne.next
                                    fe64 = ensure_i64_op(ne, counter)
                                    counter = fe64.next
                                    used_nested = 1
                                }
                            }
                        }
                    }
                    if used_nested == 0 {
                        let fe = gen_expr(toks, slots, fns, defs, src, vstart, vstop, counter)
                        counter = fe.next
                        fe64 = ensure_i64_op(fe, counter)
                        counter = fe64.next
                    }
                        let off = idx * stride + fi
                        emit_str("  %t")
                        pint(counter)
                        if dst_is_ptr == 1 {
                            emit_str(" = getelementptr i64, i64* %t")
                            pint(dst_base)
                            emit_str(", i64 ")
                            pint(off)
                        } else {
                            emit_str(" = getelementptr [")
                            pint(bufsz)
                            emit_str(" x i64], [")
                            pint(bufsz)
                            emit_str(" x i64]* %v")
                            pint(dst_base)
                            emit_str(", i64 0, i64 ")
                            pint(off)
                        }
                        putchar(10)
                        emit_str("  store i64 ")
                        emit_op(fe64)
                        emit_str(", i64* %t")
                        pint(counter)
                        putchar(10)
                        counter = counter + 1
                    fq = vstop + 1
                }
            } else {
                emit_str("  call void @llvm.trap()")
                putchar(10)
            }
        } else {
            let e = gen_expr(toks, slots, fns, defs, src, q, estop, counter)
            counter = e.next
            let mut ek = e.kind
            let mut ev = e.val
            if elem_sty == 0 - 2 {
                emit_str("  %t")
                pint(counter)
                emit_str(" = ptrtoint i8* ")
                emit_op(e)
                emit_str(" to i64")
                putchar(10)
                ek = 1
                ev = counter
                counter = counter + 1
            }
            emit_str("  %t")
            pint(counter)
            if dst_is_ptr == 1 {
                emit_str(" = getelementptr i64, i64* %t")
                pint(dst_base)
                emit_str(", i64 ")
                pint(idx)
            } else {
                emit_str(" = getelementptr [")
                pint(bufsz)
                emit_str(" x i64], [")
                pint(bufsz)
                emit_str(" x i64]* %v")
                pint(dst_base)
                emit_str(", i64 0, i64 ")
                pint(idx)
            }
            putchar(10)
            emit_str("  store i64 ")
            emit_op(Op { kind: ek, val: ev, next: 0 })
            emit_str(", i64* %t")
            pint(counter)
            putchar(10)
            counter = counter + 1
        }
        idx = idx + 1
        q = estop + 1
    }
    return counter
}

# Fixed capacity for generated List buffers. Early self-host stages used 64,
# which is enough for snippets but not for a compiler reading a real source file
# again. Most generated Lists stay at 4096 to keep recursive compiler scopes
# stack-bounded; the 4-field Token shape gets a larger cap for growing
# file-sized compiler sources in full retarget and embedded self probes.
fn list_cap() -> Int { return 4096 }
fn list_lenidx() -> Int { return list_cap() - 1 }
fn list_struct_cap(nf: Int) -> Int {
    if nf == 4 { return 262144 }
    return list_cap()
}
fn list_lenidx_for_nfields(nf: Int) -> Int { return list_struct_cap(nf) * nf }
fn list_bufsz_for_nfields(nf: Int) -> Int { return list_lenidx_for_nfields(nf) + 1 }
fn list_cap_for_sty(defs: &List<StructDef>, sty: Int) -> Int {
    if sty >= 0 { return list_struct_cap(struct_nfields(defs, sty)) }
    return list_cap()
}
fn list_lenidx_for_sty(defs: &List<StructDef>, sty: Int) -> Int {
    if sty >= 0 { return list_lenidx_for_nfields(struct_nfields(defs, sty)) }
    return list_lenidx()
}
fn list_bufsz_for_sty(defs: &List<StructDef>, sty: Int) -> Int {
    if sty >= 0 { return list_bufsz_for_nfields(struct_nfields(defs, sty)) }
    return list_cap()
}
fn map_cap() -> Int { return 256 }
fn map_value_base() -> Int { return map_cap() }
fn map_lenidx() -> Int { return map_cap() * 2 }
fn map_bufsz() -> Int { return map_lenidx() + 1 }
fn map_value_int_ty() -> Int { return 0 }
fn map_value_bool_ty() -> Int { return 1 }
fn map_value_char_ty() -> Int { return 2 }
fn map_str_int_ty() -> Int { return 3 }
fn map_str_bool_ty() -> Int { return 4 }
fn map_str_char_ty() -> Int { return 5 }
fn map_str_str_ty() -> Int { return 6 }
fn result_str_int_ty() -> Int { return 0 - 20 }
fn result_str_str_ty() -> Int { return 0 - 21 }
fn result_struct_int_base_ty() -> Int { return 0 - 2000 }
fn result_struct_int_ty(sty: Int) -> Int { return result_struct_int_base_ty() - sty }
fn result_struct_int_payload_ty(ty: Int) -> Int {
    if ty <= result_struct_int_base_ty() { return result_struct_int_base_ty() - ty }
    return 0 - 1
}
fn is_result_struct_int_ty(ty: Int) -> Bool { return result_struct_int_payload_ty(ty) >= 0 }
fn is_result_ty(ty: Int) -> Bool { return ty == result_str_int_ty() or ty == result_str_str_ty() or is_result_struct_int_ty(ty) }
fn retcfg_pack(retout: Int, retkind: Int, retty: Int) -> Int {
    return (((retout + 1) * 200000) + (retty + 100000)) * 10 + retkind
}
fn retcfg_retout(retcfg: Int) -> Int {
    let body = retcfg / 10
    return (body / 200000) - 1
}
fn retcfg_retty(retcfg: Int) -> Int {
    let body = retcfg / 10
    let group = body / 200000
    return (body - (group * 200000)) - 100000
}
fn retcfg_retkind(retcfg: Int) -> Int {
    let body = retcfg / 10
    return retcfg - (body * 10)
}
fn retcfg_returns_vais_result_str_int(defs: &List<StructDef>, src: Str, retcfg: Int) -> Int {
    if retcfg_retkind(retcfg) != 2 { return 0 }
    let retty = retcfg_retty(retcfg)
    if retty < 0 { return 0 }
    if retty >= defs.len() { return 0 }
    let d = defs[retty]
    return is_vais_result_str_int_name(src, d.nstart, d.nlen)
}
fn map_int_param_ty() -> Int { return 0 - 3 }
fn map_bool_param_ty() -> Int { return 0 - 4 }
fn map_char_param_ty() -> Int { return 0 - 5 }
fn map_str_int_param_ty() -> Int { return 0 - 6 }
fn map_str_bool_param_ty() -> Int { return 0 - 7 }
fn map_str_char_param_ty() -> Int { return 0 - 8 }
fn map_str_str_param_ty() -> Int { return 0 - 9 }
fn map_param_ty() -> Int { return map_int_param_ty() }
fn is_map_param_ty(pty: Int) -> Bool { return pty == map_int_param_ty() or pty == map_bool_param_ty() or pty == map_char_param_ty() or pty == map_str_int_param_ty() or pty == map_str_bool_param_ty() or pty == map_str_char_param_ty() or pty == map_str_str_param_ty() }
fn map_param_value_ty(pty: Int) -> Int {
    if pty == map_str_str_param_ty() { return map_str_str_ty() }
    if pty == map_str_char_param_ty() { return map_str_char_ty() }
    if pty == map_str_bool_param_ty() { return map_str_bool_ty() }
    if pty == map_str_int_param_ty() { return map_str_int_ty() }
    if pty == map_char_param_ty() { return map_value_char_ty() }
    if pty == map_bool_param_ty() { return map_value_bool_ty() }
    return map_value_int_ty()
}
fn map_is_str_key(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let msty = sty_of(slots, src, qs, ql)
    if msty == map_str_int_ty() or msty == map_str_bool_ty() or msty == map_str_char_ty() or msty == map_str_str_ty() { return 1 }
    return 0
}
fn map_is_str_value(slots: &List<Slot>, src: Str, qs: Int, ql: Int) -> Int {
    let msty = sty_of(slots, src, qs, ql)
    if msty == map_str_str_ty() { return 1 }
    return 0
}
fn emit_map_helper_name(slots: &List<Slot>, src: Str, qs: Int, ql: Int, name: Str) -> Int {
    if map_is_str_key(slots, src, qs, ql) == 1 {
        emit_str("__vais_map_str_int_")
    } else {
        emit_str("__vais_map_int_int_")
    }
    emit_str(name)
    return 0
}
fn emit_map_key_arg(slots: &List<Slot>, src: Str, qs: Int, ql: Int, key: Op) -> Int {
    if map_is_str_key(slots, src, qs, ql) == 1 { emit_str("i8* ") } else { emit_str("i64 ") }
    emit_op(key)
    return 0
}
fn gen_map_key_expr(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, qs: Int, ql: Int, kstart: Int, kstop: Int, counter: Int) -> Op {
    if map_is_str_key(slots, src, qs, ql) == 1 {
        let kt = toks[kstart]
        if kstart + 1 == kstop and kt.kind == 1 {
            let kslot = find_slot(slots, src, kt.nstart, kt.nlen)
            if kslot >= 0 and isarr_of(slots, src, kt.nstart, kt.nlen) == 3 {
                emit_str("  %t")
                pint(counter)
                emit_str(" = load i8*, i8** %v")
                pint(kslot)
                putchar(10)
                return Op { kind: 2, val: counter, next: counter + 1 }
            }
        }
    }
    return gen_expr(toks, slots, fns, defs, src, kstart, kstop, counter)
}
fn map_arg_matches_param(slots: &List<Slot>, src: Str, qs: Int, ql: Int, want_ty: Int) -> Int {
    let aarr = isarr_of(slots, src, qs, ql)
    if aarr != 5 and aarr != 6 { return 0 }
    if sty_of(slots, src, qs, ql) == map_param_value_ty(want_ty) { return 1 }
    return 0
}

fn emit_map_base_ptr(slots: &List<Slot>, src: Str, qs: Int, ql: Int, counter: Int) -> Int {
    let mslot = find_slot(slots, src, qs, ql)
    let karr = isarr_of(slots, src, qs, ql)
    emit_str("  %t")
    pint(counter)
    if karr == 6 {
        emit_str(" = load i64*, i64** %v")
        pint(mslot)
    } else {
        emit_str(" = getelementptr [")
        pint(map_bufsz())
        emit_str(" x i64], [")
        pint(map_bufsz())
        emit_str(" x i64]* %v")
        pint(mslot)
        emit_str(", i64 0, i64 0")
    }
    putchar(10)
    return counter
}

fn emit_list_base_ptr(slots: &List<Slot>, src: Str, qs: Int, ql: Int, counter: Int) -> Int {
    let lslot = find_slot(slots, src, qs, ql)
    let larr = isarr_of(slots, src, qs, ql)
    if larr == 4 {
        emit_str("  %t")
        pint(counter)
        emit_str(" = load i64*, i64** %v")
        pint(lslot)
        putchar(10)
        return counter
    } else {
        let lc = counter
        emit_str("  %t")
        pint(lc)
        emit_str(" = load i64, i64* %v")
        pint(lslot + 1)
        putchar(10)
        let lp = lc + 1
        emit_str("  %t")
        pint(lp)
        emit_str(" = getelementptr [")
        pint(list_cap())
        emit_str(" x i64], [")
        pint(list_cap())
        emit_str(" x i64]* %v")
        pint(lslot)
        emit_str(", i64 0, i64 ")
        pint(list_lenidx())
        putchar(10)
        emit_str("  store i64 %t")
        pint(lc)
        emit_str(", i64* %t")
        pint(lp)
        putchar(10)
        let bp = lp + 1
        emit_str("  %t")
        pint(bp)
        emit_str(" = getelementptr [")
        pint(list_cap())
        emit_str(" x i64], [")
        pint(list_cap())
        emit_str(" x i64]* %v")
        pint(lslot)
        emit_str(", i64 0, i64 0")
        putchar(10)
        return bp
    }
}

fn emit_inline_list_literal_arg(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, q: Int, elem_sty: Int, counter: Int) -> Op {
    let aid = counter
    let bufsz = list_bufsz_for_sty(defs, elem_sty)
    let lenidx = list_lenidx_for_sty(defs, elem_sty)
    emit_str("  %la")
    pint(aid)
    emit_str(" = alloca [")
    pint(bufsz)
    emit_str(" x i64]")
    putchar(10)
    let bend = bracket_end(toks, q + 1)
    let lit_len = list_literal_elem_count(toks, q + 1, bend)
    let base = counter + 1
    emit_str("  %t")
    pint(base)
    emit_str(" = getelementptr [")
    pint(bufsz)
    emit_str(" x i64], [")
    pint(bufsz)
    emit_str(" x i64]* %la")
    pint(aid)
    emit_str(", i64 0, i64 0")
    putchar(10)
    let mut cc = emit_list_literal_data(toks, slots, fns, defs, src, q + 1, bend, elem_sty, (0 - base) - 1, base + 1)
    emit_str("  %t")
    pint(cc)
    emit_str(" = getelementptr i64, i64* %t")
    pint(base)
    emit_str(", i64 ")
    pint(lenidx)
    putchar(10)
    emit_str("  store i64 ")
    pint(lit_len)
    emit_str(", i64* %t")
    pint(cc)
    putchar(10)
    cc = cc + 1
    return Op { kind: 3, val: base, next: cc }
}

# After a call that passed List-local slot `lslot` by pointer, copy the length the
# callee wrote into buf[63] back into the local's length slot (%v<lslot+1>), so the
# caller's xs.len / further passes see pushes. No-op if lslot < 0. Returns counter.
# lslot = the local List buffer slot, or -1 for none. lenidx = the index where
# the callee stored the updated length (63 for scalar Lists, 64*nf for
# List-of-structs), and bufsz = the buffer's array size ([bufsz x i64]). These
# must match the local List's allocation so the GEP type is well-typed.
fn sync_list_len(lslot: Int, lenidx: Int, bufsz: Int, counter: Int) -> Int {
    if lslot < 0 { return counter }
    let lp = counter
    emit_str("  %t")
    pint(lp)
    emit_str(" = getelementptr [")
    pint(bufsz)
    emit_str(" x i64], [")
    pint(bufsz)
    emit_str(" x i64]* %v")
    pint(lslot)
    emit_str(", i64 0, i64 ")
    pint(lenidx)
    putchar(10)
    let lv = lp + 1
    emit_str("  %t")
    pint(lv)
    emit_str(" = load i64, i64* %t")
    pint(lp)
    putchar(10)
    emit_str("  store i64 %t")
    pint(lv)
    emit_str(", i64* %v")
    pint(lslot + 1)
    putchar(10)
    return lv + 1
}

fn emit_list_bounds_trap(idx: Op, len: Op, counter: Int) -> Int {
    let lt0 = counter
    emit_str("  %t")
    pint(lt0)
    emit_str(" = icmp slt i64 ")
    emit_op(idx)
    emit_str(", 0")
    putchar(10)
    let ge = lt0 + 1
    emit_str("  %t")
    pint(ge)
    emit_str(" = icmp sge i64 ")
    emit_op(idx)
    emit_str(", ")
    emit_op(len)
    putchar(10)
    let bad = ge + 1
    emit_str("  %t")
    pint(bad)
    emit_str(" = or i1 %t")
    pint(lt0)
    emit_str(", %t")
    pint(ge)
    putchar(10)
    let lab = bad + 1
    emit_str("  br i1 %t")
    pint(bad)
    emit_str(", label %list_bounds_trap")
    pint(lab)
    emit_str(", label %list_bounds_ok")
    pint(lab)
    putchar(10)
    emit_str("list_bounds_trap")
    pint(lab)
    emit_str(":")
    putchar(10)
    emit_str("  call void @llvm.trap()")
    putchar(10)
    emit_str("  unreachable")
    putchar(10)
    emit_str("list_bounds_ok")
    pint(lab)
    emit_str(":")
    putchar(10)
    return lab + 1
}

fn emit_list_insert_bounds_trap(idx: Op, len: Op, counter: Int) -> Int {
    let lt0 = counter
    emit_str("  %t")
    pint(lt0)
    emit_str(" = icmp slt i64 ")
    emit_op(idx)
    emit_str(", 0")
    putchar(10)
    let gt = lt0 + 1
    emit_str("  %t")
    pint(gt)
    emit_str(" = icmp sgt i64 ")
    emit_op(idx)
    emit_str(", ")
    emit_op(len)
    putchar(10)
    let bad = gt + 1
    emit_str("  %t")
    pint(bad)
    emit_str(" = or i1 %t")
    pint(lt0)
    emit_str(", %t")
    pint(gt)
    putchar(10)
    let lab = bad + 1
    emit_str("  br i1 %t")
    pint(bad)
    emit_str(", label %list_insert_bounds_trap")
    pint(lab)
    emit_str(", label %list_insert_bounds_ok")
    pint(lab)
    putchar(10)
    emit_str("list_insert_bounds_trap")
    pint(lab)
    emit_str(":")
    putchar(10)
    emit_str("  call void @llvm.trap()")
    putchar(10)
    emit_str("  unreachable")
    putchar(10)
    emit_str("list_insert_bounds_ok")
    pint(lab)
    emit_str(":")
    putchar(10)
    return lab + 1
}

fn emit_list_nonempty_trap(len: Op, counter: Int) -> Int {
    let bad = counter
    emit_str("  %t")
    pint(bad)
    emit_str(" = icmp sle i64 ")
    emit_op(len)
    emit_str(", 0")
    putchar(10)
    let lab = bad + 1
    emit_str("  br i1 %t")
    pint(bad)
    emit_str(", label %list_empty_trap")
    pint(lab)
    emit_str(", label %list_empty_ok")
    pint(lab)
    putchar(10)
    emit_str("list_empty_trap")
    pint(lab)
    emit_str(":")
    putchar(10)
    emit_str("  call void @llvm.trap()")
    putchar(10)
    emit_str("  unreachable")
    putchar(10)
    emit_str("list_empty_ok")
    pint(lab)
    emit_str(":")
    putchar(10)
    return lab + 1
}

fn emit_list_capacity_trap(len: Op, cap: Int, counter: Int) -> Int {
    let full = counter
    emit_str("  %t")
    pint(full)
    emit_str(" = icmp sge i64 ")
    emit_op(len)
    emit_str(", ")
    pint(cap)
    putchar(10)
    let lab = full + 1
    emit_str("  br i1 %t")
    pint(full)
    emit_str(", label %list_capacity_trap")
    pint(lab)
    emit_str(", label %list_capacity_ok")
    pint(lab)
    putchar(10)
    emit_str("list_capacity_trap")
    pint(lab)
    emit_str(":")
    putchar(10)
    emit_str("  call void @llvm.trap()")
    putchar(10)
    emit_str("  unreachable")
    putchar(10)
    emit_str("list_capacity_ok")
    pint(lab)
    emit_str(":")
    putchar(10)
    return lab + 1
}

fn emit_struct_return_field_call(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, close: Int, counter: Int) -> Op {
    let crsty_expr = call_retsty(toks, fns, src, i)
    if crsty_expr < 0 { return Op { kind: 0 - 1, val: 0, next: counter } }
    let tail_dot = toks[close + 1]
    if tail_dot.kind != 27 { return Op { kind: 0 - 1, val: 0, next: counter } }
    let fld_call = toks[close + 2]
    let nf_call = struct_flat_nfields(toks, defs, src, crsty_expr)
    let tmpstruct_call = counter
    emit_str("  %sa")
    pint(tmpstruct_call)
    emit_str(" = alloca [")
    pint(nf_call)
    emit_str(" x i64]")
    putchar(10)
    let base_call = tmpstruct_call + 1
    emit_str("  %t")
    pint(base_call)
    emit_str(" = getelementptr [")
    pint(nf_call)
    emit_str(" x i64], [")
    pint(nf_call)
    emit_str(" x i64]* %sa")
    pint(tmpstruct_call)
    emit_str(", i64 0, i64 0")
    putchar(10)
    let after_call = emit_struct_out_call(toks, slots, fns, defs, src, i, i + 2, close, base_call + 1, base_call)
    let fi_call = field_chain_flat_offset(toks, defs, src, crsty_expr, close + 2)
    emit_str("  %t")
    pint(after_call)
    emit_str(" = getelementptr [")
    pint(nf_call)
    emit_str(" x i64], [")
    pint(nf_call)
    emit_str(" x i64]* %sa")
    pint(tmpstruct_call)
    emit_str(", i64 0, i64 ")
    pint(fi_call)
    putchar(10)
    let load_call = after_call + 1
    emit_str("  %t")
    pint(load_call)
    emit_str(" = load i64, i64* %t")
    pint(after_call)
    putchar(10)
    let fty_call = field_chain_type_index(toks, defs, src, crsty_expr, close + 2)
    if fty_call == 0 - 2 {
        let fend_call = field_chain_end_pos(toks, defs, src, crsty_expr, close + 2)
        return emit_str_from_i64_value(toks, src, load_call, fend_call, load_call + 1)
    }
    return Op { kind: 1, val: load_call, next: load_call + 1 }
}

# A factor: number, or a variable (emit a load from its alloca -> a temp).
fn gen_factor(toks: &List<Token>, slots: &List<Slot>, fns: &List<Fn>, defs: &List<StructDef>, src: Str, i: Int, counter: Int) -> Op {
    let t = toks[i]
    if t.kind == 0 { return Op { kind: 0, val: t.value, next: counter } }
    if t.kind == 42 {
        let arg = gen_factor(toks, slots, fns, defs, src, i + 1, counter)
        let cmp = arg.next
        emit_str("  %t")
        pint(cmp)
        emit_str(" = icmp eq i64 ")
        emit_op(arg)
        emit_str(", 0")
        putchar(10)
        let zc = cmp + 1
        emit_str("  %t")
        pint(zc)
        emit_str(" = zext i1 %t")
        pint(cmp)
        emit_str(" to i64")
        putchar(10)
        return Op { kind: 1, val: zc, next: zc + 1 }
    }
    # boolean literals `true`/`false` are tokenized as identifiers (kind 1); treat
    # them as the integer constants 1/0 (Vais bools are i64). Used by the common
    # self-host `let mut go = true; ... go = false` loop-flag pattern.
    if t.kind == 1 {
        if kw4(src, t.nstart, t.nlen, 116, 114, 117, 101) == 1 { return Op { kind: 0, val: 1, next: counter } }
        if kw5(src, t.nstart, t.nlen, 102, 97, 108, 115, 101) == 1 { return Op { kind: 0, val: 0, next: counter } }
    }
    if t.kind == 1 {
        let nx_result_ctor = toks[i + 1]
        if nx_result_ctor.kind == 9 {
            let mut result_ctor_is_err = 0
            if is_ok_kw(src, t.nstart, t.nlen) == 1 { result_ctor_is_err = 0 }
            else if is_err_kw(src, t.nstart, t.nlen) == 1 { result_ctor_is_err = 1 }
            else { result_ctor_is_err = 0 - 1 }
            if result_ctor_is_err >= 0 {
                let result_close = paren_end(toks, i + 2)
                let result_first = toks[i + 2]
                let mut result_arg_raw = Op { kind: 0, val: 0, next: counter }
                let mut result_arg_handled = 0
                if result_ctor_is_err == 0 and result_close == i + 3 and result_first.kind == 1 {
                    let result_payload_ty = sty_of(slots, src, result_first.nstart, result_first.nlen)
                    if result_payload_ty >= 0 and isarr_of(slots, src, result_first.nstart, result_first.nlen) == 0 {
                        let result_payload_slot = find_slot(slots, src, result_first.nstart, result_first.nlen)
                        let result_payload_nf = struct_flat_nfields(toks, defs, src, result_payload_ty)
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = call i8* @malloc(i64 ")
                        pint(result_payload_nf * 8)
                        emit_str(")")
                        putchar(10)
                        let heap_raw = counter
                        emit_str("  %t")
                        pint(counter + 1)
                        emit_str(" = bitcast i8* %t")
                        pint(heap_raw)
                        emit_str(" to i64*")
                        putchar(10)
                        let heap_ptr = counter + 1
                        let mut copy_i = 0
                        let mut copy_cc = counter + 2
                        while copy_i < result_payload_nf {
                            emit_str("  %t")
                            pint(copy_cc)
                            emit_str(" = getelementptr [")
                            pint(result_payload_nf)
                            emit_str(" x i64], [")
                            pint(result_payload_nf)
                            emit_str(" x i64]* %v")
                            pint(result_payload_slot)
                            emit_str(", i64 0, i64 ")
                            pint(copy_i)
                            putchar(10)
                            let srcp = copy_cc
                            copy_cc = copy_cc + 1
                            emit_str("  %t")
                            pint(copy_cc)
                            emit_str(" = load i64, i64* %t")
                            pint(srcp)
                            putchar(10)
                            let srcv = copy_cc
                            copy_cc = copy_cc + 1
                            emit_str("  %t")
                            pint(copy_cc)
                            emit_str(" = getelementptr i64, i64* %t")
                            pint(heap_ptr)
                            emit_str(", i64 ")
                            pint(copy_i)
                            putchar(10)
                            let dstp = copy_cc
                            copy_cc = copy_cc + 1
                            emit_str("  store i64 %t")
                            pint(srcv)
                            emit_str(", i64* %t")
                            pint(dstp)
                            putchar(10)
                            copy_i = copy_i + 1
                        }
                        result_arg_raw = Op { kind: 3, val: heap_ptr, next: copy_cc }
                        result_arg_handled = 1
                    }
                }
                if result_arg_handled == 0 {
                    result_arg_raw = gen_expr(toks, slots, fns, defs, src, i + 2, result_close, counter)
                }
                let result_arg = ensure_i64_op(result_arg_raw, result_arg_raw.next)
                let result_mul = result_arg.next
                emit_str("  %t")
                pint(result_mul)
                emit_str(" = mul i64 ")
                emit_op(result_arg)
                emit_str(", 2")
                putchar(10)
                if result_ctor_is_err == 0 {
                    return Op { kind: 1, val: result_mul, next: result_mul + 1 }
                }
                let result_err = result_mul + 1
                emit_str("  %t")
                pint(result_err)
                emit_str(" = add i64 %t")
                pint(result_mul)
                emit_str(", 1")
                putchar(10)
                return Op { kind: 1, val: result_err, next: result_err + 1 }
            }
        }
    }
    if t.kind == 28 {
        # string literal as a value (e.g. a call argument): GEP the @.s<nstart>
        # global to an i8* temp. Op kind 2 = i8* pointer.
        emit_str("  %t")
        pint(counter)
        emit_str(" = getelementptr [")
        pint(t.value + 1)
        emit_str(" x i8], [")
        pint(t.value + 1)
        emit_str(" x i8]* @.s")
        pint(t.nstart)
        emit_str(", i64 0, i64 0")
        putchar(10)
        return Op { kind: 2, val: counter, next: counter + 1 }
    }
    if t.kind == 9 {
        # parenthesized group: `( <expr> )` -> evaluate the inner expression.
        let close = paren_end(toks, i + 1)
        return gen_expr(toks, slots, fns, defs, src, i + 1, close, counter)
    }
    if t.kind == 1 {
        let nx = toks[i + 1]
        if nx.kind == 9 {
            # print/puts with interpolation: a string literal containing `{ident}`
            # emits a printf call against the @.fmt<nstart> format global, loading Int
            # variables as i64 varargs and Str variables as i8* varargs.
            let sarg = toks[i + 2]
            if is_puts(src, t.nstart, t.nlen) == 1 or is_print(src, t.nstart, t.nlen) == 1 {
                if sarg.kind == 28 {
                    if lit_has_brace(src, sarg.nstart, sarg.nlen) == 1 {
                        # 1) load each {ident} operand to a temp; remember temp numbers
                        #    in a small fixed array (up to 8 interpolations).
                        let mut iv0 = 0
                        let mut iv1 = 0
                        let mut iv2 = 0
                        let mut iv3 = 0
                        let mut iv4 = 0
                        let mut iv5 = 0
                        let mut iv6 = 0
                        let mut iv7 = 0
                        let mut ik0 = 1
                        let mut ik1 = 1
                        let mut ik2 = 1
                        let mut ik3 = 1
                        let mut ik4 = 1
                        let mut ik5 = 1
                        let mut ik6 = 1
                        let mut ik7 = 1
                        let mut nv = 0
                        let mut cc2 = counter
                        let mut k = 0
                        while k < sarg.nlen {
                            let istop = interp_end(src, sarg.nstart, sarg.nlen, k)
                            if istop >= 0 {
                                # valid `{ident}`: the ident is [k+1, e); load it.
                                let astart = sarg.nstart + k + 1
                                let alen = istop - (k + 1)
                                let vslot = find_slot(slots, src, astart, alen)
                                let is_str_arg = isarr_of(slots, src, astart, alen) == 3
                                emit_str("  %t")
                                pint(cc2)
                                if is_str_arg { emit_str(" = load i8*, i8** %v") }
                                else { emit_str(" = load i64, i64* %v") }
                                pint(vslot)
                                putchar(10)
                                let mut vk = 1
                                if is_str_arg { vk = 2 }
                                if nv == 0 { iv0 = cc2; ik0 = vk }
                                else if nv == 1 { iv1 = cc2; ik1 = vk }
                                else if nv == 2 { iv2 = cc2; ik2 = vk }
                                else if nv == 3 { iv3 = cc2; ik3 = vk }
                                else if nv == 4 { iv4 = cc2; ik4 = vk }
                                else if nv == 5 { iv5 = cc2; ik5 = vk }
                                else if nv == 6 { iv6 = cc2; ik6 = vk }
                                else { iv7 = cc2; ik7 = vk }
                                nv = nv + 1
                                cc2 = cc2 + 1
                                k = istop + 1
                            } else {
                                k = k + 1
                            }
                        }
                        # 2) emit the printf call with the format global + i64 varargs
                        let flen = fmt_len(src, sarg.nstart, sarg.nlen) + 1
                        let dest = cc2
                        emit_str("  %t")
                        pint(dest)
                        emit_str(" = call i32 (i8*, ...) @printf(i8* getelementptr([")
                        pint(flen)
                        emit_str(" x i8], [")
                        pint(flen)
                        emit_str(" x i8]* @.fmt")
                        pint(sarg.nstart)
                        emit_str(", i64 0, i64 0)")
                        let mut vi = 0
                        while vi < nv {
                            let mut vt = iv0
                            let mut vk = ik0
                            if vi == 1 { vt = iv1; vk = ik1 }
                            else if vi == 2 { vt = iv2; vk = ik2 }
                            else if vi == 3 { vt = iv3; vk = ik3 }
                            else if vi == 4 { vt = iv4; vk = ik4 }
                            else if vi == 5 { vt = iv5; vk = ik5 }
                            else if vi == 6 { vt = iv6; vk = ik6 }
                            else if vi == 7 { vt = iv7; vk = ik7 }
                            if vk == 2 { emit_str(", i8* %t") }
                            else { emit_str(", i64 %t") }
                            pint(vt)
                            vi = vi + 1
                        }
                        emit_str(")")
                        putchar(10)
                        return Op { kind: 1, val: dest, next: dest + 1 }
                    }
                    let pdest = counter
                    emit_str("  %t")
                    pint(pdest)
                    emit_str(" = call i32 @puts(i8* getelementptr([")
                    pint(sarg.value + 1)
                    emit_str(" x i8], [")
                    pint(sarg.value + 1)
                    emit_str(" x i8]* @.s")
                    pint(sarg.nstart)
                    emit_str(", i64 0, i64 0))")
                    putchar(10)
                    return Op { kind: 1, val: pdest, next: pdest + 1 }
                }
                let pclose = paren_end(toks, i + 2)
                let parg = gen_str_expr(toks, slots, fns, defs, src, i + 2, pclose, counter)
                let pdest2 = parg.next
                emit_str("  %t")
                pint(pdest2)
                emit_str(" = call i32 @puts(i8* ")
                emit_op(parg)
                emit_str(")")
                putchar(10)
                return Op { kind: 1, val: pdest2, next: pdest2 + 1 }
            }
            # call: name ( arg0 [, ... up to arg9] ) — 0..10 args.
            let close = paren_end(toks, i + 2)
            let bid = builtin_call_id(src, t.nstart, t.nlen)
            if bid > 0 {
                # Int(x) conversion is identity for the current Int-native slice.
                if bid == 1 {
                    return gen_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                }
                if bid == 10 {
                    let arg = gen_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                    let dests = arg.next
                    emit_str("  %t")
                    pint(dests)
                    emit_str(" = call i8* @__vais_int_to_str(i64 ")
                    emit_op(arg)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dests, next: dests + 1 }
                }
                if bid == 12 {
                    let arg_trim = gen_str_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                    let dest_trim = arg_trim.next
                    emit_str("  %t")
                    pint(dest_trim)
                    emit_str(" = call i8* @__vais_str_trim(i8* ")
                    emit_op(arg_trim)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_trim, next: dest_trim + 1 }
                }
                if bid == 13 {
                    let arg_lower = gen_str_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                    let dest_lower = arg_lower.next
                    emit_str("  %t")
                    pint(dest_lower)
                    emit_str(" = call i8* @__vais_str_lower(i8* ")
                    emit_op(arg_lower)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_lower, next: dest_lower + 1 }
                }
                if bid == 21 {
                    let arg_upper = gen_str_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                    let dest_upper = arg_upper.next
                    emit_str("  %t")
                    pint(dest_upper)
                    emit_str(" = call i8* @__vais_str_upper(i8* ")
                    emit_op(arg_upper)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_upper, next: dest_upper + 1 }
                }
                if bid == 27 {
                    let arg_byte = gen_expr(toks, slots, fns, defs, src, i + 2, close, counter)
                    let dest_byte = arg_byte.next
                    emit_str("  %t")
                    pint(dest_byte)
                    emit_str(" = call i8* @__vais_str_from_byte(i64 ")
                    emit_op(arg_byte)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_byte, next: dest_byte + 1 }
                }
                if bid == 28 {
                    let comma_concat = arg_comma_end(toks, i + 2, close)
                    let concat_left = gen_str_expr(toks, slots, fns, defs, src, i + 2, comma_concat, counter)
                    let concat_right = gen_str_expr(toks, slots, fns, defs, src, comma_concat + 1, close, concat_left.next)
                    let dest_concat = concat_right.next
                    emit_str("  %t")
                    pint(dest_concat)
                    emit_str(" = call i8* @__vais_str_concat(i8* ")
                    emit_op(concat_left)
                    emit_str(", i8* ")
                    emit_op(concat_right)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_concat, next: dest_concat + 1 }
                }
                if bid == 14 {
                    let comma_slice1 = arg_comma_end(toks, i + 2, close)
                    let slice_text = gen_str_expr(toks, slots, fns, defs, src, i + 2, comma_slice1, counter)
                    let comma_slice2 = arg_comma_end(toks, comma_slice1 + 1, close)
                    let slice_start = gen_expr(toks, slots, fns, defs, src, comma_slice1 + 1, comma_slice2, slice_text.next)
                    let slice_len = gen_expr(toks, slots, fns, defs, src, comma_slice2 + 1, close, slice_start.next)
                    let dest_slice = slice_len.next
                    emit_str("  %t")
                    pint(dest_slice)
                    emit_str(" = call i8* @__vais_str_slice(i8* ")
                    emit_op(slice_text)
                    emit_str(", i64 ")
                    emit_op(slice_start)
                    emit_str(", i64 ")
                    emit_op(slice_len)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_slice, next: dest_slice + 1 }
                }
                if bid == 23 {
                    let comma_replace1 = arg_comma_end(toks, i + 2, close)
                    let replace_text = gen_str_expr(toks, slots, fns, defs, src, i + 2, comma_replace1, counter)
                    let comma_replace2 = arg_comma_end(toks, comma_replace1 + 1, close)
                    let replace_needle = gen_str_expr(toks, slots, fns, defs, src, comma_replace1 + 1, comma_replace2, replace_text.next)
                    let replace_value = gen_str_expr(toks, slots, fns, defs, src, comma_replace2 + 1, close, replace_needle.next)
                    let dest_replace = replace_value.next
                    emit_str("  %t")
                    pint(dest_replace)
                    emit_str(" = call i8* @__vais_str_replace(i8* ")
                    emit_op(replace_text)
                    emit_str(", i8* ")
                    emit_op(replace_needle)
                    emit_str(", i8* ")
                    emit_op(replace_value)
                    emit_str(")")
                    putchar(10)
                    return Op { kind: 2, val: dest_replace, next: dest_replace + 1 }
                }
                if bid == 25 {
                    let comma_join = arg_comma_end(toks, i + 2, close)
                    let join_parts = toks[i + 2]
                    let join_sep = gen_str_expr(toks, slots, fns, defs, src, comma_join + 1, close, counter)
                    let join_base0 = join_sep.next
                    let join_base = emit_list_base_ptr(slots, src, join_parts.nstart, join_parts.nlen, join_base0)
                    let dest_join = join_base + 1
                    emit_str("  %t")
                    pint(dest_join)
                    emit_str(" = call i8* @__vais_str_join(i64* %t")
                    pint(join_base)
                    emit_str(", i8* ")
                    emit_op(join_sep)
                    emit_str(")")
                    putchar(10)

	                            putchar(10)
	                            let pssrcmethodv = counter
	                            counter = counter + 1
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = add i64 %t")
	                            pint(psbase)
	                            emit_str(", ")
	                            pint(pskmethod)
	                            putchar(10)
	                            let psoffmethod = counter
	                            counter = counter + 1
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr i64, i64* %t")
	                            pint(psbp)
	                            emit_str(", i64 %t")
	                            pint(psoffmethod)
	                            putchar(10)
	                            let psdestmethodp = counter
	                            counter = counter + 1
	                            emit_str("  store i64 %t")
	                            pint(pssrcmethodv)
	                            emit_str(", i64* %t")
	                            pint(psdestmethodp)
	                            putchar(10)
	                            pskmethod = pskmethod + 1
	                        }
	                    } else {
	                        emit_str("  call void @llvm.trap()")
	                        putchar(10)
	                    }
	                } else if psvaltok.kind == 1 and psnexttok.kind == 23 and sty_of(slots, src, psvaltok.nstart, psvaltok.nlen) == ppsty {
	                    let pssrcbend = bracket_end(toks, i + 6)
	                    if psargstop == pssrcbend + 1 {
	                        let pssrckind = isarr_of(slots, src, psvaltok.nstart, psvaltok.nlen)
	                        if pssrckind == 2 or pssrckind == 4 {
	                            let pssrcslot = find_slot(slots, src, psvaltok.nstart, psvaltok.nlen)
	                            let psidx = gen_expr(toks, slots, fns, defs, src, i + 6, pssrcbend, counter)
	                            counter = psidx.next
	                            let mut pssrcbp = 0
	                            let mut pssrclen = 0
	                            if pssrckind == 4 {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64*, i64** %v")
	                                pint(pssrcslot)
	                                putchar(10)
	                                pssrcbp = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = getelementptr i64, i64* %t")
	                                pint(pssrcbp)
	                                emit_str(", i64 ")
	                                pint(list_lenidx_for_nfields(pnf))
	                                putchar(10)
	                                let pssrclenp = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %t")
	                                pint(pssrclenp)
	                                putchar(10)
	                                pssrclen = counter
	                                counter = counter + 1
	                            } else {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %v")
	                                pint(pssrcslot + 1)
	                                putchar(10)
	                                pssrclen = counter
	                                counter = counter + 1
	                            }
	                            counter = emit_list_bounds_trap(psidx, Op { kind: 1, val: pssrclen, next: 0 }, counter)
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = mul i64 ")
	                            emit_op(psidx)
	                            emit_str(", ")
	                            pint(pnf)
	                            putchar(10)
	                            let pssrcbase = counter
	                            counter = counter + 1
	                            let mut pskelem = 0
	                            while pskelem < pnf {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = add i64 %t")
	                                pint(pssrcbase)
	                                emit_str(", ")
	                                pint(pskelem)
	                                putchar(10)
	                                let pssrcoff = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                if pssrckind == 4 {
	                                    emit_str(" = getelementptr i64, i64* %t")
	                                    pint(pssrcbp)
	                                    emit_str(", i64 %t")
	                                    pint(pssrcoff)
	                                } else {
	                                    let pssrcbufsz = list_bufsz_for_nfields(pnf)
	                                    emit_str(" = getelementptr [")
	                                    pint(pssrcbufsz)
	                                    emit_str(" x i64], [")
	                                    pint(pssrcbufsz)
	                                    emit_str(" x i64]* %v")
	                                    pint(pssrcslot)
	                                    emit_str(", i64 0, i64 %t")
	                                    pint(pssrcoff)
	                                }
	                                putchar(10)
	                                let pssrcelem_p = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %t")
	                                pint(pssrcelem_p)
	                                putchar(10)
	                                let pssrcelem_v = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = add i64 %t")
	                                pint(psbase)
	                                emit_str(", ")
	                                pint(pskelem)
	                                putchar(10)
	                                let psdstoff = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = getelementptr i64, i64* %t")
	                                pint(psbp)
	                                emit_str(", i64 %t")
	                                pint(psdstoff)
	                                putchar(10)
	                                let psdstelem_p = counter
	                                counter = counter + 1
	                                emit_str("  store i64 %t")
	                                pint(pssrcelem_v)
	                                emit_str(", i64* %t")
	                                pint(psdstelem_p)
	                                putchar(10)
	                                pskelem = pskelem + 1
	                            }
	                        } else {
	                            emit_str("  call void @llvm.trap()")
	                            putchar(10)
	                        }
	                    } else {
	                        emit_str("  call void @llvm.trap()")
	                        putchar(10)
	                    }
	                } else if psvaltok.kind == 1 and psargstop == i + 5 and sty_of(slots, src, psvaltok.nstart, psvaltok.nlen) == ppsty and isarr_of(slots, src, psvaltok.nstart, psvaltok.nlen) == 0 {
	                    let pssrcslot = find_slot(slots, src, psvaltok.nstart, psvaltok.nlen)
	                    let mut psklocal = 0
	                    while psklocal < pnf {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr [")
	                        pint(pnf)
	                        emit_str(" x i64], [")
	                        pint(pnf)
	                        emit_str(" x i64]* %v")
	                        pint(pssrcslot)
	                        emit_str(", i64 0, i64 ")
	                        pint(psklocal)
	                        putchar(10)
	                        let pssrclocalp = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = load i64, i64* %t")
	                        pint(pssrclocalp)
	                        putchar(10)
	                        let pssrclocalv = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = add i64 %t")
	                        pint(psbase)
	                        emit_str(", ")
	                        pint(psklocal)
	                        putchar(10)
	                        let psofflocal = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr i64, i64* %t")
	                        pint(psbp)
	                        emit_str(", i64 %t")
	                        pint(psofflocal)
	                        putchar(10)
	                        let psdestlocalp = counter
	                        counter = counter + 1
	                        emit_str("  store i64 %t")
	                        pint(pssrclocalv)
	                        emit_str(", i64* %t")
	                        pint(psdestlocalp)
	                        putchar(10)
	                        psklocal = psklocal + 1
	                    }
	                } else {
	                    # iterate struct-literal fields. token layout: name . push ( Type
	                    # then the open-brace at i+5 starts the struct literal.
                    let psbopen = i + 5
                    let psbclose = match_brace(toks, psbopen, end)
                    let mut psq = psbopen + 1
                    while psq < psbclose {
                        let psfld = toks[psq]
                        let psfi = field_index(defs, ppsty, src, psfld.nstart, psfld.nlen)
                        let mut psvstart = psq + 1
                        let pscolt = toks[psq + 1]
                        if pscolt.kind == 16 { psvstart = psq + 2 }
                        let psvstop = arr_elem_end(toks, psvstart, psbclose)
                        let pse = gen_expr(toks, slots, fns, defs, src, psvstart, psvstop, counter)
                        counter = pse.next
                        let pse64 = ensure_i64_op(pse, counter)
                        counter = pse64.next
                        # offset = base + fi
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = add i64 %t")
                        pint(psbase)
                        emit_str(", ")
                        pint(psfi)
                        putchar(10)
                        let psoff = counter
                        counter = counter + 1
                        # element ptr = bufptr + offset
                        emit_str("  %t")
                        pint(counter)
                        emit_str(" = getelementptr i64, i64* %t")
                        pint(psbp)
                        emit_str(", i64 %t")
                        pint(psoff)
                        putchar(10)
                        let psep = counter
                        counter = counter + 1
                        emit_str("  store i64 ")
                        emit_op(pse64)
                        emit_str(", i64* %t")
                        pint(psep)
                        putchar(10)
                        psq = psvstop + 1
                    }
                }
                # len = len + 1 -> ptr[64*nf]
                emit_str("  %t")
                pint(counter)
                emit_str(" = add i64 %t")
                pint(pslen)
                emit_str(", 1")
                putchar(10)
                let psinc = counter
                counter = counter + 1
                emit_str("  store i64 %t")
                pint(psinc)
                emit_str(", i64* %t")
                pint(pslenp)
                putchar(10)
                let psstop = find_stmt_end(toks, src, psargstop, end)
                if psstop < end {
                    let psst = toks[psstop]
                    if psst.kind == 6 { i = psstop + 1 } else { i = psstop }
                } else { i = psstop }
               } else {
                # push a SCALAR to a List PARAMETER (is_arr=4, buffer pointer): load
                # ptr, len from ptr[63], store v at ptr[len], len+1 back to ptr[63].
                let pslot = find_slot(slots, src, t.nstart, t.nlen)
                let pargstop = paren_end(toks, i + 4)
                let pe = gen_expr(toks, slots, fns, defs, src, i + 4, pargstop, counter)
                counter = pe.next
                let mut pek = pe.kind
                let mut pev = pe.val
                if ppsty == 0 - 2 {
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = ptrtoint i8* ")
                    emit_op(pe)
                    emit_str(" to i64")
                    putchar(10)
                    pek = 1
                    pev = counter
                    counter = counter + 1
                }
                let pbp = counter
                emit_str("  %t")
                pint(pbp)
                emit_str(" = load i64*, i64** %v")
                pint(pslot)
                putchar(10)
                let plenp = pbp + 1
                emit_str("  %t")
                pint(plenp)
                emit_str(" = getelementptr i64, i64* %t")
                pint(pbp)
                emit_str(", i64 ")
                pint(list_lenidx())
                putchar(10)
                let plen = plenp + 1
                emit_str("  %t")
                pint(plen)
	                emit_str(" = load i64, i64* %t")
	                pint(plenp)
	                putchar(10)
	                counter = plen + 1
	                counter = emit_list_capacity_trap(Op { kind: 1, val: plen, next: 0 }, list_cap(), counter)
	                let pep = counter
	                emit_str("  %t")
	                pint(pep)
	                emit_str(" = getelementptr i64, i64* %t")
                pint(pbp)
	                emit_str(", i64 %t")
	                pint(plen)
	                putchar(10)
	                counter = counter + 1
	                emit_str("  store i64 ")
	                emit_op(Op { kind: pek, val: pev, next: 0 })
	                emit_str(", i64* %t")
	                pint(pep)
	                putchar(10)
	                let pinc = counter
	                emit_str("  %t")
	                pint(pinc)
                emit_str(" = add i64 %t")
                pint(plen)
	                emit_str(", 1")
	                putchar(10)
	                counter = counter + 1
	                emit_str("  store i64 %t")
	                pint(pinc)
                emit_str(", i64* %t")
                pint(plenp)
                putchar(10)
	                let pstop = find_stmt_end(toks, src, pargstop, end)
	                if pstop < end {
	                    let pst = toks[pstop]
	                    if pst.kind == 6 { i = pstop + 1 } else { i = pstop }
	                } else { i = pstop }
               }
              } else {
                # list push: lst.push(expr) ;
                let slot = find_slot(slots, src, t.nstart, t.nlen)
                let lsty = sty_of(slots, src, t.nstart, t.nlen)
                # method name at i+2, '(' at i+3, arg from i+4
                let argstop = paren_end(toks, i + 4)
                if lsty >= 0 {
                    # List-of-structs push: arg is `Type { f: v, ... }`. Store each
                    # field at buf[len*nf + field_index]; buffer is [64*nf+1 x i64]
                    # (the +1 length-header slot is unused for local push).
                    let nf = struct_flat_nfields(toks, defs, src, lsty)
                    let lbuf = list_bufsz_for_nfields(nf)
                    # load len, compute base = len*nf
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = load i64, i64* %v")
                    pint(slot + 1)
                    putchar(10)
	                    let lenc = counter
	                    counter = counter + 1
	                    counter = emit_list_capacity_trap(Op { kind: 1, val: lenc, next: 0 }, list_struct_cap(nf), counter)
	                    emit_str("  %t")
	                    pint(counter)
                    emit_str(" = mul i64 %t")
                    pint(lenc)
                    emit_str(", ")
                    pint(nf)
                    putchar(10)
                    let basec = counter
                    counter = counter + 1
                    let valtok = toks[i + 4]
                    let nexttok = toks[i + 5]
                    let rsty = call_retsty(toks, fns, src, i + 4)
                    if valtok.kind == 1 and nexttok.kind == 9 and rsty == lsty {
                        let cclose = paren_end(toks, i + 6)
                        if argstop == cclose + 1 {
                            let tmpstruct = counter
                            emit_str("  %sa")
                            pint(tmpstruct)
                            emit_str(" = alloca [")
                            pint(nf)
                            emit_str(" x i64]")
                            putchar(10)
                            counter = counter + 1
                            emit_str("  %t")
                            pint(counter)
                            emit_str(" = getelementptr [")
                            pint(nf)
                            emit_str(" x i64], [")
                            pint(nf)
                            emit_str(" x i64]* %sa")
                            pint(tmpstruct)
                            emit_str(", i64 0, i64 0")
                            putchar(10)
                            let outp = counter
                            counter = counter + 1
                            counter = emit_struct_out_call(toks, slots, fns, defs, src, i + 4, i + 6, cclose, counter, outp)
                            let mut kcall = 0
                            while kcall < nf {
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = getelementptr [")
                                pint(nf)
                                emit_str(" x i64], [")
                                pint(nf)
                                emit_str(" x i64]* %sa")
                                pint(tmpstruct)
                                emit_str(", i64 0, i64 ")
                                pint(kcall)
                                putchar(10)
                                let srcp = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = load i64, i64* %t")
                                pint(srcp)
                                putchar(10)
                                let srcv = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = add i64 %t")
                                pint(basec)
                                emit_str(", ")
                                pint(kcall)
                                putchar(10)
                                let offcall = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = getelementptr [")
                                pint(lbuf)
                                emit_str(" x i64], [")
                                pint(lbuf)
                                emit_str(" x i64]* %v")
                                pint(slot)
                                emit_str(", i64 0, i64 %t")
                                pint(offcall)
                                putchar(10)
                                let destp = counter
                                counter = counter + 1
                                emit_str("  store i64 %t")
                                pint(srcv)
                                emit_str(", i64* %t")
                                pint(destp)
                                putchar(10)
	                            kcall = kcall + 1
	                        }
	                    } else {
	                        emit_str("  call void @llvm.trap()")
	                        putchar(10)
	                    }
	                } else if valtok.kind == 1 and nexttok.kind == 27 {
	                    let method_tmp = emit_los_method_to_tmp(toks, slots, fns, defs, src, i + 4, argstop, lsty, counter)
	                    if method_tmp.kind == 1 {
	                        counter = method_tmp.next
	                        let mut kmethod = 0
	                        while kmethod < nf {
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr [")
	                            pint(nf)
	                            emit_str(" x i64], [")
	                            pint(nf)
	                            emit_str(" x i64]* %sa")
	                            pint(method_tmp.val)
	                            emit_str(", i64 0, i64 ")
	                            pint(kmethod)
	                            putchar(10)
	                            let srcmethodp = counter
	                            counter = counter + 1
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = load i64, i64* %t")
	                            pint(srcmethodp)
	                            putchar(10)
	                            let srcmethodv = counter
	                            counter = counter + 1
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = add i64 %t")
	                            pint(basec)
	                            emit_str(", ")
	                            pint(kmethod)
	                            putchar(10)
	                            let offmethod = counter
	                            counter = counter + 1
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = getelementptr [")
	                            pint(lbuf)
	                            emit_str(" x i64], [")
	                            pint(lbuf)
	                            emit_str(" x i64]* %v")
	                            pint(slot)
	                            emit_str(", i64 0, i64 %t")
	                            pint(offmethod)
	                            putchar(10)
	                            let destmethodp = counter
	                            counter = counter + 1
	                            emit_str("  store i64 %t")
	                            pint(srcmethodv)
	                            emit_str(", i64* %t")
	                            pint(destmethodp)
	                            putchar(10)
	                            kmethod = kmethod + 1
	                        }
	                    } else {
	                        emit_str("  call void @llvm.trap()")
	                        putchar(10)
	                    }
	                } else if valtok.kind == 1 and nexttok.kind == 23 and sty_of(slots, src, valtok.nstart, valtok.nlen) == lsty {
	                    let srcbend_elem = bracket_end(toks, i + 6)
	                    if argstop == srcbend_elem + 1 {
	                        let srckind_elem = isarr_of(slots, src, valtok.nstart, valtok.nlen)
	                        if srckind_elem == 2 or srckind_elem == 4 {
	                            let srcslot_elem = find_slot(slots, src, valtok.nstart, valtok.nlen)
	                            let idx_elem = gen_expr(toks, slots, fns, defs, src, i + 6, srcbend_elem, counter)
	                            counter = idx_elem.next
	                            let mut srcbp_elem = 0
	                            let mut srclen_elem = 0
	                            if srckind_elem == 4 {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64*, i64** %v")
	                                pint(srcslot_elem)
	                                putchar(10)
	                                srcbp_elem = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = getelementptr i64, i64* %t")
	                                pint(srcbp_elem)
	                                emit_str(", i64 ")
	                                pint(list_lenidx_for_nfields(nf))
	                                putchar(10)
	                                let srclenp_elem = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %t")
	                                pint(srclenp_elem)
	                                putchar(10)
	                                srclen_elem = counter
	                                counter = counter + 1
	                            } else {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %v")
	                                pint(srcslot_elem + 1)
	                                putchar(10)
	                                srclen_elem = counter
	                                counter = counter + 1
	                            }
	                            counter = emit_list_bounds_trap(idx_elem, Op { kind: 1, val: srclen_elem, next: 0 }, counter)
	                            emit_str("  %t")
	                            pint(counter)
	                            emit_str(" = mul i64 ")
	                            emit_op(idx_elem)
	                            emit_str(", ")
	                            pint(nf)
	                            putchar(10)
	                            let srcbase_elem = counter
	                            counter = counter + 1
	                            let mut kelem = 0
	                            while kelem < nf {
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = add i64 %t")
	                                pint(srcbase_elem)
	                                emit_str(", ")
	                                pint(kelem)
	                                putchar(10)
	                                let srcoff_elem = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                if srckind_elem == 4 {
	                                    emit_str(" = getelementptr i64, i64* %t")
	                                    pint(srcbp_elem)
	                                    emit_str(", i64 %t")
	                                    pint(srcoff_elem)
	                                } else {
	                                    emit_str(" = getelementptr [")
	                                    pint(lbuf)
	                                    emit_str(" x i64], [")
	                                    pint(lbuf)
	                                    emit_str(" x i64]* %v")
	                                    pint(srcslot_elem)
	                                    emit_str(", i64 0, i64 %t")
	                                    pint(srcoff_elem)
	                                }
	                                putchar(10)
	                                let srcelem_p = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = load i64, i64* %t")
	                                pint(srcelem_p)
	                                putchar(10)
	                                let srcelem_v = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = add i64 %t")
	                                pint(basec)
	                                emit_str(", ")
	                                pint(kelem)
	                                putchar(10)
	                                let dstoff_elem = counter
	                                counter = counter + 1
	                                emit_str("  %t")
	                                pint(counter)
	                                emit_str(" = getelementptr [")
	                                pint(lbuf)
	                                emit_str(" x i64], [")
	                                pint(lbuf)
	                                emit_str(" x i64]* %v")
	                                pint(slot)
	                                emit_str(", i64 0, i64 %t")
	                                pint(dstoff_elem)
	                                putchar(10)
	                                let dstelem_p = counter
	                                counter = counter + 1
	                                emit_str("  store i64 %t")
	                                pint(srcelem_v)
	                                emit_str(", i64* %t")
	                                pint(dstelem_p)
	                                putchar(10)
	                                kelem = kelem + 1
	                            }
	                        } else {
	                            emit_str("  call void @llvm.trap()")
	                            putchar(10)
	                        }
	                    } else {
	                        emit_str("  call void @llvm.trap()")
	                        putchar(10)
	                    }
	                } else if valtok.kind == 1 and argstop == i + 5 and sty_of(slots, src, valtok.nstart, valtok.nlen) == lsty and isarr_of(slots, src, valtok.nstart, valtok.nlen) == 0 {
	                    let srcslot = find_slot(slots, src, valtok.nstart, valtok.nlen)
	                    let mut klocal = 0
	                    while klocal < nf {
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr [")
	                        pint(nf)
	                        emit_str(" x i64], [")
	                        pint(nf)
	                        emit_str(" x i64]* %v")
	                        pint(srcslot)
	                        emit_str(", i64 0, i64 ")
	                        pint(klocal)
	                        putchar(10)
	                        let srcp_local = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = load i64, i64* %t")
	                        pint(srcp_local)
	                        putchar(10)
	                        let srcv_local = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = add i64 %t")
	                        pint(basec)
	                        emit_str(", ")
	                        pint(klocal)
	                        putchar(10)
	                        let offlocal = counter
	                        counter = counter + 1
	                        emit_str("  %t")
	                        pint(counter)
	                        emit_str(" = getelementptr [")
	                        pint(lbuf)
	                        emit_str(" x i64], [")
	                        pint(lbuf)
	                        emit_str(" x i64]* %v")
	                        pint(slot)
	                        emit_str(", i64 0, i64 %t")
	                        pint(offlocal)
	                        putchar(10)
	                        let destlocalp = counter
	                        counter = counter + 1
	                        emit_str("  store i64 %t")
	                        pint(srcv_local)
	                        emit_str(", i64* %t")
	                        pint(destlocalp)
	                        putchar(10)
	                        klocal = klocal + 1
	                    }
	                } else {
	                    # iterate the struct-literal fields. token layout: name . push
	                    # ( Type then open-brace at i+5 (i=name, so i+5 is the brace).
                        let bopen = i + 5
                        let bclose = match_brace(toks, bopen, end)
                        let mut q = bopen + 1
                        while q < bclose {
                            let fld = toks[q]
                            let fi = field_flat_offset(toks, defs, src, lsty, fld.nstart, fld.nlen)
                            let mut vstart = q + 1
                            let colt = toks[q + 1]
                            if colt.kind == 16 { vstart = q + 2 }
                            let vstop = arg_comma_end(toks, vstart, bclose)
                            let mut e = Op { kind: 0, val: 0, next: counter }
                            let mut used_nested = 0
                            let nt = toks[vstart]
                            let nb = toks[vstart + 1]
                            if nt.kind == 1 and nb.kind == 11 {
                                let nty = struct_index_by_name(defs, src, nt.nstart, nt.nlen)
                                if nty >= 0 {
                                    let fty = struct_field_type_index(toks, defs, src, lsty, fld.nstart, fld.nlen)
                                    if fty == nty {
                                        let nbclose = match_brace(toks, vstart + 1, vstop)
                                        let mut nq = vstart + 2
                                        while nq < nbclose {
                                            let nfld = toks[nq]
                                            let noff = field_flat_offset(toks, defs, src, nty, nfld.nstart, nfld.nlen)
                                            let mut nvstart = nq + 1
                                            let ncolon = toks[nq + 1]
                                            if ncolon.kind == 16 { nvstart = nq + 2 }
                                            let nvstop = arg_comma_end(toks, nvstart, nbclose)
                                            e = gen_expr(toks, slots, fns, defs, src, nvstart, nvstop, counter)
                                            counter = e.next
                                            e = ensure_i64_op(e, counter)
                                            counter = e.next
                                            emit_str("  %t")
                                            pint(counter)
                                            emit_str(" = add i64 %t")
                                            pint(basec)
                                            emit_str(", ")
                                            pint(fi + noff)
                                            putchar(10)
                                            let noffc = counter
                                            counter = counter + 1
                                            emit_str("  %t")
                                            pint(counter)
                                            emit_str(" = getelementptr [")
                                            pint(lbuf)
                                            emit_str(" x i64], [")
                                            pint(lbuf)
                                            emit_str(" x i64]* %v")
                                            pint(slot)
                                            emit_str(", i64 0, i64 %t")
                                            pint(noffc)
                                            putchar(10)
                                            let ngepc = counter
                                            counter = counter + 1
                                            emit_str("  store i64 ")
                                            emit_op(e)
                                            emit_str(", i64* %t")
                                            pint(ngepc)
                                            putchar(10)
                                            nq = nvstop + 1
                                        }
                                        used_nested = 1
                                    }
                                }
                            }
                            if used_nested == 0 {
                                e = gen_expr(toks, slots, fns, defs, src, vstart, vstop, counter)
                                counter = e.next
                                e = ensure_i64_op(e, counter)
                                counter = e.next
                            }
                                # field offset = base + fi
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = add i64 %t")
                                pint(basec)
                                emit_str(", ")
                                pint(fi)
                                putchar(10)
                                let offc = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = getelementptr [")
                                pint(lbuf)
                                emit_str(" x i64], [")
                                pint(lbuf)
                                emit_str(" x i64]* %v")
                                pint(slot)
                                emit_str(", i64 0, i64 %t")
                                pint(offc)
                                putchar(10)
                                let gepc = counter
                                counter = counter + 1
                                emit_str("  store i64 ")
                                emit_op(e)
                                emit_str(", i64* %t")
                                pint(gepc)
                                putchar(10)
                            q = vstop + 1
                        }
                    }
                    # len = len + 1
                    emit_str("  %t")
                    pint(counter)
                    emit_str(" = add i64 %t")
                    pint(lenc)
                    emit_str(", 1")
                    putchar(10)
                    let incc = counter
                    counter = counter + 1
                    emit_str("  store i64 %t")
                    pint(incc)
                    emit_str(", i64* %v")
                    pint(slot + 1)
                    putchar(10)
                    let stop = find_stmt_end(toks, src, argstop, end)
                    if stop < end {
                        let st = toks[stop]
                        if st.kind == 6 { i = stop + 1 } else { i = stop }
                    } else { i = stop }
                } else {
                  # scalar List push: store one value at buf[len]; len = len + 1
                  let e = gen_expr(toks, slots, fns, defs, src, i + 4, argstop, counter)
                  counter = e.next
                  let mut epk = e.kind
                  let mut epv = e.val
                  if lsty == 0 - 2 {
                      emit_str("  %t")
                      pint(counter)
                      emit_str(" = ptrtoint i8* ")
                      emit_op(e)
                      emit_str(" to i64")
                      putchar(10)
                      epk = 1
                      epv = counter
                      counter = counter + 1
                  }
                  emit_str("  %t")
                  pint(counter)
                  emit_str(" = load i64, i64* %v")
                  pint(slot + 1)
                  putchar(10)
	                  let lenc = counter
	                  counter = counter + 1
	                  counter = emit_list_capacity_trap(Op { kind: 1, val: lenc, next: 0 }, list_cap(), counter)
	                  emit_str("  %t")
	                  pint(counter)
                  emit_str(" = getelementptr [")
                  pint(list_cap())
                  emit_str(" x i64], [")
                  pint(list_cap())
                  emit_str(" x i64]* %v")
                  pint(slot)
                  emit_str(", i64 0, i64 %t")
                  pint(lenc)
                  putchar(10)
                  let gepc = counter
                  counter = counter + 1
                  emit_str("  store i64 ")
                  emit_op(Op { kind: epk, val: epv, next: 0 })
                  emit_str(", i64* %t")
                  pint(gepc)
                  putchar(10)
                  emit_str("  %t")
                  pint(counter)
                  emit_str(" = add i64 %t")
                  pint(lenc)
                  emit_str(", 1")
                  putchar(10)
                  let incc = counter
                  counter = counter + 1
                  emit_str("  store i64 %t")
                  pint(incc)
                  emit_str(", i64* %v")
                  pint(slot + 1)
                  putchar(10)
                  let stop = find_stmt_end(toks, src, argstop, end)
                  if stop < end {
                      let st = toks[stop]
                      if st.kind == 6 { i = stop + 1 } else { i = stop }
                  } else { i = stop }
                }
              }
            } else if nx.kind == 23 {
                # array/list element write: name [ idx ] = expr ;
                # List-of-structs field write: name [ idx ] . field = expr ;
                let slot = find_slot(slots, src, t.nstart, t.nlen)
                let alen = arrlen_of(slots, src, t.nstart, t.nlen)
                let warr = isarr_of(slots, src, t.nstart, t.nlen)
                let bend = bracket_end(toks, i + 2)
                let dot_assign = toks[bend + 1]
                let elem_sty_assign = sty_of(slots, src, t.nstart, t.nlen)
                let mut did_struct_field_assign = 0
                if dot_assign.kind == 27 {
                    if elem_sty_assign >= 0 {
                        if warr == 2 or warr == 4 {
                            did_struct_field_assign = 1
                            let fld_assign = toks[bend + 2]
                            let nf_assign = struct_flat_nfields(toks, defs, src, elem_sty_assign)
                            let fi_assign = field_chain_flat_offset(toks, defs, src, elem_sty_assign, bend + 2)
                            let mut val_start_assign = bend + 4
                            let nested_dot_assign = toks[bend + 3]
                            if nested_dot_assign.kind == 27 { val_start_assign = bend + 6 }
                            let stop = find_stmt_end(toks, src, val_start_assign, end)
                            let idxop = gen_expr(toks, slots, fns, defs, src, i + 2, bend, counter)
                            let idxkind = idxop.kind
                            let idxval = idxop.val
                            counter = idxop.next
                            let mut basep = 0
                            let mut wlen = 0
                            if warr == 4 {
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = load i64*, i64** %v")
                                pint(slot)
                                putchar(10)
                                basep = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = getelementptr i64, i64* %t")
                                pint(basep)
                                emit_str(", i64 ")
                                pint(list_lenidx_for_nfields(nf_assign))
                                putchar(10)
                                let lenp = counter
                                counter = counter + 1
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = load i64, i64* %t")
                                pint(lenp)
                                putchar(10)
                                wlen = counter
                                counter = counter + 1
                            } else {
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = load i64, i64* %v")
                                pint(slot + 1)
                                putchar(10)
                                wlen = counter
                                counter = counter + 1
                            }
                            counter = emit_list_bounds_trap(Op { kind: idxkind, val: idxval, next: 0 }, Op { kind: 1, val: wlen, next: 0 }, counter)
                            let valop = gen_expr(toks, slots, fns, defs, src, val_start_assign, stop, counter)
                            counter = valop.next
                            let valop64 = ensure_i64_op(valop, counter)
                            let valkind = valop64.kind
                            let valval = valop64.val
                            counter = valop64.next
                            emit_str("  %t")
                            pint(counter)
                            emit_str(" = mul i64 ")
                            emit_op(Op { kind: idxkind, val: idxval, next: 0 })
                            emit_str(", ")
                            pint(nf_assign)
                            putchar(10)
                            let mulc = counter
                            counter = counter + 1
                            emit_str("  %t")
                            pint(counter)
                            emit_str(" = add i64 %t")
                            pint(mulc)
                            emit_str(", ")
                            pint(fi_assign)
                            putchar(10)
                            let offc = counter
                            counter = counter + 1
                            emit_str("  %t")
                            pint(counter)
                            if warr == 4 {
                                emit_str(" = getelementptr i64, i64* %t")
                                pint(basep)
                                emit_str(", i64 %t")
                                pint(offc)
                            } else {
                                let bufsz = list_bufsz_for_nfields(nf_assign)
                                emit_str(" = getelementptr [")
                                pint(bufsz)
                                emit_str(" x i64], [")
                                pint(bufsz)
                                emit_str(" x i64]* %v")
                                pint(slot)
                                emit_str(", i64 0, i64 %t")
                                pint(offc)
                            }
                            putchar(10)
                            let gepc = counter
                            counter = counter + 1
                            emit_str("  store i64 ")
                            emit_op(Op { kind: valkind, val: valval, next: 0 })
                            emit_str(", i64* %t")
                            pint(gepc)
                            putchar(10)
                            if stop < end and toks[stop].kind == 6 { i = stop + 1 } else { i = stop }
                        }
                    }
                }
                if did_struct_field_assign == 0 {
                    let mut did_struct_element_assign = 0
                    if dot_assign.kind == 5 {
                        if elem_sty_assign >= 0 {
                            if warr == 2 or warr == 4 {
                                did_struct_element_assign = 1
                                let nf_assign = struct_flat_nfields(toks, defs, src, elem_sty_assign)
                                let bufsz_assign = list_bufsz_for_nfields(nf_assign)
                                let stop = find_stmt_end(toks, src, bend + 2, end)
                                let idxop = gen_expr(toks, slots, fns, defs, src, i + 2, bend, counter)
                                let idxkind = idxop.kind
                                let idxval = idxop.val
                                counter = idxop.next
                                let mut basep = 0
                                let mut wlen = 0
                                if warr == 4 {
                                    emit_str("  %t")
                                    pint(counter)
                                    emit_str(" = load i64*, i64** %v")
                                    pint(slot)
                                    putchar(10)
                                    basep = counter
                                    counter = counter + 1
                                    emit_str("  %t")
                                    pint(counter)
                                    emit_str(" = getelementptr i64, i64* %t")
                                    pint(basep)
                                    emit_str(", i64 ")
                                    pint(list_lenidx_for_nfields(nf_assign))
                                    putchar(10)
                                    let lenp = counter
                                    counter = counter + 1
                                    emit_str("  %t")
                                    pint(counter)
                                    emit_str(" = load i64, i64* %t")
                                    pint(lenp)
                                    putchar(10)
                                    wlen = counter
                                    counter = counter + 1
                                } else {
                                    emit_str("  %t")
                                    pint(counter)
                                    emit_str(" = load i64, i64* %v")
                                    pint(slot + 1)
                                    putchar(10)
                                    wlen = counter
                                    counter = counter + 1
                                }
                                counter = emit_list_bounds_trap(Op { kind: idxkind, val: idxval, next: 0 }, Op { kind: 1, val: wlen, next: 0 }, counter)
                                emit_str("  %t")
                                pint(counter)
                                emit_str(" = mul i64 ")
                                emit_op(Op { kind: idxkind, val: idxval, next: 0 })
                                emit_str(", ")
                                pint(nf_assign)
                                putchar(10)
                                let destbase = counter
                                counter = counter + 1
                                let vt = toks[bend + 2]
                                let vaft = toks[bend + 3]
                                if vt.kind == 1 and vaft.kind == 11 and struct_index_by_name(defs, src, vt.nstart, vt.nlen) == elem_sty_assign {
                                    let bopen_assign = bend + 3
                                    let bclose_assign = match_brace(toks, bopen_assign, stop)
                                    let mut qassign = bopen_assign + 1
                                    while qassign < bclose_assign {
                                        let fld_assign2 = toks[qassign]
                                        let fi_assign2 = field_flat_offset(toks, defs, src, elem_sty_assign, fld_assign2.nstart, fld_assign2.nlen)
                                        let mut vstart_assign = qassign + 1
                                        let colt_assign = toks[qassign + 1]
                                        if colt_assign.kind == 16 { vstart_assign = qassign + 2 }
                                        let vstop_assign = arg_comma_end(toks, vstart_assign, bclose_assign)
                                        let ve = gen_expr(toks, slots, fns, defs, src, vstart_assign, vstop_assign, counter)
                                        counter = ve.next
                                        let ve64 = ensure_i64_op(ve, counter)
                                        counter = ve64.next
                                        emit_str("  %t")
                                        pint(counter)
                                        emit_str(" = add i64 %t")
                                        pint(destbase)
                                        emit_str(", ")
                                        pint(fi_assign2)
                                        putchar(10)
                                        let offc = counter
                                        counter = counter + 1
                                        emit_str("  %t")
                                        pint(counter)
                                        if warr == 4 {
                                            emit_str(" = getelementptr i64, i64* %t")
                                            pint(basep)
                                            emit_str(", i64 %t")
                                            pint(offc)
                                        } else {
                                            emit_str(" = getelementptr [")
                                            pint(bufsz_assign)
                                            emit_str(" x i64], [")
                                            pint(bufsz_assign)
                                            emit_str(" x i64]* %v")
                                            pint(slot)
                                            emit_str(", i64 0, i64 %t")
                                            pint(offc)
                                        }
                                        putchar(10)
                                        let destp = counter
                                        counter = counter + 1
                                        emit_str("  store i64 ")
                                        emit_op(ve64)
                                        emit_str(", i64* %t")
                                        pint(destp)
                                        putchar(10)
                                        qassign = vstop_assign + 1
                                    }
                                } else if vt.kind == 1 and stop == bend + 3 and sty_of(slots, src, vt.nstart, vt.nlen) == elem_sty_assign and isarr_of(slots, src, vt.nstart, vt.nlen) == 0 {
                                    let vslot_assign = find_slot(slots, src, vt.nstart, vt.nlen)
                                    let mut kassign = 0
                                    while kassign < nf_assign {
                                        emit_str("  %t")
                                        pint(counter)
                                        emit_str(" = getelementptr [")
                                        pint(nf_assign)
                                        emit_str(" x i64], [")
                                        pint(nf_assign)
                                        emit_str(" x i64]* %v")
                                        pint(vslot_assign)
                                        emit_str(", i64 0, i64 ")
                                        pint(kassign)
                                        putchar(10)
                                        let srcp = counter
                                        counter = counter + 1
                                        emit_str("  %t")
                                        pint(counter)
                                        emit_str(" = load i64, i64* %t")
                                        pint(srcp)
                                        putchar(10)
                                        let srcv = counter
                                        counter = counter + 1
                                        emit_str("  %t")
                                        pint(counter)
                                        emit_str(" = add i64 %t")
                                        pint(destbase)
                                        emit_str(", ")
                                        pint(kassign)
                                        putchar(10)
                                        let offc2 = counter
                                        counter = counter + 1
                                        emit_str("  %t")
                                        pint(counter)
                                        if warr == 4 {
                                            emit_str(" = getelementptr i64, i64* %t")
                                            pint(basep)
                                            emit_str(", i64 %t")
                                            pint(offc2)
                                        } else {
                                            emit_str(" = getelementptr [")
                                            pint(bufsz_assign)
                                            emit_str(" x i64], [")
                                            pint(bufsz_assign)
                                            emit_str(" x i64]* %v")
                                            pint(slot)
                                            emit_str(", i64 0, i64 %t")
                                            pint(offc2)
                                        }
                                        putchar(10)
                                        let destp2 = counter
                                        counter = counter + 1
                                        emit_str("  store i64 %t")
                                        pint(srcv)
                                        emit_str(", i64* %t")
                                        pint(destp2)
                                        putchar(10)
                                        kassign = kassign + 1
                                    }
                                } else if vt.kind == 1 and vaft.kind == 9 and call_retsty(toks, fns, src, bend + 2) == elem_sty_assign {
                                    let cclose_assign = paren_end(toks, bend + 4)
                                    if stop == cclose_assign + 1 {
                                        let tmpstruct = counter
                                        emit_str("  %sa")
                                        pint(tmpstruct)
                                        emit_str(" = alloca [")
                                        pint(nf_assign)
                                        emit_str(" x i64]")
                                        putchar(10)
                                        counter = counter + 1
                                        emit_str("  %t")
                                        pint(counter)
                                        emit_str(" = getelementptr [")
                                        pint(nf_assign)
                                        emit_str(" x i64], [")
                                        pint(nf_assign)
                                        emit_str(" x i64]* %sa")
                                        pint(tmpstruct)
                                        emit_str(", i64 0, i64 0")
                                        putchar(10)
                                        let outp_assign = counter
                                        counter = counter + 1
                                        counter = emit_struct_out_call(toks, slots, fns, defs, src, bend + 2, bend + 4, cclose_assign, counter, outp_assign)
                                        let mut kcall = 0
                                        while kcall < nf_assign {
                                            emit_str("  %t")
                                            pint(counter)
                                            emit_str(" = getelementptr [")
                                            pint(nf_assign)
                                            emit_str(" x i64], [")
                                            pint(nf_assign)
                                            emit_str(" x i64]* %sa")
                                            pint(tmpstruct)
                                            emit_str(", i64 0, i64 ")
                                            pint(kcall)
                                            putchar(10)
                                            let srcp_call = counter
                                            counter = counter + 1
                                            emit_str("  %t")
                                            pint(counter)
                                            emit_str(" = load i64, i64* %t")
                                            pint(srcp_call)
                                            putchar(10)
                                            let srcv_call = counter
                                            counter = counter + 1
                                            emit_str("  %t")
                                            pint(counter)
                                            emit_str(" = add i64 %t")
                                            pint(destbase)
                                            emit_str(", ")
                                            pint(kcall)
                                            putchar(10)
                                            let off_call = counter
                                            counter = counter + 1
                                            emit_str("  %t")
                                            pint(counter)
                                            if warr == 4 {
                                                emit_str(" = getelementptr i64, i64* %t")
                                                pint(basep)
                                                emit_str(", i64 %t")
                                                pint(off_call)
                                            } else {
                                                emit_str(" = getelementptr [")
                                                pint(bufsz_assign)
                                                emit_str(" x i64], [")
                                                pint(bufsz_assign)
                                                emit_str(" x i64]* %v")
                                                pint(slot)
                                                emit_str(", i64 0, i64 %t")
                                                pint(off_call)
                                            }
                                            putchar(10)
                                            let destp_call = counter
                                            counter = counter + 1
                                            emit_str("  store i64 %t")
                                            pint(srcv_call)
                                            emit_str(", i64* %t")
                                            pint(destp_call)
                                            putchar(10)
                                            kcall = kcall + 1
                                        }
                                    } else {
                                        emit_str("  call void @llvm.trap()")

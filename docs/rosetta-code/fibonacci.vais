// Fibonacci Sequence
// Computes the nth Fibonacci number using recursion

fn fibonacci(n: i64) -> i64 {
    I n <= 1 {
        return n
    }
    return @(n - 1) + @(n - 2)
}

fn main() -> i64 {
    println("Fibonacci numbers:")
    L i := 0; i < 10; i := i + 1 {
        println("fib({}) = {}", i, fibonacci(i))
    }
    return 0
}

# LIVING_SPEC/01_keywords/S_struct_generic.vais
# Key concept: S Name<T> { field: T } 제네릭 구조체.
# 사용 시 타입 파라미터가 단형화됨.

struct Box<T> {
    value: T
}

struct Pair<T> {
    first: T,
    second: T
}

impl Pair<i64> {
    fn sum(&self) -> i64 = self.first + self.second
}

fn main() -> i64 {
    b := Box { value: 99 }
    p := Pair { first: 10, second: 32 }
    total := p.sum()
    total + b.value - 141
}

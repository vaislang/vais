# LIVING_SPEC/01_keywords/EN_enum_tuple.vais
# Key concept: EN Name { Variant(Type, ...), ... } 튜플 열거형 선언.
# 각 variant는 내부 값을 갖는다. M 패턴으로 내부 값 추출.

EN Shape {
    Circle(i64),
    Rect(i64, i64)
}

F area(s: Shape) -> i64 {
    M s {
        Circle(r) => r * r,
        Rect(w, h) => w * h
    }
}

F main() -> i64 {
    c := area(Circle(5))
    r := area(Rect(3, 4))
    c + r
}

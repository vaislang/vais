# LIVING_SPEC/01_keywords/B_break_continue.vais
# Key concept: B로 loop 탈출, C로 다음 iteration.

fn find_first_even(limit: i64) -> i64 {
    result := mut -1
    LF i: 0..limit {
        I i % 2 != 0 { C }
        result = i
        B
    }
    result
}

fn main() -> i64 {
    find_first_even(10)  # 0
}

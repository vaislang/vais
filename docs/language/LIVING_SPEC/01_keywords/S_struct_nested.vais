# LIVING_SPEC/01_keywords/S_struct_nested.vais
# Key concept: 구조체 안에 구조체 필드를 중첩해서 사용.
# 중첩 접근: outer.inner.field

struct Vec2 {
    x: i64,
    y: i64
}

struct Line {
    start: Vec2,
    end: Vec2
}

fn length_squared(line: Line) -> i64 {
    dx := line.end.x - line.start.x
    dy := line.end.y - line.start.y
    dx * dx + dy * dy
}

fn main() -> i64 {
    s := Vec2 { x: 0, y: 0 }
    e := Vec2 { x: 3, y: 4 }
    ln := Line { start: s, end: e }
    length_squared(ln)
}

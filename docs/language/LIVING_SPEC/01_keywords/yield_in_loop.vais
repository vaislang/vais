# LIVING_SPEC/01_keywords/yield_in_loop.vais
# Key concept: `yield` expression inside `LF` loop.
# W1-D boundary: this is a simplified syntax/check reference. It does not
# certify coroutine desugaring, yielded-value collection, async scheduling, or
# DB/server/web streaming behavior.

fn counter(max: i64) -> i64 {
    L i: 0..max {
        yield i
    }
    0
}

fn main() -> i64 {
    counter(3)
}

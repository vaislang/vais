# LIVING_SPEC/01_keywords/S_struct_simple.vais
# Key concept: S Name { field: Type, ... } 구조체 선언.
# 생성: Name { field: value } 리터럴. 접근: instance.field.

S Point {
    x: i64,
    y: i64
}

F manhattan(p: Point) -> i64 {
    p.x + p.y
}

F main() -> i64 {
    p := Point { x: 3, y: 4 }
    manhattan(p)
}

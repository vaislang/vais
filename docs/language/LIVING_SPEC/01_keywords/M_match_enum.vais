# LIVING_SPEC/01_keywords/M_match_enum.vais
# Key concept: M expr { EnumVariant(bind) => ... } 열거형 패턴 매치.
# 튜플/유닛 variant 모두 패턴으로 분해 가능.

enum Cmd {
    Quit,
    Move(i64, i64),
    Print(i64)
}

fn run(c: Cmd) -> i64 {
    match c {
        Quit => 0,
        Move(x, y) => x + y,
        Print(v) => v
    }
}

fn main() -> i64 {
    a := run(Move(3, 4))
    b := run(Print(10))
    c := run(Quit)
    a + b + c
}

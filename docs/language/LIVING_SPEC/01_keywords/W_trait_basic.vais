# LIVING_SPEC/01_keywords/W_trait_basic.vais
# Key concept: W TraitName { F method(...) -> T } 트레이트 선언.
# X Type: TraitName { ... } 로 구현. 다형성 인터페이스 정의.

trait Describable {
    fn describe(self) -> i64
}

struct Dog {
    age: i64
}

impl Dog: Describable {
    fn describe(self) -> i64 {
        self.age
    }
}

fn main() -> i64 {
    d := Dog { age: 3 }
    d.describe()
}

# LIVING_SPEC/01_keywords/comptime_const_init.vais
# Key concept: B.3 — `const NAME: T = comptime { expr }` supported via
# const-expression folder. Integer arithmetic covered; complex control flow
# inside comptime block remains outside this example.

const ALPHA: i64 = comptime { 2 * 10 }
const BETA: i64 = comptime { 100 - 1 }

fn main() -> i64 {
    ALPHA + BETA
}

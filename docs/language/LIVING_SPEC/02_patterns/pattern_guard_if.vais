# LIVING_SPEC/02_patterns/pattern_guard_if.vais
# Key concept: match arm guard тАФ `pattern I cond => body`.
# VaisыКФ guardьЧР single-char `I` эВдьЫМыУЬ ьВмьЪй (not `if` ident).

F sign(n: i64) -> i64 {
    M n {
        x I x < 0 => -1,
        0 => 0,
        _ => 1
    }
}

F main() -> i64 {
    a := sign(-5)
    b := sign(0)
    c := sign(7)
    a + b + c
}

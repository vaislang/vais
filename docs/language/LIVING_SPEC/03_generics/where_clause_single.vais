# LIVING_SPEC/03_generics/where_clause_single.vais
# Key concept: F f<T>(x: T) where T: Trait 단일 where 절 트레이트 바운드.
# where 절은 시그니처 뒤에 위치하며 trait bound를 분리해서 표현.

trait Printable {
    fn value(&self) -> i64
}

struct Score {
    pts: i64
}

impl Score: Printable {
    fn value(&self) -> i64 = self.pts
}

fn show<T>(item: T) -> i64 where type: Printable {
    item.value()
}

fn main() -> i64 {
    s := Score { pts: 100 }
    show(s)
}

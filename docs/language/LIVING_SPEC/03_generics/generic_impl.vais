# LIVING_SPEC/03_generics/generic_impl.vais
# Key concept: X Name<T> { F new(...) -> Self } 제네릭 impl 블록.
# Self는 현재 타입을 가리킴; 생성자 패턴.

S Box<T> {
    val: T
}

X Box<i64> {
    F new(v: i64) -> Box<i64> = Box { val: v }

    F get(&self) -> i64 = self.val

    F doubled(&self) -> i64 = self.val * 2
}

F main() -> i64 {
    b := Box::new(21)
    b.doubled()
}

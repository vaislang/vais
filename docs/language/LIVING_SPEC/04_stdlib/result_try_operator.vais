# LIVING_SPEC/04_stdlib/result_try_operator.vais
# Key concept: A2-01/A2-02 `?` value/error propagation for Core-typed
# Result/Option shapes. This example does not claim cleanup, ownership
# transfer, or broad generic error conversion.

fn step(n: i64) -> Result<i64, i64> {
    I n < 0 { Err(1) } else { Ok(n + 1) }
}

fn wrap(x: i64) -> Result<i64, i64> {
    v: i64 = step(x)?
    return Ok(v * 2)
}

fn main() -> i64 {
    match wrap(5) {
        Ok(v) => v,
        Err(_) => -1
    }
}

# LIVING_SPEC/04_stdlib/range_inclusive_exclusive.vais
# Key concept: `0..5` 배타(0~4), `0..=5` 포함(0~5).

fn sum_exclusive() -> i64 {
    s := mut 0
    LF i: 0..5 {
        s = s + i
    }
    s  # 0+1+2+3+4 = 10
}

fn sum_inclusive() -> i64 {
    s := mut 0
    LF i: 0..=5 {
        s = s + i
    }
    s  # 0+1+2+3+4+5 = 15
}

fn main() -> i64 {
    sum_exclusive() + sum_inclusive()
}

# LIVING_SPEC/05_idioms/idiom_match_over_if_chain.vais
# Key concept: ❌ 긴 I/EL I 체인 vs ✅ M 패턴 매칭
# ✅ DO: M으로 enum variant를 직접 분기 — 추가 variant 시 경고.
# ❌ DON'T: I x == A { ... } EL I x == B { ... } — 매칭 누락 위험.

enum Command { Start, Stop, Pause, Resume }

fn priority(c: Command) -> i64 {
    match c {
        Start => 3,
        Resume => 2,
        Pause => 1,
        Stop => 0
    }
}

fn main() -> i64 {
    priority(Start) + priority(Stop)
}

# LIVING_SPEC/05_idioms/idiom_fresh_vars_minimal.vais
# Key concept: ❌ 단계별 새 이름 vs ✅ 같은 이름 재바인딩
# ✅ DO: `x := transform(x)` — Vais의 := 재바인딩으로 단계 표현.
# ❌ DON'T: x1, x2, x3 난립 — 가독성 저하.

fn process(n: i64) -> i64 {
    x := n + 1
    x := x * 2
    x := x - 3
    x
}

fn main() -> i64 {
    process(5)  # ((5+1)*2)-3 = 9
}

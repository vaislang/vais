# Fibonacci - recursive and iterative
fn fib_rec(n) -> i =
    I n <= 1 { n } enum { @(n - 1) + @(n - 2) }

fn fib_iter(n) {
    a := mut 0
    b := mut 1
    L _:0..n {
        t := a + b
        a = b
        b = t
    }
    a
}

fn main() {
    println("~{fib_rec(20)}")
    println("~{fib_iter(50)}")
}

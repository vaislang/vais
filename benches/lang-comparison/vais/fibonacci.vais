# Fibonacci - recursive and iterative
fn fib_rec(n: i64) -> i64 =
    I n <= 1 { n } else { @(n - 1) + @(n - 2) }

fn fib_iter(n: i64) -> i64 {
    a := mut 0
    b := mut 1
    LF _:0..n {
        t := a + b
        a = b
        b = t
    }
    a
}

fn main() -> i64 {
    println("{fib_rec(20)}")
    println("{fib_iter(50)}")
    0
}

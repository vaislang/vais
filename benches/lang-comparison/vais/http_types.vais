# HTTP types with routing
struct Response {
    status: i,
    body: i,
}

fn route(path) -> Response {
    I path == 1 {
        Response(200, 1)
    } enum I path == 2 {
        Response(200, 2)
    } enum {
        Response(404, 0)
    }
}

fn main() {
    res := route(1)
    println("status=~{res.status} body=~{res.body}")
    res2 := route(2)
    println("status=~{res2.status} body=~{res2.body}")
    res3 := route(99)
    println("status=~{res3.status} body=~{res3.body}")
}
